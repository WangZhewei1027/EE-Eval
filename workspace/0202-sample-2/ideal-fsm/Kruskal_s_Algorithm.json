{
  "meta": {
    "concept": "Kruskal's Algorithm",
    "topic": "Minimum Spanning Tree Construction",
    "educational_goal": "Demonstrate the process of constructing a minimum spanning tree using Kruskal's Algorithm",
    "expected_interactions": [
      "addEdge",
      "findSet",
      "unionSets",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AddingEdge",
      "label": "AddingEdge",
      "type": "atomic",
      "entry_actions": [
        "highlightEdge()",
        "checkCycle()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_CycleCheck",
      "label": "CycleCheck",
      "type": "atomic",
      "entry_actions": [
        "performCycleCheck()",
        "showCycleFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_UnionSets",
      "label": "UnionSets",
      "type": "atomic",
      "entry_actions": [
        "unionDisjointSets()",
        "updateGraph()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_DrawingMST",
      "label": "DrawingMST",
      "type": "atomic",
      "entry_actions": [
        "updateMSTVisualization()",
        "animateEdgeAddition()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_ResettingGraph",
      "label": "ResettingGraph",
      "type": "atomic",
      "entry_actions": [
        "clearAllEdges()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksAddEdge",
      "event_type": "user_action",
      "description": "User clicks the Add Edge button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "CycleCheckComplete",
      "event_type": "system_event",
      "description": "Cycle check completes successfully"
    },
    {
      "id": "CycleDetected",
      "event_type": "system_event",
      "description": "Cycle detected in the graph"
    },
    {
      "id": "UnionComplete",
      "event_type": "system_event",
      "description": "Union of sets complete"
    },
    {
      "id": "MSTUpdateComplete",
      "event_type": "system_event",
      "description": "Minimum spanning tree update complete"
    },
    {
      "id": "GraphResetComplete",
      "event_type": "system_event",
      "description": "Graph reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AddingEdge",
      "event": "UserClicksAddEdge",
      "guard": "edgeSelected",
      "actions": [
        "captureEdge()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:edgeSelected",
        "dom:addEdgeButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AddingEdge",
      "to": "S2_CycleCheck",
      "event": "CycleCheckComplete",
      "guard": "noCycleDetected",
      "actions": [
        "validateEdge()",
        "prepareUnion()"
      ],
      "expected_observables": [
        "dom:cycleCheckPassed"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_CycleCheck",
      "to": "S3_UnionSets",
      "event": "CycleCheckComplete",
      "guard": "validEdge",
      "actions": [
        "performUnion()",
        "beginGraphUpdate()"
      ],
      "expected_observables": [
        "dom:unionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_AddingEdge",
      "to": "S0_Idle",
      "event": "CycleDetected",
      "guard": "cycleExists",
      "actions": [
        "showCycleError()",
        "resetEdgeSelection()"
      ],
      "expected_observables": [
        "dom:cycleErrorShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_UnionSets",
      "to": "S4_DrawingMST",
      "event": "UnionComplete",
      "guard": "unionSuccessful",
      "actions": [
        "updateMSTStructure()",
        "triggerMSTVisualization()"
      ],
      "expected_observables": [
        "dom:mstStructureUpdated",
        "dom:newEdgeVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S4_DrawingMST",
      "to": "S0_Idle",
      "event": "MSTUpdateComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearEdgeSelection()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_ResettingGraph",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_ResettingGraph",
      "to": "S0_Idle",
      "event": "GraphResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetEdgeSelection()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "edge_selection",
    "add_edge",
    "reset",
    "mst_visualization"
  ]
}