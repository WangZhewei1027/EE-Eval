{
  "meta": {
    "concept": "Bellman-Ford Algorithm",
    "topic": "Shortest Path Finding",
    "educational_goal": "Demonstrate the Bellman-Ford algorithm for finding shortest paths in graphs",
    "expected_interactions": [
      "setGraph",
      "runAlgorithm",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SettingGraph",
      "label": "SettingGraph",
      "type": "atomic",
      "entry_actions": [
        "captureGraphInput()",
        "highlightGraphInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_RunningAlgorithm",
      "label": "RunningAlgorithm",
      "type": "operation",
      "entry_actions": [
        "initializeAlgorithm()",
        "startIterations()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_AlgorithmComplete",
      "label": "AlgorithmComplete",
      "type": "atomic",
      "entry_actions": [
        "displayResults()",
        "highlightShortestPaths()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_ResettingGraph",
      "label": "ResettingGraph",
      "type": "atomic",
      "entry_actions": [
        "clearGraphData()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserSetsGraph",
      "event_type": "user_action",
      "description": "User sets the graph input"
    },
    {
      "id": "UserRunsAlgorithm",
      "event_type": "user_action",
      "description": "User clicks the Run Algorithm button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "GraphInputValidationComplete",
      "event_type": "system_event",
      "description": "Graph input validation completes successfully"
    },
    {
      "id": "GraphInputValidationFailed",
      "event_type": "system_event",
      "description": "Graph input validation fails"
    },
    {
      "id": "AlgorithmExecutionComplete",
      "event_type": "system_event",
      "description": "Bellman-Ford algorithm execution complete"
    },
    {
      "id": "GraphResetComplete",
      "event_type": "system_event",
      "description": "Graph reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SettingGraph",
      "event": "UserSetsGraph",
      "guard": "inputNotEmpty",
      "actions": [
        "captureGraphData()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:graphInputCaptured",
        "dom:setGraphButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SettingGraph",
      "to": "S2_RunningAlgorithm",
      "event": "GraphInputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateGraphData()",
        "prepareAlgorithm()"
      ],
      "expected_observables": [
        "dom:graphInputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S1_SettingGraph",
      "to": "S3_ErrorAlert",
      "event": "GraphInputValidationFailed",
      "guard": "inputIsInvalid",
      "actions": [
        "showError()",
        "focusGraphInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetGraphInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S2_RunningAlgorithm",
      "to": "S4_AlgorithmComplete",
      "event": "AlgorithmExecutionComplete",
      "guard": "algorithmRanSuccessfully",
      "actions": [
        "updateGraphVisualization()",
        "showShortestPaths()"
      ],
      "expected_observables": [
        "dom:graphVisualizationUpdated",
        "dom:shortestPathsHighlighted"
      ],
      "timeout": 3000
    },
    {
      "from": "S4_AlgorithmComplete",
      "to": "S0_Idle",
      "event": "AlgorithmExecutionComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearGraphInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_ResettingGraph",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_ResettingGraph",
      "to": "S0_Idle",
      "event": "GraphResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetGraphInputField()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "graph_input",
    "run_algorithm",
    "reset",
    "graph_visualization"
  ]
}