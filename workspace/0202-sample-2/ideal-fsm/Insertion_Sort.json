{
  "meta": {
    "concept": "InsertionSort",
    "topic": "Insertion Sort Visualization",
    "educational_goal": "Demonstrate the process of insertion sort",
    "expected_interactions": [
      "start_sort",
      "step_sort",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderArray()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SortStart",
      "label": "SortStart",
      "type": "atomic",
      "entry_actions": [
        "highlightCurrentElement()",
        "disableControls()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_Comparing",
      "label": "Comparing",
      "type": "atomic",
      "entry_actions": [
        "compareWithPrevious()",
        "showComparisonFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_Swapping",
      "label": "Swapping",
      "type": "atomic",
      "entry_actions": [
        "swapElements()",
        "updateArrayVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_StepComplete",
      "label": "StepComplete",
      "type": "atomic",
      "entry_actions": [
        "highlightSortedPart()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_ArrayResetting",
      "label": "ArrayResetting",
      "type": "atomic",
      "entry_actions": [
        "clearArray()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksStartSort",
      "event_type": "user_action",
      "description": "User clicks the Start Sort button"
    },
    {
      "id": "UserClicksStepSort",
      "event_type": "user_action",
      "description": "User clicks the Step Sort button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ComparisonComplete",
      "event_type": "system_event",
      "description": "Comparison between elements completes"
    },
    {
      "id": "SwapComplete",
      "event_type": "system_event",
      "description": "Swap operation completes"
    },
    {
      "id": "StepSortComplete",
      "event_type": "system_event",
      "description": "Step sort operation completes"
    },
    {
      "id": "ArrayResetComplete",
      "event_type": "system_event",
      "description": "Array reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SortStart",
      "event": "UserClicksStartSort",
      "guard": "arrayNotEmpty",
      "actions": [
        "beginSort()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:startSortButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SortStart",
      "to": "S2_Comparing",
      "event": "UserClicksStepSort",
      "guard": "currentElementExists",
      "actions": [
        "compareElements()",
        "highlightComparison()"
      ],
      "expected_observables": [
        "dom:comparisonStarted"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Comparing",
      "to": "S3_Swapping",
      "event": "ComparisonComplete",
      "guard": "elementsNeedSwapping",
      "actions": [
        "performSwap()",
        "updateVisualization()"
      ],
      "expected_observables": [
        "dom:elementsSwapped"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_Comparing",
      "to": "S4_StepComplete",
      "event": "ComparisonComplete",
      "guard": "elementsInOrder",
      "actions": [
        "markSorted()",
        "advanceToNextElement()"
      ],
      "expected_observables": [
        "dom:stepComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_Swapping",
      "to": "S4_StepComplete",
      "event": "SwapComplete",
      "guard": "swapSuccessful",
      "actions": [
        "highlightSortedPart()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:swapComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S4_StepComplete",
      "to": "S0_Idle",
      "event": "StepSortComplete",
      "guard": "sortComplete",
      "actions": [
        "enableControls()",
        "clearHighlight()"
      ],
      "expected_observables": [
        "dom:sortComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_ArrayResetting",
      "event": "UserClicksReset",
      "guard": "arrayNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_ArrayResetting",
      "to": "S0_Idle",
      "event": "ArrayResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:arrayCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "start_sort",
    "step_sort",
    "reset",
    "array_visualization"
  ]
}