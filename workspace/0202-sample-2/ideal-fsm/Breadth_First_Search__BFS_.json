{
  "meta": {
    "concept": "Breadth-First Search (BFS)",
    "topic": "Breadth-First Search Visualization",
    "educational_goal": "Demonstrate BFS traversal on a graph",
    "expected_interactions": [
      "start",
      "pause",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_StartTraversal",
      "label": "StartTraversal",
      "type": "atomic",
      "entry_actions": [
        "readStartNode()",
        "highlightStartNode()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_Traversing",
      "label": "Traversing",
      "type": "operation",
      "entry_actions": [
        "beginBFS()",
        "showTraversalProgress()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_Paused",
      "label": "Paused",
      "type": "atomic",
      "entry_actions": [
        "pauseTraversal()",
        "showPauseFeedback()"
      ],
      "exit_actions": [
        "clearPauseFeedback()"
      ]
    },
    {
      "id": "S4_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearTraversalData()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksStart",
      "event_type": "user_action",
      "description": "User clicks the Start button"
    },
    {
      "id": "UserClicksPause",
      "event_type": "user_action",
      "description": "User clicks the Pause button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "TraversalComplete",
      "event_type": "system_event",
      "description": "BFS traversal completes successfully"
    },
    {
      "id": "TraversalPaused",
      "event_type": "system_event",
      "description": "Traversal is paused"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_StartTraversal",
      "event": "UserClicksStart",
      "guard": "startNodeSelected",
      "actions": [
        "captureStartNode()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:startButtonClicked",
        "dom:startNodeHighlighted"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_StartTraversal",
      "to": "S2_Traversing",
      "event": "TraversalComplete",
      "guard": "true",
      "actions": [
        "executeBFS()",
        "updateGraphVisualization()"
      ],
      "expected_observables": [
        "dom:traversalStarted"
      ],
      "timeout": 3000
    },
    {
      "from": "S2_Traversing",
      "to": "S3_Paused",
      "event": "TraversalPaused",
      "guard": "pauseRequested",
      "actions": [
        "pauseBFS()",
        "showPauseState()"
      ],
      "expected_observables": [
        "dom:traversalPaused"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_Paused",
      "to": "S2_Traversing",
      "event": "UserClicksStart",
      "guard": "true",
      "actions": [
        "resumeBFS()",
        "clearPauseState()"
      ],
      "expected_observables": [
        "dom:traversalResumed"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Traversing",
      "to": "S0_Idle",
      "event": "TraversalComplete",
      "guard": "traversalFinished",
      "actions": [
        "enableControls()",
        "clearTraversalData()"
      ],
      "expected_observables": [
        "dom:traversalComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S4_Resetting",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "start",
    "pause",
    "reset",
    "graph_visualization"
  ]
}