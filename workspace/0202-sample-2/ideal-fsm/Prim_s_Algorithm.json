{
  "meta": {
    "concept": "Prim's Algorithm",
    "topic": "Minimum Spanning Tree Visualization",
    "educational_goal": "Demonstrate Prim's algorithm for finding a minimum spanning tree",
    "expected_interactions": [
      "start",
      "selectNode",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AlgorithmStart",
      "label": "AlgorithmStart",
      "type": "atomic",
      "entry_actions": [
        "highlightStartNode()",
        "disableControls()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_SelectingNode",
      "label": "SelectingNode",
      "type": "atomic",
      "entry_actions": [
        "highlightSelectableNodes()",
        "showSelectionOptions()"
      ],
      "exit_actions": [
        "clearSelectionOptions()"
      ]
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_UpdatingTree",
      "label": "UpdatingTree",
      "type": "atomic",
      "entry_actions": [
        "updateTreeStructure()",
        "animateEdgeSelection()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_DrawingTree",
      "label": "DrawingTree",
      "type": "atomic",
      "entry_actions": [
        "updateGraphVisualization()",
        "animateTreeUpdate()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ResettingGraph",
      "label": "ResettingGraph",
      "type": "atomic",
      "entry_actions": [
        "clearGraph()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksStart",
      "event_type": "user_action",
      "description": "User clicks the Start button"
    },
    {
      "id": "UserSelectsNode",
      "event_type": "user_action",
      "description": "User selects a node to add to the tree"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "NodeSelectionComplete",
      "event_type": "system_event",
      "description": "Node selection completes successfully"
    },
    {
      "id": "NodeSelectionFailed",
      "event_type": "system_event",
      "description": "Node selection fails"
    },
    {
      "id": "TreeUpdateComplete",
      "event_type": "system_event",
      "description": "Tree update and graph visualization complete"
    },
    {
      "id": "GraphResetComplete",
      "event_type": "system_event",
      "description": "Graph reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AlgorithmStart",
      "event": "UserClicksStart",
      "guard": "graphNotEmpty",
      "actions": [
        "captureStartNode()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:startButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AlgorithmStart",
      "to": "S2_SelectingNode",
      "event": "NodeSelectionComplete",
      "guard": "nodeIsSelectable",
      "actions": [
        "highlightSelectableEdges()",
        "prepareNodeSelection()"
      ],
      "expected_observables": [
        "dom:nodeSelectionOptionsShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_SelectingNode",
      "to": "S4_UpdatingTree",
      "event": "NodeSelectionComplete",
      "guard": "validNodeSelected",
      "actions": [
        "addNodeToTree()",
        "beginEdgeSelection()"
      ],
      "expected_observables": [
        "dom:edgeSelectionStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_SelectingNode",
      "to": "S3_ErrorAlert",
      "event": "NodeSelectionFailed",
      "guard": "selectionInvalid",
      "actions": [
        "showError()",
        "focusSelection()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetSelection()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_UpdatingTree",
      "to": "S5_DrawingTree",
      "event": "TreeUpdateComplete",
      "guard": "treeUpdatedSuccessfully",
      "actions": [
        "updateGraphStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:graphStructureChanged",
        "dom:newEdgeVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_DrawingTree",
      "to": "S0_Idle",
      "event": "TreeUpdateComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearSelection()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ResettingGraph",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ResettingGraph",
      "to": "S0_Idle",
      "event": "GraphResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetSelectionField()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "start",
    "reset",
    "graph_visualization"
  ]
}