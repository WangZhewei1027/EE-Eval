{
  "meta": {
    "concept": "CountingSort",
    "topic": "Counting Sort Visualization",
    "educational_goal": "Demonstrate counting sort algorithm",
    "expected_interactions": [
      "sort",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderArray()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_SortStart",
      "label": "SortStart",
      "type": "atomic",
      "entry_actions": [
        "readInputArray()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateArray()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_CountingElements",
      "label": "CountingElements",
      "type": "atomic",
      "entry_actions": [
        "initializeCountArray()",
        "countElements()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_BuildingOutput",
      "label": "BuildingOutput",
      "type": "atomic",
      "entry_actions": [
        "buildOutputArray()",
        "updateVisualization()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S6_ArrayResetting",
      "label": "ArrayResetting",
      "type": "atomic",
      "entry_actions": [
        "clearArray()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksSort",
      "event_type": "user_action",
      "description": "User clicks the Sort button"
    },
    {
      "id": "UserEntersArray",
      "event_type": "user_action",
      "description": "User enters array in input field"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "CountingComplete",
      "event_type": "system_event",
      "description": "Counting elements complete"
    },
    {
      "id": "OutputBuildingComplete",
      "event_type": "system_event",
      "description": "Output array building complete"
    },
    {
      "id": "ArrayResetComplete",
      "event_type": "system_event",
      "description": "Array reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_SortStart",
      "event": "UserClicksSort",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readInputArray",
        "dom:sortButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_SortStart",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateArray()",
        "prepareCounting()"
      ],
      "expected_observables": [
        "dom:arrayValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S4_CountingElements",
      "event": "InputValidationComplete",
      "guard": "validArray",
      "actions": [
        "parseInputArray()",
        "beginCounting()"
      ],
      "expected_observables": [
        "dom:countingStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_SortStart",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S4_CountingElements",
      "to": "S5_BuildingOutput",
      "event": "CountingComplete",
      "guard": "countingSuccessful",
      "actions": [
        "updateCountArray()",
        "triggerOutputBuilding()"
      ],
      "expected_observables": [
        "dom:countArrayUpdated",
        "dom:outputBuildingStarted"
      ],
      "timeout": 3000
    },
    {
      "from": "S5_BuildingOutput",
      "to": "S0_Idle",
      "event": "OutputBuildingComplete",
      "guard": "visualizationComplete",
      "actions": [
        "enableControls()",
        "clearInput()"
      ],
      "expected_observables": [
        "dom:visualizationComplete"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_ArrayResetting",
      "event": "UserClicksReset",
      "guard": "arrayNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_ArrayResetting",
      "to": "S0_Idle",
      "event": "ArrayResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:arrayCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "sort",
    "reset",
    "array_visualization"
  ]
}