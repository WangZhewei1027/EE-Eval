{
  "meta": {
    "concept": "SelectionSort",
    "topic": "Selection Sort Visualization",
    "educational_goal": "Demonstrate the process of selection sort",
    "expected_interactions": [
      "inputArray",
      "startSort",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderArray()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InputArray",
      "label": "InputArray",
      "type": "atomic",
      "entry_actions": [
        "readArrayInput()",
        "highlightInputField()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateArrayInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_Sorting",
      "label": "Sorting",
      "type": "operation",
      "entry_actions": [
        "startSelectionSort()",
        "highlightCurrentElement()"
      ],
      "exit_actions": []
    },
    {
      "id": "S5_SortingComplete",
      "label": "SortingComplete",
      "type": "atomic",
      "entry_actions": [
        "showSortedArray()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S6_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearArray()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserInputsArray",
      "event_type": "user_action",
      "description": "User inputs an array"
    },
    {
      "id": "UserClicksStartSort",
      "event_type": "user_action",
      "description": "User clicks the Start Sort button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Array input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Array input validation fails"
    },
    {
      "id": "SortingStepComplete",
      "event_type": "system_event",
      "description": "A step in the sorting process completes"
    },
    {
      "id": "SortingComplete",
      "event_type": "system_event",
      "description": "Sorting process completes"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InputArray",
      "event": "UserInputsArray",
      "guard": "inputNotEmpty",
      "actions": [
        "captureArrayInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:arrayInputCaptured"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InputArray",
      "to": "S2_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateArray()",
        "prepareSorting()"
      ],
      "expected_observables": [
        "dom:inputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S1_InputArray",
      "to": "S3_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsInvalid",
      "actions": [
        "showError()",
        "focusInputField()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S2_ValidatingInput",
      "to": "S4_Sorting",
      "event": "UserClicksStartSort",
      "guard": "inputIsValid",
      "actions": [
        "beginSorting()",
        "highlightFirstElement()"
      ],
      "expected_observables": [
        "dom:sortingStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S4_Sorting",
      "to": "S4_Sorting",
      "event": "SortingStepComplete",
      "guard": "moreElementsToSort",
      "actions": [
        "highlightNextElement()",
        "swapIfNecessary()"
      ],
      "expected_observables": [
        "dom:elementHighlighted",
        "dom:swapPerformed"
      ],
      "timeout": 2000
    },
    {
      "from": "S4_Sorting",
      "to": "S5_SortingComplete",
      "event": "SortingComplete",
      "guard": "allElementsSorted",
      "actions": [
        "displaySortedArray()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:arraySorted"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S6_Resetting",
      "event": "UserClicksReset",
      "guard": "arrayNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S6_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:arrayCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "start_sort",
    "reset",
    "array_visualization"
  ]
}