{
  "meta": {
    "concept": "Depth-First Search (DFS)",
    "topic": "DFS Algorithm Visualization",
    "educational_goal": "Demonstrate DFS traversal on a graph",
    "expected_interactions": [
      "start",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_StartDFS",
      "label": "StartDFS",
      "type": "atomic",
      "entry_actions": [
        "highlightStartNode()",
        "disableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S2_Traversing",
      "label": "Traversing",
      "type": "operation",
      "entry_actions": [
        "performDFS()",
        "updateTraversalPath()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_TraversalComplete",
      "label": "TraversalComplete",
      "type": "atomic",
      "entry_actions": [
        "showTraversalComplete()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearTraversalPath()",
        "resetGraphVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksStart",
      "event_type": "user_action",
      "description": "User clicks the Start button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "DFSComplete",
      "event_type": "system_event",
      "description": "DFS traversal completes"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Graph reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_StartDFS",
      "event": "UserClicksStart",
      "guard": "graphNotEmpty",
      "actions": [
        "captureStartNode()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:startButtonClicked",
        "dom:startNodeHighlighted"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_StartDFS",
      "to": "S2_Traversing",
      "event": "UserClicksStart",
      "guard": "startNodeValid",
      "actions": [
        "beginTraversal()"
      ],
      "expected_observables": [
        "dom:traversalStarted"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Traversing",
      "to": "S3_TraversalComplete",
      "event": "DFSComplete",
      "guard": "traversalSuccessful",
      "actions": [
        "highlightTraversalPath()",
        "showCompletionMessage()"
      ],
      "expected_observables": [
        "dom:traversalPathHighlighted",
        "dom:completionMessageShown"
      ],
      "timeout": 3000
    },
    {
      "from": "S3_TraversalComplete",
      "to": "S0_Idle",
      "event": "UserClicksReset",
      "guard": "true",
      "actions": [
        "prepareReset()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S0_Idle",
      "to": "S4_Resetting",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetInitiated"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "start",
    "reset",
    "graph_visualization"
  ]
}