{
  "meta": {
    "concept": "Floyd-Warshall Algorithm",
    "topic": "Floyd-Warshall Algorithm Visualization",
    "educational_goal": "Demonstrate the process of finding shortest paths in a weighted graph",
    "expected_interactions": [
      "initialize",
      "step",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_Initializing",
      "label": "Initializing",
      "type": "atomic",
      "entry_actions": [
        "initializeGraph()",
        "showInitializationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S2_Stepping",
      "label": "Stepping",
      "type": "atomic",
      "entry_actions": [
        "performStep()",
        "highlightCurrentStep()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S3_Completed",
      "label": "Completed",
      "type": "atomic",
      "entry_actions": [
        "showCompletionMessage()",
        "highlightShortestPaths()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearGraph()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksInitialize",
      "event_type": "user_action",
      "description": "User clicks the Initialize button"
    },
    {
      "id": "UserClicksStep",
      "event_type": "user_action",
      "description": "User clicks the Step button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InitializationComplete",
      "event_type": "system_event",
      "description": "Graph initialization completes"
    },
    {
      "id": "StepComplete",
      "event_type": "system_event",
      "description": "Algorithm step completes"
    },
    {
      "id": "AlgorithmComplete",
      "event_type": "system_event",
      "description": "All steps of the algorithm are complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Graph reset operation complete"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_Initializing",
      "event": "UserClicksInitialize",
      "guard": "graphNotInitialized",
      "actions": [
        "disableControls()",
        "startInitialization()"
      ],
      "expected_observables": [
        "dom:initializeButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_Initializing",
      "to": "S2_Stepping",
      "event": "InitializationComplete",
      "guard": "true",
      "actions": [
        "enableStepControl()",
        "prepareFirstStep()"
      ],
      "expected_observables": [
        "dom:graphInitialized"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_Stepping",
      "to": "S2_Stepping",
      "event": "UserClicksStep",
      "guard": "moreStepsRemaining",
      "actions": [
        "executeStep()",
        "updateVisualization()"
      ],
      "expected_observables": [
        "dom:stepExecuted"
      ],
      "timeout": 1500
    },
    {
      "from": "S2_Stepping",
      "to": "S3_Completed",
      "event": "AlgorithmComplete",
      "guard": "true",
      "actions": [
        "showFinalPaths()",
        "disableStepControl()"
      ],
      "expected_observables": [
        "dom:algorithmCompleted"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S4_Resetting",
      "event": "UserClicksReset",
      "guard": "graphInitialized",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S4_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "clearGraphState()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "initialize",
    "step",
    "reset",
    "graph_visualization"
  ]
}