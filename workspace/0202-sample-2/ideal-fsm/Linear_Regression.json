{
  "meta": {
    "concept": "LinearRegression",
    "topic": "Linear Regression Visualization",
    "educational_goal": "Demonstrate fitting a linear model to data points",
    "expected_interactions": [
      "addDataPoint",
      "fitModel",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderGraph()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AddingDataPoint",
      "label": "AddingDataPoint",
      "type": "atomic",
      "entry_actions": [
        "captureDataPoint()",
        "highlightInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_FittingModel",
      "label": "FittingModel",
      "type": "operation",
      "entry_actions": [
        "computeLinearRegression()",
        "showFitFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_ResettingGraph",
      "label": "ResettingGraph",
      "type": "atomic",
      "entry_actions": [
        "clearDataPoints()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserAddsDataPoint",
      "event_type": "user_action",
      "description": "User adds a data point"
    },
    {
      "id": "UserClicksFitModel",
      "event_type": "user_action",
      "description": "User clicks the Fit Model button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "DataPointAdded",
      "event_type": "system_event",
      "description": "Data point added successfully"
    },
    {
      "id": "ModelFitComplete",
      "event_type": "system_event",
      "description": "Model fitting completes successfully"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Graph reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AddingDataPoint",
      "event": "UserAddsDataPoint",
      "guard": "inputNotEmpty",
      "actions": [
        "captureInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:dataPointInputCaptured"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AddingDataPoint",
      "to": "S0_Idle",
      "event": "DataPointAdded",
      "guard": "dataPointValid",
      "actions": [
        "addDataPointToGraph()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:dataPointAddedToGraph"
      ],
      "timeout": 1000
    },
    {
      "from": "S1_AddingDataPoint",
      "to": "S3_ErrorAlert",
      "event": "DataPointAdded",
      "guard": "dataPointInvalid",
      "actions": [
        "showError()",
        "focusInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S0_Idle",
      "to": "S2_FittingModel",
      "event": "UserClicksFitModel",
      "guard": "dataPointsExist",
      "actions": [
        "computeRegression()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:modelFittingStarted"
      ],
      "timeout": 3000
    },
    {
      "from": "S2_FittingModel",
      "to": "S0_Idle",
      "event": "ModelFitComplete",
      "guard": "fitSuccessful",
      "actions": [
        "updateGraphWithModel()",
        "enableControls()"
      ],
      "expected_observables": [
        "dom:modelDisplayedOnGraph"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S4_ResettingGraph",
      "event": "UserClicksReset",
      "guard": "graphNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S4_ResettingGraph",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:graphCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "input",
    "addDataPoint",
    "fitModel",
    "reset",
    "graph_visualization"
  ]
}