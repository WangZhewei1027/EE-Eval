{
  "meta": {
    "concept": "KnapsackProblem",
    "topic": "Knapsack Problem Visualization",
    "educational_goal": "Demonstrate the process of solving the knapsack problem using dynamic programming",
    "expected_interactions": [
      "add_item",
      "solve",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderKnapsack()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_AddingItem",
      "label": "AddingItem",
      "type": "atomic",
      "entry_actions": [
        "readItemInput()",
        "highlightItemInput()"
      ],
      "exit_actions": [
        "clearItemHighlight()"
      ]
    },
    {
      "id": "S2_ValidatingItem",
      "label": "ValidatingItem",
      "type": "atomic",
      "entry_actions": [
        "validateItemInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S3_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S4_SolvingKnapsack",
      "label": "SolvingKnapsack",
      "type": "atomic",
      "entry_actions": [
        "executeKnapsackAlgorithm()",
        "updateSolutionVisualization()"
      ],
      "exit_actions": [
        "enableControls()"
      ]
    },
    {
      "id": "S5_Resetting",
      "label": "Resetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllItems()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksAddItem",
      "event_type": "user_action",
      "description": "User clicks the Add Item button"
    },
    {
      "id": "UserEntersItem",
      "event_type": "user_action",
      "description": "User enters item details in input fields"
    },
    {
      "id": "UserClicksSolve",
      "event_type": "user_action",
      "description": "User clicks the Solve button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "ItemValidationComplete",
      "event_type": "system_event",
      "description": "Item validation completes successfully"
    },
    {
      "id": "ItemValidationFailed",
      "event_type": "system_event",
      "description": "Item validation fails"
    },
    {
      "id": "KnapsackSolutionComplete",
      "event_type": "system_event",
      "description": "Knapsack solution computation complete"
    },
    {
      "id": "ResetComplete",
      "event_type": "system_event",
      "description": "Reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_AddingItem",
      "event": "UserClicksAddItem",
      "guard": "inputNotEmpty",
      "actions": [
        "captureItemInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readItemInput",
        "dom:addItemButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_AddingItem",
      "to": "S2_ValidatingItem",
      "event": "ItemValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateItemDetails()",
        "prepareForAddition()"
      ],
      "expected_observables": [
        "dom:itemValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_ValidatingItem",
      "to": "S0_Idle",
      "event": "ItemValidationComplete",
      "guard": "validItem",
      "actions": [
        "addItemToKnapsack()",
        "updateItemList()"
      ],
      "expected_observables": [
        "dom:itemAdded"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_AddingItem",
      "to": "S3_ErrorAlert",
      "event": "ItemValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusItemInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetItemInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S0_Idle",
      "to": "S4_SolvingKnapsack",
      "event": "UserClicksSolve",
      "guard": "itemsPresent",
      "actions": [
        "disableControls()",
        "beginSolving()"
      ],
      "expected_observables": [
        "dom:solveButtonClicked"
      ],
      "timeout": 3000
    },
    {
      "from": "S4_SolvingKnapsack",
      "to": "S0_Idle",
      "event": "KnapsackSolutionComplete",
      "guard": "solutionComputed",
      "actions": [
        "enableControls()",
        "displaySolution()"
      ],
      "expected_observables": [
        "dom:solutionDisplayed"
      ],
      "timeout": 1000
    },
    {
      "from": "S0_Idle",
      "to": "S5_Resetting",
      "event": "UserClicksReset",
      "guard": "itemsPresent",
      "actions": [
        "confirmReset()",
        "beginResetOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S5_Resetting",
      "to": "S0_Idle",
      "event": "ResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetItemInputFields()"
      ],
      "expected_observables": [
        "dom:itemsCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "item_input",
    "add_item",
    "solve",
    "reset",
    "knapsack_visualization"
  ]
}