{
  "meta": {
    "concept": "Deque",
    "topic": "Double-Ended Queue Operations",
    "educational_goal": "Demonstrate deque insertion and removal from both ends",
    "expected_interactions": [
      "insertFront",
      "insertRear",
      "removeFront",
      "removeRear",
      "reset"
    ]
  },
  "states": [
    {
      "id": "S0_Idle",
      "label": "Idle",
      "type": "idle",
      "entry_actions": [
        "renderDeque()",
        "enableControls()"
      ],
      "exit_actions": []
    },
    {
      "id": "S1_InsertFrontStart",
      "label": "InsertFrontStart",
      "type": "atomic",
      "entry_actions": [
        "readFrontInputValue()",
        "highlightFrontInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S2_InsertRearStart",
      "label": "InsertRearStart",
      "type": "atomic",
      "entry_actions": [
        "readRearInputValue()",
        "highlightRearInput()"
      ],
      "exit_actions": [
        "clearHighlight()"
      ]
    },
    {
      "id": "S3_ValidatingInput",
      "label": "ValidatingInput",
      "type": "atomic",
      "entry_actions": [
        "validateInput()",
        "showValidationFeedback()"
      ],
      "exit_actions": []
    },
    {
      "id": "S4_ErrorAlert",
      "label": "ErrorAlert",
      "type": "atomic",
      "entry_actions": [
        "showErrorDialog()",
        "highlightError()"
      ],
      "exit_actions": [
        "clearError()"
      ]
    },
    {
      "id": "S5_InsertingFront",
      "label": "InsertingFront",
      "type": "atomic",
      "entry_actions": [
        "addNodeToFront()",
        "updateDequeVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S6_InsertingRear",
      "label": "InsertingRear",
      "type": "atomic",
      "entry_actions": [
        "addNodeToRear()",
        "updateDequeVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S7_RemovingFront",
      "label": "RemovingFront",
      "type": "atomic",
      "entry_actions": [
        "removeNodeFromFront()",
        "updateDequeVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S8_RemovingRear",
      "label": "RemovingRear",
      "type": "atomic",
      "entry_actions": [
        "removeNodeFromRear()",
        "updateDequeVisualization()"
      ],
      "exit_actions": []
    },
    {
      "id": "S9_DequeResetting",
      "label": "DequeResetting",
      "type": "atomic",
      "entry_actions": [
        "clearAllNodes()",
        "resetVisualization()"
      ],
      "exit_actions": [
        "returnToIdle()"
      ]
    }
  ],
  "events": [
    {
      "id": "UserClicksInsertFront",
      "event_type": "user_action",
      "description": "User clicks the Insert Front button"
    },
    {
      "id": "UserClicksInsertRear",
      "event_type": "user_action",
      "description": "User clicks the Insert Rear button"
    },
    {
      "id": "UserClicksRemoveFront",
      "event_type": "user_action",
      "description": "User clicks the Remove Front button"
    },
    {
      "id": "UserClicksRemoveRear",
      "event_type": "user_action",
      "description": "User clicks the Remove Rear button"
    },
    {
      "id": "UserClicksReset",
      "event_type": "user_action",
      "description": "User clicks the Reset button"
    },
    {
      "id": "InputValidationComplete",
      "event_type": "system_event",
      "description": "Input validation completes successfully"
    },
    {
      "id": "InputValidationFailed",
      "event_type": "system_event",
      "description": "Input validation fails"
    },
    {
      "id": "InsertionComplete",
      "event_type": "system_event",
      "description": "Node insertion and deque update complete"
    },
    {
      "id": "RemovalComplete",
      "event_type": "system_event",
      "description": "Node removal and deque update complete"
    },
    {
      "id": "DequeResetComplete",
      "event_type": "system_event",
      "description": "Deque reset operation complete"
    },
    {
      "id": "UserDismissesAlert",
      "event_type": "user_action",
      "description": "User dismisses error alert dialog"
    }
  ],
  "transitions": [
    {
      "from": "S0_Idle",
      "to": "S1_InsertFrontStart",
      "event": "UserClicksInsertFront",
      "guard": "inputNotEmpty",
      "actions": [
        "captureFrontInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readFrontInputValue",
        "dom:insertFrontButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S0_Idle",
      "to": "S2_InsertRearStart",
      "event": "UserClicksInsertRear",
      "guard": "inputNotEmpty",
      "actions": [
        "captureRearInput()",
        "disableControls()"
      ],
      "expected_observables": [
        "dom:readRearInputValue",
        "dom:insertRearButtonClicked"
      ],
      "timeout": 2000
    },
    {
      "from": "S1_InsertFrontStart",
      "to": "S3_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateFrontValue()",
        "prepareFrontInsertion()"
      ],
      "expected_observables": [
        "dom:frontInputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_InsertRearStart",
      "to": "S3_ValidatingInput",
      "event": "InputValidationComplete",
      "guard": "inputIsValid",
      "actions": [
        "validateRearValue()",
        "prepareRearInsertion()"
      ],
      "expected_observables": [
        "dom:rearInputValidated"
      ],
      "timeout": 1000
    },
    {
      "from": "S3_ValidatingInput",
      "to": "S5_InsertingFront",
      "event": "InputValidationComplete",
      "guard": "validNumber",
      "actions": [
        "parseFrontInputValue()",
        "beginFrontInsertion()"
      ],
      "expected_observables": [
        "dom:frontNodeCreationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S3_ValidatingInput",
      "to": "S6_InsertingRear",
      "event": "InputValidationComplete",
      "guard": "validNumber",
      "actions": [
        "parseRearInputValue()",
        "beginRearInsertion()"
      ],
      "expected_observables": [
        "dom:rearNodeCreationStarted"
      ],
      "timeout": 1500
    },
    {
      "from": "S1_InsertFrontStart",
      "to": "S4_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusFrontInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S2_InsertRearStart",
      "to": "S4_ErrorAlert",
      "event": "InputValidationFailed",
      "guard": "inputIsEmpty",
      "actions": [
        "showError()",
        "focusRearInput()"
      ],
      "expected_observables": [
        "dom:errorDialogShown"
      ],
      "timeout": 1000
    },
    {
      "from": "S4_ErrorAlert",
      "to": "S0_Idle",
      "event": "UserDismissesAlert",
      "guard": "true",
      "actions": [
        "clearErrorState()",
        "resetInput()"
      ],
      "expected_observables": [
        "dom:errorDialogClosed"
      ],
      "timeout": 500
    },
    {
      "from": "S5_InsertingFront",
      "to": "S0_Idle",
      "event": "InsertionComplete",
      "guard": "nodeInsertedSuccessfully",
      "actions": [
        "updateDequeStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:dequeStructureChanged",
        "dom:newFrontNodeVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S6_InsertingRear",
      "to": "S0_Idle",
      "event": "InsertionComplete",
      "guard": "nodeInsertedSuccessfully",
      "actions": [
        "updateDequeStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:dequeStructureChanged",
        "dom:newRearNodeVisible"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S7_RemovingFront",
      "event": "UserClicksRemoveFront",
      "guard": "dequeNotEmpty",
      "actions": [
        "confirmFrontRemoval()",
        "beginFrontRemoval()"
      ],
      "expected_observables": [
        "dom:removeFrontButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S0_Idle",
      "to": "S8_RemovingRear",
      "event": "UserClicksRemoveRear",
      "guard": "dequeNotEmpty",
      "actions": [
        "confirmRearRemoval()",
        "beginRearRemoval()"
      ],
      "expected_observables": [
        "dom:removeRearButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S7_RemovingFront",
      "to": "S0_Idle",
      "event": "RemovalComplete",
      "guard": "nodeRemovedSuccessfully",
      "actions": [
        "updateDequeStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:dequeStructureChanged",
        "dom:frontNodeRemoved"
      ],
      "timeout": 3000
    },
    {
      "from": "S8_RemovingRear",
      "to": "S0_Idle",
      "event": "RemovalComplete",
      "guard": "nodeRemovedSuccessfully",
      "actions": [
        "updateDequeStructure()",
        "triggerVisualization()"
      ],
      "expected_observables": [
        "dom:dequeStructureChanged",
        "dom:rearNodeRemoved"
      ],
      "timeout": 3000
    },
    {
      "from": "S0_Idle",
      "to": "S9_DequeResetting",
      "event": "UserClicksReset",
      "guard": "dequeNotEmpty",
      "actions": [
        "confirmReset()",
        "beginClearOperation()"
      ],
      "expected_observables": [
        "dom:resetButtonClicked"
      ],
      "timeout": 500
    },
    {
      "from": "S9_DequeResetting",
      "to": "S0_Idle",
      "event": "DequeResetComplete",
      "guard": "true",
      "actions": [
        "enableControls()",
        "resetInputField()"
      ],
      "expected_observables": [
        "dom:dequeCleared",
        "dom:visualizationReset"
      ],
      "timeout": 1000
    }
  ],
  "components": [
    "inputFront",
    "inputRear",
    "insertFront",
    "insertRear",
    "removeFront",
    "removeRear",
    "reset",
    "deque_visualization"
  ]
}