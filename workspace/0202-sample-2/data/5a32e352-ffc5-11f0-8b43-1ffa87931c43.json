    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Selection Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f0f0f0;\n    text-align: center;\n  }\n  h1 {\n    margin-bottom: 0.1em;\n  }\n  #arrayContainer {\n    margin: 30px auto;\n    display: flex;\n    justify-content: center;\n    align-items: flex-end;\n    height: 250px;\n    width: 80%;\n    max-width: 800px;\n    border: 1px solid #aaa;\n    background: white;\n    padding: 10px;\n    box-sizing: border-box;\n    border-radius: 8px;\n  }\n  .bar {\n    margin: 0 2px;\n    background-color: steelblue;\n    width: 25px;\n    border-radius: 3px 3px 0 0;\n    transition: background-color 0.3s, height 0.3s;\n    display: flex;\n    justify-content: center;\n    align-items: flex-end;\n    color: white;\n    font-weight: bold;\n    font-size: 14px;\n  }\n  .bar.highlight {\n    background-color: #f39c12;\n  }\n  .bar.current-min {\n    background-color: #e74c3c;\n  }\n  .bar.sorted {\n    background-color: #2ecc71;\n  }\n  #controls {\n    margin-top: 20px;\n  }\n  button, input[type=number] {\n    font-size: 16px;\n    padding: 8px 12px;\n    margin: 0 5px 10px 5px;\n    border-radius: 5px;\n    border: 1px solid #aaa;\n  }\n  button:hover {\n    cursor: pointer;\n    background-color: #ddd;\n  }\n  button:disabled {\n    background-color: #eee;\n    cursor: default;\n  }\n  label {\n    font-size: 16px;\n    margin-left: 10px;\n  }\n  #speedLabel {\n    margin-left: 15px;\n    font-weight: bold;\n  }\n</style>\n</head>\n<body>\n<h1>Selection Sort Visualization</h1>\n<div id=\"arrayContainer\"></div>\n<div id=\"controls\">\n  <button id=\"generateBtn\">Generate New Array</button>\n  <button id=\"startBtn\">Start Sorting</button>\n  <label for=\"sizeInput\">Array Size:</label>\n  <input type=\"number\" id=\"sizeInput\" min=\"5\" max=\"50\" value=\"20\" />\n  <label for=\"speedInput\">Speed:</label>\n  <input type=\"range\" id=\"speedInput\" min=\"1\" max=\"1000\" value=\"300\" />\n  <span id=\"speedLabel\">300 ms</span>\n</div>\n<script>\n(() => {\n  const arrayContainer = document.getElementById('arrayContainer');\n  const generateBtn = document.getElementById('generateBtn');\n  const startBtn = document.getElementById('startBtn');\n  const sizeInput = document.getElementById('sizeInput');\n  const speedInput = document.getElementById('speedInput');\n  const speedLabel = document.getElementById('speedLabel');\n\n  let array = [];\n  let delayTime = parseInt(speedInput.value, 10);\n  let isSorting = false;\n\n  function generateArray(size) {\n    array = [];\n    // Generate array with random integers from 5 to 100\n    for(let i = 0; i < size; i++) {\n      array.push(Math.floor(Math.random() * 95) + 5);\n    }\n  }\n\n  function renderArray(highlightIndices = {}, sortedIndices = {}) {\n    arrayContainer.innerHTML = '';\n    const maxVal = Math.max(...array);\n    array.forEach((value, index) => {\n      const bar = document.createElement('div');\n      bar.classList.add('bar');\n      bar.style.height = `${(value / maxVal) * 200 + 30}px`;\n      bar.textContent = value;\n      if (highlightIndices.current === index) {\n        bar.classList.add('highlight');\n      }\n      if (highlightIndices.min === index) {\n        bar.classList.add('current-min');\n      }\n      if (sortedIndices[index]) {\n        bar.classList.add('sorted');\n      }\n      arrayContainer.appendChild(bar);\n    });\n  }\n\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  async function selectionSort() {\n    isSorting = true;\n    generateBtn.disabled = true;\n    startBtn.disabled = true;\n    sizeInput.disabled = true;\n    speedInput.disabled = true;\n\n    let n = array.length;\n    let sortedIndices = {};\n\n    for (let i = 0; i < n - 1; i++) {\n      let minIndex = i;\n      renderArray({current: i, min: minIndex}, sortedIndices);\n      await sleep(delayTime);\n\n      for (let j = i + 1; j < n; j++) {\n        renderArray({current: j, min: minIndex}, sortedIndices);\n        await sleep(delayTime / 2);\n        if (array[j] < array[minIndex]) {\n          minIndex = j;\n          renderArray({current: j, min: minIndex}, sortedIndices);\n          await sleep(delayTime / 2);\n        }\n      }\n\n      if (minIndex !== i) {\n        // Swap values\n        [array[i], array[minIndex]] = [array[minIndex], array[i]];\n        renderArray({current: i, min: minIndex}, sortedIndices);\n        await sleep(delayTime);\n      }\n      sortedIndices[i] = true;\n      renderArray({}, sortedIndices);\n    }\n    sortedIndices[n-1] = true;\n    renderArray({}, sortedIndices);\n\n    isSorting = false;\n    generateBtn.disabled = false;\n    startBtn.disabled = false;\n    sizeInput.disabled = false;\n    speedInput.disabled = false;\n  }\n\n  function updateSpeedLabel() {\n    speedLabel.textContent = `${speedInput.value} ms`;\n  }\n\n  generateBtn.addEventListener('click', () => {\n    if (isSorting) return;\n    const size = parseInt(sizeInput.value, 10);\n    if (isNaN(size) || size < 5 || size > 50) {\n      alert('Array size must be between 5 and 50');\n      return;\n    }\n    generateArray(size);\n    renderArray();\n  });\n\n  startBtn.addEventListener('click', () => {\n    if (isSorting) return;\n    selectionSort();\n  });\n\n  speedInput.addEventListener('input', () => {\n    delayTime = parseInt(speedInput.value, 10);\n    updateSpeedLabel();\n  });\n\n  sizeInput.addEventListener('change', () => {\n    if (isSorting) return;\n    let val = parseInt(sizeInput.value, 10);\n    if (isNaN(val) || val < 5) val = 5;\n    if (val > 50) val = 50;\n    sizeInput.value = val;\n  });\n\n  // Init\n  generateArray(parseInt(sizeInput.value, 10));\n  renderArray();\n  updateSpeedLabel();\n})();\n</script>\n</body>\n</html>"
