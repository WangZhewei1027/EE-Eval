    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Binary Tree Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f9f9f9;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #treeCanvas {\n    background: #fff;\n    border: 1px solid #ccc;\n    display: block;\n    margin: 20px auto;\n  }\n  #controls {\n    text-align: center;\n    margin-bottom: 15px;\n  }\n  input[type=\"number\"] {\n    width: 60px;\n    padding: 5px;\n    font-size: 1rem;\n  }\n  button {\n    padding: 6px 12px;\n    font-size: 1rem;\n    margin: 0 5px;\n    cursor: pointer;\n  }\n  #info {\n    max-width: 600px;\n    margin: 0 auto;\n    font-size: 1rem;\n    line-height: 1.4;\n  }\n  .traversal-result {\n    font-weight: bold;\n    margin-top: 8px;\n  }\n</style>\n</head>\n<body>\n<h1>Binary Tree Interactive Demonstration</h1>\n\n<div id=\"controls\">\n  <input type=\"number\" id=\"valueInput\" placeholder=\"Value\" />\n  <button id=\"insertBtn\">Insert Node</button>\n  <button id=\"clearBtn\">Clear Tree</button>\n  <br /><br />\n  <button id=\"preOrderBtn\">Pre-order Traversal</button>\n  <button id=\"inOrderBtn\">In-order Traversal</button>\n  <button id=\"postOrderBtn\">Post-order Traversal</button>\n  <button id=\"levelOrderBtn\">Level-order Traversal</button>\n</div>\n\n<canvas id=\"treeCanvas\" width=\"800\" height=\"400\"></canvas>\n\n<div id=\"info\">\n  <p>This demonstration shows a <strong>Binary Tree</strong> where each node has at most two children (left and right).</p>\n  <p>You can insert integer values into the tree. The tree will be displayed graphically, with each node shown as a circle containing its value.</p>\n  <p>Use the traversal buttons to see the order in which nodes are visited during different tree traversals:</p>\n  <ul>\n    <li><strong>Pre-order:</strong> Visit node, then left subtree, then right subtree.</li>\n    <li><strong>In-order:</strong> Visit left subtree, then node, then right subtree.</li>\n    <li><strong>Post-order:</strong> Visit left subtree, then right subtree, then node.</li>\n    <li><strong>Level-order:</strong> Visit nodes level by level from top to bottom.</li>\n  </ul>\n  <div id=\"traversalOutput\" class=\"traversal-result\"></div>\n</div>\n\n<script>\n(() => {\n  // Define Node class for binary tree\n  class Node {\n    constructor(value) {\n      this.value = value;\n      this.left = null;\n      this.right = null;\n    }\n  }\n\n  // Define BinaryTree class\n  class BinaryTree {\n    constructor() {\n      this.root = null;\n    }\n\n    insert(value) {\n      const newNode = new Node(value);\n      if (this.root === null) {\n        this.root = newNode;\n        return;\n      }\n      // For demonstration, insert smaller values to left, larger or equal to right\n      function insertNode(current, newNode) {\n        if (newNode.value < current.value) {\n          if (current.left === null) {\n            current.left = newNode;\n          } else {\n            insertNode(current.left, newNode);\n          }\n        } else {\n          if (current.right === null) {\n            current.right = newNode;\n          } else {\n            insertNode(current.right, newNode);\n          }\n        }\n      }\n      insertNode(this.root, newNode);\n    }\n\n    clear() {\n      this.root = null;\n    }\n\n    preOrderTraversal() {\n      const result = [];\n      function traverse(node) {\n        if (!node) return;\n        result.push(node.value);\n        traverse(node.left);\n        traverse(node.right);\n      }\n      traverse(this.root);\n      return result;\n    }\n\n    inOrderTraversal() {\n      const result = [];\n      function traverse(node) {\n        if (!node) return;\n        traverse(node.left);\n        result.push(node.value);\n        traverse(node.right);\n      }\n      traverse(this.root);\n      return result;\n    }\n\n    postOrderTraversal() {\n      const result = [];\n      function traverse(node) {\n        if (!node) return;\n        traverse(node.left);\n        traverse(node.right);\n        result.push(node.value);\n      }\n      traverse(this.root);\n      return result;\n    }\n\n    levelOrderTraversal() {\n      const result = [];\n      if (!this.root) return result;\n      const queue = [this.root];\n      while (queue.length > 0) {\n        const node = queue.shift();\n        result.push(node.value);\n        if (node.left) queue.push(node.left);\n        if (node.right) queue.push(node.right);\n      }\n      return result;\n    }\n\n  }\n\n  // Drawing the binary tree on canvas\n  function drawTree(tree, canvas) {\n    const ctx = canvas.getContext('2d');\n    ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n    if (!tree.root) {\n      ctx.font = '20px Arial';\n      ctx.fillStyle = '#999';\n      ctx.textAlign = 'center';\n      ctx.fillText('Tree is empty', canvas.width / 2, canvas.height / 2);\n      return;\n    }\n\n    // Calculate positions for nodes (using a simple recursive layout)\n    // We'll assign x and y coordinates for each node\n    const nodeRadius = 20;\n    const levelHeight = 80;\n\n    // First find tree height to calculate horizontal spacing\n    function treeHeight(node) {\n      if (!node) return 0;\n      return 1 + Math.max(treeHeight(node.left), treeHeight(node.right));\n    }\n    const height = treeHeight(tree.root);\n\n    // Get positions:\n    // We perform an in-order traversal and assign x positions in sorted order\n    const positions = new Map();\n    let xPos = 0;\n    function assignPositions(node, depth) {\n      if (!node) return;\n      assignPositions(node.left, depth + 1);\n      const x = xPos++;\n      const y = depth;\n      positions.set(node, { x, y });\n      assignPositions(node.right, depth + 1);\n    }\n    assignPositions(tree.root, 0);\n\n    // Calculate scale to fit canvas width\n    // x goes from 0 to xPos - 1\n    const maxX = xPos - 1;\n    const xSpacing = (canvas.width - 40) / (maxX || 1);\n    // y is depth, from 0 to height-1\n    const ySpacing = levelHeight;\n\n    // Draw edges first\n    function drawEdge(parentNode, childNode) {\n      const from = positions.get(parentNode);\n      const to = positions.get(childNode);\n      if (!from || !to) return;\n      const fromX = 20 + from.x * xSpacing;\n      const fromY = 40 + from.y * ySpacing;\n      const toX = 20 + to.x * xSpacing;\n      const toY = 40 + to.y * ySpacing;\n      ctx.strokeStyle = '#555';\n      ctx.lineWidth = 2;\n      ctx.beginPath();\n      ctx.moveTo(fromX, fromY + nodeRadius);\n      // Slight curve line downward\n      const midX = (fromX + toX) / 2;\n      ctx.bezierCurveTo(midX, fromY + ySpacing / 2, midX, toY - ySpacing / 2, toX, toY - nodeRadius);\n      ctx.stroke();\n    }\n\n    function drawNode(node) {\n      const pos = positions.get(node);\n      if (!pos) return;\n      const x = 20 + pos.x * xSpacing;\n      const y = 40 + pos.y * ySpacing;\n\n      // Draw node circle\n      ctx.fillStyle = '#4a90e2';\n      ctx.strokeStyle = '#003366';\n      ctx.lineWidth = 3;\n      ctx.beginPath();\n      ctx.arc(x, y, nodeRadius, 0, 2 * Math.PI);\n      ctx.fill();\n      ctx.stroke();\n\n      // Draw node value\n      ctx.fillStyle = 'white';\n      ctx.font = 'bold 14px Arial';\n      ctx.textAlign = 'center';\n      ctx.textBaseline = 'middle';\n      ctx.fillText(node.value, x, y);\n    }\n\n    // Draw all edges recursively\n    function drawEdges(node) {\n      if (!node) return;\n      if (node.left) drawEdge(node, node.left);\n      if (node.right) drawEdge(node, node.right);\n      drawEdges(node.left);\n      drawEdges(node.right);\n    }\n    drawEdges(tree.root);\n\n    // Draw all nodes recursively\n    function drawNodes(node) {\n      if (!node) return;\n      drawNodes(node.left);\n      drawNode(node);\n      drawNodes(node.right);\n    }\n    drawNodes(tree.root);\n  }\n\n  // Initialize\n  const tree = new BinaryTree();\n  const canvas = document.getElementById('treeCanvas');\n  const valueInput = document.getElementById('valueInput');\n  const insertBtn = document.getElementById('insertBtn');\n  const clearBtn = document.getElementById('clearBtn');\n  const traversalOutput = document.getElementById('traversalOutput');\n  const preOrderBtn = document.getElementById('preOrderBtn');\n  const inOrderBtn = document.getElementById('inOrderBtn');\n  const postOrderBtn = document.getElementById('postOrderBtn');\n  const levelOrderBtn = document.getElementById('levelOrderBtn');\n\n  // Insert node handler\n  insertBtn.addEventListener('click', () => {\n    const val = Number(valueInput.value);\n    if (Number.isInteger(val)) {\n      tree.insert(val);\n      valueInput.value = '';\n      traversalOutput.textContent = '';\n      drawTree(tree, canvas);\n    } else {\n      alert('Please enter a valid integer value.');\n    }\n    valueInput.focus();\n  });\n\n  // Clear tree handler\n  clearBtn.addEventListener('click', () => {\n    tree.clear();\n    traversalOutput.textContent = '';\n    drawTree(tree, canvas);\n    valueInput.focus();\n  });\n\n  // Traversal button handlers\n  preOrderBtn.addEventListener('click', () => {\n    if (!tree.root) {\n      traversalOutput.textContent = 'Tree is empty.';\n      return;\n    }\n    const result = tree.preOrderTraversal();\n    traversalOutput.textContent = 'Pre-order: ' + result.join(', ');\n  });\n\n  inOrderBtn.addEventListener('click', () => {\n    if (!tree.root) {\n      traversalOutput.textContent = 'Tree is empty.';\n      return;\n    }\n    const result = tree.inOrderTraversal();\n    traversalOutput.textContent = 'In-order: ' + result.join(', ');\n  });\n\n  postOrderBtn.addEventListener('click', () => {\n    if (!tree.root) {\n      traversalOutput.textContent = 'Tree is empty.';\n      return;\n    }\n    const result = tree.postOrderTraversal();\n    traversalOutput.textContent = 'Post-order: ' + result.join(', ');\n  });\n\n  levelOrderBtn.addEventListener('click', () => {\n    if (!tree.root) {\n      traversalOutput.textContent = 'Tree is empty.';\n      return;\n    }\n    const result = tree.levelOrderTraversal();\n    traversalOutput.textContent = 'Level-order: ' + result.join(', ');\n  });\n\n  // Initial draw\n  drawTree(tree, canvas);\n})();\n</script>\n</body>\n</html>"
