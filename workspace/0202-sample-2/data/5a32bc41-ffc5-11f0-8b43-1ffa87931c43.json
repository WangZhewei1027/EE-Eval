    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Weighted Graph Demo</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 0; padding: 0;\n      display: flex;\n      flex-direction: column;\n      height: 100vh;\n    }\n    header {\n      background: #007acc;\n      color: white;\n      padding: 1em;\n      text-align: center;\n    }\n    main {\n      flex: 1;\n      display: flex;\n      flex-direction: row;\n      overflow: hidden;\n    }\n    #graphCanvas {\n      flex: 1;\n      background-color: #f0f0f0;\n      cursor: grab;\n    }\n    #controls {\n      width: 320px;\n      border-left: 1px solid #ccc;\n      padding: 1em;\n      box-sizing: border-box;\n      overflow-y: auto;\n      background-color: #fafafa;\n    }\n    h2 {\n      margin-top: 0;\n    }\n    label {\n      display: block;\n      margin: 0.5em 0 0.2em;\n      font-weight: bold;\n    }\n    input[type=\"text\"], input[type=\"number\"] {\n      width: 100%;\n      padding: 0.25em 0.5em;\n      box-sizing: border-box;\n    }\n    button {\n      margin-top: 0.5em;\n      padding: 0.5em 1em;\n      font-size: 1em;\n      cursor: pointer;\n      border: none;\n      background-color: #007acc;\n      color: white;\n      border-radius: 3px;\n    }\n    button:disabled {\n      background-color: #888;\n      cursor: not-allowed;\n    }\n    ul {\n      list-style: none;\n      padding-left: 0;\n    }\n    ul li {\n      padding: 2px 0;\n      font-family: monospace;\n    }\n    .edge-weight {\n      font-weight: bold;\n      color: #c0392b;\n      margin-left: 5px;\n    }\n    #message {\n      margin-top: 1em;\n      min-height: 1.5em;\n      color: #d35400;\n      font-weight: bold;\n    }\n    #dijkstraControls {\n      margin-top: 1em;\n      border-top: 1px solid #ccc;\n      padding-top: 1em;\n    }\n    #pathResult {\n      margin-top: 0.5em;\n      background-color: #e8f6f3;\n      padding: 0.5em;\n      border-radius: 5px;\n      font-family: monospace;\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <h1>Weighted Graph Interactive Demo</h1>\n  </header>\n  <main>\n    <canvas id=\"graphCanvas\" width=\"800\" height=\"600\" tabindex=\"0\" aria-label=\"Weighted graph visualization\"></canvas>\n    <aside id=\"controls\" role=\"region\" aria-live=\"polite\">\n      <h2>Graph Controls</h2>\n      <section aria-label=\"Add Node\">\n        <label for=\"nodeIdInput\">Node ID (unique)</label>\n        <input type=\"text\" id=\"nodeIdInput\" maxlength=\"3\" aria-describedby=\"nodeHelp\" placeholder=\"e.g. A\" />\n        <small id=\"nodeHelp\">Node ids are short, like A, B, C...</small>\n        <button id=\"addNodeBtn\">Add Node</button>\n      </section>\n      <section aria-label=\"Add Edge\" style=\"margin-top:1em;\">\n        <label for=\"edgeStartInput\">Start Node ID</label>\n        <input type=\"text\" id=\"edgeStartInput\" maxlength=\"3\" placeholder=\"e.g. A\" />\n        <label for=\"edgeEndInput\">End Node ID</label>\n        <input type=\"text\" id=\"edgeEndInput\" maxlength=\"3\" placeholder=\"e.g. B\" />\n        <label for=\"edgeWeightInput\">Weight (positive number)</label>\n        <input type=\"number\" id=\"edgeWeightInput\" min=\"0.01\" step=\"0.01\" placeholder=\"e.g. 5\" />\n        <button id=\"addEdgeBtn\">Add Edge</button>\n      </section>\n\n      <section aria-label=\"Graph Information\" style=\"margin-top: 2em;\">\n        <h3>Nodes (<span id=\"nodeCount\">0</span>)</h3>\n        <ul id=\"nodesList\" aria-live=\"polite\" aria-atomic=\"true\"></ul>\n        <h3>Edges (<span id=\"edgeCount\">0</span>)</h3>\n        <ul id=\"edgesList\" aria-live=\"polite\" aria-atomic=\"true\"></ul>\n      </section>\n\n      <section id=\"dijkstraControls\" aria-label=\"Find shortest path\">\n        <h3>Dijkstra Shortest Path</h3>\n        <label for=\"startNodeDijkstra\">Start Node</label>\n        <input type=\"text\" id=\"startNodeDijkstra\" maxlength=\"3\" placeholder=\"e.g. A\" />\n        <label for=\"endNodeDijkstra\">End Node</label>\n        <input type=\"text\" id=\"endNodeDijkstra\" maxlength=\"3\" placeholder=\"e.g. B\" />\n        <button id=\"findPathBtn\">Find Shortest Path</button>\n        <div id=\"pathResult\" aria-live=\"polite\"></div>\n      </section>\n\n      <div id=\"message\" role=\"alert\" aria-live=\"assertive\"></div>\n    </aside>\n  </main>\n\n  <script>\n    /*\n     * Weighted Graph Demo\n     * \n     * Features:\n     * - Add nodes by ID\n     * - Add weighted edges between nodes\n     * - Canvas visualization with drag & position nodes\n     * - Shows nodes and edges in lists\n     * - Find shortest path with Dijkstra's algorithm\n     */\n\n    (function() {\n      // Canvas setup\n      const canvas = document.getElementById('graphCanvas');\n      const ctx = canvas.getContext('2d');\n\n      // DOM Elements\n      const nodeIdInput = document.getElementById('nodeIdInput');\n      const addNodeBtn = document.getElementById('addNodeBtn');\n      const edgeStartInput = document.getElementById('edgeStartInput');\n      const edgeEndInput = document.getElementById('edgeEndInput');\n      const edgeWeightInput = document.getElementById('edgeWeightInput');\n      const addEdgeBtn = document.getElementById('addEdgeBtn');\n      const nodesList = document.getElementById('nodesList');\n      const edgesList = document.getElementById('edgesList');\n      const nodeCount = document.getElementById('nodeCount');\n      const edgeCount = document.getElementById('edgeCount');\n      const message = document.getElementById('message');\n      const startNodeDijkstra = document.getElementById('startNodeDijkstra');\n      const endNodeDijkstra = document.getElementById('endNodeDijkstra');\n      const findPathBtn = document.getElementById('findPathBtn');\n      const pathResult = document.getElementById('pathResult');\n\n      // Graph Data Structures\n      class Graph {\n        constructor() {\n          this.nodes = new Map(); \n          // key: nodeId (string) -> value: Node instance\n          this.edges = new Map(); \n          // key: nodeId, value: Map of adjacent nodeId -> weight\n        }\n        addNode(id, x = null, y = null) {\n          if (this.nodes.has(id)) return false;\n          // If x,y not provided, place randomly near center\n          if (x === null || y === null) {\n            x = canvas.width/2 + (Math.random()-0.5)*200;\n            y = canvas.height/2 + (Math.random()-0.5)*200;\n          }\n          this.nodes.set(id, new Node(id, x, y));\n          this.edges.set(id, new Map());\n          return true;\n        }\n        hasNode(id) {\n          return this.nodes.has(id);\n        }\n        removeNode(id) {\n          if (!this.nodes.has(id)) return false;\n          this.nodes.delete(id);\n          this.edges.delete(id);\n          // Remove edges connected to id\n          for (const [from, adjs] of this.edges) {\n            if (adjs.has(id)) {\n              adjs.delete(id);\n            }\n          }\n          return true;\n        }\n        addEdge(from, to, weight) {\n          if (!this.nodes.has(from) || !this.nodes.has(to)) return false;\n          if (weight <= 0) return false;\n          this.edges.get(from).set(to, weight);\n          this.edges.get(to).set(from, weight); // Undirected\n          return true;\n        }\n        removeEdge(from, to) {\n          if (!this.nodes.has(from) || !this.nodes.has(to)) return false;\n          const removed1 = this.edges.get(from).delete(to);\n          const removed2 = this.edges.get(to).delete(from);\n          return removed1 || removed2;\n        }\n        getEdges() {\n          // Return edges as [from,to,weight], only one direction (from < to) to avoid duplicates\n          const seen = new Set();\n          const result = [];\n          for (const [from, adjs] of this.edges) {\n            for (const [to, weight] of adjs) {\n              const edgeId = [from,to].sort().join('-');\n              if (!seen.has(edgeId)) {\n                seen.add(edgeId);\n                result.push({from, to, weight});\n              }\n            }\n          }\n          return result;\n        }\n      }\n\n      class Node {\n        constructor(id, x, y) {\n          this.id = id;\n          this.x = x;\n          this.y = y;\n          this.radius = 20;\n          this.isDragging = false;\n        }\n      }\n\n      // Initialize Graph\n      const graph = new Graph();\n\n      // Add some sample nodes and edges to start with\n      function addSampleGraph() {\n        graph.addNode('A', 150, 150);\n        graph.addNode('B', 400, 100);\n        graph.addNode('C', 650, 150);\n        graph.addNode('D', 200, 400);\n        graph.addNode('E', 600, 400);\n\n        graph.addEdge('A', 'B', 7);\n        graph.addEdge('A', 'D', 5);\n        graph.addEdge('B', 'C', 8);\n        graph.addEdge('B', 'D', 9);\n        graph.addEdge('B', 'E', 7);\n        graph.addEdge('C', 'E', 5);\n        graph.addEdge('D', 'E', 15);\n      }\n\n      // Rendering Variables\n      let draggingNode = null;\n      let dragOffsetX = 0;\n      let dragOffsetY = 0;\n\n      function drawGraph(highlightedPath = null) {\n        ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n        // Draw edges first\n        for (const {from, to, weight} of graph.getEdges()) {\n          const nodeFrom = graph.nodes.get(from);\n          const nodeTo = graph.nodes.get(to);\n\n          const isHighlighted = highlightedPath && highlightedPath.some((val, i, arr) => {\n            if(i === arr.length-1) return false;\n            return (val === from && arr[i+1] === to) || (val === to && arr[i+1] === from);\n          });\n\n          ctx.lineWidth = isHighlighted ? 4 : 2;\n          ctx.strokeStyle = isHighlighted ? '#e67e22' : '#7f8c8d';\n          ctx.beginPath();\n          ctx.moveTo(nodeFrom.x, nodeFrom.y);\n          ctx.lineTo(nodeTo.x, nodeTo.y);\n          ctx.stroke();\n\n          // Draw weight label - midpoint of edge line\n          const midX = (nodeFrom.x + nodeTo.x)/2;\n          const midY = (nodeFrom.y + nodeTo.y)/2;\n          ctx.fillStyle = '#c0392b';\n          ctx.font = '14px Arial';\n          ctx.fillText(weight, midX + 5, midY - 5);\n        }\n\n        // Draw nodes on top\n        for (const node of graph.nodes.values()) {\n          // Circle\n          ctx.beginPath();\n          ctx.fillStyle = '#2980b9';\n          ctx.strokeStyle = '#34495e';\n          ctx.lineWidth = 2;\n          ctx.arc(node.x, node.y, node.radius, 0, 2 * Math.PI);\n          ctx.fill();\n\n          // Highlight if in path\n          if (highlightedPath && highlightedPath.includes(node.id)) {\n            ctx.strokeStyle = '#e67e22';\n            ctx.lineWidth = 4;\n            ctx.stroke();\n          } else {\n            ctx.stroke();\n          }\n\n          // Text\n          ctx.fillStyle = 'white';\n          ctx.font = 'bold 16px Arial';\n          ctx.textAlign = 'center';\n          ctx.textBaseline = 'middle';\n          ctx.fillText(node.id, node.x, node.y);\n        }\n      }\n\n      function updateGraphInfo() {\n        // Nodes List\n        nodesList.innerHTML = '';\n        for (const node of graph.nodes.values()) {\n          const li = document.createElement('li');\n          li.textContent = `${node.id} (x: ${node.x.toFixed(1)}, y: ${node.y.toFixed(1)})`;\n          nodesList.appendChild(li);\n        }\n        nodeCount.textContent = graph.nodes.size;\n\n        // Edges List\n        edgesList.innerHTML = '';\n        for (const edge of graph.getEdges()) {\n          const li = document.createElement('li');\n          li.innerHTML = `${edge.from} — ${edge.to} <span class=\"edge-weight\">(weight: ${edge.weight})</span>`;\n          edgesList.appendChild(li);\n        }\n        edgeCount.textContent = graph.getEdges().length;\n      }\n\n      // Validate Node ID: simple uppercase alphabetical max 3 chars\n      function validNodeId(id) {\n        const r = /^[A-Z0-9]{1,3}$/;\n        return r.test(id);\n      }\n\n      // Add Node Handler\n      addNodeBtn.addEventListener('click', () => {\n        message.textContent = '';\n        const id = nodeIdInput.value.trim().toUpperCase();\n        if (!validNodeId(id)) {\n          message.textContent = 'Invalid Node ID. Use 1-3 uppercase letters or numbers (A-Z,0-9).';\n          return;\n        }\n        if (graph.hasNode(id)) {\n          message.textContent = `Node \"${id}\" already exists.`;\n          return;\n        }\n        graph.addNode(id);\n        nodeIdInput.value = '';\n        updateGraphInfo();\n        drawGraph();\n      });\n\n      // Add Edge Handler\n      addEdgeBtn.addEventListener('click', () => {\n        message.textContent = '';\n        const from = edgeStartInput.value.trim().toUpperCase();\n        const to = edgeEndInput.value.trim().toUpperCase();\n        const weight = parseFloat(edgeWeightInput.value);\n\n        if (!(validNodeId(from) && validNodeId(to))) {\n          message.textContent = 'Start and End node IDs must be valid (1-3 uppercase letters/numbers).';\n          return;\n        }\n        if (from === to) {\n          message.textContent = 'Cannot create edge from a node to itself.';\n          return;\n        }\n        if (!graph.hasNode(from)) {\n          message.textContent = `Node \"${from}\" does not exist.`;\n          return;\n        }\n        if (!graph.hasNode(to)) {\n          message.textContent = `Node \"${to}\" does not exist.`;\n          return;\n        }\n        if (isNaN(weight) || weight <= 0) {\n          message.textContent = 'Weight must be a positive number.';\n          return;\n        }\n        graph.addEdge(from, to, weight);\n        edgeStartInput.value = '';\n        edgeEndInput.value = '';\n        edgeWeightInput.value = '';\n        updateGraphInfo();\n        drawGraph();\n      });\n\n      // Canvas Interaction: Drag nodes\n      canvas.addEventListener('mousedown', e => {\n        const pos = getMousePos(canvas, e);\n        for (const node of graph.nodes.values()) {\n          if (distance(pos, node) <= node.radius) {\n            draggingNode = node;\n            dragOffsetX = pos.x - node.x;\n            dragOffsetY = pos.y - node.y;\n            canvas.style.cursor = 'grabbing';\n            break;\n          }\n        }\n      });\n      canvas.addEventListener('mouseup', e => {\n        if (draggingNode) {\n          draggingNode = null;\n          canvas.style.cursor = 'grab';\n          updateGraphInfo();\n          drawGraph();\n        }\n      });\n      canvas.addEventListener('mouseleave', e => {\n        if (draggingNode) {\n          draggingNode = null;\n          canvas.style.cursor = 'grab';\n          updateGraphInfo();\n          drawGraph();\n        }\n      });\n      canvas.addEventListener('mousemove', e => {\n        if (draggingNode) {\n          const pos = getMousePos(canvas, e);\n          draggingNode.x = pos.x - dragOffsetX;\n          draggingNode.y = pos.y - dragOffsetY;\n          drawGraph(currentHighlightedPath);\n        }\n      });\n\n      function getMousePos(canvas, evt) {\n        const rect = canvas.getBoundingClientRect();\n        return {\n          x: evt.clientX - rect.left,\n          y: evt.clientY - rect.top\n        };\n      }\n      function distance(p1, p2) {\n        return Math.sqrt((p1.x - p2.x)**2 + (p1.y - p2.y)**2);\n      }\n\n      // Dijkstra's Algorithm Implementation\n      function dijkstra(graph, startId, endId) {\n        if (!graph.hasNode(startId) || !graph.hasNode(endId)) return null;\n\n        const distances = new Map();\n        const previous = new Map();\n        const pq = new MinPriorityQueue();\n\n        for (const nodeId of graph.nodes.keys()) {\n          distances.set(nodeId, Infinity);\n          previous.set(nodeId, null);\n        }\n        distances.set(startId, 0);\n        pq.enqueue(startId, 0);\n\n        while (!pq.isEmpty()) {\n          const currentNode = pq.dequeue();\n          if (currentNode === endId) break;\n          for (const [neighbor, weight] of graph.edges.get(currentNode)) {\n            const altDistance = distances.get(currentNode) + weight;\n            if (altDistance < distances.get(neighbor)) {\n              distances.set(neighbor, altDistance);\n              previous.set(neighbor, currentNode);\n              pq.enqueue(neighbor, altDistance);\n            }\n          }\n        }\n\n        // Build path by walking back from endId\n        if (distances.get(endId) === Infinity) return null;\n\n        const path = [];\n        let u = endId;\n        while (u !== null) {\n          path.unshift(u);\n          u = previous.get(u);\n        }\n\n        return {path, distance: distances.get(endId)};\n      }\n\n      // Simple Priority Queue for Dijkstra\n      class MinPriorityQueue {\n        constructor() {\n          this.queue = [];\n        }\n        enqueue(val, priority) {\n          this.queue.push({val, priority});\n          this.queue.sort((a,b) => a.priority - b.priority);\n        }\n        dequeue() {\n          if (this.queue.length === 0) return null;\n          return this.queue.shift().val;\n        }\n        isEmpty() {\n          return this.queue.length === 0;\n        }\n      }\n\n      // Dijkstra Controls\n      let currentHighlightedPath = null;\n\n      findPathBtn.addEventListener('click', () => {\n        message.textContent = '';\n        pathResult.textContent = '';\n        currentHighlightedPath = null;\n\n        const start = startNodeDijkstra.value.trim().toUpperCase();\n        const end = endNodeDijkstra.value.trim().toUpperCase();\n\n        if (!validNodeId(start) || !validNodeId(end)) {\n          message.textContent = 'Start and End node IDs must be valid (1-3 uppercase letters/numbers).';\n          return;\n        }\n        if (!graph.hasNode(start) || !graph.hasNode(end)) {\n          message.textContent = `Both nodes must exist in the graph.`;\n          return;\n        }\n        if (start === end) {\n          message.textContent = 'Start and End nodes are the same.';\n          return;\n        }\n\n        const result = dijkstra(graph, start, end);\n\n        if (!result) {\n          message.textContent = `No path found between ${start} and ${end}.`;\n          drawGraph();\n          return;\n        }\n\n        currentHighlightedPath = result.path;\n        drawGraph(currentHighlightedPath);\n\n        pathResult.textContent = `Path: ${result.path.join(' → ')} (Total weight: ${result.distance.toFixed(2)})`;\n      });\n\n      // Initial setup\n      addSampleGraph();\n      updateGraphInfo();\n      drawGraph();\n\n      // Accessibility focus style on canvas\n      canvas.style.outline = 'none';\n      canvas.addEventListener('focus', () => {\n        canvas.style.boxShadow = '0 0 5px 2px #2980b9';\n      });\n      canvas.addEventListener('blur', () => {\n        canvas.style.boxShadow = 'none';\n      });\n\n    })();\n  </script>\n</body>\n</html>"
  },
