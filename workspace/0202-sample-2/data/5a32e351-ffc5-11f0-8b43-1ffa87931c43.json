    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Bubble Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    background: #222;\n    color: #eee;\n    margin: 0;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    padding: 20px;\n  }\n  h1 {\n    margin-bottom: 0.2em;\n  }\n  #array-container {\n    display: flex;\n    align-items: flex-end;\n    justify-content: center;\n    margin: 20px 0;\n    height: 300px;\n    width: 80vw;\n    max-width: 800px;\n    border: 2px solid #444;\n    background: #111;\n    position: relative;\n  }\n  .bar {\n    margin: 0 2px;\n    background-color: #4a90e2;\n    width: 20px;\n    border-radius: 3px 3px 0 0;\n    transition: background-color 0.3s;\n    position: relative;\n  }\n  .bar span {\n    position: absolute;\n    top: -22px;\n    width: 100%;\n    text-align: center;\n    font-size: 12px;\n    color: #ccc;\n  }\n  .bar.comparing {\n    background-color: #f39c12;\n  }\n  .bar.swapping {\n    background-color: #e74c3c;\n  }\n  .bar.sorted {\n    background-color: #2ecc71;\n  }\n  #controls {\n    margin-top: 10px;\n  }\n  button {\n    background: #4a90e2;\n    color: #eee;\n    border: none;\n    padding: 8px 16px;\n    margin: 0 8px;\n    font-size: 14px;\n    border-radius: 4px;\n    cursor: pointer;\n    transition: background 0.3s;\n  }\n  button:disabled {\n    background: #333;\n    cursor: not-allowed;\n  }\n  button:hover:not(:disabled) {\n    background: #357ab8;\n  }\n  #info {\n    max-width: 800px;\n    margin-top: 15px;\n    font-size: 14px;\n    line-height: 1.4;\n    color: #aaa;\n  }\n</style>\n</head>\n<body>\n\n<h1>Bubble Sort Visualization</h1>\n<div id=\"array-container\"></div>\n\n<div id=\"controls\">\n  <button id=\"shuffle-btn\">Shuffle</button>\n  <button id=\"start-btn\">Start Sorting</button>\n</div>\n\n<div id=\"info\">\n  <p><strong>Bubble Sort</strong> is a simple sorting algorithm that repeatedly steps through the list, compares adjacent elements, and swaps them if they are in the wrong order. This pass through the list is repeated until the list is sorted.</p>\n  <p>The bars being compared are highlighted in <span style=\"color:#f39c12;\">orange</span>, those swapping turn <span style=\"color:#e74c3c;\">red</span>, and sorted bars are colored <span style=\"color:#2ecc71;\">green</span>.</p>\n</div>\n\n<script>\n  const container = document.getElementById('array-container');\n  const shuffleBtn = document.getElementById('shuffle-btn');\n  const startBtn = document.getElementById('start-btn');\n\n  const ARRAY_SIZE = 30;\n  const DELAY = 80; // ms delay between steps\n\n  let array = [];\n  let bars = [];\n  let sorting = false;\n  let timeoutIds = [];\n\n  function createArray() {\n    array = [];\n    for (let i = 0; i < ARRAY_SIZE; i++) {\n      array.push(getRandomInt(10, 300));\n    }\n  }\n\n  function getRandomInt(min, max) {\n    return Math.floor(Math.random() * (max - min + 1) + min);\n  }\n\n  function renderArray() {\n    container.innerHTML = '';\n    bars = [];\n    const barWidth = Math.floor((container.clientWidth - ARRAY_SIZE * 4) / ARRAY_SIZE);\n    for (let i = 0; i < array.length; i++) {\n      const bar = document.createElement('div');\n      bar.className = 'bar';\n      bar.style.height = array[i] + 'px';\n      bar.style.width = barWidth > 20 ? '20px' : barWidth + 'px';\n      const valSpan = document.createElement('span');\n      valSpan.textContent = array[i];\n      bar.appendChild(valSpan);\n      container.appendChild(bar);\n      bars.push(bar);\n    }\n  }\n\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  async function bubbleSort() {\n    sorting = true;\n    shuffleBtn.disabled = true;\n    startBtn.disabled = true;\n\n    let n = array.length;\n    for (let i = 0; i < n - 1; i++) {\n      let swapped = false;\n      for (let j = 0; j < n - 1 - i; j++) {\n        // Highlight bars being compared\n        bars[j].classList.add('comparing');\n        bars[j+1].classList.add('comparing');\n        await sleep(DELAY);\n\n        if (array[j] > array[j + 1]) {\n          // Highlight bars swapping\n          bars[j].classList.remove('comparing');\n          bars[j+1].classList.remove('comparing');\n          bars[j].classList.add('swapping');\n          bars[j+1].classList.add('swapping');\n          await sleep(DELAY);\n\n          // Swap values in array\n          [array[j], array[j + 1]] = [array[j + 1], array[j]];\n          // Swap heights visually\n          bars[j].style.height = array[j] + 'px';\n          bars[j].querySelector('span').textContent = array[j];\n          bars[j + 1].style.height = array[j + 1] + 'px';\n          bars[j + 1].querySelector('span').textContent = array[j + 1];\n\n          await sleep(DELAY);\n          bars[j].classList.remove('swapping');\n          bars[j+1].classList.remove('swapping');\n\n          swapped = true;\n        }\n\n        bars[j].classList.remove('comparing');\n        bars[j+1].classList.remove('comparing');\n      }\n      // Mark the last sorted element\n      bars[n - 1 - i].classList.add('sorted');\n\n      if (!swapped) break;\n    }\n    // Mark the first element (if loop completed early)\n    bars[0].classList.add('sorted');\n\n    sorting = false;\n    shuffleBtn.disabled = false;\n    startBtn.disabled = false;\n  }\n\n  function resetBarsColor() {\n    for (const bar of bars) {\n      bar.classList.remove('comparing', 'swapping', 'sorted');\n    }\n  }\n\n  function shuffleArray() {\n    if (sorting) return;\n    createArray();\n    renderArray();\n    resetBarsColor();\n  }\n\n  shuffleBtn.addEventListener('click', shuffleArray);\n\n  startBtn.addEventListener('click', async () => {\n    if (sorting) return;\n    await bubbleSort();\n  });\n\n  window.addEventListener('resize', () => {\n    // Update bar widths on resize\n    renderArray();\n  });\n\n  // Initial setup\n  createArray();\n  renderArray();\n</script>\n\n</body>\n</html>"
