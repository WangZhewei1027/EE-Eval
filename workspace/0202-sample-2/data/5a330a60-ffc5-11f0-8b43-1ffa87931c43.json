    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Quick Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f0f2f5;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  h1 {\n    margin-bottom: 0.1em;\n  }\n  #array-container {\n    margin: 20px 0;\n    display: flex;\n    gap: 4px;\n    justify-content: center;\n  }\n  .bar {\n    width: 20px;\n    background-color: #72aee6;\n    transition: background-color 0.3s, height 0.3s;\n    text-align: center;\n    color: white;\n    font-weight: bold;\n    font-size: 12px;\n    border-radius: 4px 4px 0 0;\n    display: flex;\n    justify-content: center;\n    align-items: flex-end;\n  }\n  .bar.pivot {\n    background-color: #e67373;\n  }\n  .bar.compare {\n    background-color: #f2d16b;\n  }\n  .bar.swap {\n    background-color: #7de7a6;\n  }\n  button {\n    padding: 10px 18px;\n    font-size: 1rem;\n    border: none;\n    border-radius: 5px;\n    background-color: #4285f4;\n    color: white;\n    cursor: pointer;\n    margin-top: 10px;\n  }\n  button:disabled {\n    background-color: #a1c2f7;\n    cursor: not-allowed;\n  }\n  #description {\n    max-width: 600px;\n    text-align: center;\n    margin-bottom: 10px;\n    color: #333;\n  }\n  #speed-control {\n    margin-top: 10px;\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n  #speed-control label {\n    font-size: 0.9rem;\n  }\n  #speed {\n    width: 120px;\n  }\n</style>\n</head>\n<body>\n<h1>Quick Sort Visualization</h1>\n<div id=\"description\">\n  Quick Sort is a divide-and-conquer sorting algorithm that picks a <em>pivot</em> element,\n  partitions the array such that elements smaller than pivot come before it and larger ones after,\n  then recursively sorts the sub-arrays.\n</div>\n<div id=\"array-container\"></div>\n<div id=\"speed-control\">\n  <label for=\"speed\">Animation Speed (ms):</label>\n  <input type=\"range\" id=\"speed\" min=\"50\" max=\"1000\" value=\"400\" step=\"50\" />\n  <span id=\"speed-value\">400</span>\n</div>\n<button id=\"start-btn\">Start Quick Sort</button>\n<button id=\"reset-btn\">Reset Array</button>\n\n<script>\n(() => {\n  const arrayContainer = document.getElementById(\"array-container\");\n  const startBtn = document.getElementById(\"start-btn\");\n  const resetBtn = document.getElementById(\"reset-btn\");\n  const speedInput = document.getElementById(\"speed\");\n  const speedValue = document.getElementById(\"speed-value\");\n\n  let array = [];\n  const arraySize = 20;\n  let delay = +speedInput.value;\n\n  function createRandomArray(size) {\n    const arr = [];\n    while(arr.length < size){\n      const val = Math.floor(Math.random() * 200) + 10; // values between 10 and 209\n      if(!arr.includes(val)) arr.push(val); // unique values for visual clarity\n    }\n    return arr;\n  }\n\n  // Render bars representing array\n  function renderArray(arr, highlight = {}) {\n    arrayContainer.innerHTML = \"\";\n    arr.forEach((value, i) => {\n      const bar = document.createElement(\"div\");\n      bar.classList.add(\"bar\");\n      bar.style.height = `${value}px`;\n      bar.textContent = \"\";\n      if (highlight.pivot === i) bar.classList.add(\"pivot\");\n      if (highlight.compare && highlight.compare.includes(i)) bar.classList.add(\"compare\");\n      if (highlight.swap && highlight.swap.includes(i)) bar.classList.add(\"swap\");\n      arrayContainer.appendChild(bar);\n    });\n  }\n\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // QuickSort with async visualization\n  async function quickSort(arr, left, right) {\n    if (left < right) {\n      const pivotIndex = await partition(arr, left, right);\n      await quickSort(arr, left, pivotIndex - 1);\n      await quickSort(arr, pivotIndex + 1, right);\n    }\n  }\n\n  async function partition(arr, left, right) {\n    let pivotValue = arr[right];\n    let i = left - 1;\n\n    renderArray(arr, { pivot: right });\n    await sleep(delay);\n\n    for (let j = left; j < right; j++) {\n      renderArray(arr, { pivot: right, compare: [j] });\n      await sleep(delay);\n\n      if (arr[j] < pivotValue) {\n        i++;\n        // Swap arr[i] and arr[j]\n        [arr[i], arr[j]] = [arr[j], arr[i]];\n        renderArray(arr, { pivot: right, swap: [i, j] });\n        await sleep(delay);\n      }\n    }\n    // Place pivot after smaller elements\n    [arr[i + 1], arr[right]] = [arr[right], arr[i + 1]];\n    renderArray(arr, { swap: [i + 1, right] });\n    await sleep(delay);\n\n    return i + 1;\n  }\n\n  function disableButtons(state) {\n    startBtn.disabled = state;\n    resetBtn.disabled = state;\n    speedInput.disabled = state;\n  }\n\n  function setup() {\n    array = createRandomArray(arraySize);\n    renderArray(array);\n    disableButtons(false);\n  }\n\n  startBtn.addEventListener(\"click\", async () => {\n    disableButtons(true);\n    await quickSort(array, 0, array.length - 1);\n    renderArray(array);\n    disableButtons(false);\n  });\n\n  resetBtn.addEventListener(\"click\", () => {\n    setup();\n  });\n\n  speedInput.addEventListener(\"input\", (e) => {\n    delay = +e.target.value;\n    speedValue.textContent = delay;\n  });\n\n  // Initial setup\n  setup();\n})();\n</script>\n</body>\n</html>"
