    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Floyd-Warshall Algorithm Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f9fafb;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #graph-input {\n    margin-bottom: 15px;\n  }\n  label {\n    font-weight: bold;\n  }\n  textarea {\n    width: 100%;\n    height: 120px;\n    font-family: monospace;\n    font-size: 14px;\n    margin-top: 5px;\n    margin-bottom: 10px;\n  }\n  button {\n    background-color: #2d89ef;\n    color: white;\n    border: none;\n    padding: 10px 18px;\n    font-size: 16px;\n    cursor: pointer;\n    border-radius: 4px;\n  }\n  button:hover {\n    background-color: #1b5fa7;\n  }\n  .output-section {\n    margin-top: 25px;\n  }\n  table {\n    border-collapse: collapse;\n    margin: 10px 0;\n    width: 100%;\n    max-width: 600px;\n  }\n  th, td {\n    border: 1px solid #bbb;\n    padding: 6px 8px;\n    text-align: center;\n  }\n  th {\n    background: #2d89ef;\n    color: white;\n  }\n  td.infinity {\n    color: #d33;\n    font-style: italic;\n  }\n  .note {\n    font-size: 0.9em;\n    color: #555;\n    margin-top: -10px;\n    margin-bottom: 15px;\n    max-width: 600px;\n  }\n  #steps {\n    max-width: 90vw;\n    max-height: 250px;\n    overflow-y: auto;\n    background: #f0f4ff;\n    border: 1px solid #999;\n    padding: 10px;\n    font-family: monospace;\n    font-size: 13px;\n    white-space: pre-wrap;\n  }\n</style>\n</head>\n<body>\n<h1>Floyd-Warshall Algorithm Demo</h1>\n\n<section id=\"graph-input\">\n  <label for=\"matrixInput\">Enter adjacency matrix (use 0 for no self loops, 9999 or INF for no edge):</label>\n  <textarea id=\"matrixInput\" aria-label=\"Adjacency matrix input\" spellcheck=\"false\">\n0 3 9999 7\n8 0 2 9999\n5 9999 0 1\n2 9999 9999 0\n  </textarea>\n  <div class=\"note\">\n    Use spaces to separate numbers and line breaks for new rows. Example above is a 4x4 graph.\n  </div>\n  <button id=\"runBtn\">Run Floyd-Warshall</button>\n</section>\n\n<section class=\"output-section\" aria-live=\"polite\" aria-atomic=\"true\">\n  <h2>Distance Matrix Result</h2>\n  <div id=\"result\"></div>\n</section>\n\n<section class=\"output-section\">\n  <h2>Step-by-Step Update Log</h2>\n  <div id=\"steps\" tabindex=\"0\" aria-label=\"Step by step updates\"></div>\n</section>\n\n<script>\n(() => {\n  const INF = 9999;\n\n  // Parse input matrix from textarea - convert to numbers, validate rectangular\n  function parseMatrix(text) {\n    const lines = text.trim().split('\\n');\n    const matrix = [];\n    for (const line of lines) {\n      const row = line.trim().split(/\\s+/).map(x => {\n        if (x.toUpperCase() === 'INF') return INF;\n        const n = Number(x);\n        return isNaN(n) ? INF : n;\n      });\n      matrix.push(row);\n    }\n    // Validate rectangle shape\n    const rowLength = matrix[0].length;\n    for (const r of matrix) {\n      if (r.length !== rowLength) throw new Error('Matrix is not rectangular.');\n    }\n    // Validate square\n    if (matrix.length !== matrix[0].length) throw new Error('Matrix must be square.');\n    return matrix;\n  }\n\n  // Clone matrix deeply (2d array)\n  function cloneMatrix(m) {\n    return m.map(row => row.slice());\n  }\n\n  // Format matrix as HTML table\n  function matrixToTable(matrix) {\n    const n = matrix.length;\n    let html = '<table><thead><tr><th></th>';\n    for (let i = 0; i < n; i++) {\n      html += `<th>V${i}</th>`;\n    }\n    html += '</tr></thead><tbody>';\n    for (let i = 0; i < n; i++) {\n      html += `<tr><th>V${i}</th>`;\n      for (let j = 0; j < n; j++) {\n        if (matrix[i][j] === INF) {\n          html += `<td class=\"infinity\">∞</td>`;\n        } else {\n          html += `<td>${matrix[i][j]}</td>`;\n        }\n      }\n      html += '</tr>';\n    }\n    html += '</tbody></table>';\n    return html;\n  }\n\n  // Floyd-Warshall algorithm with step logging\n  function floydWarshall(matrix, logger) {\n    const n = matrix.length;\n    // dist initialized with input matrix\n    const dist = cloneMatrix(matrix);\n\n    // For all k,i,j check if path i->k->j is shorter than i->j\n    for (let k = 0; k < n; k++) {\n      logger(`Using vertex V${k} as intermediate:`);\n      for (let i = 0; i < n; i++) {\n        for (let j = 0; j < n; j++) {\n          const before = dist[i][j];\n          if (dist[i][k] !== INF && dist[k][j] !== INF) {\n            const newDist = dist[i][k] + dist[k][j];\n            if (newDist < dist[i][j]) {\n              dist[i][j] = newDist;\n              logger(`  Updated dist[V${i}][V${j}] from ${before === INF ? '∞' : before} to ${newDist} via V${k}`);\n            }\n          }\n        }\n      }\n      logger(''); // blank line after each k\n    }\n    return dist;\n  }\n\n  // DOM Elements\n  const matrixInput = document.getElementById('matrixInput');\n  const runBtn = document.getElementById('runBtn');\n  const resultDiv = document.getElementById('result');\n  const stepsDiv = document.getElementById('steps');\n\n  runBtn.addEventListener('click', () => {\n    resultDiv.innerHTML = '';\n    stepsDiv.textContent = '';\n    let matrix;\n    try {\n      matrix = parseMatrix(matrixInput.value);\n    } catch (e) {\n      alert('Error parsing matrix: ' + e.message);\n      return;\n    }\n\n    // Log collector\n    const logs = [];\n    function logger(msg) {\n      logs.push(msg);\n      // For better UX, also update live step output gradually\n      // but here we do at once for clarity\n    }\n\n    const distResult = floydWarshall(matrix, logger);\n    // Show final distance matrix\n    resultDiv.innerHTML = matrixToTable(distResult);\n    // Show logs\n    stepsDiv.textContent = logs.join('\\n');\n    stepsDiv.focus();\n  });\n})();\n</script>\n\n</body>\n</html>"
  },
