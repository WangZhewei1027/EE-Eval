    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Linked List Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n  }\n  .container {\n    max-width: 720px;\n    margin: auto;\n  }\n  h1 {\n    text-align: center;\n  }\n  .controls {\n    margin-bottom: 20px;\n    display: flex;\n    flex-wrap: wrap;\n    gap: 10px;\n    align-items: center;\n  }\n  .controls input[type=\"text\"], .controls input[type=\"number\"] {\n    padding: 6px;\n    font-size: 16px;\n    flex: 1 0 120px;\n  }\n  button {\n    padding: 6px 14px;\n    font-size: 16px;\n    cursor: pointer;\n  }\n  #linkedlist {\n    display: flex;\n    gap: 16px;\n    flex-wrap: wrap;\n    align-items: center;\n    justify-content: center;\n  }\n  .node {\n    border: 2px solid #3498db;\n    border-radius: 6px;\n    padding: 10px 18px;\n    position: relative;\n    background: #eaf4fc;\n    min-width: 50px;\n    text-align: center;\n    font-weight: 600;\n    font-size: 18px;\n  }\n  .node .arrow {\n    position: absolute;\n    right: -28px;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 25px;\n    height: 20px;\n  }\n  svg {\n    overflow: visible;\n  }\n  .empty {\n    font-size: 18px;\n    color: #777;\n    text-align: center;\n    margin-top: 40px;\n  }\n  .info {\n    margin-top: 30px;\n    padding: 12px;\n    background: #f0f8ff;\n    border: 1px solid #a5d7ff;\n    border-radius: 6px;\n    line-height: 1.4;\n    color: #333;\n  }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>Linked List Demo</h1>\n  <div class=\"controls\">\n    <input type=\"text\" id=\"valueInput\" placeholder=\"Value (text or number)\" />\n    <input type=\"number\" id=\"indexInput\" placeholder=\"Index (optional)\" min=\"0\" style=\"max-width: 100px\"/>\n    <button id=\"pushBtn\" title=\"Add at End\">Push (Add at End)</button>\n    <button id=\"unshiftBtn\" title=\"Add at Start\">Unshift (Add at Start)</button>\n    <button id=\"insertBtn\" title=\"Insert at Index\">Insert at Index</button>\n    <button id=\"popBtn\" title=\"Remove from End\">Pop (Remove End)</button>\n    <button id=\"shiftBtn\" title=\"Remove from Start\">Shift (Remove Start)</button>\n    <button id=\"removeBtn\" title=\"Remove at Index\">Remove at Index</button>\n    <button id=\"clearBtn\" title=\"Clear the list\">Clear List</button>\n  </div>\n\n  <div id=\"linkedlist\" aria-label=\"Linked list visualization\" role=\"list\"></div>\n  <div id=\"empty\" class=\"empty\">The linked list is empty.</div>\n\n  <div class=\"info\">\n    <strong>About this demo:</strong>  \n    <p>A <em>linked list</em> is a linear data structure where each element (called a node) contains a value and a pointer/reference to the next node. This demo allows you to add, insert and remove nodes to see how the list changes.</p>\n    <ul>\n      <li><strong>Push:</strong> Add node to the end.</li>\n      <li><strong>Unshift:</strong> Add node to the start.</li>\n      <li><strong>Insert at Index:</strong> Insert node at specified position (0-based).</li>\n      <li><strong>Pop:</strong> Remove node from the end.</li>\n      <li><strong>Shift:</strong> Remove node from the start.</li>\n      <li><strong>Remove at Index:</strong> Remove node at specified position.</li>\n    </ul>\n  </div>\n</div>\n\n<script>\n  // Linked List Node class\n  class Node {\n    constructor(value) {\n      this.value = value;\n      this.next = null;\n    }\n  }\n\n  // Linked List class\n  class LinkedList {\n    constructor() {\n      this.head = null;\n      this.tail = null;\n      this.length = 0;\n    }\n\n    push(value) {\n      const newNode = new Node(value);\n      if (!this.head) {\n        this.head = newNode;\n        this.tail = newNode;\n      } else {\n        this.tail.next = newNode;\n        this.tail = newNode;\n      }\n      this.length++;\n      return this;\n    }\n\n    unshift(value) {\n      const newNode = new Node(value);\n      if (!this.head) {\n        this.head = newNode;\n        this.tail = newNode;\n      } else {\n        newNode.next = this.head;\n        this.head = newNode;\n      }\n      this.length++;\n      return this;\n    }\n\n    insert(index, value) {\n      if (index < 0 || index > this.length) return false;\n      if (index === 0) {\n        this.unshift(value);\n        return true;\n      }\n      if (index === this.length) {\n        this.push(value);\n        return true;\n      }\n      const newNode = new Node(value);\n      let prev = this.getNodeAt(index - 1);\n      newNode.next = prev.next;\n      prev.next = newNode;\n      this.length++;\n      return true;\n    }\n\n    pop() {\n      if (!this.head) return undefined;\n      if (this.length === 1) {\n        let val = this.head.value;\n        this.head = null;\n        this.tail = null;\n        this.length--;\n        return val;\n      }\n      let current = this.head;\n      let prev = current;\n      while (current.next) {\n        prev = current;\n        current = current.next;\n      }\n      prev.next = null;\n      this.tail = prev;\n      this.length--;\n      return current.value;\n    }\n\n    shift() {\n      if (!this.head) return undefined;\n      let val = this.head.value;\n      this.head = this.head.next;\n      this.length--;\n      if (this.length === 0) {\n        this.tail = null;\n      }\n      return val;\n    }\n\n    remove(index) {\n      if (index < 0 || index >= this.length) return undefined;\n      if (index === 0) return this.shift();\n      if (index === this.length - 1) return this.pop();\n      let prev = this.getNodeAt(index - 1);\n      let removed = prev.next;\n      prev.next = removed.next;\n      this.length--;\n      return removed.value;\n    }\n\n    getNodeAt(index) {\n      if (index < 0 || index >= this.length) return null;\n      let current = this.head;\n      let counter = 0;\n      while (counter < index) {\n        current = current.next;\n        counter++;\n      }\n      return current;\n    }\n\n    toArray() {\n      const values = [];\n      let current = this.head;\n      while (current) {\n        values.push(current.value);\n        current = current.next;\n      }\n      return values;\n    }\n  }\n\n  // DOM elements\n  const valueInput = document.getElementById(\"valueInput\");\n  const indexInput = document.getElementById(\"indexInput\");\n  const pushBtn = document.getElementById(\"pushBtn\");\n  const unshiftBtn = document.getElementById(\"unshiftBtn\");\n  const insertBtn = document.getElementById(\"insertBtn\");\n  const popBtn = document.getElementById(\"popBtn\");\n  const shiftBtn = document.getElementById(\"shiftBtn\");\n  const removeBtn = document.getElementById(\"removeBtn\");\n  const clearBtn = document.getElementById(\"clearBtn\");\n  const linkedListDiv = document.getElementById(\"linkedlist\");\n  const emptyDiv = document.getElementById(\"empty\");\n\n  // Initialize linked list\n  const list = new LinkedList();\n\n  function renderList() {\n    linkedListDiv.innerHTML = \"\";\n    if (list.length === 0) {\n      emptyDiv.style.display = \"block\";\n      return;\n    }\n    emptyDiv.style.display = \"none\";\n\n    let current = list.head;\n    let index = 0;\n    while (current) {\n      const nodeDiv = document.createElement(\"div\");\n      nodeDiv.classList.add(\"node\");\n      nodeDiv.setAttribute(\"role\",\"listitem\");\n      nodeDiv.setAttribute(\"aria-label\",\"Node \"+index + \" Value: \" + current.value);\n      nodeDiv.textContent = current.value;\n\n      // If there is a next node, add arrow\n      if (current.next) {\n        const arrowSvg = document.createElementNS(\"http://www.w3.org/2000/svg\", \"svg\");\n        arrowSvg.setAttribute(\"class\", \"arrow\");\n        arrowSvg.setAttribute(\"viewBox\", \"0 0 24 24\");\n        arrowSvg.setAttribute(\"aria-hidden\", \"true\");\n        arrowSvg.innerHTML = `\n          <line x1=\"0\" y1=\"12\" x2=\"18\" y2=\"12\" stroke=\"#3498db\" stroke-width=\"3\" stroke-linecap=\"round\"/>\n          <polyline points=\"12,6 18,12 12,18\" fill=\"none\" stroke=\"#3498db\" stroke-width=\"3\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        `;\n        nodeDiv.appendChild(arrowSvg);\n      }\n      linkedListDiv.appendChild(nodeDiv);\n\n      current = current.next;\n      index++;\n    }\n  }\n\n  function getInputValue() {\n    let val = valueInput.value.trim();\n    if (val === \"\") {\n      alert(\"Please enter a value.\");\n      return null;\n    }\n    return val;\n  }\n  function getIndexValue() {\n    if (indexInput.value === \"\") return null;\n    const idx = parseInt(indexInput.value, 10);\n    if (isNaN(idx) || idx < 0) {\n      alert(\"Please enter a valid non-negative index.\");\n      return null;\n    }\n    return idx;\n  }\n\n  pushBtn.addEventListener(\"click\", () => {\n    let val = getInputValue();\n    if (val === null) return;\n    list.push(val);\n    renderList();\n    valueInput.value = \"\";\n  });\n\n  unshiftBtn.addEventListener(\"click\", () => {\n    let val = getInputValue();\n    if (val === null) return;\n    list.unshift(val);\n    renderList();\n    valueInput.value = \"\";\n  });\n\n  insertBtn.addEventListener(\"click\", () => {\n    let val = getInputValue();\n    if (val === null) return;\n    const idx = getIndexValue();\n    if (idx === null) {\n      alert(\"Please enter an index for insertion.\");\n      return;\n    }\n    if (idx > list.length) {\n      alert(\"Index out of bounds. Max allowed index is \" + list.length);\n      return;\n    }\n    const inserted = list.insert(idx, val);\n    if (!inserted) {\n      alert(\"Insertion failed at index \" + idx);\n      return;\n    }\n    renderList();\n    valueInput.value = \"\";\n    indexInput.value = \"\";\n  });\n\n  popBtn.addEventListener(\"click\", () => {\n    if (list.length === 0) {\n      alert(\"List is empty.\");\n      return;\n    }\n    const removed = list.pop();\n    alert(\"Removed from end: \" + removed);\n    renderList();\n  });\n\n  shiftBtn.addEventListener(\"click\", () => {\n    if (list.length === 0) {\n      alert(\"List is empty.\");\n      return;\n    }\n    const removed = list.shift();\n    alert(\"Removed from start: \" + removed);\n    renderList();\n  });\n\n  removeBtn.addEventListener(\"click\", () => {\n    if (list.length === 0) {\n      alert(\"List is empty.\");\n      return;\n    }\n    const idx = getIndexValue();\n    if (idx === null) {\n      alert(\"Please enter an index to remove.\");\n      return;\n    }\n    if (idx >= list.length) {\n      alert(\"Index out of bounds. Max allowed index is \" + (list.length - 1));\n      return;\n    }\n    const removed = list.remove(idx);\n    alert(\"Removed value at index \"+idx+\": \" + removed);\n    renderList();\n    indexInput.value = \"\";\n  });\n\n  clearBtn.addEventListener(\"click\", () => {\n    if (confirm(\"Clear the entire list?\")) {\n      list.head = null;\n      list.tail = null;\n      list.length = 0;\n      renderList();\n    }\n  });\n\n  // Initial render\n  renderList();\n</script>\n</body>\n</html>"
  },
