  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Kruskal's Algorithm Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 0; padding: 0;\n    display: flex;\n    flex-direction: column;\n    height: 100vh;\n  }\n  header {\n    background: #0057b7;\n    color: white;\n    padding: 1rem;\n    text-align: center;\n  }\n  #container {\n    display: flex;\n    flex: 1;\n    overflow: hidden;\n  }\n  #canvas-container {\n    flex: 2;\n    background: #f9f9f9;\n    position: relative;\n  }\n  #controls {\n    flex: 1;\n    border-left: 1px solid #ccc;\n    padding: 1rem;\n    box-sizing: border-box;\n    overflow-y: auto;\n  }\n  #description {\n    font-size: 0.9rem;\n    margin-bottom: 1rem;\n  }\n  button {\n    background-color: #0057b7;\n    color: white;\n    border: none;\n    padding: 0.6rem 1rem;\n    border-radius: 3px;\n    cursor: pointer;\n    margin-bottom: 1rem;\n    width: 100%;\n    font-size: 1rem;\n  }\n  button:disabled {\n    background-color: #aaa;\n    cursor: default;\n  }\n  h2 {\n    margin-top: 0;\n  }\n  #edge-list {\n    max-height: 30vh;\n    overflow-y: auto;\n    margin-bottom: 1rem;\n  }\n  #union-find-sets {\n    font-size: 0.9rem;\n    white-space: pre-wrap;\n    background: #eef6ff;\n    border: 1px solid #99c2ff;\n    padding: 0.5rem;\n    border-radius: 4px;\n    max-height: 25vh;\n    overflow-y: auto;\n  }\n  #legend {\n    font-size: 0.9rem;\n    margin-top: 1rem;\n    background: #f1f1f1;\n    border-radius: 5px;\n    padding: 0.5rem;\n  }\n\n  /* Tooltip for edges */\n  #tooltip {\n    position: absolute;\n    background: rgba(0,0,0,0.75);\n    color: white;\n    padding: 3px 6px;\n    border-radius: 3px;\n    pointer-events:none;\n    font-size: 0.8rem;\n    visibility: hidden;\n    user-select:none;\n    z-index: 10;\n  }\n</style>\n</head>\n<body>\n  <header>\n    <h1>Kruskal’s Algorithm Demonstration</h1>\n    <p>Visualizing Minimum Spanning Tree construction step-by-step</p>\n  </header>\n  <div id=\"container\">\n    <div id=\"canvas-container\">\n      <canvas id=\"graphCanvas\"></canvas>\n      <div id=\"tooltip\"></div>\n    </div>\n    <aside id=\"controls\">\n      <h2>Controls</h2>\n      <button id=\"startBtn\">Start Algorithm</button>\n      <button id=\"stepBtn\" disabled>Next Step</button>\n      <button id=\"resetBtn\" disabled>Reset</button>\n\n      <h2>Edges (sorted by weight)</h2>\n      <div id=\"edge-list\"></div>\n\n      <h2>Union-Find Sets</h2>\n      <div id=\"union-find-sets\"></div>\n\n      <h2>Legend</h2>\n      <div id=\"legend\">\n        <ul>\n          <li><span style=\"color:#0A74DA;font-weight:bold;\">●</span> Node</li>\n          <li><span style=\"border-bottom: 3px solid green;\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> MST Edge</li>\n          <li><span style=\"border-bottom: 3px solid #ccc;\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> Unused Edge</li>\n          <li><span style=\"border-bottom: 3px solid red;\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</span> Edge creating cycle (skipped)</li>\n        </ul>\n      </div>\n    </aside>\n  </div>\n\n<script>\n(() => {\n  // Canvas setup\n  const canvas = document.getElementById('graphCanvas');\n  const ctx = canvas.getContext('2d');\n  const tooltip = document.getElementById('tooltip');\n\n  // Responsive canvas size\n  function resizeCanvas() {\n    canvas.width = canvas.parentElement.clientWidth;\n    canvas.height = canvas.parentElement.clientHeight;\n    drawGraph();\n  }\n  window.addEventListener('resize', resizeCanvas);\n\n  // Graph definition (small example)\n  // Each node: id, position (x,y)\n  const nodes = [\n    {id: 0, x: 100, y: 100},\n    {id: 1, x: 300, y: 80},\n    {id: 2, x: 420, y: 160},\n    {id: 3, x: 250, y: 250},\n    {id: 4, x: 120, y: 230},\n    {id: 5, x: 480, y: 300},\n    {id: 6, x: 600, y: 140},\n    {id: 7, x: 650, y: 250},\n  ];\n\n  // Edges: {u,v,weight}\n  let edges = [\n    {u:0, v:1, weight: 4},\n    {u:0, v:4, weight: 7},\n    {u:1, v:2, weight: 9},\n    {u:1, v:3, weight: 8},\n    {u:2, v:3, weight: 5},\n    {u:2, v:6, weight: 20},\n    {u:3, v:4, weight: 6},\n    {u:3, v:5, weight: 10},\n    {u:4, v:5, weight: 12},\n    {u:5, v:6, weight: 2},\n    {u:6, v:7, weight: 3},\n    {u:5, v:7, weight: 1},\n  ];\n\n  // Sort edges by ascending weight before running algorithm\n  edges.sort((a,b) => a.weight - b.weight);\n\n  // UI elements\n  const startBtn = document.getElementById('startBtn');\n  const stepBtn = document.getElementById('stepBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const edgeListContainer = document.getElementById('edge-list');\n  const ufSetsContainer = document.getElementById('union-find-sets');\n\n  // Visualization state\n  let state = {\n    mstEdges: new Set(),          // edges included in MST, identified by index in edges[]\n    skippedEdges: new Set(),      // edges rejected (making cycle)\n    currentEdgeIndex: 0,          // the index of the next edge to consider\n    running: false,\n    unionFind: null,\n  };\n\n  // Disjoint Set Union (Union Find) data structure for cycle detection\n  class UnionFind {\n    constructor(n) {\n      this.parent = Array.from({length:n}, (_, i) => i);\n      this.rank = new Array(n).fill(0);\n    }\n    find(u) {\n      if(this.parent[u] !== u) {\n        this.parent[u] = this.find(this.parent[u]);\n      }\n      return this.parent[u];\n    }\n    union(u,v) {\n      let rootU = this.find(u);\n      let rootV = this.find(v);\n      if(rootU === rootV) return false; // Cycle detected\n      if(this.rank[rootU] > this.rank[rootV]) {\n        this.parent[rootV] = rootU;\n      } else if(this.rank[rootU] < this.rank[rootV]) {\n        this.parent[rootU] = rootV;\n      } else {\n        this.parent[rootV] = rootU;\n        this.rank[rootU]++;\n      }\n      return true;\n    }\n    getSets() {\n      // returns array of arrays grouping nodes by sets\n      const map = new Map();\n      for(let i = 0; i < this.parent.length; i++){\n        let root = this.find(i);\n        if(!map.has(root)) map.set(root, []);\n        map.get(root).push(i);\n      }\n      return Array.from(map.values());\n    }\n  }\n\n  // Initialize UI controls and states\n  function init(){\n    updateEdgeList();\n    updateUnionFind();\n    drawGraph();\n    startBtn.disabled = false;\n    stepBtn.disabled = true;\n    resetBtn.disabled = true;\n    state.mstEdges.clear();\n    state.skippedEdges.clear();\n    state.currentEdgeIndex = 0;\n    state.running = false;\n    state.unionFind = new UnionFind(nodes.length);\n  }\n\n  // Draw graph with current state info\n  function drawGraph(){\n    ctx.clearRect(0, 0, canvas.width, canvas.height);\n\n    // Draw edges first\n    edges.forEach((edge, idx) => {\n      const n1 = nodes[edge.u];\n      const n2 = nodes[edge.v];\n\n      if(state.mstEdges.has(idx)){\n        // MST edge: thick green line\n        ctx.strokeStyle = \"green\";\n        ctx.lineWidth = 4;\n      } else if(state.skippedEdges.has(idx)){\n        // Skipped edges (cycle): red dashed line\n        ctx.strokeStyle = \"red\";\n        ctx.lineWidth = 2;\n        ctx.setLineDash([6,6]);\n      } else if(idx === state.currentEdgeIndex && state.running){\n        // Current edge considered: blue thicker line\n        ctx.strokeStyle = \"#0077ff\";\n        ctx.lineWidth = 3;\n        ctx.setLineDash([]);\n      } else {\n        // normal edge: light grey\n        ctx.strokeStyle = \"#ccc\";\n        ctx.lineWidth = 2;\n        ctx.setLineDash([]);\n      }\n      ctx.beginPath();\n      ctx.moveTo(n1.x, n1.y);\n      ctx.lineTo(n2.x, n2.y);\n      ctx.stroke();\n\n      // Draw weight near middle of edge\n      let midX = (n1.x + n2.x)/2;\n      let midY = (n1.y + n2.y)/2;\n      ctx.fillStyle = \"black\";\n      ctx.font = \"12px Arial\";\n      ctx.fillText(edge.weight, midX+5, midY-5);\n    });\n\n    // Draw nodes on top\n    nodes.forEach(node => {\n      ctx.beginPath();\n      ctx.fillStyle = \"#0A74DA\";\n      ctx.strokeStyle = \"black\";\n      ctx.lineWidth = 1;\n      ctx.arc(node.x, node.y, 14, 0, 2*Math.PI);\n      ctx.fill();\n      ctx.stroke();\n\n      // Node label inside circle\n      ctx.fillStyle = \"white\";\n      ctx.font = \"bold 14px Arial\";\n      ctx.textAlign = \"center\";\n      ctx.textBaseline = \"middle\";\n      ctx.fillText(node.id, node.x, node.y);\n    });\n  }\n\n  // Update edge list display (show sorted edges with highlight on current)\n  function updateEdgeList(){\n    edgeListContainer.innerHTML = \"\";\n    edges.forEach((edge, idx) => {\n      const div = document.createElement('div');\n      div.style.marginBottom = \"4px\";\n      div.style.fontSize = '0.9rem';\n\n      let text = `(${edge.u} - ${edge.v}) weight: ${edge.weight}`;\n      if(state.mstEdges.has(idx)){\n        div.style.color = \"green\";\n        div.style.fontWeight = \"bold\";\n        text = \"✅ \" + text;\n      } else if(state.skippedEdges.has(idx)){\n        div.style.color = \"red\";\n        text = \"⛔ \" + text;\n      } else if(idx === state.currentEdgeIndex && state.running){\n        div.style.color = \"#0077ff\";\n        div.style.fontWeight = \"bold\";\n        text = \"♦ \" + text;\n      }\n      div.textContent = text;\n      edgeListContainer.appendChild(div);\n    });\n  }\n\n  // Update union-find sets display\n  function updateUnionFind(){\n    let sets = state.unionFind.getSets();\n    let text = \"\";\n    sets.forEach((set, i) => {\n      text += `Set ${i+1}: { ${set.join(\", \")} }\\n`;\n    });\n    ufSetsContainer.textContent = text.trim();\n  }\n\n  // Step through one edge for Kruskal\n  function step(){\n    if(state.currentEdgeIndex >= edges.length){\n      alert(\"Algorithm completed! MST formed.\");\n      stepBtn.disabled = true;\n      startBtn.disabled = true;\n      resetBtn.disabled = false;\n      return;\n    }\n\n    const edge = edges[state.currentEdgeIndex];\n    let u = edge.u;\n    let v = edge.v;\n    \n    const added = state.unionFind.union(u, v);\n    if(added){\n      state.mstEdges.add(state.currentEdgeIndex);\n    } else {\n      // creates cycle - skip this edge\n      state.skippedEdges.add(state.currentEdgeIndex);\n    }\n\n    state.currentEdgeIndex++;\n\n    updateEdgeList();\n    updateUnionFind();\n    drawGraph();\n\n    // Enable reset when finished\n    if(state.currentEdgeIndex >= edges.length){\n      stepBtn.disabled = true;\n      resetBtn.disabled = false;\n    }\n  }\n\n  function start(){\n    if(state.running) return;\n    state.running = true;\n    startBtn.disabled = true;\n    stepBtn.disabled = false;\n    resetBtn.disabled = false;\n    updateEdgeList();\n    updateUnionFind();\n    drawGraph();\n  }\n\n  function reset(){\n    state.mstEdges.clear();\n    state.skippedEdges.clear();\n    state.currentEdgeIndex = 0;\n    state.running = false;\n    state.unionFind = new UnionFind(nodes.length);\n    updateEdgeList();\n    updateUnionFind();\n\n    startBtn.disabled = false;\n    stepBtn.disabled = true;\n    resetBtn.disabled = true;\n    drawGraph();\n  }\n\n  // Edge hover tooltip\n  function edgeAtPosition(mx, my){\n    // Return edge index if mouse near edge line else null\n    const radius = 8; // proximity for hover\n\n    for(let idx=0; idx < edges.length; idx++){\n      const edge = edges[idx];\n      const n1 = nodes[edge.u];\n      const n2 = nodes[edge.v];\n      // Calculate distance from point to segment\n      const dist = pointSegmentDistance(mx, my, n1.x, n1.y, n2.x, n2.y);\n      if(dist <= radius){\n        return idx;\n      }\n    }\n    return null;\n  }\n\n  // Distance from point px,py to segment (x1,y1)-(x2,y2)\n  function pointSegmentDistance(px, py, x1, y1, x2, y2){\n    const A = px - x1;\n    const B = py - y1;\n    const C = x2 - x1;\n    const D = y2 - y1;\n\n    const dot = A * C + B * D;\n    const len_sq = C * C + D * D;\n    let param = -1;\n    if(len_sq !== 0)\n        param = dot / len_sq;\n\n    let xx, yy;\n\n    if(param < 0){\n      xx = x1;\n      yy = y1;\n    }\n    else if(param > 1){\n      xx = x2;\n      yy = y2;\n    }\n    else{\n      xx = x1 + param * C;\n      yy = y1 + param * D;\n    }\n\n    const dx = px - xx;\n    const dy = py - yy;\n    return Math.sqrt(dx * dx + dy * dy);\n  }\n\n  canvas.addEventListener('mousemove', (e) => {\n    const rect = canvas.getBoundingClientRect();\n    const mx = e.clientX - rect.left;\n    const my = e.clientY - rect.top;\n\n    const idx = edgeAtPosition(mx, my);\n\n    if(idx !== null){\n      const edge = edges[idx];\n      tooltip.style.visibility = 'visible';\n      tooltip.style.left = (mx + 15) + 'px';\n      tooltip.style.top = (my + 10) + 'px';\n      tooltip.textContent = `Edge (${edge.u} - ${edge.v}), weight ${edge.weight}`;\n    } else {\n      tooltip.style.visibility = 'hidden';\n    }\n  });\n\n  canvas.addEventListener('mouseleave', () => {\n    tooltip.style.visibility = 'hidden';\n  });\n\n  // Event listeners\n  startBtn.addEventListener('click', start);\n  stepBtn.addEventListener('click', step);\n  resetBtn.addEventListener('click', reset);\n\n  // Initial draw\n  state.unionFind = new UnionFind(nodes.length);\n  resizeCanvas();\n  init();\n\n})();\n</script>\n\n</body>\n</html>"
  },
