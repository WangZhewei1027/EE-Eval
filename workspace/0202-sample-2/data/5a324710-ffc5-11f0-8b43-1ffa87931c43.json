    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Stack Data Structure Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f4f8;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n    color: #0b3d91;\n  }\n  .container {\n    max-width: 500px;\n    margin: 2rem auto;\n    background: white;\n    border-radius: 6px;\n    padding: 1.5rem 2rem;\n    box-shadow: 0 2px 8px rgba(0,0,0,0.15);\n  }\n  label {\n    font-weight: bold;\n  }\n  input[type=\"text\"] {\n    width: 70%;\n    padding: 0.4rem 0.6rem;\n    margin-right: 0.5rem;\n    border: 1px solid #bbb;\n    border-radius: 4px;\n    font-size: 1rem;\n  }\n  button {\n    padding: 0.45rem 1rem;\n    border: none;\n    background: #0b3d91;\n    color: white;\n    font-size: 1rem;\n    border-radius: 4px;\n    cursor: pointer;\n    margin-top: 0.5rem;\n    transition: background-color 0.3s ease;\n  }\n  button:hover {\n    background: #06407a;\n  }\n  .stack-container {\n    margin-top: 2rem;\n    text-align: center;\n  }\n  .stack {\n    display: flex;\n    flex-direction: column-reverse;\n    align-items: center;\n    max-width: 200px;\n    margin: 0 auto;\n    border: 2px solid #0b3d91;\n    border-radius: 6px;\n    padding: 10px 0;\n    background: #e7edf8;\n  }\n  .stack-element {\n    width: 80%;\n    margin: 4px 0;\n    padding: 8px 0;\n    background: #1e50a2;\n    color: white;\n    border-radius: 4px;\n    box-shadow: 0 2px 4px rgba(12,37,73,0.7);\n    font-size: 1.1rem;\n    user-select: none;\n  }\n  .stack-label {\n    margin-bottom: 10px;\n    font-weight: bold;\n    color: #0b3d91;\n    font-size: 1.2rem;\n  }\n  .info {\n    margin-top: 1rem;\n    color: #0b3d91;\n    font-style: italic;\n  }\n  .message {\n    margin-top: 1rem;\n    min-height: 1.3em;\n    font-weight: bold;\n  }\n  .message.error {\n    color: #d93025;\n  }\n  .message.success {\n    color: #188038;\n  }\n</style>\n</head>\n<body>\n<h1>Stack Data Structure Visualization</h1>\n<div class=\"container\" role=\"main\">\n  <label for=\"pushInput\">Element to Push:</label><br />\n  <input type=\"text\" id=\"pushInput\" aria-label=\"Element to push onto stack\" />\n  <button id=\"pushBtn\" aria-describedby=\"pushButtonDesc\">Push</button>\n  <div id=\"pushButtonDesc\" class=\"visually-hidden\">Adds the element to the top of the stack.</div>\n\n  <button id=\"popBtn\" style=\"margin-left:8px;\" aria-describedby=\"popButtonDesc\">Pop</button>\n  <div id=\"popButtonDesc\" class=\"visually-hidden\">Removes the element from the top of the stack.</div>\n\n  <button id=\"peekBtn\" aria-describedby=\"peekButtonDesc\">Peek</button>\n  <div id=\"peekButtonDesc\" class=\"visually-hidden\">Shows the element at the top of the stack without removing it.</div>\n\n  <button id=\"clearBtn\" style=\"margin-left:8px;\" aria-describedby=\"clearButtonDesc\">Clear Stack</button>\n  <div id=\"clearButtonDesc\" class=\"visually-hidden\">Empties the entire stack.</div>\n\n  <div class=\"stack-container\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\">\n    <div class=\"stack-label\">Stack (Top at bottom):</div>\n    <div id=\"stack\" class=\"stack\" role=\"list\" aria-label=\"Stack elements\">\n      <!-- Stack elements will appear here -->\n    </div>\n  </div>\n\n  <div id=\"message\" class=\"message\" aria-live=\"assertive\" aria-atomic=\"true\"></div>\n  <p class=\"info\">Demo Max Stack Size: 10 elements</p>\n</div>\n\n<script>\n  class Stack {\n    constructor(maxSize = 10) {\n      this.items = [];\n      this.maxSize = maxSize;\n    }\n\n    push(element) {\n      if (this.items.length >= this.maxSize) {\n        throw new Error('Stack Overflow: Max size reached.');\n      }\n      this.items.push(element);\n    }\n\n    pop() {\n      if (this.isEmpty()) {\n        throw new Error('Stack Underflow: No elements to pop.');\n      }\n      return this.items.pop();\n    }\n\n    peek() {\n      if (this.isEmpty()) {\n        throw new Error('Stack is empty: Nothing to peek at.');\n      }\n      return this.items[this.items.length - 1];\n    }\n\n    isEmpty() {\n      return this.items.length === 0;\n    }\n\n    clear() {\n      this.items = [];\n    }\n\n    size() {\n      return this.items.length;\n    }\n\n    getElements() {\n      return [...this.items]; // return copy of array\n    }\n  }\n\n  // Initialize stack and DOM elements\n  const stack = new Stack(10);\n  const stackDiv = document.getElementById('stack');\n  const pushInput = document.getElementById('pushInput');\n  const pushBtn = document.getElementById('pushBtn');\n  const popBtn = document.getElementById('popBtn');\n  const peekBtn = document.getElementById('peekBtn');\n  const clearBtn = document.getElementById('clearBtn');\n  const messageDiv = document.getElementById('message');\n\n  function renderStack() {\n    stackDiv.innerHTML = '';\n    if (stack.isEmpty()) {\n      stackDiv.innerHTML = '<div style=\"color:#666; font-style: italic; margin:8px;\">Stack is empty</div>';\n      return;\n    }\n    // We display the top of stack at the bottom (using flex-column-reverse)\n    // So pushing adds to the bottom visually\n    stack.getElements().forEach((elem, index) => {\n      const elDiv = document.createElement('div');\n      elDiv.className = 'stack-element';\n      elDiv.setAttribute('role', 'listitem');\n      elDiv.textContent = elem;\n      stackDiv.appendChild(elDiv);\n    });\n  }\n\n  function showMessage(text, type='') {\n    messageDiv.textContent = text;\n    messageDiv.className = 'message';\n    if(type === 'error') {\n      messageDiv.classList.add('error');\n    } else if(type === 'success') {\n      messageDiv.classList.add('success');\n    }\n  }\n\n  // Event listeners\n  pushBtn.addEventListener('click', () => {\n    const val = pushInput.value.trim();\n    if (val === '') {\n      showMessage('Please enter a value to push.', 'error');\n      pushInput.focus();\n      return;\n    }\n    try {\n      stack.push(val);\n      renderStack();\n      showMessage(`Pushed \"${val}\" onto the stack.`, 'success');\n      pushInput.value = '';\n      pushInput.focus();\n    } catch(err) {\n      showMessage(err.message, 'error');\n    }\n  });\n\n  popBtn.addEventListener('click', () => {\n    try {\n      const popped = stack.pop();\n      renderStack();\n      showMessage(`Popped \"${popped}\" from the stack.`, 'success');\n      pushInput.focus();\n    } catch(err) {\n      showMessage(err.message, 'error');\n    }\n  });\n\n  peekBtn.addEventListener('click', () => {\n    try {\n      const top = stack.peek();\n      showMessage(`Top element is \"${top}\".`, 'success');\n      pushInput.focus();\n    } catch(err) {\n      showMessage(err.message, 'error');\n    }\n  });\n\n  clearBtn.addEventListener('click', () => {\n    stack.clear();\n    renderStack();\n    showMessage('Stack has been cleared.', 'success');\n    pushInput.focus();\n  });\n\n  // Allow pressing Enter in input to push element\n  pushInput.addEventListener('keydown', e => {\n    if(e.key === 'Enter') {\n      pushBtn.click();\n    }\n  });\n\n  // Initial render\n  renderStack();\n</script>\n</body>\n</html>"
