    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Insertion Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f9f9f9;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #arrayContainer {\n    display: flex;\n    justify-content: center;\n    align-items: flex-end;\n    margin: 40px auto;\n    width: 90%;\n    max-width: 800px;\n    height: 300px;\n    border: 1px solid #ccc;\n    background: #fff;\n    position: relative;\n  }\n  .bar {\n    margin: 0 2px;\n    background-color: #3498db;\n    width: 20px;\n    display: flex;\n    align-items: flex-end;\n    justify-content: center;\n    font-size: 12px;\n    color: white;\n    border-radius: 3px 3px 0 0;\n    transition: background-color 0.3s ease;\n  }\n  .bar.current {\n    background-color: #e67e22;\n  }\n  .bar.compared {\n    background-color: #e74c3c;\n  }\n  .bar.sorted {\n    background-color: #2ecc71;\n  }\n  #controls {\n    text-align: center;\n    margin-top: 20px;\n  }\n  button, input[type=number] {\n    font-size: 16px;\n    padding: 6px 12px;\n    margin: 0 5px;\n  }\n  #speedLabel {\n    margin-left: 15px;\n    font-size: 14px;\n  }\n</style>\n</head>\n<body>\n\n<h1>Insertion Sort Visualization</h1>\n\n<div id=\"arrayContainer\"></div>\n\n<div id=\"controls\">\n  <button id=\"generateBtn\">Generate New Array</button>\n  <button id=\"startBtn\">Start Sort</button>\n  <button id=\"pauseBtn\" disabled>Pause</button>\n  <label for=\"speedRange\">Speed:</label>\n  <input type=\"range\" id=\"speedRange\" min=\"100\" max=\"2000\" step=\"100\" value=\"600\" />\n  <span id=\"speedLabel\">600 ms</span>\n</div>\n\n<script>\n(() => {\n  const arrayContainer = document.getElementById('arrayContainer');\n  const generateBtn = document.getElementById('generateBtn');\n  const startBtn = document.getElementById('startBtn');\n  const pauseBtn = document.getElementById('pauseBtn');\n  const speedRange = document.getElementById('speedRange');\n  const speedLabel = document.getElementById('speedLabel');\n\n  let array = [];\n  const ARRAY_SIZE = 30;\n  const MAX_VALUE = 100;\n  let sorting = false;\n  let paused = false;\n  let delay = 600;\n\n  let timeoutId = null;\n\n  // Generate random array\n  function generateArray() {\n    array = [];\n    for (let i = 0; i < ARRAY_SIZE; i++) {\n      array.push(Math.floor(Math.random() * MAX_VALUE) + 5);\n    }\n  }\n\n  // Render array bars\n  function renderArray(highlight = {}) {\n    // highlight keys: currentIndex, comparedIndex, sortedIndices (Set)\n    arrayContainer.innerHTML = '';\n    const sortedIndices = highlight.sortedIndices || new Set();\n\n    array.forEach((value, i) => {\n      const bar = document.createElement('div');\n      bar.classList.add('bar');\n      bar.style.height = `${value * 2.5}px`; // scale to fit container height\n      bar.textContent = value;\n\n      if (i === highlight.currentIndex) bar.classList.add('current');\n      if (i === highlight.comparedIndex) bar.classList.add('compared');\n      if (sortedIndices.has(i)) bar.classList.add('sorted');\n      arrayContainer.appendChild(bar);\n    });\n  }\n\n  // Sleep helper\n  function sleep(ms) {\n    return new Promise(resolve => {\n      timeoutId = setTimeout(resolve, ms);\n    });\n  }\n\n  // Async Insertion Sort with visualization and pause support\n  async function insertionSort() {\n    sorting = true;\n    paused = false;\n    startBtn.disabled = true;\n    generateBtn.disabled = true;\n    pauseBtn.disabled = false;\n    pauseBtn.textContent = 'Pause';\n\n    const sortedIndices = new Set();\n\n    for (let i = 1; i < array.length; i++) {\n      let key = array[i];\n      let j = i - 1;\n\n      // Highlight current element\n      renderArray({ currentIndex: i, sortedIndices });\n\n      await waitWhilePaused();\n\n      while (j >= 0 && array[j] > key) {\n        renderArray({ currentIndex: i, comparedIndex: j, sortedIndices });\n        await sleep(delay);\n        await waitWhilePaused();\n\n        array[j + 1] = array[j];\n        renderArray({ currentIndex: j, comparedIndex: j + 1, sortedIndices });\n        await sleep(delay);\n        await waitWhilePaused();\n\n        j--;\n      }\n      array[j + 1] = key;\n      sortedIndices.add(i);\n      renderArray({ currentIndex: j + 1, sortedIndices });\n      await sleep(delay);\n      await waitWhilePaused();\n    }\n    // Mark all as sorted\n    for (let i = 0; i < array.length; i++) sortedIndices.add(i);\n    renderArray({ sortedIndices });\n\n    sorting = false;\n    startBtn.disabled = false;\n    generateBtn.disabled = false;\n    pauseBtn.disabled = true;\n  }\n\n  // Helper to wait while paused\n  function waitWhilePaused() {\n    return new Promise(resolve => {\n      if (!paused) {\n        resolve();\n      } else {\n        const check = () => {\n          if (!paused) {\n            resolve();\n          } else {\n            timeoutId = setTimeout(check, 100);\n          }\n        };\n        check();\n      }\n    });\n  }\n\n  function reset() {\n    if (timeoutId) {\n      clearTimeout(timeoutId);\n      timeoutId = null;\n    }\n    sorting = false;\n    paused = false;\n    startBtn.disabled = false;\n    generateBtn.disabled = false;\n    pauseBtn.disabled = true;\n    pauseBtn.textContent = 'Pause';\n  }\n\n  // Event listeners\n  generateBtn.addEventListener('click', () => {\n    reset();\n    generateArray();\n    renderArray();\n  });\n\n  startBtn.addEventListener('click', async () => {\n    if (sorting) return;\n    await insertionSort();\n  });\n\n  pauseBtn.addEventListener('click', () => {\n    if (!sorting) return;\n    paused = !paused;\n    pauseBtn.textContent = paused ? 'Resume' : 'Pause';\n    if (!paused && timeoutId === null) {\n      // trigger waiting promises to continue\n    }\n  });\n\n  speedRange.addEventListener('input', () => {\n    delay = Number(speedRange.value);\n    speedLabel.textContent = `${delay} ms`;\n  });\n\n  // Initial setup\n  generateArray();\n  renderArray();\n})();\n</script>\n\n</body>\n</html>"
