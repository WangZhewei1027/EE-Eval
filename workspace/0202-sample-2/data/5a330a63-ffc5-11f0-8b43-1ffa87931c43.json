    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Radix Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f7f9fc;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n    margin-bottom: 10px;\n  }\n  #inputArea, #controls {\n    max-width: 700px;\n    margin: 0 auto 20px;\n  }\n  label {\n    font-weight: bold;\n  }\n  input[type=\"text\"] {\n    width: 80%;\n    padding: 8px;\n    font-size: 1rem;\n    margin-right: 10px;\n    box-sizing: border-box;\n  }\n  button {\n    padding: 9px 15px;\n    font-size: 1rem;\n    cursor: pointer;\n    border: none;\n    background-color: #007acc;\n    color: white;\n    border-radius: 4px;\n    transition: background-color 0.2s ease;\n  }\n  button:disabled {\n    background-color: #cccccc;\n    cursor: not-allowed;\n  }\n  button:hover:not(:disabled) {\n    background-color: #005fa3;\n  }\n\n  #arrayContainer {\n    max-width: 700px;\n    margin: 0 auto 30px;\n    display: flex;\n    flex-wrap: wrap;\n    gap: 6px;\n    justify-content: center;\n  }\n  .array-item {\n    background-color: #007acc;\n    color: white;\n    font-weight: bold;\n    padding: 10px 14px;\n    border-radius: 5px;\n    min-width: 40px;\n    text-align: center;\n    user-select: none;\n    transition: background-color 0.3s ease;\n  }\n  .highlight {\n    background-color: #ffa500 !important;\n    color: #000 !important;\n  }\n  .bucket-container {\n    display: flex;\n    justify-content: center;\n    gap: 12px;\n    flex-wrap: wrap;\n    margin-bottom: 30px;\n  }\n  .bucket {\n    background-color: #e1e7f0;\n    border-radius: 8px;\n    padding: 8px 6px 12px;\n    width: 50px;\n    min-height: 50px;\n    box-sizing: border-box;\n    text-align: center;\n    font-weight: bold;\n    color: #555;\n  }\n  .bucket-label {\n    font-size: 0.8rem;\n    margin-bottom: 4px;\n  }\n  .bucket-items {\n    min-height: 30px;\n    display: flex;\n    flex-direction: column;\n    gap: 4px;\n  }\n  .bucket-item {\n    background-color: #007acc;\n    color: white;\n    padding: 4px 6px;\n    border-radius: 3px;\n    font-size: 0.85rem;\n  }\n  .log {\n    max-width: 700px;\n    margin: 0 auto;\n    background: #fff;\n    border-radius: 6px;\n    border: 1px solid #ccc;\n    max-height: 180px;\n    overflow-y: auto;\n    padding: 12px;\n    font-family: monospace;\n    font-size: 0.9rem;\n    white-space: pre-wrap;\n  }\n  #speedLabel {\n    margin-left: 12px;\n    font-weight: normal;\n  }\n  #speedRange {\n    vertical-align: middle;\n  }\n</style>\n</head>\n<body>\n  <h1>Radix Sort Visualization</h1>\n  <div id=\"inputArea\">\n    <label for=\"inputArray\">Enter numbers (comma or space separated):</label><br/>\n    <input type=\"text\" id=\"inputArray\" placeholder=\"e.g. 170, 45, 75, 90, 802, 24, 2, 66\" />\n    <button id=\"startBtn\">Start Sort</button>\n  </div>\n  <div id=\"controls\" style=\"max-width:700px; margin: 0 auto 20px;display:flex; align-items:center; justify-content:center; gap: 12px;\">\n    <button id=\"prevStepBtn\" disabled>&laquo; Previous Step</button>\n    <button id=\"nextStepBtn\" disabled>Next Step &raquo;</button>\n    <label for=\"speedRange\">Speed:\n      <input type=\"range\" id=\"speedRange\" min=\"100\" max=\"2000\" step=\"100\" value=\"800\" />\n      <span id=\"speedLabel\">800 ms</span>\n    </label>\n    <button id=\"autoBtn\" disabled>Auto Play</button>\n    <button id=\"resetBtn\">Reset</button>\n  </div>\n\n  <div id=\"arrayContainer\" aria-live=\"polite\" aria-label=\"Array elements\"></div>\n\n  <div id=\"bucketsArea\" class=\"bucket-container\" aria-label=\"Digit buckets\" style=\"display:none;\"></div>\n\n  <div class=\"log\" id=\"logArea\" aria-live=\"polite\" aria-atomic=\"true\">\n    Ready to start radix sort.\n  </div>\n\n<script>\n(() => {\n  const inputArrayEl = document.getElementById('inputArray');\n  const startBtn = document.getElementById('startBtn');\n  const arrayContainer = document.getElementById('arrayContainer');\n  const bucketsArea = document.getElementById('bucketsArea');\n  const logArea = document.getElementById('logArea');\n\n  const prevStepBtn = document.getElementById('prevStepBtn');\n  const nextStepBtn = document.getElementById('nextStepBtn');\n  const autoBtn = document.getElementById('autoBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const speedRange = document.getElementById('speedRange');\n  const speedLabel = document.getElementById('speedLabel');\n\n  let inputArray = [];\n  let states = []; // Each state represents a step with the array + buckets + highlighted indices\n  let currentStep = -1;\n  let maxDigits = 0;\n  let autoPlayInterval = null;\n  let autoPlaying = false;\n  let speed = parseInt(speedRange.value);\n\n  function log(msg) {\n    logArea.textContent = msg;\n  }\n\n  // Render the array with optional highlights: highlights is an object {indices: [], buckets: {digit: []}} or special info\n  function renderArray(arr, highlights = {}) {\n    arrayContainer.innerHTML = '';\n    arr.forEach((num, i) => {\n      const div = document.createElement('div');\n      div.className = 'array-item';\n      div.textContent = num;\n      if (highlights.indices && highlights.indices.includes(i)) {\n        div.classList.add('highlight');\n      }\n      arrayContainer.appendChild(div);\n    });\n  }\n\n  // Render the buckets with their contents and highlight extracted items\n  // buckets: array of arrays (10 buckets)\n  // highlights: array of indices per bucket to highlight\n  function renderBuckets(buckets, highlights = {}) {\n    bucketsArea.style.display = 'flex';\n    bucketsArea.innerHTML = '';\n    for (let d = 0; d < 10; d++) {\n      const bucket = document.createElement('div');\n      bucket.className = 'bucket';\n      const label = document.createElement('div');\n      label.className = 'bucket-label';\n      label.textContent = d;\n      bucket.appendChild(label);\n      const itemsCont = document.createElement('div');\n      itemsCont.className = 'bucket-items';\n      buckets[d].forEach((num, idx) => {\n        const itemEl = document.createElement('div');\n        itemEl.className = 'bucket-item';\n        itemEl.textContent = num;\n        if (\n          highlights[d] &&\n          highlights[d].includes(idx)\n        ) {\n          itemEl.classList.add('highlight');\n        }\n        itemsCont.appendChild(itemEl);\n      });\n      bucket.appendChild(itemsCont);\n      bucketsArea.appendChild(bucket);\n    }\n  }\n\n  // Disable or enable controls\n  function setControlsDisabled(disabled) {\n    startBtn.disabled = disabled;\n    prevStepBtn.disabled = disabled || currentStep <= 0;\n    nextStepBtn.disabled = disabled || currentStep >= states.length - 1;\n    autoBtn.disabled = disabled || states.length === 0;\n    resetBtn.disabled = false;\n    inputArrayEl.disabled = disabled;\n  }\n\n  // Reset the interface\n  function resetAll() {\n    if (autoPlaying) toggleAutoPlay();\n    states = [];\n    currentStep = -1;\n    maxDigits = 0;\n    inputArray = [];\n    arrayContainer.innerHTML = '';\n    bucketsArea.style.display = 'none';\n    bucketsArea.innerHTML = '';\n    log('Ready to start radix sort.');\n    setControlsDisabled(false);\n  }\n\n  // Get digit at exp (1, 10, 100, ...) from right for number num\n  function getDigit(num, exp) {\n    return Math.floor(num / exp) % 10;\n  }\n\n  // Prepare the states array for the entire radix sort, capturing each step\n  function prepareRadixStates(arr) {\n    let resultStates = [];\n    let doneArray = [...arr];\n    maxDigits = Math.max(...doneArray).toString().length;\n\n    function cloneBuckets(buckets) {\n      return buckets.map(bucket => [...bucket]);\n    }\n\n    // Initial state, no highlights\n    resultStates.push({\n      array: [...doneArray],\n      buckets: Array(10).fill(null).map(() => []),\n      highlightsArray: [],\n      highlightsBuckets: {},\n      message: `Initial array: [${doneArray.join(', ')}]`\n    });\n\n    for (let d = 0, exp = 1; d < maxDigits; d++, exp *= 10) {\n      // Show extraction to buckets step by step\n      const buckets = Array(10).fill(null).map(() => []);\n      // For animation: create a step after placing each element into a bucket\n      for (let i = 0; i < doneArray.length; i++) {\n        const digit = getDigit(doneArray[i], exp);\n        buckets[digit].push(doneArray[i]);\n        resultStates.push({\n          array: [...doneArray],\n          buckets: cloneBuckets(buckets),\n          highlightsArray: [i],\n          highlightsBuckets: { [digit]: [buckets[digit].length - 1] },\n          message: `Digit ${digit} extracted from array index ${i} to bucket ${digit}`\n        });\n      }\n\n      // Now reassemble array from buckets\n      let idx = 0;\n      for (let b = 0; b < 10; b++) {\n        // For visual reassembling, include steps per item\n        for (let j = 0; j < buckets[b].length; j++) {\n          doneArray[idx] = buckets[b][j];\n          // Highlight index we just placed in array\n          let highlightsArray = [idx];\n          let highlightsBuckets = { [b]: [j] };\n          resultStates.push({\n            array: [...doneArray],\n            buckets: cloneBuckets(buckets),\n            highlightsArray,\n            highlightsBuckets,\n            message: `Placed ${buckets[b][j]} from bucket ${b} back into array at index ${idx}`\n          });\n          idx++;\n        }\n      }\n      resultStates.push({\n        array: [...doneArray],\n        buckets: cloneBuckets(buckets),\n        highlightsArray: [],\n        highlightsBuckets: {},\n        message: `Array after sorting on digit place ${d + 1} (exp=${exp}): [${doneArray.join(', ')}]`\n      });\n    }\n    resultStates.push({\n      array: [...doneArray],\n      buckets: Array(10).fill(null).map(() => []),\n      highlightsArray: [],\n      highlightsBuckets: {},\n      message: `Radix sort completed! Sorted array: [${doneArray.join(', ')}]`\n    });\n    return resultStates;\n  }\n\n  function renderStep(step) {\n    const state = states[step];\n    renderArray(state.array, { indices: state.highlightsArray });\n    renderBuckets(state.buckets, state.highlightsBuckets);\n    log(state.message);\n  }\n\n  function gotoStep(step) {\n    if (step < 0 || step >= states.length) return;\n    currentStep = step;\n    renderStep(currentStep);\n    prevStepBtn.disabled = currentStep <= 0;\n    nextStepBtn.disabled = currentStep >= states.length - 1;\n  }\n\n  function nextStep() {\n    if (currentStep < states.length - 1) {\n      gotoStep(currentStep + 1);\n    }\n  }\n  function prevStep() {\n    if (currentStep > 0) {\n      gotoStep(currentStep - 1);\n    }\n  }\n\n  function toggleAutoPlay() {\n    if (autoPlaying) {\n      autoPlaying = false;\n      clearInterval(autoPlayInterval);\n      autoBtn.textContent = 'Auto Play';\n      prevStepBtn.disabled = currentStep <= 0;\n      nextStepBtn.disabled = currentStep >= states.length - 1;\n      startBtn.disabled = false;\n      inputArrayEl.disabled = false;\n    } else {\n      if (states.length === 0) return;\n      if (currentStep >= states.length - 1) {\n        gotoStep(0);\n      }\n      autoPlaying = true;\n      autoBtn.textContent = 'Pause';\n      prevStepBtn.disabled = true;\n      nextStepBtn.disabled = true;\n      startBtn.disabled = true;\n      inputArrayEl.disabled = true;\n      autoPlayInterval = setInterval(() => {\n        if (currentStep < states.length - 1) {\n          nextStep();\n        } else {\n          toggleAutoPlay();\n        }\n      }, speed);\n    }\n  }\n\n  // Event Listeners\n  startBtn.addEventListener('click', () => {\n    // Parse input\n    const raw = inputArrayEl.value.trim();\n    if (!raw) {\n      alert('Please enter numbers separated by commas or spaces.');\n      return;\n    }\n    let parts = raw.split(/[\\s,]+/);\n    let nums = [];\n    for (let p of parts) {\n      const n = Number(p);\n      if (isNaN(n) || !Number.isInteger(n) || n < 0) {\n        alert(`Invalid input: \"${p}\". Please enter only non-negative integers.`);\n        return;\n      }\n      nums.push(n);\n    }\n    if (nums.length === 0) {\n      alert('Please enter at least one number.');\n      return;\n    }\n    if (nums.length > 50) {\n      alert('Please enter at most 50 numbers for clarity.');\n      return;\n    }\n    inputArray = nums;\n    states = prepareRadixStates(inputArray);\n    currentStep = 0;\n    renderStep(currentStep);\n    setControlsDisabled(false);\n    prevStepBtn.disabled = true; // We are at step 0\n    nextStepBtn.disabled = false;\n    autoBtn.disabled = false;\n    log('Radix sort started. Use Next Step to proceed.');\n  });\n\n  prevStepBtn.addEventListener('click', () => {\n    prevStep();\n  });\n\n  nextStepBtn.addEventListener('click', () => {\n    nextStep();\n  });\n\n  autoBtn.addEventListener('click', () => {\n    toggleAutoPlay();\n  });\n\n  resetBtn.addEventListener('click', () => {\n    resetAll();\n  });\n\n  speedRange.addEventListener('input', () => {\n    speed = parseInt(speedRange.value);\n    speedLabel.textContent = speed + ' ms';\n    if (autoPlaying) {\n      clearInterval(autoPlayInterval);\n      autoPlayInterval = setInterval(() => {\n        if (currentStep < states.length - 1) {\n          nextStep();\n        } else {\n          toggleAutoPlay();\n        }\n      }, speed);\n    }\n  });\n\n  // Initialize disabled states for buttons\n  setControlsDisabled(true);\n\n})();\n</script>\n\n</body>\n</html>"
  },
