    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Adjacency List Example</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 20px;\n      max-width: 700px;\n    }\n    h1 {\n      text-align: center;\n    }\n    pre {\n      background: #f0f0f0;\n      padding: 15px;\n      border-radius: 6px;\n      overflow-x: auto;\n    }\n    #graphInput {\n      width: 100%;\n      height: 120px;\n      font-family: monospace;\n      font-size: 14px;\n      margin-bottom: 10px;\n    }\n    button {\n      background-color: #007bff;\n      color: white;\n      border: none;\n      padding: 10px 15px;\n      cursor: pointer;\n      border-radius: 4px;\n      font-size: 16px;\n    }\n    button:hover {\n      background-color: #0056b3;\n    }\n    #output {\n      margin-top: 20px;\n    }\n    .node {\n      font-weight: bold;\n      color: #2c3e50;\n    }\n    .neighbor-list {\n      color: #34495e;\n    }\n  </style>\n</head>\n<body>\n  <h1>Adjacency List Demonstration</h1>\n  <p>\n    This example shows a simple <strong>Adjacency List</strong> representation of a directed graph.\n    <br />\n    You can edit the edges in the textarea below and click <em>Build Graph</em> to see the adjacency list.\n  </p>\n\n  <label for=\"graphInput\">\n    Enter edges (one per line) in the format <code>node1 node2</code> to represent an edge from node1 → node2.\n    <br />Example:\n  </label>\n  <pre>\nA B\nA C\nB D\nC D\nD E\n  </pre>\n\n  <textarea id=\"graphInput\" aria-label=\"Graph edges input\">\nA B\nA C\nB D\nC D\nD E\n  </textarea>\n  <br />\n  <button id=\"buildGraphBtn\">Build Graph</button>\n\n  <div id=\"output\"></div>\n\n  <script>\n    /**\n     * Builds an adjacency list from a list of edges.\n     * \n     * @param {string} input - Multiline string with edges, each line \"node1 node2\"\n     * @returns {Map<string, string[]>} Adjacency list map.\n     */\n    function buildAdjacencyList(input) {\n      const adjacencyList = new Map();\n\n      const lines = input.trim().split('\\n');\n      for (const line of lines) {\n        const parts = line.trim().split(/\\s+/);\n        if (parts.length !== 2) continue; // skip invalid lines\n\n        const [from, to] = parts;\n\n        if (!adjacencyList.has(from)) {\n          adjacencyList.set(from, []);\n        }\n        adjacencyList.get(from).push(to);\n\n        // Also ensure 'to' node exists in map even if it has no neighbors\n        if (!adjacencyList.has(to)) {\n          adjacencyList.set(to, []);\n        }\n      }\n\n      return adjacencyList;\n    }\n\n    /**\n     * Displays adjacency list in the output area.\n     * \n     * @param {Map<string,string[]>} adjacencyList \n     */\n    function displayAdjacencyList(adjacencyList) {\n      const outputDiv = document.getElementById('output');\n      outputDiv.innerHTML = '<h2>Adjacency List</h2>';\n\n      const ul = document.createElement('ul');\n      for (const [node, neighbors] of adjacencyList) {\n        const li = document.createElement('li');\n        li.innerHTML = `<span class=\"node\">${node}</span>: <span class=\"neighbor-list\">${neighbors.length > 0 ? neighbors.join(', ') : '(no neighbors)'}</span>`;\n        ul.appendChild(li);\n      }\n      outputDiv.appendChild(ul);\n    }\n\n    document.getElementById('buildGraphBtn').addEventListener('click', () => {\n      const input = document.getElementById('graphInput').value;\n      const adjacencyList = buildAdjacencyList(input);\n      displayAdjacencyList(adjacencyList);\n    });\n\n    // Initial display on page load\n    window.onload = () => {\n      const input = document.getElementById('graphInput').value;\n      const adjacencyList = buildAdjacencyList(input);\n      displayAdjacencyList(adjacencyList);\n    };\n  </script>\n</body>\n</html>"
