    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Linear Regression Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 1rem;\n    background: #fafafa;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #container {\n    max-width: 700px;\n    margin: 0 auto;\n  }\n  #canvas {\n    border: 1px solid #ccc;\n    background: white;\n    display: block;\n    margin: 1rem auto;\n  }\n  #instructions {\n    text-align: center;\n    margin-bottom: 0.5rem;\n  }\n  #resetButton {\n    display: block;\n    margin: 1rem auto;\n    padding: 0.6rem 1.2rem;\n    font-size: 1rem;\n    cursor: pointer;\n    border: none;\n    background-color: #007bff;\n    color: white;\n    border-radius: 4px;\n    transition: background-color 0.25s;\n  }\n  #resetButton:hover {\n    background-color: #0056b3;\n  }\n  #formula {\n    text-align: center;\n    font-weight: bold;\n    margin-top: 1rem;\n  }\n  #note {\n    font-size: 0.9rem;\n    margin-top: 0.3rem;\n    text-align: center;\n    color: #555;\n  }\n</style>\n</head>\n<body>\n  <div id=\"container\">\n    <h1>Linear Regression Demo</h1>\n    <div id=\"instructions\">Click on the canvas to add data points. The red line shows the best fit (linear regression).</div>\n    <canvas id=\"canvas\" width=\"600\" height=\"400\"></canvas>\n    <button id=\"resetButton\">Reset Points</button>\n    <div id=\"formula\"></div>\n    <div id=\"note\">Linear regression fits a line y = mx + b minimizing squared errors.</div>\n  </div>\n<script>\n(() => {\n  const canvas = document.getElementById('canvas');\n  const ctx = canvas.getContext('2d');\n  const resetButton = document.getElementById('resetButton');\n  const formulaDiv = document.getElementById('formula');\n  const width = canvas.width;\n  const height = canvas.height;\n\n  // Store points as {x: number, y: number} in canvas pixel coords\n  // Origin top-left, y increases down. We'll invert y for displaying regression.\n  let points = [];\n\n  // Margins for axes\n  const margin = 40;\n\n  // Axis ranges - dynamically adjust as points added\n  // Start default range\n  let xMin = 0, xMax = 10;\n  let yMin = 0, yMax = 10;\n\n  // Convert data point coords to canvas pixels\n  // Linear scale\n  function dataToCanvasX(x) {\n    return margin + ((x - xMin) / (xMax - xMin)) * (width - 2*margin);\n  }\n  function dataToCanvasY(y) {\n    // invert y axis for drawing (yMax top, yMin bottom)\n    return margin + ((yMax - y) / (yMax - yMin)) * (height - 2*margin);\n  }\n  // Convert canvas coords back to data values\n  function canvasToDataX(px) {\n    return xMin + ((px - margin) / (width - 2*margin)) * (xMax - xMin);\n  }\n  function canvasToDataY(py) {\n    return yMax - ((py - margin) / (height - 2*margin)) * (yMax - yMin);\n  }\n\n  // Compute linear regression line parameters (m, b):\n  // y = m*x + b\n  // Using least squares formula:\n  // m = (N*Σxy - Σx*Σy) / (N*Σx² - (Σx)²)\n  // b = (Σy - m*Σx)/N\n  function linearRegression(pts) {\n    const N = pts.length;\n    if (N === 0) return null;\n    let sumX = 0, sumY = 0, sumXY = 0, sumXX = 0;\n    for (const p of pts) {\n      sumX += p.x;\n      sumY += p.y;\n      sumXY += p.x * p.y;\n      sumXX += p.x * p.x;\n    }\n    const denominator = N * sumXX - sumX * sumX;\n    if (denominator === 0) {\n      // vertical line or all points same x?\n      return null;\n    }\n    const m = (N * sumXY - sumX * sumY) / denominator;\n    const b = (sumY - m * sumX) / N;\n    return { m, b };\n  }\n\n  // Update scale domain based on points (simple padding)\n  function updateScale() {\n    if (points.length === 0) {\n      xMin = 0;\n      xMax = 10;\n      yMin = 0;\n      yMax = 10;\n      return;\n    }\n    xMin = Math.min(...points.map(p => p.x));\n    xMax = Math.max(...points.map(p => p.x));\n    yMin = Math.min(...points.map(p => p.y));\n    yMax = Math.max(...points.map(p => p.y));\n    // add padding 10% on each side\n    const xPad = (xMax - xMin) * 0.1 || 1;\n    const yPad = (yMax - yMin) * 0.1 || 1;\n    xMin -= xPad;\n    xMax += xPad;\n    yMin -= yPad;\n    yMax += yPad;\n    // Prevent zero range\n    if (xMin === xMax) {\n      xMin -= 1;\n      xMax += 1;\n    }\n    if (yMin === yMax) {\n      yMin -= 1;\n      yMax += 1;\n    }\n  }\n\n  // Draw axes with ticks and labels\n  function drawAxes() {\n    ctx.strokeStyle = '#666';\n    ctx.fillStyle = '#666';\n    ctx.lineWidth = 1;\n    ctx.font = '12px Arial';\n    ctx.textAlign = 'center';\n    ctx.textBaseline = 'middle';\n\n    // Draw X axis line\n    ctx.beginPath();\n    ctx.moveTo(margin, height - margin);\n    ctx.lineTo(width - margin, height - margin);\n    ctx.stroke();\n\n    // Draw Y axis line\n    ctx.beginPath();\n    ctx.moveTo(margin, margin);\n    ctx.lineTo(margin, height - margin);\n    ctx.stroke();\n\n    // Draw ticks on X axis\n    const xTicks = 10;\n    for (let i = 0; i <= xTicks; i++) {\n      const xVal = xMin + (i / xTicks) * (xMax - xMin);\n      const xPos = dataToCanvasX(xVal);\n      ctx.beginPath();\n      ctx.moveTo(xPos, height - margin);\n      ctx.lineTo(xPos, height - margin + 6);\n      ctx.stroke();\n      ctx.fillText(xVal.toFixed(1), xPos, height - margin + 18);\n    }\n\n    // Draw ticks on Y axis\n    const yTicks = 10;\n    ctx.textAlign = 'right';\n    for (let i = 0; i <= yTicks; i++) {\n      const yVal = yMin + (i / yTicks) * (yMax - yMin);\n      const yPos = dataToCanvasY(yVal);\n      ctx.beginPath();\n      ctx.moveTo(margin - 6, yPos);\n      ctx.lineTo(margin, yPos);\n      ctx.stroke();\n      ctx.fillText(yVal.toFixed(1), margin - 8, yPos);\n    }\n  }\n\n  // Draw points as blue circles\n  function drawPoints() {\n    ctx.fillStyle = '#007bff';\n    for (const p of points) {\n      const cx = dataToCanvasX(p.x);\n      const cy = dataToCanvasY(p.y);\n      ctx.beginPath();\n      ctx.arc(cx, cy, 5, 0, Math.PI * 2);\n      ctx.fill();\n      ctx.strokeStyle = 'white';\n      ctx.lineWidth = 1;\n      ctx.stroke();\n    }\n  }\n\n  // Draw regression line in red\n  function drawRegressionLine(mb) {\n    if (!mb) return;\n    const { m, b } = mb;\n\n    // Find intersection points with plot area (at xMin and xMax)\n    let y1 = m * xMin + b;\n    let y2 = m * xMax + b;\n\n    // Clip y1 and y2 to yMin and yMax for visible line segment\n    // If line goes outside range, find intersection within bounds\n    function clipLine() {\n      let pointsClipped = [];\n\n      // Check y range at xMin\n      if (y1 < yMin) {\n        // solve for x when y = yMin: x = (yMin - b)/m\n        const x = (yMin - b) / m;\n        pointsClipped.push({ x, y: yMin });\n      } else if (y1 > yMax) {\n        const x = (yMax - b) / m;\n        pointsClipped.push({ x, y: yMax });\n      } else {\n        pointsClipped.push({ x: xMin, y: y1 });\n      }\n\n      // Check y range at xMax\n      if (y2 < yMin) {\n        const x = (yMin - b) / m;\n        pointsClipped.push({ x, y: yMin });\n      } else if (y2 > yMax) {\n        const x = (yMax - b) / m;\n        pointsClipped.push({ x, y: yMax });\n      } else {\n        pointsClipped.push({ x: xMax, y: y2 });\n      }\n\n      return pointsClipped;\n    }\n\n    let linePts = clipLine();\n\n    ctx.strokeStyle = '#e63946'; // red\n    ctx.lineWidth = 2;\n    ctx.beginPath();\n    ctx.moveTo(dataToCanvasX(linePts[0].x), dataToCanvasY(linePts[0].y));\n    ctx.lineTo(dataToCanvasX(linePts[1].x), dataToCanvasY(linePts[1].y));\n    ctx.stroke();\n  }\n\n  function clearCanvas() {\n    ctx.clearRect(0, 0, width, height);\n  }\n\n  function draw() {\n    clearCanvas();\n    updateScale();\n    drawAxes();\n    drawPoints();\n    const mb = linearRegression(points);\n    drawRegressionLine(mb);\n\n    if (mb) {\n      const { m, b } = mb;\n      const mRounded = m.toFixed(3);\n      const bRounded = b.toFixed(3);\n      let sign = b >= 0 ? '+' : '-';\n      let bAbs = Math.abs(bRounded);\n      formulaDiv.textContent = `Regression line: y = ${mRounded}x ${sign} ${bAbs}`;\n    } else {\n      formulaDiv.textContent = 'Add at least two distinct points to compute linear regression.';\n    }\n  }\n\n  // Mouse click handler to add point\n  canvas.addEventListener('click', e => {\n    // get mouse position relative to canvas\n    const rect = canvas.getBoundingClientRect();\n    const px = e.clientX - rect.left;\n    const py = e.clientY - rect.top;\n\n    // Ignore clicks outside plotting area (inside margin)\n    if (\n      px < margin || px > (width - margin) ||\n      py < margin || py > (height - margin)\n    ) {\n      return;\n    }\n    const x = canvasToDataX(px);\n    const y = canvasToDataY(py);\n    points.push({ x, y });\n    draw();\n  });\n\n  resetButton.addEventListener('click', () => {\n    points = [];\n    draw();\n  });\n\n  // Initialize drawing\n  draw();\n})();\n</script>\n</body>\n</html>"
