    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Red-Black Tree Visualization & Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f5f5f5;\n  }\n  h1 {\n    text-align: center;\n    margin-bottom: 10px;\n  }\n  #controls {\n    text-align: center;\n    margin-bottom: 20px;\n  }\n  input[type=\"number\"] {\n    font-size: 1rem;\n    padding: 5px;\n    width: 80px;\n  }\n  button {\n    font-size: 1rem;\n    padding: 6px 12px;\n    margin-left: 10px;\n    cursor: pointer;\n  }\n  #treeCanvas {\n    background: white;\n    border: 1px solid #ccc;\n    display: block;\n    margin: 0 auto 30px auto;\n  }\n  #info {\n    max-width: 960px;\n    margin: 0 auto;\n    line-height: 1.5;\n    background: #fff;\n    padding: 15px 20px;\n    border-radius: 8px;\n    box-shadow: 0 0 15px #ccc;\n  }\n  .node {\n    stroke-width: 3px;\n  }\n</style>\n</head>\n<body>\n<h1>Red-Black Tree Visualizer</h1>\n<div id=\"controls\">\n  <input id=\"inputValue\" type=\"number\" placeholder=\"Value\" />\n  <button id=\"insertBtn\">Insert</button>\n  <button id=\"clearBtn\">Clear Tree</button>\n</div>\n<canvas id=\"treeCanvas\" width=\"960\" height=\"500\"></canvas>\n\n<div id=\"info\">\n  <h2>About Red-Black Trees</h2>\n  <p>\n    A <strong>Red-Black Tree</strong> is a kind of self-balancing binary search tree where each node contains an extra bit \n    representing \"color\" (either red or black). This color bit ensures the tree remains approximately balanced during insertions and deletions.\n  </p>\n  <h3>Properties:</h3>\n  <ul>\n    <li>Each node is either red or black.</li>\n    <li>The root is always black.</li>\n    <li>All leaves (NIL or null nodes) are black.</li>\n    <li>If a node is red, then both its children are black (no two reds in a row).</li>\n    <li>Every path from a given node to any of its descendant leaves contains the same number of black nodes.</li>\n  </ul>\n  <h3>Operations:</h3>\n  <p>\n    This demo supports <strong>insertions</strong>. After each insertion, the tree automatically rebalances and recolors \n    to maintain Red-Black properties.\n  </p>\n</div>\n\n<script>\n// Red-Black Tree Implementation and Visualization\n\nconst canvas = document.getElementById('treeCanvas');\nconst ctx = canvas.getContext('2d');\n\nconst NODE_RADIUS = 20;\nconst VERTICAL_SPACING = 70;\nconst HORIZONTAL_SPACING = 30;\n\nclass RBNode {\n  constructor(value, color = 'red', parent = null) {\n    this.value = value;\n    this.color = color; // 'red' or 'black'\n    this.parent = parent;\n    this.left = null;  // RBNode or null\n    this.right = null; // RBNode or null\n  }\n\n  get grandparent() {\n    return this.parent ? this.parent.parent : null;\n  }\n  get uncle() {\n    if (!this.grandparent) return null;\n    if (this.parent === this.grandparent.left) return this.grandparent.right;\n    else return this.grandparent.left;\n  }\n}\n\nclass RBTree {\n  constructor() {\n    this.root = null;\n  }\n\n  rotateLeft(node) {\n    let pivot = node.right;\n    if (!pivot) return;\n\n    pivot.parent = node.parent;\n    if (!node.parent) this.root = pivot;\n    else if (node === node.parent.left) node.parent.left = pivot;\n    else node.parent.right = pivot;\n\n    node.right = pivot.left;\n    if (pivot.left) pivot.left.parent = node;\n\n    pivot.left = node;\n    node.parent = pivot;\n  }\n\n  rotateRight(node) {\n    let pivot = node.left;\n    if (!pivot) return;\n\n    pivot.parent = node.parent;\n    if (!node.parent) this.root = pivot;\n    else if (node === node.parent.left) node.parent.left = pivot;\n    else node.parent.right = pivot;\n\n    node.left = pivot.right;\n    if (pivot.right) pivot.right.parent = node;\n\n    pivot.right = node;\n    node.parent = pivot;\n  }\n\n  insert(value) {\n    if (this.root === null) {\n      this.root = new RBNode(value, 'black');\n      return;\n    }\n\n    let newNode = this._bstInsert(value);\n    this._fixInsertion(newNode);\n  }\n\n  _bstInsert(value) {\n    let current = this.root;\n    let parent = null;\n\n    while (current) {\n      if (value === current.value) return current; // no duplicates\n\n      parent = current;\n      if (value < current.value) current = current.left;\n      else current = current.right;\n    }\n\n    let newNode = new RBNode(value, 'red', parent);\n    if (value < parent.value) parent.left = newNode;\n    else parent.right = newNode;\n\n    return newNode;\n  }\n\n  _fixInsertion(node) {\n    while (node !== this.root && node.parent.color === 'red') {\n      if (node.parent === node.grandparent.left) {\n        let uncle = node.grandparent.right;\n        if (uncle && uncle.color === 'red') {\n          // Case 1: uncle red\n          node.parent.color = 'black';\n          uncle.color = 'black';\n          node.grandparent.color = 'red';\n          node = node.grandparent;\n        } else {\n          if (node === node.parent.right) {\n            // Case 2: node is right child\n            node = node.parent;\n            this.rotateLeft(node);\n          }\n          // Case 3: node is left child\n          node.parent.color = 'black';\n          node.grandparent.color = 'red';\n          this.rotateRight(node.grandparent);\n        }\n      } else {\n        // mirror cases\n        let uncle = node.grandparent.left;\n        if (uncle && uncle.color === 'red') {\n          // Case 1 mirror\n          node.parent.color = 'black';\n          uncle.color = 'black';\n          node.grandparent.color = 'red';\n          node = node.grandparent;\n        } else {\n          if (node === node.parent.left) {\n            // Case 2 mirror\n            node = node.parent;\n            this.rotateRight(node);\n          }\n          // Case 3 mirror\n          node.parent.color = 'black';\n          node.grandparent.color = 'red';\n          this.rotateLeft(node.grandparent);\n        }\n      }\n    }\n    this.root.color = 'black';\n  }\n\n  // Compute positions for nodes for visualization\n  computeNodePositions() {\n    if (!this.root) return;\n\n    // Calculate horizontal positions using in-order traversal number & depth for vertical pos\n    let x = 0;\n    function inOrder(node, depth, coords) {\n      if (!node) return;\n      inOrder(node.left, depth + 1, coords);\n      coords.push({ node, depth, posX: x++ });\n      inOrder(node.right, depth + 1, coords);\n    }\n    const coords = [];\n    x = 0;\n    inOrder(this.root, 0, coords);\n\n    // Map posX to canvas width positions with spacing\n    const maxPosX = coords.reduce((max, c) => Math.max(max, c.posX), 0);\n    coords.forEach(c => {\n      c.x = HORIZONTAL_SPACING + c.posX * ((canvas.width - 2 * HORIZONTAL_SPACING) / (maxPosX + 1));\n      c.y = VERTICAL_SPACING + c.depth * VERTICAL_SPACING;\n      c.node._pos = { x: c.x, y: c.y };\n    });\n  }\n}\n\n// Drawing functions\n\nfunction drawNode(node) {\n  const { x, y } = node._pos;\n  ctx.beginPath();\n  ctx.lineWidth = 3;\n  ctx.strokeStyle = '#000';\n  ctx.fillStyle = node.color === 'red' ? '#d22' : '#222';\n  ctx.shadowColor = 'rgba(0,0,0,0.2)';\n  ctx.shadowBlur = 4;\n  ctx.shadowOffsetX = 1;\n  ctx.shadowOffsetY = 1;\n  ctx.arc(x, y, NODE_RADIUS, 0, 2 * Math.PI);\n  ctx.fill();\n  ctx.shadowBlur = 0;\n  ctx.shadowOffsetX = 0;\n  ctx.shadowOffsetY = 0;\n  ctx.stroke();\n\n  // Draw text (node value)\n  ctx.fillStyle = 'white';\n  ctx.font = 'bold 14px Arial';\n  ctx.textAlign = 'center';\n  ctx.textBaseline = 'middle';\n  ctx.fillText(node.value, x, y);\n}\n\nfunction drawEdge(parent, child) {\n  if (!parent || !child) return;\n\n  const from = parent._pos;\n  const to = child._pos;\n\n  // Calculate line start/end so it doesn't overlap node circle\n  const angle = Math.atan2(to.y - from.y, to.x - from.x);\n  const startX = from.x + NODE_RADIUS * Math.cos(angle);\n  const startY = from.y + NODE_RADIUS * Math.sin(angle);\n  const endX = to.x - NODE_RADIUS * Math.cos(angle);\n  const endY = to.y - NODE_RADIUS * Math.sin(angle);\n\n  ctx.beginPath();\n  ctx.strokeStyle = '#555';\n  ctx.lineWidth = 2;\n  ctx.moveTo(startX, startY);\n  ctx.lineTo(endX, endY);\n  ctx.stroke();\n}\n\nfunction drawTree(tree) {\n  ctx.clearRect(0, 0, canvas.width, canvas.height);\n  if (!tree.root) return;\n\n  tree.computeNodePositions();\n\n  // Draw edges first (parent to children)\n  function edges(node) {\n    if (!node) return;\n    if (node.left) drawEdge(node, node.left);\n    if (node.right) drawEdge(node, node.right);\n    edges(node.left);\n    edges(node.right);\n  }\n  edges(tree.root);\n\n  // Draw nodes on top\n  function nodes(node) {\n    if (!node) return;\n    drawNode(node);\n    nodes(node.left);\n    nodes(node.right);\n  }\n  nodes(tree.root);\n}\n\n// Interactivity & UI handling\nconst tree = new RBTree();\n\nconst inputValue = document.getElementById('inputValue');\nconst insertBtn = document.getElementById('insertBtn');\nconst clearBtn = document.getElementById('clearBtn');\n\ninsertBtn.addEventListener('click', () => {\n  const val = parseInt(inputValue.value);\n  if (isNaN(val)) {\n    alert(\"Please enter a valid number.\");\n    return;\n  }\n  tree.insert(val);\n  drawTree(tree);\n  inputValue.value = '';\n  inputValue.focus();\n});\n\nclearBtn.addEventListener('click', () => {\n  tree.root = null;\n  ctx.clearRect(0, 0, canvas.width, canvas.height);\n  inputValue.value = '';\n  inputValue.focus();\n});\n\n// Initial draw (empty)\ndrawTree(tree);\n</script>\n\n</body>\n</html>"
  },
