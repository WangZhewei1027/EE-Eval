    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Union-Find (Disjoint Set) Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 1em;\n    background: #f0f4f8;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n    margin-bottom: 0;\n  }\n  #container {\n    max-width: 900px;\n    margin: 0 auto;\n  }\n  #setsDisplay {\n    margin-top: 1em;\n    font-size: 1.2em;\n  }\n  #graph {\n    margin-top: 2em;\n    text-align: center;\n  }\n  svg {\n    background: #fff;\n    border: 1px solid #ddd;\n    border-radius: 8px;\n    max-width: 100%;\n    height: 350px;\n  }\n  .node circle {\n    stroke: #555;\n    stroke-width: 2px;\n    fill: #9acdff;\n    cursor: pointer;\n    transition: fill 0.3s;\n  }\n  .node text {\n    pointer-events: none;\n    font-weight: bold;\n    font-size: 14px;\n  }\n  .node.highlight circle {\n    fill: #ff8c00;\n    stroke: #cc7000;\n  }\n  .edge {\n    stroke: #888;\n    stroke-width: 2px;\n  }\n  .edge.highlight {\n    stroke: #ff8c00;\n    stroke-width: 3px;\n  }\n  form {\n    margin-top: 1em;\n    display: flex;\n    gap: 0.5em;\n    flex-wrap: wrap;\n    justify-content: center;\n  }\n  input[type=number] {\n    width: 5em;\n    padding: 0.3em;\n    font-size: 1em;\n  }\n  button {\n    background: #007bff;\n    border: none;\n    color: white;\n    padding: 0.5em 1.3em;\n    font-size: 1em;\n    border-radius: 5px;\n    cursor: pointer;\n    transition: background 0.3s;\n  }\n  button:hover:not(:disabled) {\n    background: #0056b3;\n  }\n  #message {\n    margin-top: 1em;\n    text-align: center;\n    font-weight: bold;\n    color: #e03e3e;\n    min-height: 1.2em;\n  }\n  #legend {\n    margin-top: 1.5em;\n    font-size: 0.9em;\n    max-width: 400px;\n    margin-left: auto;\n    margin-right: auto;\n  }\n  #legend span.box {\n    display: inline-block;\n    width: 18px;\n    height: 18px;\n    vertical-align: middle;\n    margin-right: 6px;\n    border-radius: 5px;\n  }\n  #legend .nodeBox {\n    background-color: #9acdff;\n    border: 2px solid #555;\n  }\n  #legend .highlightBox {\n    background-color: #ff8c00;\n    border: 2px solid #cc7000;\n  }\n</style>\n</head>\n<body>\n<div id=\"container\">\n  <h1>Union-Find (Disjoint Set) Data Structure Demo</h1>\n  <p style=\"max-width:700px; margin: 0 auto 1em auto; text-align:center;\">\n    This visualization demonstrates the Union-Find (Disjoint Set) data structure. You can union two elements or test if two elements are in the same set (connected). The sets and connections update visually.\n  </p>\n\n  <form id=\"unionForm\" aria-label=\"Union two elements form\">\n    <label for=\"unionA\">Union A:</label>\n    <input type=\"number\" min=\"0\" max=\"9\" id=\"unionA\" name=\"unionA\" required aria-required=\"true\" aria-label=\"First element for union\" />\n    <label for=\"unionB\">with B:</label>\n    <input type=\"number\" min=\"0\" max=\"9\" id=\"unionB\" name=\"unionB\" required aria-required=\"true\" aria-label=\"Second element for union\" />\n    <button type=\"submit\">Union</button>\n  </form>\n\n  <form id=\"findForm\" aria-label=\"Check connection form\" style=\"margin-top:1em;\">\n    <label for=\"findA\">Check if A:</label>\n    <input type=\"number\" min=\"0\" max=\"9\" id=\"findA\" name=\"findA\" required aria-required=\"true\" aria-label=\"First element for find\" />\n    <label for=\"findB\">and B:</label>\n    <input type=\"number\" min=\"0\" max=\"9\" id=\"findB\" name=\"findB\" required aria-required=\"true\" aria-label=\"Second element for find\" />\n    <button type=\"submit\">Connected?</button>\n  </form>\n\n  <div id=\"message\" role=\"alert\" aria-live=\"polite\"></div>\n\n  <div id=\"setsDisplay\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n  <div id=\"graph\" aria-label=\"Union-Find sets graph visualization\">\n    <svg id=\"svgCanvas\" viewBox=\"0 0 600 350\" role=\"img\" aria-describedby=\"legend\" ></svg>\n  </div>\n\n  <div id=\"legend\">\n    <p><span class=\"box nodeBox\"></span> Node (Element)</p>\n    <p><span class=\"box highlightBox\"></span> Highlighted node/edge during operation</p>\n  </div>\n</div>\n\n<script>\n(() => {\n  // Union-Find implementation with path compression and union by rank\n  class UnionFind {\n    constructor(n) {\n      this.parent = Array.from({ length: n }, (_, i) => i);\n      this.rank = Array(n).fill(0);\n      this.n = n;\n    }\n    find(x) {\n      if (this.parent[x] !== x) {\n        this.parent[x] = this.find(this.parent[x]);\n      }\n      return this.parent[x];\n    }\n    union(x, y) {\n      const rootX = this.find(x);\n      const rootY = this.find(y);\n      if (rootX === rootY) return false; // Already united\n      if (this.rank[rootX] < this.rank[rootY]) {\n        this.parent[rootX] = rootY;\n      } else if (this.rank[rootX] > this.rank[rootY]) {\n        this.parent[rootY] = rootX;\n      } else {\n        this.parent[rootY] = rootX;\n        this.rank[rootX]++;\n      }\n      return true;\n    }\n    connected(x, y) {\n      return this.find(x) === this.find(y);\n    }\n    getSets() {\n      const setsMap = new Map();\n      for(let i=0; i < this.n; i++) {\n        const root = this.find(i);\n        if (!setsMap.has(root)) setsMap.set(root, []);\n        setsMap.get(root).push(i);\n      }\n      return Array.from(setsMap.values());\n    }\n  }\n\n  // Visualization variables and helpers\n  const svgNS = \"http://www.w3.org/2000/svg\";\n  const svg = document.getElementById(\"svgCanvas\");\n  const n = 10; // Elements from 0 to 9\n  const radius = 20;\n  const centerX = 300;\n  const centerY = 175;\n  const circleRadius = 140;\n\n  // Calculate fixed positions for nodes in a circle\n  const positions = Array.from({ length: n }, (_, i) => {\n    const angle = (2 * Math.PI / n) * i - Math.PI / 2;\n    return {\n      x: centerX + circleRadius * Math.cos(angle),\n      y: centerY + circleRadius * Math.sin(angle)\n    };\n  });\n\n  // Create SVG elements for nodes\n  const nodes = [];\n  for(let i=0; i < n; i++) {\n    const group = document.createElementNS(svgNS, \"g\");\n    group.classList.add(\"node\");\n    group.setAttribute(\"data-id\", i);\n    group.setAttribute(\"tabindex\", \"0\");\n    group.setAttribute(\"aria-label\", `Node ${i}`);\n\n    const circle = document.createElementNS(svgNS, \"circle\");\n    circle.setAttribute(\"r\", radius);\n    circle.setAttribute(\"cx\", positions[i].x);\n    circle.setAttribute(\"cy\", positions[i].y);\n\n    const text = document.createElementNS(svgNS, \"text\");\n    text.setAttribute(\"x\", positions[i].x);\n    text.setAttribute(\"y\", positions[i].y + 5);\n    text.setAttribute(\"text-anchor\", \"middle\");\n    text.textContent = i;\n\n    group.appendChild(circle);\n    group.appendChild(text);\n    svg.appendChild(group);\n    nodes.push(group);\n  }\n\n  // Edges are drawn as lines between parents and children in the UF tree\n  // We'll update edges dynamically on each union\n  const edgesGroup = document.createElementNS(svgNS, \"g\");\n  edgesGroup.setAttribute(\"id\", \"edgesGroup\");\n  svg.appendChild(edgesGroup);\n\n  // Create UnionFind instance\n  const uf = new UnionFind(n);\n\n  // Message display element\n  const message = document.getElementById(\"message\");\n\n  // Display sets\n  const setsDisplay = document.getElementById(\"setsDisplay\");\n  function displaySets() {\n    const sets = uf.getSets();\n    setsDisplay.innerHTML = \"Current Sets: \";\n    sets.forEach((set, idx) => {\n      const span = document.createElement(\"span\");\n      span.style.padding = \"0 6px\";\n      span.style.margin = \"0 5px\";\n      span.style.background = `hsl(${120 + idx * 40}, 60%, 80%)`;\n      span.style.borderRadius = \"4px\";\n      span.textContent = `{${set.join(\", \")}}`;\n      setsDisplay.appendChild(span);\n    });\n  }\n\n  // Draw edges between parents and children to reflect union structure\n  function drawEdges(highlightPath=[]) {\n    while(edgesGroup.firstChild) edgesGroup.removeChild(edgesGroup.firstChild);\n    for(let child=0; child < n; child++) {\n      const parent = uf.parent[child];\n      if (parent !== child) {\n        const line = document.createElementNS(svgNS, \"line\");\n        line.classList.add(\"edge\");\n        // Highlight edges in the path if any\n        if (highlightPath.some(e => (e[0] === parent && e[1] === child) || (e[1] === parent && e[0] === child))) {\n          line.classList.add(\"highlight\");\n        }\n        line.setAttribute(\"x1\", positions[parent].x);\n        line.setAttribute(\"y1\", positions[parent].y);\n        line.setAttribute(\"x2\", positions[child].x);\n        line.setAttribute(\"y2\", positions[child].y);\n        edgesGroup.appendChild(line);\n      }\n    }\n  }\n\n  // Highlight nodes and edges for find path visualization\n  // Returns all edges along the find path for highlighting\n  function highlightFindPath(x) {\n    let path = [];\n    let current = x;\n    const visitedNodes = new Set();\n    while (uf.parent[current] !== current) {\n      path.push([uf.parent[current], current]);\n      visitedNodes.add(current);\n      current = uf.parent[current];\n      if (visitedNodes.has(current)) break; // cycle guard (shouldn't happen)\n    }\n    return path;\n  }\n\n  // Highlight nodes function, clears old highlights first\n  function highlightNodes(ids) {\n    nodes.forEach(node => {\n      node.classList.toggle(\"highlight\", ids.includes(+node.getAttribute(\"data-id\")));\n    });\n  }\n  function clearHighlights() {\n    highlightNodes([]);\n    const allEdges = edgesGroup.querySelectorAll(\".edge.highlight\");\n    allEdges.forEach(edge => edge.classList.remove(\"highlight\"));\n  }\n\n  // On union form submit\n  document.getElementById(\"unionForm\").addEventListener(\"submit\", e => {\n    e.preventDefault();\n    clearHighlights();\n    const a = parseInt(e.target.unionA.value, 10);\n    const b = parseInt(e.target.unionB.value, 10);\n    if (isNaN(a) || isNaN(b) || a < 0 || a >= n || b < 0 || b >= n) {\n      message.textContent = \"Please enter valid elements between 0 and 9.\";\n      return;\n    }\n    if (a === b) {\n      message.textContent = \"Cannot union the same element with itself.\";\n      return;\n    }\n\n    // Highlight find path for a and b before union\n    const pathA = highlightFindPath(a);\n    const pathB = highlightFindPath(b);\n    drawEdges([...pathA, ...pathB]);\n    highlightNodes([a, b, ...pathA.flat(), ...pathB.flat()]);\n\n    if (uf.connected(a, b)) {\n      message.textContent = `Elements ${a} and ${b} are already in the same set.`;\n    } else {\n      uf.union(a, b);\n      message.textContent = `Union done: merged sets containing ${a} and ${b}.`;\n      drawEdges();\n      highlightNodes([]); // clear highlights after update\n    }\n    displaySets();\n  });\n\n  // On find (connected) form submit\n  document.getElementById(\"findForm\").addEventListener(\"submit\", e => {\n    e.preventDefault();\n    clearHighlights();\n    const a = parseInt(e.target.findA.value, 10);\n    const b = parseInt(e.target.findB.value, 10);\n    if (isNaN(a) || isNaN(b) || a < 0 || a >= n || b < 0 || b >= n) {\n      message.textContent = \"Please enter valid elements between 0 and 9.\";\n      return;\n    }\n    if (a === b) {\n      message.textContent = `Elements ${a} and ${b} are the same element, so they are connected.`;\n      highlightNodes([a]);\n      return;\n    }\n\n    // Highlight the find paths for both a and b\n    const pathA = highlightFindPath(a);\n    const pathB = highlightFindPath(b);\n    drawEdges([...pathA, ...pathB]);\n\n    // Highlight nodes on the paths plus a and b\n    const nodesToHighlight = new Set([a, b]);\n    pathA.forEach(([p,c]) => { nodesToHighlight.add(p); nodesToHighlight.add(c); });\n    pathB.forEach(([p,c]) => { nodesToHighlight.add(p); nodesToHighlight.add(c); });\n    highlightNodes(Array.from(nodesToHighlight));\n\n    if (uf.connected(a, b)) {\n      message.textContent = `Yes, elements ${a} and ${b} are connected (in the same set).`;\n    } else {\n      message.textContent = `No, elements ${a} and ${b} are NOT connected (in different sets).`;\n    }\n  });\n\n  // Initialize display\n  displaySets();\n  drawEdges();\n\n  // Keyboard accessibility: allow focusing nodes, tooltip with set root info\n  nodes.forEach(node => {\n    node.addEventListener(\"focus\", () => {\n      const id = +node.getAttribute(\"data-id\");\n      const root = uf.find(id);\n      message.textContent = `Element ${id} belongs to set with root ${root}.`;\n      highlightNodes([id]);\n      drawEdges();\n    });\n    node.addEventListener(\"blur\", () => {\n      message.textContent = \"\";\n      clearHighlights();\n      drawEdges();\n    });\n  });\n})();\n</script>\n</body>\n</html>"
  },
