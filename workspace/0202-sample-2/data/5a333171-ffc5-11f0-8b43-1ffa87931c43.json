    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Breadth-First Search (BFS) Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 10px;\n    background: #f0f0f0;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  h1 {\n    margin-bottom: 5px;\n  }\n  #graph-container {\n    margin-top: 10px;\n    position: relative;\n  }\n  svg {\n    background: #fff;\n    border: 1px solid #ccc;\n    border-radius: 6px;\n  }\n  .node circle {\n    fill: #69b3a2;\n    stroke: #2f6650;\n    stroke-width: 2px;\n    transition: fill 0.3s;\n  }\n  .node.visited circle {\n    fill: #ffa500;\n  }\n  .node.current circle {\n    fill: #e63946;\n  }\n  .node text {\n    font-size: 14px;\n    fill: #fff;\n    pointer-events: none;\n    user-select: none;\n  }\n  line {\n    stroke: #555;\n    stroke-width: 2px;\n  }\n  #controls {\n    margin-top: 15px;\n  }\n  button {\n    font-size: 16px;\n    padding: 8px 15px;\n    margin-right: 10px;\n    cursor: pointer;\n  }\n  #queue {\n    margin-top: 15px;\n    font-family: monospace;\n    background: #fff;\n    padding: 8px 12px;\n    border-radius: 6px;\n    width: 320px;\n    box-shadow: 0 0 6px rgba(0,0,0,0.15);\n  }\n  #legend {\n    margin-top: 15px;\n    display: flex;\n    justify-content: center;\n    gap: 25px;\n  }\n  .legend-item {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n    font-size: 14px;\n  }\n  .legend-color {\n    width: 18px;\n    height: 18px;\n    border-radius: 50%;\n  }\n  .color-unvisited {\n    background: #69b3a2;\n    border: 2px solid #2f6650;\n  }\n  .color-visited {\n    background: #ffa500;\n  }\n  .color-current {\n    background: #e63946;\n  }\n</style>\n</head>\n<body>\n<h1>Breadth-First Search (BFS) Demonstration</h1>\n<div>\n  <strong>Graph:</strong> Undirected Graph, nodes numbered 0 to 8.\n</div>\n<div id=\"graph-container\">\n  <svg id=\"graph-svg\" width=\"600\" height=\"400\"></svg>\n</div>\n\n<div id=\"controls\">\n  <button id=\"startBtn\">Start BFS</button>\n  <button id=\"resetBtn\" disabled>Reset</button>\n</div>\n\n<div id=\"queue\"><strong>Queue:</strong> [ ]</div>\n\n<div id=\"legend\">\n  <div class=\"legend-item\">\n    <div class=\"legend-color color-unvisited\"></div> Unvisited Node\n  </div>\n  <div class=\"legend-item\">\n    <div class=\"legend-color color-visited\"></div> Visited Node\n  </div>\n  <div class=\"legend-item\">\n    <div class=\"legend-color color-current\"></div> Current Node\n  </div>\n</div>\n\n<script>\n(() => {\n  // Graph data\n  // Adjacency list representation of an undirected graph with 9 nodes (0-8)\n  const graph = {\n    0: [1, 3],\n    1: [0, 2, 4],\n    2: [1, 5],\n    3: [0, 4, 6],\n    4: [1, 3, 5, 7],\n    5: [2, 4, 8],\n    6: [3, 7],\n    7: [4, 6, 8],\n    8: [5, 7]\n  };\n\n  // Coordinates for each node for visualization (circle centers)\n  const nodePositions = {\n    0: { x: 100, y: 80 },\n    1: { x: 200, y: 50 },\n    2: { x: 300, y: 80 },\n    3: { x: 100, y: 180 },\n    4: { x: 200, y: 180 },\n    5: { x: 300, y: 180 },\n    6: { x: 100, y: 280 },\n    7: { x: 200, y: 280 },\n    8: { x: 300, y: 280 }\n  };\n\n  const svg = document.getElementById('graph-svg');\n  const queueDisplay = document.getElementById('queue');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n\n  // State variables\n  let visited = {};\n  let queue = [];\n  let currentNode = null;\n  let bfsInterval = null;\n\n  // Create SVG elements for edges first (lines between nodes)\n  function drawEdges() {\n    // Keep track of drawn edges to avoid duplicates in undirected graph\n    const drawnEdges = new Set();\n\n    Object.entries(graph).forEach(([nodeStr, neighbors]) => {\n      const node = Number(nodeStr);\n      neighbors.forEach(neighbor => {\n        // Add edge only if not drawn in opposite direction\n        const edgeId = node < neighbor ? `${node}-${neighbor}` : `${neighbor}-${node}`;\n        if (!drawnEdges.has(edgeId)) {\n          const posA = nodePositions[node];\n          const posB = nodePositions[neighbor];\n          const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n          line.setAttribute('x1', posA.x);\n          line.setAttribute('y1', posA.y);\n          line.setAttribute('x2', posB.x);\n          line.setAttribute('y2', posB.y);\n          line.setAttribute('stroke', '#555');\n          line.setAttribute('stroke-width', '2');\n          svg.appendChild(line);\n          drawnEdges.add(edgeId);\n        }\n      });\n    });\n  }\n\n  // Create SVG elements for nodes (circles with text)\n  const nodeElements = {};\n  function drawNodes() {\n    Object.entries(nodePositions).forEach(([nodeStr, pos]) => {\n      const node = Number(nodeStr);\n      // Create <g> container for circle and label\n      const g = document.createElementNS('http://www.w3.org/2000/svg', 'g');\n      g.classList.add('node');\n      g.setAttribute('data-node', node);\n      g.setAttribute('tabindex', '0'); // keyboard focusable\n\n      // Circle\n      const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n      circle.setAttribute('cx', pos.x);\n      circle.setAttribute('cy', pos.y);\n      circle.setAttribute('r', 22);\n      g.appendChild(circle);\n\n      // Text label\n      const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n      text.setAttribute('x', pos.x);\n      text.setAttribute('y', pos.y + 5); // vertical align center-ish\n      text.setAttribute('text-anchor', 'middle');\n      text.textContent = node;\n      g.appendChild(text);\n\n      svg.appendChild(g);\n      nodeElements[node] = g;\n    });\n  }\n\n  // Update node color states:\n  // unvisited: default (blue-green)\n  // visited: orange\n  // current: red\n  function updateNodeStates() {\n    Object.entries(nodeElements).forEach(([nodeStr, g]) => {\n      const node = Number(nodeStr);\n      g.classList.remove('visited', 'current');\n      if (currentNode === node) {\n        g.classList.add('current');\n      } else if (visited[node]) {\n        g.classList.add('visited');\n      }\n    });\n  }\n\n  function updateQueueDisplay() {\n    queueDisplay.innerHTML = `<strong>Queue:</strong> [ ${queue.join(', ')} ]`;\n  }\n\n  // BFS Step function: processes one node per call\n  function bfsStep() {\n    if (queue.length === 0) {\n      clearInterval(bfsInterval);\n      currentNode = null;\n      updateNodeStates();\n      startBtn.disabled = true;\n      resetBtn.disabled = false;\n      queueDisplay.innerHTML += \" <em>(Finished)</em>\";\n      return;\n    }\n    currentNode = queue.shift();\n    visited[currentNode] = true;\n\n    // Enqueue all unvisited neighbors\n    graph[currentNode].forEach(neighbor => {\n      if (!visited[neighbor] && !queue.includes(neighbor)) {\n        queue.push(neighbor);\n      }\n    });\n\n    updateNodeStates();\n    updateQueueDisplay();\n  }\n\n  // Initialization and reset\n  function resetGraph() {\n    visited = {};\n    queue = [];\n    currentNode = null;\n    updateNodeStates();\n    updateQueueDisplay();\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n  }\n\n  // Start BFS from node 0\n  function startBFS() {\n    // Initialize BFS from node 0\n    resetGraph();\n    queue.push(0);\n    updateQueueDisplay();\n    updateNodeStates();\n\n    // Steps every 1.2 seconds\n    bfsInterval = setInterval(bfsStep, 1200);\n\n    startBtn.disabled = true;\n    resetBtn.disabled = false;\n  }\n\n  function init() {\n    drawEdges();\n    drawNodes();\n    resetGraph();\n\n    startBtn.addEventListener('click', startBFS);\n    resetBtn.addEventListener('click', () => {\n      clearInterval(bfsInterval);\n      resetGraph();\n    });\n  }\n\n  init();\n})();\n</script>\n</body>\n</html>"
