    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Recursion Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f4f8;\n    color: #333;\n  }\n  h1 {\n    color: #007acc;\n  }\n  input[type=\"number\"] {\n    width: 80px;\n    padding: 0.3rem;\n    font-size: 1rem;\n  }\n  button {\n    padding: 0.4rem 1rem;\n    font-size: 1rem;\n    margin-left: 0.5rem;\n    cursor: pointer;\n    background-color: #007acc;\n    color: white;\n    border: none;\n    border-radius: 4px;\n  }\n  button:hover {\n    background-color: #005fa3;\n  }\n  pre {\n    background: #e3eefd;\n    border-radius: 5px;\n    padding: 1rem;\n    margin-top: 1rem;\n    white-space: pre-wrap;\n  }\n  .result {\n    margin-top: 1rem;\n    font-weight: bold;\n  }\n</style>\n</head>\n<body>\n<h1>Understanding Recursion: Factorial & Fibonacci</h1>\n\n<p>\n  Enter a number to see <strong>recursive</strong> calculations for factorial and Fibonacci sequence.\n</p>\n\n<label for=\"inputNumber\">Number (non-negative integer): </label>\n<input type=\"number\" id=\"inputNumber\" min=\"0\" max=\"30\" value=\"5\" />\n<button id=\"computeBtn\">Compute</button>\n\n<div class=\"result\" id=\"resultArea\"></div>\n<pre id=\"traceArea\"></pre>\n\n<script>\n// Recursive function to calculate factorial\nfunction factorial(n, trace) {\n  trace.push(`factorial(${n}) called.`);\n  if (n === 0 || n === 1) {\n    trace.push(`factorial(${n}) = 1 (base case)`);\n    return 1;\n  }\n  const result = n * factorial(n - 1, trace);\n  trace.push(`factorial(${n}) = ${n} * factorial(${n - 1}) = ${result}`);\n  return result;\n}\n\n// Recursive function to calculate nth Fibonacci number\nfunction fibonacci(n, trace) {\n  trace.push(`fibonacci(${n}) called.`);\n  if (n === 0) {\n    trace.push(`fibonacci(0) = 0 (base case)`);\n    return 0;\n  }\n  if (n === 1) {\n    trace.push(`fibonacci(1) = 1 (base case)`);\n    return 1;\n  }\n  const result = fibonacci(n - 1, trace) + fibonacci(n - 2, trace);\n  trace.push(`fibonacci(${n}) = fibonacci(${n-1}) + fibonacci(${n-2}) = ${result}`);\n  return result;\n}\n\ndocument.getElementById('computeBtn').addEventListener('click', () => {\n  const n = parseInt(document.getElementById('inputNumber').value);\n  const resultArea = document.getElementById('resultArea');\n  const traceArea = document.getElementById('traceArea');\n  \n  if (isNaN(n) || n < 0) {\n    resultArea.textContent = 'Please enter a valid non-negative integer.';\n    traceArea.textContent = '';\n    return;\n  }\n  if (n > 30) {\n    // prevent very high calculation times for fibonacci\n    resultArea.textContent = 'Please enter a number 30 or less for performance reasons.';\n    traceArea.textContent = '';\n    return;\n  }\n  \n  // Clear previous results\n  resultArea.textContent = '';\n  traceArea.textContent = '';\n  \n  // Factorial calculation with trace\n  const factTrace = [];\n  const factResult = factorial(n, factTrace);\n  \n  // Fibonacci calculation with trace\n  const fibTrace = [];\n  const fibResult = fibonacci(n, fibTrace);\n  \n  resultArea.innerHTML = `<strong>Results for n = ${n}:</strong><br>\n                          Factorial(${n}) = ${factResult}<br>\n                          Fibonacci(${n}) = ${fibResult}`;\n  \n  // Combine traces and show a clear separation\n  traceArea.textContent = \n    \"Factorial Trace:\\n\" + factTrace.join('\\n') + \n    \"\\n\\nFibonacci Trace:\\n\" + fibTrace.join('\\n');\n});\n</script>\n</body>\n</html>"
