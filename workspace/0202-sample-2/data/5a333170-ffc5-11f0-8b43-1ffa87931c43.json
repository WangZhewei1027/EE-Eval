    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Depth-First Search (DFS) Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f9f9f9;\n  }\n  h1 {\n    text-align: center;\n  }\n  #graph-container {\n    display: flex;\n    justify-content: center;\n    margin-bottom: 15px;\n  }\n  svg {\n    border: 1px solid #ccc;\n    background: white;\n    box-shadow: 2px 2px 10px rgba(0,0,0,0.1);\n  }\n  .node {\n    stroke: #555;\n    stroke-width: 2px;\n    fill: #eee;\n    cursor: pointer;\n    transition: fill 0.3s, stroke-width 0.3s;\n  }\n  .node.visited {\n    fill: #6cace4;\n    stroke: #0b61a4;\n    stroke-width: 3px;\n  }\n  .node.current {\n    fill: #f7b733;\n    stroke: #c16a00;\n    stroke-width: 3px;\n    animation: pulse 1s infinite alternate;\n  }\n  @keyframes pulse {\n    0% { filter: drop-shadow(0 0 2px #c16a00); }\n    100% { filter: drop-shadow(0 0 8px #f7b733); }\n  }\n  .edge {\n    stroke: #999;\n    stroke-width: 2px;\n  }\n  .edge.visited {\n    stroke: #0b61a4;\n    stroke-width: 3px;\n  }\n  #controls {\n    text-align: center;\n    margin-bottom: 20px;\n  }\n  #controls button {\n    margin: 0 5px;\n    padding: 8px 14px;\n    font-size: 16px;\n    border-radius: 5px;\n    border: none;\n    cursor: pointer;\n    background: #0b61a4;\n    color: white;\n    transition: background-color 0.3s;\n  }\n  #controls button:hover:enabled {\n    background: #094877;\n  }\n  #controls button:disabled {\n    background: #ccc;\n    cursor: not-allowed;\n  }\n  #log {\n    max-width: 700px;\n    margin: 0 auto;\n    background: white;\n    padding: 12px 15px;\n    border-radius: 5px;\n    box-shadow: 0 0 5px #ccc;\n    min-height: 70px;\n    font-size: 16px;\n    overflow-y: auto;\n  }\n  #log p {\n    margin: 3px 0;\n  }\n  .label {\n    font-size: 14px;\n    pointer-events: none;\n    user-select: none;\n    fill: #333;\n  }\n</style>\n</head>\n<body>\n  <h1>Depth-First Search (DFS) Visualization</h1>\n  <div id=\"graph-container\">\n    <svg width=\"700\" height=\"450\" id=\"graph\"></svg>\n  </div>\n  <div id=\"controls\">\n    <button id=\"startBtn\">Start DFS</button>\n    <button id=\"resetBtn\" disabled>Reset</button>\n  </div>\n  <div id=\"log\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n<script>\n(() => {\n  const svg = document.getElementById('graph');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const logDiv = document.getElementById('log');\n\n  // Graph definition as adjacency list\n  // We'll create a graph with 8 nodes (A-H)\n  // Structure:\n  // A connected to B, C\n  // B connected to D, E\n  // C connected to F\n  // E connected to G, H\n  //\n  // Graph is undirected for demo purpose\n\n  const nodes = [\n    {id: 'A', x: 350, y: 40},\n    {id: 'B', x: 150, y: 130},\n    {id: 'C', x: 550, y: 130},\n    {id: 'D', x: 80, y: 220},\n    {id: 'E', x: 220, y: 220},\n    {id: 'F', x: 620, y: 220},\n    {id: 'G', x: 170, y: 330},\n    {id: 'H', x: 270, y: 320},\n  ];\n\n  const edges = [\n    ['A','B'], ['A','C'],\n    ['B','D'], ['B','E'],\n    ['C','F'],\n    ['E','G'], ['E','H'],\n  ];\n\n  // Build adjacency list map structure\n  const adjacency = {};\n  nodes.forEach(({id}) => adjacency[id] = []);\n  edges.forEach(([u,v]) => {\n    adjacency[u].push(v);\n    adjacency[v].push(u);\n  });\n\n  // Draw edges\n  const edgeElements = [];\n  edges.forEach(([u,v]) => {\n    const source = nodes.find(n => n.id === u);\n    const target = nodes.find(n => n.id === v);\n    const line = document.createElementNS(\"http://www.w3.org/2000/svg\", \"line\");\n    line.setAttribute('x1', source.x);\n    line.setAttribute('y1', source.y);\n    line.setAttribute('x2', target.x);\n    line.setAttribute('y2', target.y);\n    line.classList.add('edge');\n    svg.appendChild(line);\n    edgeElements.push({el: line, u, v});\n  });\n\n  // Draw nodes\n  const nodeElements = {};\n  nodes.forEach(({id, x, y}) => {\n    // Circle\n    const circle = document.createElementNS(\"http://www.w3.org/2000/svg\", \"circle\");\n    circle.setAttribute('cx', x);\n    circle.setAttribute('cy', y);\n    circle.setAttribute('r', 25);\n    circle.classList.add('node');\n    circle.setAttribute('tabindex', 0);\n    circle.setAttribute('aria-label', `Node ${id}`);\n    circle.setAttribute('role', 'button');\n\n    // Label\n    const text = document.createElementNS(\"http://www.w3.org/2000/svg\", \"text\");\n    text.setAttribute('x', x);\n    text.setAttribute('y', y+6);\n    text.setAttribute('text-anchor', 'middle');\n    text.classList.add('label');\n    text.textContent = id;\n\n    svg.appendChild(circle);\n    svg.appendChild(text);\n    nodeElements[id] = circle;\n  });\n\n  // Log utility\n  function log(msg) {\n    const p = document.createElement('p');\n    p.textContent = msg;\n    logDiv.appendChild(p);\n    logDiv.scrollTop = logDiv.scrollHeight;\n  }\n\n  // DFS variables\n  let visited = new Set();\n  let stack = [];\n  let dfsRunning = false;\n  let currentNode = null;\n\n  // Reset visualization and data\n  function reset() {\n    visited.clear();\n    stack = [];\n    dfsRunning = false;\n    currentNode = null;\n\n    // Reset node styles\n    Object.values(nodeElements).forEach(n => {\n      n.classList.remove('visited', 'current');\n      n.style.pointerEvents = 'auto';\n    });\n    // Reset edge styles\n    edgeElements.forEach(({el}) => {\n      el.classList.remove('visited');\n    });\n    // Clear log\n    logDiv.innerHTML = '';\n\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n  }\n\n  // Highlight edge between two nodes as visited\n  function highlightEdge(u,v) {\n    const edge = edgeElements.find(e =>\n      (e.u === u && e.v === v) ||\n      (e.u === v && e.v === u)\n    );\n    if(edge) edge.el.classList.add('visited');\n  }\n\n  // DFS iterative implementation with visualization\n  async function dfs(startId) {\n    dfsRunning = true;\n    startBtn.disabled = true;\n    resetBtn.disabled = true;\n\n    stack.push(startId);\n    log(`Starting DFS from node ${startId}.`);\n\n    while(stack.length > 0) {\n      currentNode = stack.pop();\n\n      // Highlight current node (temporarily)\n      Object.values(nodeElements).forEach(n => n.classList.remove('current'));\n      if(!visited.has(currentNode)) {\n        nodeElements[currentNode].classList.add('current');\n      }\n\n      await sleep(1200);\n\n      if(!visited.has(currentNode)) {\n        visited.add(currentNode);\n        nodeElements[currentNode].classList.add('visited');\n        nodeElements[currentNode].classList.remove('current');\n        log(`Visited node ${currentNode}.`);\n\n        // Add neighbors to stack (in reverse alphabetical so that DFS order matches typical recursive left-to-right)\n        const neighbors = adjacency[currentNode].slice().sort().reverse();\n        for(let neighbor of neighbors) {\n          if(!visited.has(neighbor)) {\n            stack.push(neighbor);\n            highlightEdge(currentNode, neighbor);\n            log(`Neighbor ${neighbor} added to stack.`);\n          }\n        }\n      } else {\n        // If already visited, no action needed\n        log(`Node ${currentNode} was already visited, skipping.`);\n      }\n    }\n    log(`DFS complete! All reachable nodes visited.`);\n\n    resetBtn.disabled = false;\n    dfsRunning = false;\n  }\n\n\n  // helper sleep function\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Event Listeners\n  startBtn.addEventListener('click', () => {\n    if(!dfsRunning) {\n      resetBtn.disabled = true;\n      dfs('A');\n    }\n  });\n\n  resetBtn.addEventListener('click', () => {\n    if(!dfsRunning) reset();\n  });\n\n  reset();\n\n})();\n</script>\n</body>\n</html>"
  },
