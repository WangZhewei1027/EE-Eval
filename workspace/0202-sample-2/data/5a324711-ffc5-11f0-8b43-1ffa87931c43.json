    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Queue Demonstration</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      max-width: 600px;\n      margin: 2rem auto;\n      padding: 1rem;\n      background: #f9f9f9;\n      color: #333;\n    }\n    h1 {\n      text-align: center;\n    }\n    .queue-container {\n      margin: 1rem 0;\n      min-height: 60px;\n      border: 2px solid #007bff;\n      border-radius: 5px;\n      background: white;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      gap: 10px;\n      padding: 10px;\n      flex-wrap: wrap;\n    }\n    .queue-item {\n      background: #007bff;\n      color: white;\n      padding: 10px 16px;\n      border-radius: 4px;\n      font-weight: bold;\n      min-width: 40px;\n      text-align: center;\n      position: relative;\n    }\n    .queue-item::before {\n      content: \"Front\";\n      position: absolute;\n      top: -18px;\n      left: 50%;\n      transform: translateX(-50%);\n      font-size: 0.75rem;\n      color: #555;\n      font-weight: normal;\n    }\n    .queue-item:last-child::before {\n      content: \"\";\n    }\n    label {\n      display: block;\n      margin: 1rem 0 0.5rem;\n      font-weight: bold;\n    }\n    input[type=text] {\n      padding: 0.5rem;\n      font-size: 1rem;\n      width: 100%;\n      box-sizing: border-box;\n      border-radius: 4px;\n      border: 1px solid #ccc;\n    }\n    button {\n      margin-top: 1rem;\n      padding: 0.6rem 1rem;\n      font-size: 1rem;\n      border-radius: 4px;\n      border: none;\n      cursor: pointer;\n      background: #007bff;\n      color: white;\n      transition: background 0.3s ease;\n    }\n    button:disabled {\n      background: #bbb;\n      cursor: not-allowed;\n    }\n    .buttons {\n      display: flex;\n      gap: 10px;\n      flex-wrap: wrap;\n    }\n    .info {\n      margin-top: 1rem;\n      font-size: 1rem;\n      min-height: 24px;\n      color: #d9534f; /* red for alerts */\n    }\n    .queue-item.front {\n      border: 2px solid #ffc107;\n      background: #ffc107;\n      color: #333;\n    }\n    @media (max-width: 480px) {\n      .queue-item {\n        min-width: 30px;\n        padding: 8px 12px;\n        font-size: 0.9rem;\n      }\n      button {\n        flex: 1 1 45%;\n      }\n    }\n  </style>\n</head>\n<body>\n  <h1>Queue Data Structure Demonstration</h1>\n  <p>A <strong>Queue</strong> is a First-In-First-Out (FIFO) data structure. Elements are added (enqueued) to the back and removed (dequeued) from the front.</p>\n\n  <label for=\"inputValue\">Enter value to enqueue:</label>\n  <input type=\"text\" id=\"inputValue\" placeholder=\"Enter a value\" />\n\n  <div class=\"buttons\">\n    <button id=\"enqueueBtn\">Enqueue</button>\n    <button id=\"dequeueBtn\">Dequeue</button>\n    <button id=\"peekBtn\">Peek Front</button>\n    <button id=\"clearBtn\">Clear Queue</button>\n  </div>\n\n  <div class=\"info\" id=\"info\"></div>\n\n  <div class=\"queue-container\" id=\"queueContainer\" aria-live=\"polite\" aria-label=\"Queue contents\">\n    <!-- Queue items will show here -->\n  </div>\n\n  <script>\n    class Queue {\n      constructor() {\n        this.items = [];\n      }\n      enqueue(element) {\n        this.items.push(element);\n      }\n      dequeue() {\n        if (this.isEmpty()) {\n          return null;\n        }\n        return this.items.shift();\n      }\n      front() {\n        if (this.isEmpty()) {\n          return null;\n        }\n        return this.items[0];\n      }\n      isEmpty() {\n        return this.items.length === 0;\n      }\n      clear() {\n        this.items = [];\n      }\n      getItems() {\n        return this.items;\n      }\n      size() {\n        return this.items.length;\n      }\n    }\n\n    const queue = new Queue();\n\n    const inputValue = document.getElementById('inputValue');\n    const enqueueBtn = document.getElementById('enqueueBtn');\n    const dequeueBtn = document.getElementById('dequeueBtn');\n    const peekBtn = document.getElementById('peekBtn');\n    const clearBtn = document.getElementById('clearBtn');\n    const queueContainer = document.getElementById('queueContainer');\n    const info = document.getElementById('info');\n\n    function renderQueue() {\n      queueContainer.innerHTML = '';\n      const items = queue.getItems();\n      if (items.length === 0) {\n        queueContainer.textContent = 'Queue is empty.';\n        return;\n      }\n      items.forEach((item, index) => {\n        const div = document.createElement('div');\n        div.className = 'queue-item';\n        if(index === 0) {\n          div.classList.add('front');\n          div.setAttribute('aria-label', `Front of the queue: ${item}`);\n        } else {\n          div.setAttribute('aria-label', `Queue element: ${item}`);\n        }\n        div.textContent = item;\n        queueContainer.appendChild(div);\n      });\n    }\n\n    function showInfo(message, isError = false) {\n      info.style.color = isError ? '#d9534f' : '#28a745';\n      info.textContent = message;\n      setTimeout(() => {\n        info.textContent = '';\n      }, 3000);\n    }\n\n    enqueueBtn.addEventListener('click', () => {\n      const value = inputValue.value.trim();\n      if (value === '') {\n        showInfo('Please enter a value to enqueue.', true);\n        return;\n      }\n      queue.enqueue(value);\n      renderQueue();\n      showInfo(`Enqueued \"${value}\".`);\n      inputValue.value = '';\n      inputValue.focus();\n    });\n\n    dequeueBtn.addEventListener('click', () => {\n      if (queue.isEmpty()) {\n        showInfo('Queue is empty, cannot dequeue.', true);\n        return;\n      }\n      const removed = queue.dequeue();\n      renderQueue();\n      showInfo(`Dequeued \"${removed}\".`);\n    });\n\n    peekBtn.addEventListener('click', () => {\n      if (queue.isEmpty()) {\n        showInfo('Queue is empty, nothing at front.', true);\n        return;\n      }\n      const front = queue.front();\n      showInfo(`Front of the queue: \"${front}\".`);\n    });\n\n    clearBtn.addEventListener('click', () => {\n      if (queue.isEmpty()) {\n        showInfo('Queue already empty.', true);\n        return;\n      }\n      queue.clear();\n      renderQueue();\n      showInfo('Queue cleared.');\n    });\n\n    // Render initially empty queue\n    renderQueue();\n\n    // Enable enter key to enqueue\n    inputValue.addEventListener('keydown', (e) => {\n      if (e.key === 'Enter') {\n        enqueueBtn.click();\n      }\n    });\n  </script>\n</body>\n</html>"
