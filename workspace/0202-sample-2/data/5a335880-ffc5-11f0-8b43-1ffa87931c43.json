    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Prim's Algorithm Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 0;\n    background: #f0f0f0;\n  }\n  #container {\n    max-width: 900px;\n    margin: 1rem auto;\n    background: white;\n    border-radius: 8px;\n    padding: 1rem;\n    box-shadow: 0 0 10px rgba(0,0,0,0.1);\n  }\n  h1 {\n    text-align: center;\n  }\n  #graph {\n    border: 1px solid #ccc;\n    background: #fff;\n    display: block;\n    margin: 1rem auto;\n    border-radius: 8px;\n  }\n  #controls {\n    text-align: center;\n    margin: 1rem 0;\n  }\n  button {\n    background-color: #3498db;\n    border: none;\n    color: white;\n    padding: 10px 18px;\n    margin: 0 10px;\n    border-radius: 6px;\n    font-size: 1rem;\n    cursor: pointer;\n  }\n  button:disabled {\n    background-color: #9ecae1;\n    cursor: not-allowed;\n  }\n  #info {\n    max-width: 860px;\n    margin: 0 auto;\n    background: #e8f1f9;\n    border-radius: 6px;\n    padding: 1rem;\n    font-size: 1rem;\n    line-height: 1.5rem;\n    min-height: 120px;\n  }\n  .node {\n    fill: #3498db;\n    stroke: #2980b9;\n    stroke-width: 2px;\n  }\n  .node.active {\n    fill: #e67e22;\n    stroke: #d35400;\n  }\n  .node.mst {\n    fill: #2ecc71;\n    stroke: #27ae60;\n  }\n  .edge {\n    stroke: #bbb;\n    stroke-width: 2px;\n  }\n  .edge.mst {\n    stroke: #27ae60;\n    stroke-width: 4px;\n  }\n  .edge.considered {\n    stroke: #e67e22;\n    stroke-width: 3px;\n    stroke-dasharray: 6 4;\n  }\n  text {\n    pointer-events: none;\n    font-weight: bold;\n    user-select: none;\n  }\n  #final-weight {\n    font-weight: bold;\n    text-align: center;\n    margin-top: 1rem;\n    font-size: 1.2rem;\n    color: #27ae60;\n  }\n  small {\n    display: block;\n    margin-top: 0.4rem;\n    font-size: 0.85rem;\n    color: #555;\n  }\n</style>\n</head>\n<body>\n<div id=\"container\">\n  <h1>Prim's Algorithm Demonstration</h1>\n  <svg id=\"graph\" width=\"860\" height=\"500\" aria-label=\"Graph visualization\"></svg>\n  <div id=\"controls\" role=\"region\" aria-label=\"Algorithm controls\">\n    <button id=\"start\">Start</button>\n    <button id=\"next\" disabled>Next Step</button>\n    <button id=\"reset\" disabled>Reset</button>\n  </div>\n  <div id=\"info\" aria-live=\"polite\" aria-atomic=\"true\">\n    Click <strong>Start</strong> to begin the Prim's algorithm step-by-step demonstration.\n  </div>\n  <div id=\"final-weight\" aria-live=\"polite\"></div>\n  <small>Nodes are blue. Current node is orange. Edges/nodes chosen in MST are green. Edges currently considered are dashed orange.</small>\n</div>\n\n<script>\n// --- Graph Definition ---\nconst nodes = [\n  { id: 0, x: 100, y: 100, label: 'A' },\n  { id: 1, x: 300, y: 80, label: 'B' },\n  { id: 2, x: 500, y: 100, label: 'C' },\n  { id: 3, x: 200, y: 300, label: 'D' },\n  { id: 4, x: 400, y: 280, label: 'E' },\n  { id: 5, x: 650, y: 250, label: 'F' },\n  { id: 6, x: 100, y: 400, label: 'G' }\n];\n\nconst edges = [\n  { id:0, from: 0, to: 1, weight: 4 },\n  { id:1, from: 0, to: 3, weight: 2 },\n  { id:2, from: 1, to: 2, weight: 6 },\n  { id:3, from: 1, to: 3, weight: 3 },\n  { id:4, from: 2, to: 5, weight: 1 },\n  { id:5, from: 3, to: 4, weight: 5 },\n  { id:6, from: 4, to: 5, weight: 2 },\n  { id:7, from: 3, to: 6, weight: 3 },\n  { id:8, from: 4, to: 6, weight: 7 },\n];\n\n// Build adjacency list for quick access\nconst adjacency = [];\nfor(let i=0; i<nodes.length; i++) adjacency[i] = [];\nedges.forEach(e => {\n  adjacency[e.from].push({to: e.to, weight: e.weight, edgeId: e.id});\n  adjacency[e.to].push({to: e.from, weight: e.weight, edgeId: e.id});\n});\n\n// --- SVG and Rendering Setup ---\nconst svg = document.getElementById('graph');\nconst SVG_NS = \"http://www.w3.org/2000/svg\";\n\n// Elements references for quick updates\nconst edgeElements = new Map();\nconst nodeElements = new Map();\nconst edgeWeightElements = new Map();\n\n// Draw edges\nfunction drawEdges() {\n  edges.forEach(e => {\n    const fromNode = nodes[e.from];\n    const toNode = nodes[e.to];\n    let line = document.createElementNS(SVG_NS, 'line');\n    line.setAttribute('x1', fromNode.x);\n    line.setAttribute('y1', fromNode.y);\n    line.setAttribute('x2', toNode.x);\n    line.setAttribute('y2', toNode.y);\n    line.setAttribute('class', 'edge');\n    line.setAttribute('id', 'edge-'+e.id);\n    svg.appendChild(line);\n    edgeElements.set(e.id, line);\n\n    // Edge weight label: midpoint plus offset\n    let text = document.createElementNS(SVG_NS, 'text');\n    const midX = (fromNode.x + toNode.x) / 2;\n    const midY = (fromNode.y + toNode.y) / 2;\n    text.setAttribute('x', midX + 5); // slight offset\n    text.setAttribute('y', midY - 5);\n    text.textContent = e.weight;\n    text.style.fill = '#666';\n    svg.appendChild(text);\n    edgeWeightElements.set(e.id, text);\n  });\n}\n\n// Draw nodes\nfunction drawNodes() {\n  nodes.forEach(n => {\n    // circle\n    let circle = document.createElementNS(SVG_NS, 'circle');\n    circle.setAttribute('cx', n.x);\n    circle.setAttribute('cy', n.y);\n    circle.setAttribute('r', 20);\n    circle.setAttribute('class', 'node');\n    circle.setAttribute('id', 'node-'+n.id);\n    circle.setAttribute('tabindex', 0);\n    circle.setAttribute('aria-label', `Node ${n.label}`);\n    svg.appendChild(circle);\n    nodeElements.set(n.id, circle);\n\n    // label\n    let label = document.createElementNS(SVG_NS, 'text');\n    label.setAttribute('x', n.x);\n    label.setAttribute('y', n.y+5);\n    label.setAttribute('text-anchor', 'middle');\n    label.textContent = n.label;\n    label.setAttribute('pointer-events', 'none');\n    label.style.userSelect = 'none';\n    svg.appendChild(label);\n  });\n}\n\n// Initial draw\ndrawEdges();\ndrawNodes();\n\n// --- Prim's Algorithm Implementation ---\n\n// Global state for algorithm steps\nlet primState = {\n  inMST: new Set(),\n  edgeCandidates: [], // edges crossing the cut, sorted by weight\n  mstEdges: [],\n  currentNode: null,\n  totalWeight: 0,\n  step: 0,\n  started: false,\n  finished: false\n};\n\nfunction infoMessage(msg) {\n  document.getElementById('info').textContent = msg;\n}\n\nfunction resetGraphStyles() {\n  // Reset all node and edges styles\n  nodeElements.forEach((el) => {\n    el.classList.remove('active', 'mst');\n  });\n  edgeElements.forEach((el) => {\n    el.classList.remove('mst', 'considered');\n  });\n  document.getElementById('final-weight').textContent = '';\n}\n\n// Priority queue (min-heap) for edges by weight\nclass MinHeap {\n  constructor() {\n    this.heap = [];\n  }\n  parent(i){ return (i-1)>>1; }\n  left(i){ return (i<<1)+1; }\n  right(i){ return (i<<1)+2; }\n  swap(i,j) { [this.heap[i], this.heap[j]] = [this.heap[j], this.heap[i]]; }\n  push(item) {\n    this.heap.push(item);\n    this.bubbleUp(this.heap.length-1);\n  }\n  bubbleUp(i) {\n    while(i > 0){\n      let p = this.parent(i);\n      if(this.heap[p].weight <= this.heap[i].weight) break;\n      this.swap(i,p);\n      i = p;\n    }\n  }\n  pop() {\n    if(this.heap.length === 0) return null;\n    let top = this.heap[0];\n    let end = this.heap.pop();\n    if(this.heap.length > 0){\n      this.heap[0] = end;\n      this.bubbleDown(0);\n    }\n    return top;\n  }\n  bubbleDown(i) {\n    let length = this.heap.length;\n    while(true){\n      let l = this.left(i);\n      let r = this.right(i);\n      let smallest = i;\n      if(l < length && this.heap[l].weight < this.heap[smallest].weight) smallest = l;\n      if(r < length && this.heap[r].weight < this.heap[smallest].weight) smallest = r;\n      if(smallest === i) break;\n      this.swap(i, smallest);\n      i = smallest;\n    }\n  }\n  size() {\n    return this.heap.length;\n  }\n}\n\nlet heap;\n\n// Start algorithm initializations\nfunction startPrim() {\n  resetGraphStyles();\n  primState.inMST.clear();\n  primState.mstEdges = [];\n  primState.totalWeight = 0;\n  primState.currentNode = 0; // Start from node 0 (A)\n  primState.finished = false;\n  primState.step = 0;\n  heap = new MinHeap();\n  primState.inMST.add(primState.currentNode);\n  nodeElements.get(primState.currentNode).classList.add('active');\n  infoMessage(`Step 0: Starting from node ${nodes[primState.currentNode].label}. Add all edges from this node to the priority queue.`);\n  // Push all edges from start node into priority queue\n  adjacency[primState.currentNode].forEach(edge => {\n    heap.push({from: primState.currentNode, to: edge.to, weight: edge.weight, edgeId: edge.edgeId});\n    edgeElements.get(edge.edgeId).classList.add('considered');\n  });\n\n  document.getElementById('next').disabled = false;\n  document.getElementById('reset').disabled = false;\n  document.getElementById('start').disabled = true;\n  document.getElementById('final-weight').textContent = '';\n}\n\n// Next step: pick next minimum edge connecting to MST that leads to new node\nfunction nextStep() {\n  if(primState.finished) return;\n\n  // Remove \"active\" from old node (only if not in MST green)\n  if(primState.currentNode !== null) {\n    let oldNodeEl = nodeElements.get(primState.currentNode);\n    oldNodeEl.classList.remove('active');\n    oldNodeEl.classList.add('mst');\n  }\n  // Remove considered edges coloring (clear all)\n  edgeElements.forEach((el) => el.classList.remove('considered'));\n\n  // Extract edges until one connects to a node not in MST\n  let edgeChosen = null;\n  while(heap.size() > 0){\n    let edge = heap.pop();\n    if(!primState.inMST.has(edge.to)){\n      edgeChosen = edge;\n      break;\n    }\n  }\n\n  if(edgeChosen === null) {\n    // No more edges to add, MST complete\n    primState.finished = true;\n    infoMessage(`Prim's Algorithm completed! All nodes are in the MST.`);\n    document.getElementById('final-weight').textContent = `Total weight of MST: ${primState.totalWeight}`;\n    document.getElementById('next').disabled = true;\n    document.getElementById('start').disabled = false;\n    return;\n  }\n\n  primState.step++;\n  const fromLabel = nodes[edgeChosen.from].label;\n  const toLabel = nodes[edgeChosen.to].label;\n\n  infoMessage(`Step ${primState.step}: Select edge (${fromLabel} - ${toLabel}) with weight ${edgeChosen.weight} connecting to new node ${toLabel}.`);\n\n  // Mark current edge as part of MST\n  primState.mstEdges.push(edgeChosen.edgeId);\n  primState.totalWeight += edgeChosen.weight;\n  // Mark edge green\n  edgeElements.get(edgeChosen.edgeId).classList.add('mst');\n\n  // Mark new node as active and add to MST\n  primState.currentNode = edgeChosen.to;\n  nodeElements.get(primState.currentNode).classList.add('active');\n  primState.inMST.add(primState.currentNode);\n\n  // Add all edges from new node connecting to nodes NOT yet in MST\n  adjacency[primState.currentNode].forEach(edge => {\n    if(!primState.inMST.has(edge.to)){\n      heap.push({from: primState.currentNode, to: edge.to, weight: edge.weight, edgeId: edge.edgeId});\n      edgeElements.get(edge.edgeId).classList.add('considered');\n    }\n  });\n}\n\n// Reset entire visualization and state\nfunction resetPrim() {\n  primState = {\n    inMST: new Set(),\n    edgeCandidates: [],\n    mstEdges: [],\n    currentNode: null,\n    totalWeight: 0,\n    step: 0,\n    started: false,\n    finished: false\n  };\n  resetGraphStyles();\n  infoMessage('Click Start to begin Prim\\'s algorithm demonstration.');\n  document.getElementById('next').disabled = true;\n  document.getElementById('reset').disabled = true;\n  document.getElementById('start').disabled = false;\n  document.getElementById('final-weight').textContent = '';\n}\n\n// --- Button event listeners ---\ndocument.getElementById('start').addEventListener('click', () => {\n  startPrim();\n});\ndocument.getElementById('next').addEventListener('click', () => {\n  nextStep();\n});\ndocument.getElementById('reset').addEventListener('click', () => {\n  resetPrim();\n});\n\n</script>\n</body>\n</html>"
  },
