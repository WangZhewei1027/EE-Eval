    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Knapsack Problem Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f9f9fb;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  .container {\n    max-width: 900px;\n    margin: auto;\n    background: white;\n    padding: 20px;\n    border-radius: 8px;\n    box-shadow: 0 0 15px #ccc;\n  }\n  table {\n    border-collapse: collapse;\n    width: 100%;\n    margin-bottom: 15px;\n  }\n  th, td {\n    border: 1px solid #ccc;\n    padding: 8px 12px;\n    text-align: center;\n  }\n  th {\n    background: #007bff;\n    color: white;\n  }\n  input[type=\"number\"] {\n    width: 60px;\n    padding: 5px;\n    font-size: 14px;\n  }\n  button {\n    background: #007bff;\n    color: white;\n    border: none;\n    padding: 10px 15px;\n    border-radius: 5px;\n    cursor: pointer;\n    font-size: 16px;\n    margin-top: 10px;\n  }\n  button:hover {\n    background: #0056b3;\n  }\n  .results {\n    margin-top: 20px;\n  }\n  .grid-container {\n    overflow-x: auto;\n  }\n  code {\n    background: #eee;\n    padding: 2px 4px;\n    border-radius: 3px;\n  }\n  .explanation {\n    background: #e9f1ff;\n    border-left: 5px solid #007bff;\n    padding: 10px 15px;\n    margin-bottom: 20px;\n    font-size: 14px;\n  }\n  .selected-items {\n    margin-top: 10px;\n  }\n</style>\n</head>\n<body>\n  <div class=\"container\">\n    <h1>Knapsack Problem (0/1) Demonstration</h1>\n\n    <div class=\"explanation\">\n      <strong>Problem statement:</strong><br />\n      Given a list of items each with a <code>weight</code> and a <code>value</code>, select a subset of items to maximize total value while keeping total weight ≤ the capacity of the knapsack.\n      <br /><br />\n      This is the classic <em>0/1 Knapsack problem</em>, solved here using dynamic programming.\n    </div>\n\n    <h3>Step 1: Define Knapsack Capacity</h3>\n    <label for=\"capacity\">Knapsack capacity (max weight): </label>\n    <input id=\"capacity\" type=\"number\" min=\"1\" value=\"50\" />\n\n    <h3>Step 2: Define Items</h3>\n    <p>You can edit values & weights below. Add or remove rows to test different input.</p>\n\n    <table id=\"items-table\">\n      <thead>\n        <tr>\n          <th>Item #</th>\n          <th>Value</th>\n          <th>Weight</th>\n          <th>Actions</th>\n        </tr>\n      </thead>\n      <tbody id=\"items-body\">\n        <!-- Rows go here -->\n      </tbody>\n    </table>\n    <button id=\"add-item\">+ Add Item</button>\n\n    <button id=\"solve-btn\" style=\"display:block; margin-top:25px;\">Solve Knapsack</button>\n\n    <div class=\"results\" id=\"results\" aria-live=\"polite\"></div>\n  </div>\n\n<script>\n(() => {\n  // Initial default items\n  const defaultItems = [\n    { value: 60, weight: 10 },\n    { value: 100, weight: 20 },\n    { value: 120, weight: 30 }\n  ];\n\n  const itemsBody = document.getElementById('items-body');\n  const addItemBtn = document.getElementById('add-item');\n  const solveBtn = document.getElementById('solve-btn');\n  const resultsDiv = document.getElementById('results');\n  const capacityInput = document.getElementById('capacity');\n\n  // Render items into table\n  function renderItems(items) {\n    itemsBody.innerHTML = '';\n    items.forEach((item, i) => {\n      const tr = document.createElement('tr');\n      tr.setAttribute('data-index', i);\n\n      tr.innerHTML = `\n        <td>${i + 1}</td>\n        <td><input type=\"number\" min=\"0\" step=\"1\" value=\"${item.value}\" aria-label=\"Value of item ${i+1}\"/></td>\n        <td><input type=\"number\" min=\"0\" step=\"1\" value=\"${item.weight}\" aria-label=\"Weight of item ${i+1}\"/></td>\n        <td>\n          <button title=\"Remove item\" aria-label=\"Remove item ${i+1}\" class=\"remove-item-btn\" style=\"background:#dc3545; color:white; border:none; border-radius:3px; padding:4px 8px; cursor:pointer;\">×</button>\n        </td>\n      `;\n      itemsBody.appendChild(tr);\n    });\n  }\n\n  // Get current items from table inputs\n  function getItemsFromTable() {\n    const rows = [...itemsBody.querySelectorAll('tr')];\n    const items = [];\n    for (const row of rows) {\n      const inputs = row.querySelectorAll('input[type=number]');\n      if (inputs.length === 2) {\n        const value = Number(inputs[0].value);\n        const weight = Number(inputs[1].value);\n        if (!isNaN(value) && !isNaN(weight) && value >= 0 && weight >= 0) {\n          items.push({ value, weight });\n        } else {\n          // Invalid input found; return null to indicate error\n          return null;\n        }\n      }\n    }\n    return items;\n  }\n\n  // 0/1 Knapsack DP solution\n  // Returns: { maxValue, selectedItemsIndices }\n  function knapsack(items, capacity) {\n    const n = items.length;\n    // dp[i][w] = max value using first i items with w capacity\n    const dp = Array.from({ length: n + 1 }, () =>\n      new Array(capacity + 1).fill(0)\n    );\n\n    for (let i = 1; i <= n; i++) {\n      const { value, weight } = items[i - 1];\n      for (let w = 0; w <= capacity; w++) {\n        if (weight <= w) {\n          dp[i][w] = Math.max(\n            dp[i - 1][w],\n            dp[i - 1][w - weight] + value\n          );\n        } else {\n          dp[i][w] = dp[i - 1][w];\n        }\n      }\n    }\n\n    // Backtrack to find which items were selected\n    let w = capacity;\n    const selectedIndices = [];\n    for (let i = n; i > 0; i--) {\n      if (dp[i][w] !== dp[i - 1][w]) {\n        selectedIndices.push(i - 1);\n        w -= items[i - 1].weight;\n      }\n    }\n    selectedIndices.reverse();\n\n    return { maxValue: dp[n][capacity], selectedIndices };\n  }\n\n  // Render results\n  function displayResults(maxValue, selectedIndices, items) {\n    if (items.length === 0) {\n      resultsDiv.innerHTML = '<p>No items to choose from.</p>';\n      return;\n    }\n    if (selectedIndices.length === 0) {\n      resultsDiv.innerHTML = `<p>No items can fit in the knapsack or all have zero value.</p>`;\n      return;\n    }\n\n    const totalWeight = selectedIndices.reduce((acc, idx) => acc + items[idx].weight, 0);\n\n    let html = `<h3>Solution</h3>\n      <p><strong>Maximum value achievable:</strong> ${maxValue}</p>\n      <p><strong>Total weight used:</strong> ${totalWeight} (Capacity: ${capacityInput.value})</p>\n      <div class=\"selected-items\">\n        <h4>Selected Items:</h4>\n        <table>\n          <thead><tr><th>Item #</th><th>Value</th><th>Weight</th></tr></thead>\n          <tbody>`;\n    selectedIndices.forEach(idx => {\n      const { value, weight } = items[idx];\n      html += `<tr><td>${idx + 1}</td><td>${value}</td><td>${weight}</td></tr>`;\n    });\n    html += `</tbody></table></div>`;\n\n    // Also show DP table snippet for insight (only small for demonstration)\n    if (items.length <= 10 && capacityInput.value <= 100) {\n      html += `<h4>DP Table (max values for subproblems)</h4>`;\n      const capacity = Number(capacityInput.value);\n      const n = items.length;\n      const dp = Array.from({ length: n + 1 }, () =>\n        new Array(capacity + 1).fill(0)\n      );\n\n      for (let i = 1; i <= n; i++) {\n        const { value, weight } = items[i - 1];\n        for (let w = 0; w <= capacity; w++) {\n          if (weight <= w) {\n            dp[i][w] = Math.max(\n              dp[i - 1][w],\n              dp[i - 1][w - weight] + value\n            );\n          } else {\n            dp[i][w] = dp[i - 1][w];\n          }\n        }\n      }\n\n      html += `<div class=\"grid-container\" style=\"overflow-x:auto\"><table style=\"font-size:12px; border-collapse: collapse; margin-top:10px;\">\n        <thead>\n          <tr><th>i\\\\w</th>`;\n      for (let w = 0; w <= capacity; w++) {\n        if (w % 5 === 0) html += `<th>${w}</th>`;\n      }\n      html += `</tr></thead><tbody>`;\n      for (let i = 0; i <= n; i++) {\n        html += `<tr><th style=\"background:#007bff; color:white;\">${i}</th>`;\n        for (let w = 0; w <= capacity; w++) {\n          if (w % 5 === 0) {\n            html += `<td style=\"border:1px solid #ccc; padding:4px;\">${dp[i][w]}</td>`;\n          }\n        }\n        html += `</tr>`;\n      }\n      html += `</tbody></table></div>`;\n    }\n\n    resultsDiv.innerHTML = html;\n  }\n\n  // Add new empty item row\n  function addItem() {\n    const items = getItemsFromTable() || [];\n    items.push({ value: 0, weight: 0 });\n    renderItems(items);\n    attachRemoveButtons();\n  }\n\n  // Attach click event to remove black small buttons\n  function attachRemoveButtons() {\n    const btns = document.querySelectorAll('.remove-item-btn');\n    btns.forEach(btn => {\n      btn.onclick = e => {\n        const tr = e.target.closest('tr');\n        const idx = parseInt(tr.getAttribute('data-index'), 10);\n        const items = getItemsFromTable();\n        if (!items) {\n          alert('Invalid item inputs detected. Fix values first before removing.');\n          return;\n        }\n        items.splice(idx, 1);\n        renderItems(items);\n        attachRemoveButtons();\n      };\n    });\n  }\n\n  // Initial render\n  renderItems(defaultItems);\n  attachRemoveButtons();\n\n  addItemBtn.addEventListener('click', () => {\n    addItem();\n  });\n\n  solveBtn.addEventListener('click', () => {\n    const capacity = Number(capacityInput.value);\n    if (isNaN(capacity) || capacity <= 0) {\n      alert('Please enter a valid capacity greater than 0.');\n      return;\n    }\n    const items = getItemsFromTable();\n    if (!items) {\n      alert('Please fix invalid item inputs (non-negative numbers).');\n      return;\n    }\n    if (items.length === 0) {\n      resultsDiv.innerHTML = '<p>No items to choose from.</p>';\n      return;\n    }\n    // Ensure no negative values or weights\n    if (\n      items.some(\n        ({ value, weight }) =>\n          value < 0 || weight < 0 || isNaN(value) || isNaN(weight)\n      )\n    ) {\n      alert('Item values and weights must be non-negative numbers.');\n      return;\n    }\n    const { maxValue, selectedIndices } = knapsack(items, capacity);\n    displayResults(maxValue, selectedIndices, items);\n  });\n})();\n</script>\n</body>\n</html>"
  },
