    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Deque (Double-Ended Queue) Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f4f7;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n    margin-bottom: 1rem;\n    color: #007acc;\n  }\n  .deque-container {\n    max-width: 600px;\n    margin: 0 auto 2rem;\n    background: #fff;\n    border-radius: 8px;\n    padding: 1rem;\n    box-shadow: 0 2px 6px rgb(0 0 0 / 0.1);\n  }\n  .deque-state {\n    background-color: #e1f5fe;\n    border: 2px solid #03a9f4;\n    border-radius: 4px;\n    min-height: 50px;\n    display: flex;\n    align-items: center;\n    padding: 0.5rem 1rem;\n    overflow-x: auto;\n    margin-bottom: 1rem;\n    font-weight: bold;\n  }\n  .deque-element {\n    background: #03a9f4;\n    color: white;\n    border-radius: 4px;\n    padding: 0.25rem 0.75rem;\n    margin: 0 0.25rem;\n    min-width: 30px;\n    text-align: center;\n    user-select: none;\n  }\n  .operations {\n    display: grid;\n    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));\n    gap: 1rem;\n  }\n  label {\n    display: block;\n    margin-bottom: 0.25rem;\n    font-weight: 600;\n  }\n  input[type=\"text\"], input[type=\"number\"] {\n    width: 100%;\n    padding: 0.4rem 0.6rem;\n    border: 1.5px solid #ccc;\n    border-radius: 4px;\n    font-size: 1rem;\n    box-sizing: border-box;\n  }\n  button {\n    margin-top: 0.5rem;\n    width: 100%;\n    padding: 0.5rem;\n    font-size: 1rem;\n    border: none;\n    border-radius: 4px;\n    background-color: #007acc;\n    color: white;\n    cursor: pointer;\n    transition: background-color 0.3s ease;\n  }\n  button:hover:not(:disabled) {\n    background-color: #005f99;\n  }\n  button:disabled {\n    background-color: #aaa;\n    cursor: not-allowed;\n  }\n  .message {\n    margin-top: 1rem;\n    min-height: 1.4rem;\n    font-weight: 600;\n    text-align: center;\n  }\n  footer {\n    text-align: center;\n    margin-top: 3rem;\n    font-size: 0.85rem;\n    color: #888;\n  }\n</style>\n</head>\n<body>\n<h1>Deque (Double-Ended Queue) Demo</h1>\n\n<div class=\"deque-container\" aria-label=\"Deque container\">\n  <div><strong>Current Deque State (front to rear):</strong></div>\n  <div id=\"deque-state\" class=\"deque-state\" aria-live=\"polite\" aria-atomic=\"true\" aria-relevant=\"additions removals\">\n    <!-- Elements displayed here -->\n  </div>\n  <div class=\"operations\" aria-label=\"Deque operations\">\n\n    <div>\n      <label for=\"input-add-front\">Add to Front</label>\n      <input type=\"text\" id=\"input-add-front\" placeholder=\"Enter value\" aria-describedby=\"desc-add-front\" />\n      <button id=\"btn-add-front\" type=\"button\">Add Front</button>\n      <small id=\"desc-add-front\">Insert an element at the front of the deque</small>\n    </div>\n\n    <div>\n      <label for=\"input-add-rear\">Add to Rear</label>\n      <input type=\"text\" id=\"input-add-rear\" placeholder=\"Enter value\" aria-describedby=\"desc-add-rear\" />\n      <button id=\"btn-add-rear\" type=\"button\">Add Rear</button>\n      <small id=\"desc-add-rear\">Insert an element at the rear of the deque</small>\n    </div>\n\n    <div>\n      <label>&nbsp;</label>\n      <button id=\"btn-remove-front\" type=\"button\">Remove Front</button>\n      <small>Remove element from the front</small>\n    </div>\n\n    <div>\n      <label>&nbsp;</label>\n      <button id=\"btn-remove-rear\" type=\"button\">Remove Rear</button>\n      <small>Remove element from the rear</small>\n    </div>\n  </div>\n\n  <div id=\"message\" class=\"message\" role=\"alert\" aria-live=\"assertive\" aria-atomic=\"true\"></div>\n</div>\n\n<script>\n  // Deque class implementation\n  class Deque {\n    constructor() {\n      this.items = [];\n    }\n    addFront(element) {\n      this.items.unshift(element);\n    }\n    addRear(element) {\n      this.items.push(element);\n    }\n    removeFront() {\n      return this.items.shift();\n    }\n    removeRear() {\n      return this.items.pop();\n    }\n    isEmpty() {\n      return this.items.length === 0;\n    }\n    size() {\n      return this.items.length;\n    }\n    toArray() {\n      // front is index 0 -> rear last index\n      return this.items.slice();\n    }\n  }\n\n  // Instantiate deque\n  const deque = new Deque();\n\n  // DOM Elements\n  const dequeStateEl = document.getElementById('deque-state');\n  const messageEl = document.getElementById('message');\n  const inputAddFront = document.getElementById('input-add-front');\n  const inputAddRear = document.getElementById('input-add-rear');\n  const btnAddFront = document.getElementById('btn-add-front');\n  const btnAddRear = document.getElementById('btn-add-rear');\n  const btnRemoveFront = document.getElementById('btn-remove-front');\n  const btnRemoveRear = document.getElementById('btn-remove-rear');\n\n  // Update the visual display of the deque\n  function updateDequeDisplay() {\n    dequeStateEl.innerHTML = '';\n    const elems = deque.toArray();\n\n    if(elems.length === 0) {\n      dequeStateEl.textContent = '[ empty ]';\n      btnRemoveFront.disabled = true;\n      btnRemoveRear.disabled = true;\n      return;\n    }\n    btnRemoveFront.disabled = false;\n    btnRemoveRear.disabled = false;\n\n    elems.forEach(el => {\n      const div = document.createElement('div');\n      div.className = 'deque-element';\n      div.textContent = el;\n      dequeStateEl.appendChild(div);\n    });\n  }\n\n  // Show a message to the user\n  function showMessage(text, isError = false) {\n    messageEl.textContent = text;\n    messageEl.style.color = isError ? '#D8000C' : '#007E33';\n  }\n\n  // Validate input (not empty after trimming)\n  function validateInput(value) {\n    if(value.trim() === '') {\n      showMessage('Please enter a non-empty value.', true);\n      return false;\n    }\n    return true;\n  }\n\n  // Event handlers\n  btnAddFront.addEventListener('click', () => {\n    const val = inputAddFront.value;\n    if(validateInput(val)) {\n      deque.addFront(val.trim());\n      showMessage(`Added \"${val.trim()}\" to front.`);\n      inputAddFront.value = '';\n      updateDequeDisplay();\n    }\n  });\n\n  btnAddRear.addEventListener('click', () => {\n    const val = inputAddRear.value;\n    if(validateInput(val)) {\n      deque.addRear(val.trim());\n      showMessage(`Added \"${val.trim()}\" to rear.`);\n      inputAddRear.value = '';\n      updateDequeDisplay();\n    }\n  });\n\n  btnRemoveFront.addEventListener('click', () => {\n    if(deque.isEmpty()) {\n      showMessage('Deque is empty. Nothing to remove from front.', true);\n      updateDequeDisplay();\n      return;\n    }\n    const removed = deque.removeFront();\n    showMessage(`Removed \"${removed}\" from front.`);\n    updateDequeDisplay();\n  });\n\n  btnRemoveRear.addEventListener('click', () => {\n    if(deque.isEmpty()) {\n      showMessage('Deque is empty. Nothing to remove from rear.', true);\n      updateDequeDisplay();\n      return;\n    }\n    const removed = deque.removeRear();\n    showMessage(`Removed \"${removed}\" from rear.`);\n    updateDequeDisplay();\n  });\n\n  // Initialize display\n  updateDequeDisplay();\n  showMessage('Deque is empty. Add elements using the controls above.');\n</script>\n</body>\n</html>"
