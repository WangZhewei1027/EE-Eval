    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>JavaScript Set Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2em;\n    max-width: 600px;\n  }\n  h1 {\n    color: #2c3e50;\n  }\n  section {\n    margin-bottom: 2em;\n  }\n  code {\n    background: #f4f4f4;\n    padding: 0.2em 0.4em;\n    border-radius: 3px;\n  }\n  pre {\n    background: #f9f9f9;\n    border: 1px solid #ddd;\n    padding: 1em;\n    border-radius: 4px;\n    overflow-x: auto;\n  }\n  button {\n    background-color: #2980b9;\n    color: white;\n    border: none;\n    padding: 0.5em 1em;\n    cursor: pointer;\n    border-radius: 4px;\n    font-size: 1em;\n    margin-top: 0.5em;\n  }\n  button:hover {\n    background-color: #3498db;\n  }\n  #output {\n    margin-top: 1em;\n    background: #ecf0f1;\n    border-radius: 4px;\n    padding: 1em;\n    font-family: monospace;\n    white-space: pre-wrap;\n  }\n</style>\n</head>\n<body>\n<h1>JavaScript <code>Set</code> Demo</h1>\n\n<section>\n  <p>\n    A <code>Set</code> is a built-in JavaScript object that lets you store *unique* values of any type, whether primitive or object references. It automatically ensures no duplicates.\n  </p>\n</section>\n\n<section>\n  <h2>Create a Set</h2>\n  <pre><code>const fruits = new Set(['apple', 'banana', 'orange']);</code></pre>\n</section>\n\n<section>\n  <h2>Basic Operations</h2>\n  <button id=\"btn-demo\">Run Demo</button>\n  <div id=\"output\"></div>\n</section>\n\n<script>\n  document.getElementById('btn-demo').addEventListener('click', () => {\n    let output = '';\n\n    // Create a new set\n    const fruits = new Set(['apple', 'banana', 'orange']);\n    output += 'Initial set: ' + JSON.stringify(Array.from(fruits)) + '\\n';\n\n    // Add a new item\n    fruits.add('mango');\n    output += 'After adding \"mango\": ' + JSON.stringify(Array.from(fruits)) + '\\n';\n\n    // Try to add a duplicate \"banana\"\n    fruits.add('banana');\n    output += 'After adding duplicate \"banana\": ' + JSON.stringify(Array.from(fruits)) + ' (no change)\\n';\n\n    // Check if an item exists\n    output += '\"apple\" is in set? ' + (fruits.has('apple') ? 'Yes' : 'No') + '\\n';\n    output += '\"pear\" is in set? ' + (fruits.has('pear') ? 'Yes' : 'No') + '\\n';\n\n    // Remove an item\n    fruits.delete('orange');\n    output += 'After deleting \"orange\": ' + JSON.stringify(Array.from(fruits)) + '\\n';\n\n    // Get the size\n    output += 'Set size: ' + fruits.size + '\\n';\n\n    // Iterate over the set\n    output += 'Iterate using for-of:\\n';\n    for (const fruit of fruits) {\n      output += '- ' + fruit + '\\n';\n    }\n\n    // Clear all items\n    fruits.clear();\n    output += 'Cleared set size: ' + fruits.size + '\\n';\n\n    document.getElementById('output').textContent = output;\n  });\n</script>\n</body>\n</html>"
