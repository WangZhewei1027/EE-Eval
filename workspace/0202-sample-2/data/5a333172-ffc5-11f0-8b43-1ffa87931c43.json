  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Dijkstra's Algorithm Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f7f7f7;\n    color: #333;\n  }\n  #canvasContainer {\n    text-align: center;\n    margin-bottom: 20px;\n  }\n  canvas {\n    background: #fff;\n    box-shadow: 0 0 10px rgba(100, 100, 100, 0.3);\n    border-radius: 8px;\n  }\n  #controls {\n    max-width: 700px;\n    margin: 0 auto 20px;\n    display: flex;\n    flex-wrap: wrap;\n    gap: 10px;\n    justify-content: center;\n  }\n  #controls > * {\n    flex: 1 1 140px;\n    min-width: 140px;\n  }\n  label {\n    display: block;\n    font-size: 0.9em;\n    margin-bottom: 4px;\n  }\n  select, input[type=number], button {\n    width: 100%;\n    padding: 8px 10px;\n    font-size: 1em;\n    border: 1px solid #aaa;\n    border-radius: 4px;\n  }\n  button {\n    background-color: #2d86ff;\n    color: white;\n    border: none;\n    cursor: pointer;\n    font-weight: 600;\n  }\n  button:hover:not(:disabled) {\n    background-color: #1766d1;\n  }\n  button:disabled {\n    background-color: #999;\n    cursor: not-allowed;\n  }\n  #log {\n    max-width: 700px;\n    margin: 0 auto;\n    padding: 12px;\n    height: 180px;\n    overflow-y: auto;\n    background: #ececec;\n    border-radius: 6px;\n    font-family: monospace;\n    font-size: 14px;\n    line-height: 1.3em;\n  }\n  #legend {\n    max-width: 700px;\n    margin: 20px auto 0;\n    font-size: 0.9em;\n  }\n  .legend-item {\n    display: inline-flex;\n    align-items: center;\n    margin-right: 15px;\n  }\n  .color-box {\n    width: 18px;\n    height: 18px;\n    margin-right: 6px;\n    border-radius: 4px;\n    border: 1px solid #ccc;\n  }\n  .color-unvisited { background-color: #ddd; }\n  .color-visited { background-color: #66cc66; }\n  .color-current { background-color: #ff9933; }\n  .color-edge { stroke: #bbb; }\n  .color-edge-active { stroke: #ff9933; stroke-width: 3; }\n  .color-edge-shortest { stroke: #3399ff; stroke-width: 3; }\n</style>\n</head>\n<body>\n\n<h1>Dijkstra’s Algorithm Visualization</h1>\n<p>Visual demonstration of Dijkstra's shortest path algorithm on a weighted graph.</p>\n\n<div id=\"canvasContainer\">\n  <canvas id=\"graphCanvas\" width=\"700\" height=\"500\"></canvas>\n</div>\n\n<div id=\"controls\">\n  <div>\n    <label for=\"startNode\">Start Node:</label>\n    <select id=\"startNode\"></select>\n  </div>\n  <div>\n    <label for=\"endNode\">End Node (optional):</label>\n    <select id=\"endNode\">\n      <option value=\"\">None</option>\n    </select>\n  </div>\n  <div>\n    <label>&nbsp;</label>\n    <button id=\"startBtn\">Start Algorithm</button>\n  </div>\n  <div>\n    <label>&nbsp;</label>\n    <button id=\"resetBtn\" disabled>Reset</button>\n  </div>\n</div>\n\n<div id=\"log\" aria-live=\"polite\" aria-atomic=\"false\" aria-relevant=\"additions\">\n  <em>Algorithm log will appear here...</em>\n</div>\n\n<div id=\"legend\">\n  <strong>Legend:</strong> \n  <span class=\"legend-item\"><span class=\"color-box color-unvisited\"></span> Unvisited Node</span>\n  <span class=\"legend-item\"><span class=\"color-box color-visited\"></span> Visited Node (Distance Fixed)</span>\n  <span class=\"legend-item\"><span class=\"color-box color-current\"></span> Current Node</span>\n  <span class=\"legend-item\"><svg width=\"18\" height=\"18\"><line x1=\"2\" y1=\"9\" x2=\"16\" y2=\"9\" stroke=\"#bbb\" stroke-width=\"2\"/></svg> Edge</span>\n  <span class=\"legend-item\"><svg width=\"18\" height=\"18\"><line x1=\"2\" y1=\"9\" x2=\"16\" y2=\"9\" stroke=\"#ff9933\" stroke-width=\"3\"/></svg> Edge being processed</span>\n  <span class=\"legend-item\"><svg width=\"18\" height=\"18\"><line x1=\"2\" y1=\"9\" x2=\"16\" y2=\"9\" stroke=\"#3399ff\" stroke-width=\"3\"/></svg> Shortest path edges</span>\n</div>\n\n<script>\n(() => {\n  // Graph data: nodes with positions and adjacency list with weights\n  // Hardcoded example graph with 8 nodes\n  const nodes = [\n    {id: 'A', x: 100, y: 100},\n    {id: 'B', x: 250, y: 80},\n    {id: 'C', x: 400, y: 120},\n    {id: 'D', x: 550, y: 90},\n    {id: 'E', x: 150, y: 250},\n    {id: 'F', x: 300, y: 280},\n    {id: 'G', x: 450, y: 280},\n    {id: 'H', x: 600, y: 250},\n  ];\n\n  // Edges: undirected graph; each edge has source, target and weight\n  // Represented by adjacency list with weights: map nodeId -> array of {to, weight}\n  const adjacency = {\n    A: [{to: 'B', weight: 4}, {to: 'E', weight: 7}],\n    B: [{to: 'A', weight: 4}, {to: 'C', weight: 9}, {to: 'F', weight: 2}],\n    C: [{to: 'B', weight: 9}, {to: 'D', weight: 6}, {to: 'G', weight: 3}],\n    D: [{to: 'C', weight: 6}, {to: 'H', weight: 5}],\n    E: [{to: 'A', weight: 7}, {to: 'F', weight: 3}],\n    F: [{to: 'B', weight: 2}, {to: 'E', weight: 3}, {to: 'G', weight: 4}],\n    G: [{to: 'C', weight: 3}, {to: 'F', weight: 4}, {to: 'H', weight: 8}],\n    H: [{to: 'D', weight: 5}, {to: 'G', weight: 8}],\n  };\n\n  const canvas = document.getElementById('graphCanvas');\n  const ctx = canvas.getContext('2d');\n\n  const startNodeSelect = document.getElementById('startNode');\n  const endNodeSelect = document.getElementById('endNode');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const logContainer = document.getElementById('log');\n\n  // Colors for node states\n  const colorUnvisited = '#ddd';\n  const colorVisited = '#66cc66';\n  const colorCurrent = '#ff9933';\n  const edgeColor = '#bbb';\n  const edgeActiveColor = '#ff9933';\n  const edgeShortestColor = '#3399ff';\n\n  // Radius for node circles\n  const nodeRadius = 22;\n\n  // Data structure showing current status of nodes in algorithm\n  let nodeStates = {}; \n  // nodeStates[nodeId] = 'unvisited' | 'visited' | 'current'\n  // Also store distances and previous node for path\n  let distances = {};\n  let previous = {};\n  let settledNodes = new Set();\n\n  // For animation/timing\n  let animationStep = 0;\n  let animationIntervalId = null;\n  let processingQueue = []; // Priority queue of nodes to process as {id, dist}\n  \n  // Data to visualize edges activated in current step\n  let activeEdges = [];\n  // Edges forming the shortest path (for highlighting)\n  let shortestPathEdges = [];\n\n  // To facilitate priority queue, we will create a helper function\n  function insertQueue(queue, nodeId, dist) {\n    queue.push({id: nodeId, dist});\n    queue.sort((a,b) => a.dist - b.dist);\n  }\n  function popQueue(queue) {\n    return queue.shift();\n  }\n\n  // Initialize selectable nodes in dropdowns\n  function populateNodeSelects() {\n    for (const n of nodes) {\n      const opt1 = document.createElement('option');\n      opt1.value = n.id;\n      opt1.textContent = n.id;\n      startNodeSelect.appendChild(opt1);\n\n      const opt2 = document.createElement('option');\n      opt2.value = n.id;\n      opt2.textContent = n.id;\n      endNodeSelect.appendChild(opt2);\n    }\n  }\n\n  // Reset all states to initial\n  function resetState() {\n    nodeStates = {};\n    distances = {};\n    previous = {};\n    settledNodes.clear();\n    activeEdges = [];\n    shortestPathEdges = [];\n    processingQueue = [];\n    animationStep = 0;\n    clearInterval(animationIntervalId);\n    animationIntervalId = null;\n    logContainer.textContent = '';\n    for (const n of nodes) {\n      nodeStates[n.id] = 'unvisited';\n      distances[n.id] = Infinity;\n      previous[n.id] = null;\n    }\n    drawGraph();\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n  }\n\n  // Draw the entire graph with current states\n  function drawGraph() {\n    ctx.clearRect(0, 0, canvas.width, canvas.height);\n    ctx.lineCap = 'round';\n    ctx.textAlign = 'center';\n    ctx.textBaseline = 'middle';\n    ctx.font = '14px monospace';\n\n    // Helper to get node object by id\n    function getNode(id) {\n      return nodes.find(n => n.id === id);\n    }\n\n    // Draw edges\n    // First normal edges\n    for (const [from, adj] of Object.entries(adjacency)) {\n      for (const {to, weight} of adj) {\n        // To avoid drawing twice in undirected graph, draw only if from < to lex order\n        if (from < to) {\n          const fromNode = getNode(from);\n          const toNode = getNode(to);\n\n          // Determine color and width\n          let lineColor = edgeColor;\n          let lineWidth = 2;\n          // check if active\n          if (activeEdges.some(e => (e.from === from && e.to === to) || (e.from === to && e.to === from))) {\n            lineColor = edgeActiveColor;\n            lineWidth = 4;\n          }\n          // check if in shortest path\n          if (shortestPathEdges.some(e => (e.from === from && e.to === to) || (e.from === to && e.to === from))) {\n            lineColor = edgeShortestColor;\n            lineWidth = 4;\n          }\n\n          ctx.strokeStyle = lineColor;\n          ctx.lineWidth = lineWidth;\n          ctx.beginPath();\n          ctx.moveTo(fromNode.x, fromNode.y);\n          ctx.lineTo(toNode.x, toNode.y);\n          ctx.stroke();\n\n          // Draw weight at midpoint\n          const midX = (fromNode.x + toNode.x)/2;\n          const midY = (fromNode.y + toNode.y)/2;\n          ctx.fillStyle = '#222';\n          ctx.fillRect(midX - 14, midY - 14, 28, 20);\n          ctx.fillStyle = 'white';\n          ctx.fillText(weight, midX, midY - 4);\n        }\n      }\n    }\n\n    // Draw nodes\n    for (const n of nodes) {\n      // Determine color by state\n      let fillColor = colorUnvisited;\n      if (nodeStates[n.id] === 'visited') fillColor = colorVisited;\n      else if (nodeStates[n.id] === 'current') fillColor = colorCurrent;\n\n      ctx.fillStyle = fillColor;\n      ctx.strokeStyle = '#666';\n      ctx.lineWidth = 2;\n      ctx.beginPath();\n      ctx.arc(n.x, n.y, nodeRadius, 0, 2 * Math.PI);\n      ctx.fill();\n      ctx.stroke();\n\n      // Draw node ID\n      ctx.fillStyle = '#111';\n      ctx.font = 'bold 18px monospace';\n      ctx.fillText(n.id, n.x, n.y);\n\n      // Draw distance if known and finite\n      if (distances[n.id] !== Infinity) {\n        ctx.fillStyle = '#222';\n        ctx.font = '14px monospace';\n        ctx.fillText(distances[n.id], n.x, n.y + 28);\n      }\n    }\n  }\n\n  // Log message to the log container\n  function log(message) {\n    logContainer.textContent += message + '\\n';\n    logContainer.scrollTop = logContainer.scrollHeight;\n  }\n\n  // Highlight edges on the path back from endNode to start\n  function buildShortestPathEdges(endId) {\n    shortestPathEdges = [];\n    let cur = endId;\n    while (previous[cur]) {\n      shortestPathEdges.push({from: previous[cur], to: cur});\n      cur = previous[cur];\n    }\n  }\n\n  // Main Dijkstra algorithm steps with animation (step by step)\n  function stepDijkstra(startId, endId) {\n    if (animationIntervalId) clearInterval(animationIntervalId);\n\n    // Initialize\n    for (const n of nodes) {\n      distances[n.id] = Infinity;\n      previous[n.id] = null;\n      nodeStates[n.id] = 'unvisited';\n    }\n    distances[startId] = 0;\n    processingQueue = [{id: startId, dist: 0}];\n    settledNodes.clear();\n    shortestPathEdges = [];\n    activeEdges = [];\n    animationStep = 0;\n\n    startBtn.disabled = true;\n    resetBtn.disabled = false;\n    logContainer.textContent = '';\n    log(`Starting at node: ${startId}`);\n\n    drawGraph();\n\n    animationIntervalId = setInterval(() => {\n      if (processingQueue.length === 0) {\n        clearInterval(animationIntervalId);\n        log('Algorithm complete.');\n\n        if (endId && distances[endId] !== Infinity) {\n          log(`Shortest distance to node ${endId} is ${distances[endId]}.`);\n          buildShortestPathEdges(endId);\n          drawGraph();\n          log('Shortest path highlighted in blue.');\n        } else if (endId) {\n          log(`Node ${endId} is not reachable from ${startId}.`);\n        }\n\n        nodeStates = Object.fromEntries(Object.entries(nodeStates).map(([id]) => [id, 'visited']));\n        drawGraph();\n        startBtn.disabled = true; // no restart until reset\n        return;\n      }\n\n      // Pop node with smallest tentative distance\n      let current = popQueue(processingQueue);\n      let curNode = current.id;\n      // If already settled, skip\n      if (settledNodes.has(curNode)) {\n        return;\n      }\n\n      // Set current node state to 'current'\n      for (const nId in nodeStates) {\n        if (nodeStates[nId] === 'current') nodeStates[nId] = 'unvisited';\n      }\n      nodeStates[curNode] = 'current';\n      drawGraph();\n\n      log(`Processing node ${curNode} with tentative distance ${distances[curNode]}.`);\n\n      // Explore neighbors\n      activeEdges = [];\n      const neighbors = adjacency[curNode];\n      for (const {to, weight} of neighbors) {\n        if (settledNodes.has(to)) continue;\n        activeEdges.push({from: curNode, to});\n\n        const newDist = distances[curNode] + weight;\n        if (newDist < distances[to]) {\n          distances[to] = newDist;\n          previous[to] = curNode;\n\n          // Update/Insert node in queue with new distance\n          // Remove old entry if exists:\n          processingQueue = processingQueue.filter(e => e.id !== to);\n          insertQueue(processingQueue, to, newDist);\n          log(`Updating distance of node ${to} to ${newDist} (via ${curNode}).`);\n        } else {\n          log(`No update required for node ${to} (current distance ${distances[to]}).`);\n        }\n      }\n      drawGraph();\n\n      // Mark current node as settled\n      nodeStates[curNode] = 'visited';\n      settledNodes.add(curNode);\n\n      // End if end node was just settled\n      if (endId && curNode === endId) {\n        clearInterval(animationIntervalId);\n        log(`Reached target node ${endId}. Algorithm complete.`);\n        buildShortestPathEdges(endId);\n        drawGraph();\n        startBtn.disabled = true;\n        return;\n      }\n    }, 1500);\n  }\n\n  // Event handlers\n  startBtn.addEventListener('click', () => {\n    const startId = startNodeSelect.value;\n    const endId = endNodeSelect.value || null;\n    if (!startId) {\n      alert('Please select a start node.');\n      return;\n    }\n    if (endId === startId) {\n      alert('Start node and end node must be different.');\n      return;\n    }\n    stepDijkstra(startId, endId);\n  });\n\n  resetBtn.addEventListener('click', () => {\n    resetState();\n  });\n\n  // Initialization\n  function init() {\n    populateNodeSelects();\n    resetState();\n  }\n\n  init();\n})();\n</script>\n\n</body>\n</html>"
  },
