    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Divide and Conquer Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f5f5f5;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #content {\n    max-width: 700px;\n    margin: 1rem auto;\n    background: white;\n    padding: 1.5rem;\n    border-radius: 8px;\n    box-shadow: 0 0 10px rgba(0,0,0,0.1);\n  }\n  #arrayInput {\n    width: 100%;\n    padding: 0.5rem;\n    font-size: 1rem;\n    margin-top: 0.3rem;\n    margin-bottom: 1rem;\n  }\n  button {\n    padding: 0.6rem 1.2rem;\n    font-size: 1rem;\n    cursor: pointer;\n    border: none;\n    background: #007bff;\n    color: white;\n    border-radius: 4px;\n    transition: background 0.3s ease;\n  }\n  button:hover:not(:disabled) {\n    background: #0056b3;\n  }\n  button:disabled {\n    background: #cccccc;\n    cursor: not-allowed;\n  }\n  pre {\n    background: #eaeaea;\n    padding: 1rem;\n    border-radius: 6px;\n    overflow-x: auto;\n    white-space: pre-wrap;\n    word-wrap: break-word;\n  }\n  .step {\n    margin-bottom: 1rem;\n    font-family: monospace;\n    color: #444;\n  }\n  .highlight {\n    color: #d6336c;\n    font-weight: bold;\n  }\n  .array {\n    font-family: monospace;\n    background: #f0f0f0;\n    padding: 0.2rem 0.4rem;\n    border-radius: 4px;\n  }\n  #explanation {\n    margin-top: 1rem;\n    font-style: italic;\n    color: #555;\n  }\n</style>\n</head>\n<body>\n  <h1>Divide and Conquer Algorithm Demo: Merge Sort</h1>\n  <div id=\"content\">\n    <label for=\"arrayInput\">Enter numbers to sort (comma separated):</label>\n    <input type=\"text\" id=\"arrayInput\" placeholder=\"e.g. 8,3,5,4,7,6,1,2\" value=\"8,3,5,4,7,6,1,2\" />\n    <button id=\"startBtn\">Start Sorting (Merge Sort)</button>\n    <button id=\"resetBtn\" disabled>Reset</button>\n    <div id=\"stepsContainer\"></div>\n    <div id=\"explanation\">\n      <strong>Explanation:</strong> Merge Sort is a classic example of the divide and conquer approach. \n      It divides the array into halves recursively until reaching subarrays with a single element \n      (which are considered sorted), then merges these sorted subarrays step-by-step to produce \n      a sorted array.\n    </div>\n  </div>\n\n<script>\n  // Merge Sort implementation with step-by-step explanation for demonstration\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const arrayInput = document.getElementById('arrayInput');\n  const stepsContainer = document.getElementById('stepsContainer');\n\n  let steps = [];\n  let pauseBetweenSteps = 1500; // ms\n  let currentStepIndex = 0;\n  let animationsRunning = false;\n\n  function parseInputArray(input) {\n    return input.split(',')\n      .map(x => x.trim())\n      .filter(x => x.length > 0)\n      .map(x => Number(x))\n      .filter(x => !isNaN(x));\n  }\n\n  function arrayToStr(arr) {\n    return '[' + arr.join(', ') + ']';\n  }\n\n  // The divide and conquer merge sort function that collects steps\n  function mergeSort(arr, depth=0) {\n    // Base case: arrays of length 1 or 0 are sorted\n    if (arr.length <= 1) {\n      steps.push({\n        type: 'baseCase',\n        depth,\n        arr: [...arr],\n        message: `Base case reached with single element or empty array ${arrayToStr(arr)}.`\n      });\n      return arr;\n    }\n\n    const mid = Math.floor(arr.length / 2);\n\n    steps.push({\n      type: 'divide',\n      depth,\n      arr: [...arr],\n      left: arr.slice(0, mid),\n      right: arr.slice(mid),\n      message: `Divide array ${arrayToStr(arr)} into left: ${arrayToStr(arr.slice(0, mid))} and right: ${arrayToStr(arr.slice(mid))}`\n    });\n\n    const leftSorted = mergeSort(arr.slice(0, mid), depth + 1);\n    const rightSorted = mergeSort(arr.slice(mid), depth + 1);\n\n    const merged = merge(leftSorted, rightSorted, depth);\n    \n    return merged;\n  }\n\n  // Merge two sorted arrays and add steps describing merge process\n  function merge(left, right, depth) {\n    let i = 0, j = 0;\n    let mergedArr = [];\n    steps.push({\n      type: 'mergeStart',\n      depth,\n      left: [...left],\n      right: [...right],\n      message: `Start merging ${arrayToStr(left)} and ${arrayToStr(right)}`\n    });\n\n    while (i < left.length && j < right.length) {\n      if (left[i] <= right[j]) {\n        mergedArr.push(left[i]);\n        steps.push({\n          type: 'mergeStep',\n          depth,\n          chosen: left[i],\n          from: 'left',\n          mergedSoFar: [...mergedArr],\n          leftRemaining: left.slice(i+1),\n          rightRemaining: right.slice(j),\n          message: `Choose ${left[i]} from left`\n        });\n        i++;\n      } else {\n        mergedArr.push(right[j]);\n        steps.push({\n          type: 'mergeStep',\n          depth,\n          chosen: right[j],\n          from: 'right',\n          mergedSoFar: [...mergedArr],\n          leftRemaining: left.slice(i),\n          rightRemaining: right.slice(j+1),\n          message: `Choose ${right[j]} from right`\n        });\n        j++;\n      }\n    }\n\n    // Append remaining elements, if any\n    while (i < left.length) {\n      mergedArr.push(left[i]);\n      steps.push({\n        type: 'mergeStep',\n        depth,\n        chosen: left[i],\n        from: 'left',\n        mergedSoFar: [...mergedArr],\n        leftRemaining: left.slice(i+1),\n        rightRemaining: right.slice(j),\n        message: `Appending remaining ${left[i]} from left`\n      });\n      i++;\n    }\n    while (j < right.length) {\n      mergedArr.push(right[j]);\n      steps.push({\n        type: 'mergeStep',\n        depth,\n        chosen: right[j],\n        from: 'right',\n        mergedSoFar: [...mergedArr],\n        leftRemaining: left.slice(i),\n        rightRemaining: right.slice(j+1),\n        message: `Appending remaining ${right[j]} from right`\n      });\n      j++;\n    }\n\n    steps.push({\n      type: 'mergeEnd',\n      depth,\n      mergedArr: [...mergedArr],\n      message: `Merged to ${arrayToStr(mergedArr)}`\n    });\n\n    return mergedArr;\n  }\n\n  function clearSteps() {\n    stepsContainer.innerHTML = '';\n  }\n\n  function showStep(step) {\n    const div = document.createElement('div');\n    div.classList.add('step');\n    const indent = '&nbsp;'.repeat(step.depth * 4);\n    switch(step.type) {\n      case 'baseCase':\n        div.innerHTML = `${indent}<span class=\"highlight\">Base case:</span> ${step.message}`;\n        break;\n      case 'divide':\n        div.innerHTML = `${indent}<span class=\"highlight\">Divide:</span> ${step.message}`;\n        break;\n      case 'mergeStart':\n        div.innerHTML = `${indent}<span class=\"highlight\">Merge Start:</span> ${step.message}`;\n        break;\n      case 'mergeStep':\n        div.innerHTML = `${indent}<span class=\"highlight\">Merge Step:</span> ${step.message} <br/>${indent}Merged so far: <span class=\"array\">${arrayToStr(step.mergedSoFar)}</span><br/>${indent}Left remaining: <span class=\"array\">${arrayToStr(step.leftRemaining)}</span>, Right remaining: <span class=\"array\">${arrayToStr(step.rightRemaining)}</span>`;\n        break;\n      case 'mergeEnd':\n        div.innerHTML = `${indent}<span class=\"highlight\">Merge End:</span> ${step.message}`;\n        break;\n      default:\n        div.textContent = step.message;\n    }\n    return div;\n  }\n\n  async function animateSteps() {\n    animationsRunning = true;\n    startBtn.disabled = true;\n    resetBtn.disabled = false;\n    arrayInput.disabled = true;\n    stepsContainer.innerHTML = '';\n    for(let i = 0; i < steps.length; i++) {\n      if (!animationsRunning) break;\n      const stepDiv = showStep(steps[i]);\n      stepsContainer.appendChild(stepDiv);\n      stepDiv.scrollIntoView({behavior: 'smooth', block: 'end'});\n\n      // Wait for pauseBetweenSteps ms before next step\n      await new Promise(resolve => setTimeout(resolve, pauseBetweenSteps));\n    }\n    animationsRunning = false;\n    startBtn.disabled = false;\n    resetBtn.disabled = false;\n    arrayInput.disabled = false;\n  }\n\n  startBtn.addEventListener('click', () => {\n    const arr = parseInputArray(arrayInput.value);\n    if (!arr.length) {\n      alert('Please enter a valid list of comma separated numbers.');\n      return;\n    }\n    steps = [];\n    currentStepIndex = 0;\n    clearSteps();\n    mergeSort(arr);\n    animateSteps();\n  });\n\n  resetBtn.addEventListener('click', () => {\n    animationsRunning = false;\n    stepsContainer.innerHTML = '';\n    startBtn.disabled = false;\n    resetBtn.disabled = true;\n    arrayInput.disabled = false;\n  });\n</script>\n</body>\n</html>"
