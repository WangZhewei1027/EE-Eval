    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Longest Common Subsequence Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background-color: #f9fafd;\n    color: #333;\n  }\n  h1 {\n    color: #0066cc;\n  }\n  label {\n    display: block;\n    margin-top: 1rem;\n    margin-bottom: 0.3rem;\n    font-weight: bold;\n  }\n  input[type=\"text\"] {\n    width: 100%;\n    max-width: 400px;\n    padding: 0.5rem;\n    font-size: 1rem;\n    border: 2px solid #ccc;\n    border-radius: 4px;\n    box-sizing: border-box;\n    transition: border-color 0.3s;\n  }\n  input[type=\"text\"]:focus {\n    border-color: #0066cc;\n    outline: none;\n  }\n  button {\n    margin-top: 1.2rem;\n    padding: 0.6rem 1.5rem;\n    font-size: 1rem;\n    border: none;\n    background-color: #0066cc;\n    color: white;\n    border-radius: 4px;\n    cursor: pointer;\n    transition: background-color 0.3s;\n  }\n  button:hover {\n    background-color: #004a99;\n  }\n  #result {\n    margin-top: 2rem;\n    background: white;\n    padding: 1.5rem;\n    border-radius: 8px;\n    box-shadow: 0 0 10px rgba(0,0,0,0.1);\n    max-width: 600px;\n  }\n  .highlight {\n    background-color: #e6f0ff;\n    font-weight: bold;\n    color: #004a99;\n  }\n  pre {\n    background-color: #f0f5f9;\n    border-radius: 6px;\n    padding: 1rem;\n    overflow-x: auto;\n    font-family: monospace;\n    font-size: 0.9rem;\n    max-width: 600px;\n  }\n  footer {\n    margin-top: 4rem;\n    font-size: 0.85rem;\n    color: #777;\n  }\n</style>\n</head>\n<body>\n<h1>Longest Common Subsequence (LCS) Demo</h1>\n<p>\n  The <em>Longest Common Subsequence</em> of two sequences is the longest sequence that appears in both in the same order (not necessarily contiguously).\n</p>\n\n<label for=\"str1\">First string:</label>\n<input type=\"text\" id=\"str1\" placeholder=\"Enter first string\" value=\"AGGTAB\" aria-label=\"First string\" />\n\n<label for=\"str2\">Second string:</label>\n<input type=\"text\" id=\"str2\" placeholder=\"Enter second string\" value=\"GXTXAYB\" aria-label=\"Second string\" />\n\n<button id=\"computeBtn\">Compute LCS</button>\n\n<div id=\"result\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n\n<script>\n  // Compute LCS length table and also store chosen directions for backtracking\n  function computeLCS(str1, str2) {\n    const m = str1.length;\n    const n = str2.length;\n    // dp[i][j] will hold length of LCS of str1[0..i-1] & str2[0..j-1]\n    const dp = Array(m + 1).fill(null).map(() => Array(n + 1).fill(0));\n    // directions for backtracking: \"diag\" (match), \"up\", \"left\"\n    const dir = Array(m + 1).fill(null).map(() => Array(n + 1).fill(null));\n\n    for (let i = 1; i <= m; i++) {\n      for (let j = 1; j <= n; j++) {\n        if (str1[i - 1] === str2[j - 1]) {\n          dp[i][j] = dp[i - 1][j - 1] + 1;\n          dir[i][j] = \"diag\";\n        } else if (dp[i - 1][j] >= dp[i][j - 1]) {\n          dp[i][j] = dp[i - 1][j];\n          dir[i][j] = \"up\";\n        } else {\n          dp[i][j] = dp[i][j - 1];\n          dir[i][j] = \"left\";\n        }\n      }\n    }\n    return { dp, dir };\n  }\n\n  // Backtrack to find one LCS string from dp and dir arrays\n  function backtrackLCS(dir, str1, i, j) {\n    let lcs = [];\n    while (i > 0 && j > 0) {\n      if (dir[i][j] === \"diag\") {\n        lcs.push(str1[i - 1]);\n        i--;\n        j--;\n      } else if (dir[i][j] === \"up\") {\n        i--;\n      } else {\n        j--;\n      }\n    }\n    return lcs.reverse().join('');\n  }\n\n  // To highlight the LCS characters inside the input strings\n  function highlightLCS(str, lcs) {\n    let result = \"\";\n    let lcsIndex = 0;\n    for(let i=0; i<str.length; i++) {\n      if (lcsIndex < lcs.length && str[i] === lcs[lcsIndex]) {\n        result += `<span class=\"highlight\">${str[i]}</span>`;\n        lcsIndex++;\n      } else {\n        result += str[i];\n      }\n    }\n    return result;\n  }\n\n  function generateDPTableHTML(dp, str1, str2) {\n    const m = str1.length;\n    const n = str2.length;\n\n    let html = '<table border=\"1\" cellspacing=\"0\" cellpadding=\"5\"><thead><tr><th></th><th></th>';\n    for(let j=0; j<n; j++) {\n      html += `<th>${str2[j]}</th>`;\n    }\n    html += '</tr></thead><tbody>';\n\n    for(let i=0; i<=m; i++) {\n      html += '<tr>';\n      if(i === 0) {\n        html += '<th></th>';\n      } else {\n        html += `<th>${str1[i-1]}</th>`;\n      }\n      for(let j=0; j<=n; j++) {\n        html += `<td style=\"text-align:center;\">${dp[i][j]}</td>`;\n      }\n      html += '</tr>';\n    }\n    html += '</tbody></table>';\n    return html;\n  }\n\n  document.getElementById('computeBtn').addEventListener('click', () => {\n    const str1 = document.getElementById('str1').value;\n    const str2 = document.getElementById('str2').value;\n    const resultDiv = document.getElementById('result');\n\n    if (str1.length === 0 || str2.length === 0) {\n      resultDiv.innerHTML = '<p style=\"color: red;\">Please enter both strings.</p>';\n      return;\n    }\n\n    const { dp, dir } = computeLCS(str1, str2);\n    const lcs = backtrackLCS(dir, str1, str1.length, str2.length);\n    const lengthLCS = lcs.length;\n\n    const highlightedStr1 = highlightLCS(str1, lcs);\n    const highlightedStr2 = highlightLCS(str2, lcs);\n    const dpTableHtml = generateDPTableHTML(dp, str1, str2);\n\n    resultDiv.innerHTML = `\n      <p><strong>Length of LCS:</strong> ${lengthLCS}</p>\n      <p><strong>Longest Common Subsequence:</strong> <code>${lcs || '(empty)'}</code></p>\n      <p><strong>First string with LCS highlighted:</strong><br />${highlightedStr1}</p>\n      <p><strong>Second string with LCS highlighted:</strong><br />${highlightedStr2}</p>\n      <h3>DP Table (Lengths of LCS):</h3>\n      ${dpTableHtml}\n      <p><small>Rows correspond to characters of first string (plus empty prefix), columns to second string.</small></p>\n    `;\n  });\n\n  // Initialize with default values on page load\n  window.onload = () => {\n    document.getElementById('computeBtn').click();\n  }\n</script>\n</body>\n</html>"
