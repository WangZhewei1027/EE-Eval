    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Counting Sort Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    max-width: 800px;\n  }\n  h1 {\n    text-align: center;\n  }\n  input, button {\n    font-size: 1rem;\n    padding: 8px;\n    margin-top: 8px;\n  }\n  #inputArray {\n    width: 100%;\n    box-sizing: border-box;\n  }\n  .array-container {\n    margin: 12px 0;\n    padding: 10px;\n    background-color: #f0f8ff;\n    border-radius: 6px;\n    min-height: 50px;\n    display: flex;\n    flex-wrap: wrap;\n    gap: 6px;\n  }\n  .bar {\n    height: 40px;\n    background-color: #4a90e2;\n    color: white;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    font-weight: bold;\n    border-radius: 4px;\n    min-width: 30px;\n  }\n  .bar.count {\n    background-color: #a0d468;\n    height: 30px;\n    font-weight: normal;\n  }\n  .label {\n    margin-top: 4px;\n    font-size: 0.85rem;\n    text-align: center;\n    width: 30px;\n  }\n  #steps {\n    margin-top: 20px;\n    background: #fcfcfc;\n    border: 1px solid #ddd;\n    padding: 12px;\n    border-radius: 6px;\n    max-height: 300px;\n    overflow-y: auto;\n    font-family: monospace;\n    white-space: pre-wrap;\n  }\n  #info {\n    font-size: 0.95rem;\n    margin-top: 12px;\n    line-height: 1.4;\n  }\n</style>\n</head>\n<body>\n<h1>Counting Sort Visualization</h1>\n\n<label for=\"inputArray\">\n  Enter integers (0 to 50) separated by commas or spaces:\n</label>\n<br />\n<input\n  type=\"text\"\n  id=\"inputArray\"\n  placeholder=\"e.g. 4, 1, 3, 4, 5, 6, 3, 2\"\n/>\n<br />\n<button id=\"startBtn\">Start Counting Sort</button>\n\n<div id=\"info\">\n  <strong>Counting Sort Algorithm Overview:</strong><br />\n  1. Find the maximum value in the input array.<br />\n  2. Initialize a count array to keep track of the frequency of each value.<br />\n  3. Count the occurrences of each value.<br />\n  4. Accumulate counts to get the positions.<br />\n  5. Place each element from the input array into the output array in sorted order.<br />\n</div>\n\n<h2>Original Array</h2>\n<div id=\"originalArray\" class=\"array-container\" aria-live=\"polite\"></div>\n\n<h2>Count Array</h2>\n<div id=\"countArray\" class=\"array-container\" aria-live=\"polite\"></div>\n\n<h2>Sorted Output Array</h2>\n<div id=\"outputArray\" class=\"array-container\" aria-live=\"polite\"></div>\n\n<h2>Steps & Explanation</h2>\n<div id=\"steps\" aria-live=\"polite\"></div>\n\n<script>\n  (() => {\n    const startBtn = document.getElementById(\"startBtn\");\n    const inputEl = document.getElementById(\"inputArray\");\n    const originalArrayDiv = document.getElementById(\"originalArray\");\n    const countArrayDiv = document.getElementById(\"countArray\");\n    const outputArrayDiv = document.getElementById(\"outputArray\");\n    const stepsDiv = document.getElementById(\"steps\");\n\n    // Helper to clear containers\n    function clearContainers() {\n      originalArrayDiv.innerHTML = \"\";\n      countArrayDiv.innerHTML = \"\";\n      outputArrayDiv.innerHTML = \"\";\n      stepsDiv.textContent = \"\";\n    }\n\n    // Render an array as bars with optional highlights\n    function renderArray(container, arr, options = {}) {\n      container.innerHTML = \"\";\n      const maxVal = Math.max(...arr, 1);\n      for (let i = 0; i < arr.length; i++) {\n        const val = arr[i];\n        const bar = document.createElement(\"div\");\n        bar.className = \"bar\";\n        if (options.type === \"count\") bar.classList.add(\"count\");\n\n        // width proportional to value with min width and max width capped\n        // For count array bars, value small, so fixed width with height difference\n        const baseWidth = 30;\n        let width = baseWidth;\n        if (options.type !== \"count\" && maxVal > 0) {\n          width = Math.max(30, (val / maxVal) * 60 + 30);\n        }\n\n        bar.style.minWidth = width + \"px\";\n        bar.textContent = val;\n\n        if (options.highlight && options.highlight.includes(i)) {\n          bar.style.backgroundColor = options.highlightColor || \"#ff7f50\";\n        }\n        if (options.sortedIndices && options.sortedIndices.includes(i)) {\n          bar.style.backgroundColor = \"#50c878\"; // Green for sorted\n          bar.style.color = \"#fff\";\n        }\n\n        container.appendChild(bar);\n      }\n    }\n\n    // Render count array with indexes below bars\n    function renderCountArray(container, counts, highlightIndexes = []) {\n      container.innerHTML = \"\";\n      for (let i = 0; i < counts.length; i++) {\n        const val = counts[i];\n        const wrapper = document.createElement(\"div\");\n        wrapper.style.display = \"flex\";\n        wrapper.style.flexDirection = \"column\";\n        wrapper.style.alignItems = \"center\";\n        wrapper.style.marginRight = \"6px\";\n\n        const bar = document.createElement(\"div\");\n        bar.className = \"bar count\";\n        bar.style.minWidth = \"30px\";\n        bar.textContent = val;\n\n        if (highlightIndexes.includes(i)) {\n          bar.style.backgroundColor = \"#ff7f50\";\n        }\n\n        const label = document.createElement(\"div\");\n        label.className = \"label\";\n        label.textContent = i;\n\n        wrapper.appendChild(bar);\n        wrapper.appendChild(label);\n\n        container.appendChild(wrapper);\n      }\n    }\n\n    // Delay helper for animation steps\n    function delay(ms) {\n      return new Promise((res) => setTimeout(res, ms));\n    }\n\n    startBtn.addEventListener(\"click\", async () => {\n      clearContainers();\n\n      let values = inputEl.value\n        .split(/[\\s,]+/)\n        .map((v) => v.trim())\n        .filter((v) => v.length > 0);\n\n      if (values.length === 0) {\n        alert(\"Please enter at least one integer value.\");\n        return;\n      }\n\n      // Validate & convert to numbers\n      let arr = [];\n      for (let v of values) {\n        let n = Number(v);\n        if (\n          Number.isInteger(n) &&\n          n >= 0 &&\n          n <= 50 // limit max value for demo clarity\n        )\n          arr.push(n);\n        else {\n          alert(\n            `Invalid input detected: \"${v}\". Please enter integers between 0 and 50.`\n          );\n          return;\n        }\n      }\n\n      if (arr.length > 30) {\n        alert(\"Please enter at most 30 numbers for clarity.\");\n        return;\n      }\n\n      // Show original array\n      renderArray(originalArrayDiv, arr);\n\n      stepsDiv.textContent = \"Step 1: Find the maximum value in the input array.\\n\";\n      await delay(1200);\n\n      let maxVal = Math.max(...arr);\n      stepsDiv.textContent += `Maximum value found: ${maxVal}\\n\\nStep 2: Initialize count array of size ${maxVal +\n        1} with zeros.\\n`;\n      let count = new Array(maxVal + 1).fill(0);\n      renderCountArray(countArrayDiv, count);\n      await delay(1500);\n\n      stepsDiv.textContent += \"Step 3: Count the occurrences of each value:\\n\";\n\n      // Counting occurrences with animation\n      for (let i = 0; i < arr.length; i++) {\n        let val = arr[i];\n        count[val]++;\n        stepsDiv.textContent += `Increment count[${val}] to ${count[val]}\\n`;\n        renderCountArray(countArrayDiv, count, [val]);\n        await delay(700);\n      }\n\n      stepsDiv.textContent +=\n        \"\\nStep 4: Modify the count array by accumulating counts:\\n\";\n      // Accumulate\n      for (let i = 1; i < count.length; i++) {\n        count[i] += count[i - 1];\n        stepsDiv.textContent += `count[${i}] = count[${i}] + count[${i - 1}] = ${count[i]}\\n`;\n        renderCountArray(countArrayDiv, count, [i]);\n        await delay(700);\n      }\n\n      stepsDiv.textContent +=\n        \"\\nStep 5: Build the output sorted array by placing elements in correct positions.\\n\";\n      let output = new Array(arr.length);\n\n      // We go backwards through the original array for stable sort\n      for (let i = arr.length - 1; i >= 0; i--) {\n        let val = arr[i];\n        count[val]--;\n        let pos = count[val];\n        output[pos] = val;\n        stepsDiv.textContent += `Place ${val} at output[${pos}]\\n`;\n        renderArray(outputArrayDiv, output.filter((v) => v !== undefined));\n        await delay(1000);\n      }\n\n      stepsDiv.textContent +=\n        \"\\nCounting sort completed! The output array is sorted.\\n\";\n      renderArray(outputArrayDiv, output);\n\n      // Final highlight of sorted array\n      outputArrayDiv.childNodes.forEach((bar) => {\n        bar.style.backgroundColor = \"#50c878\";\n      });\n    });\n  })();\n</script>\n</body>\n</html>"
  },
