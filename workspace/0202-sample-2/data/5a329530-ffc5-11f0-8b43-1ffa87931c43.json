    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Binary Search Tree (BST) Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f4f7f8;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #controls {\n    text-align: center;\n    margin-bottom: 15px;\n  }\n  input[type=\"number\"] {\n    width: 120px;\n    font-size: 16px;\n    padding: 6px;\n    margin-right: 10px;\n  }\n  button {\n    font-size: 16px;\n    padding: 6px 12px;\n    margin-right: 10px;\n    cursor: pointer;\n  }\n  #display {\n    max-width: 900px;\n    margin: 0 auto;\n    background: #fff;\n    border-radius: 8px;\n    box-shadow: 0 6px 12px rgba(0, 0, 0, 0.1);\n    padding: 15px;\n  }\n  #inorder, #preorder, #postorder {\n    margin-top: 10px;\n  }\n  svg {\n    display: block;\n    margin: 0 auto;\n    background: #fff;\n    border-radius: 8px;\n    border: 1px solid #ddd;\n  }\n  .node circle {\n    fill: #4a90e2;\n    stroke: #2a5d9f;\n    stroke-width: 2px;\n  }\n  .node text {\n    fill: #fff;\n    font-weight: bold;\n    font-size: 14px;\n  }\n  .edge {\n    stroke: #999;\n    stroke-width: 2px;\n  }\n  #message {\n    text-align: center;\n    color: #d9534f;\n    font-weight: bold;\n    min-height: 20px;\n    margin-bottom: 10px;\n  }\n</style>\n</head>\n<body>\n<h1>Binary Search Tree (BST) Demo</h1>\n<div id=\"controls\">\n  <input type=\"number\" id=\"valueInput\" placeholder=\"Enter value\" />\n  <button id=\"insertBtn\">Insert</button>\n  <button id=\"searchBtn\">Search</button>\n  <button id=\"deleteBtn\">Delete</button>\n  <button id=\"clearBtn\">Clear Tree</button>\n</div>\n<div id=\"message\"></div>\n<div id=\"display\">\n  <svg id=\"treeSVG\" width=\"900\" height=\"400\"></svg>\n  <div id=\"inorder\"><strong>In-order:</strong> <span id=\"inorderList\"></span></div>\n  <div id=\"preorder\"><strong>Pre-order:</strong> <span id=\"preorderList\"></span></div>\n  <div id=\"postorder\"><strong>Post-order:</strong> <span id=\"postorderList\"></span></div>\n</div>\n\n<script>\n  // BST Node class\n  class Node {\n    constructor(value) {\n      this.value = value;\n      this.left = null;\n      this.right = null;\n    }\n  }\n\n  // BST class\n  class BST {\n    constructor() {\n      this.root = null;\n    }\n\n    insert(value) {\n      if (typeof value !== \"number\" || isNaN(value)) return false;\n      this.root = this._insertRec(this.root, value);\n      return true;\n    }\n\n    _insertRec(root, value) {\n      if (root === null) {\n        return new Node(value);\n      }\n      if (value === root.value) {\n        // no duplicate values in BST\n        return root;\n      }\n      if (value < root.value) {\n        root.left = this._insertRec(root.left, value);\n      } else {\n        root.right = this._insertRec(root.right, value);\n      }\n      return root;\n    }\n\n    search(value) {\n      return this._searchRec(this.root, value);\n    }\n\n    _searchRec(root, value) {\n      if (root === null) return null;\n      if (value === root.value) return root;\n      if (value < root.value) return this._searchRec(root.left, value);\n      else return this._searchRec(root.right, value);\n    }\n\n    delete(value) {\n      let found = {deleted: false};\n      this.root = this._deleteRec(this.root, value, found);\n      return found.deleted;\n    }\n\n    _deleteRec(root, value, found) {\n      if (root === null) return root;\n      if (value < root.value) {\n        root.left = this._deleteRec(root.left, value, found);\n      } else if (value > root.value) {\n        root.right = this._deleteRec(root.right, value, found);\n      } else {\n        found.deleted = true;\n        // node with only one child or no child\n        if (root.left === null) return root.right;\n        else if (root.right === null) return root.left;\n\n        // node with two children:\n        // get the inorder successor (smallest in the right subtree)\n        let minLargerNode = this._minValueNode(root.right);\n        root.value = minLargerNode.value;\n        // delete the inorder successor\n        root.right = this._deleteRec(root.right, minLargerNode.value, found);\n      }\n      return root;\n    }\n\n    _minValueNode(node) {\n      let current = node;\n      while (current.left !== null) {\n        current = current.left;\n      }\n      return current;\n    }\n\n    inorder() {\n      let res = [];\n      this._inorderRec(this.root, res);\n      return res;\n    }\n\n    _inorderRec(node, res) {\n      if (node !== null) {\n        this._inorderRec(node.left, res);\n        res.push(node.value);\n        this._inorderRec(node.right, res);\n      }\n    }\n\n    preorder() {\n      let res = [];\n      this._preorderRec(this.root, res);\n      return res;\n    }\n\n    _preorderRec(node, res) {\n      if (node !== null) {\n        res.push(node.value);\n        this._preorderRec(node.left, res);\n        this._preorderRec(node.right, res);\n      }\n    }\n\n    postorder() {\n      let res = [];\n      this._postorderRec(this.root, res);\n      return res;\n    }\n\n    _postorderRec(node, res) {\n      if (node !== null) {\n        this._postorderRec(node.left, res);\n        this._postorderRec(node.right, res);\n        res.push(node.value);\n      }\n    }\n\n    clear() {\n      this.root = null;\n    }\n  }\n\n  // Visualization and UI\n\n  const BSTree = new BST();\n\n  const svg = document.getElementById(\"treeSVG\");\n  const width = svg.clientWidth;\n  const height = svg.clientHeight;\n  const nodeRadius = 20;\n\n  const messageDiv = document.getElementById(\"message\");\n\n  const inputValue = document.getElementById(\"valueInput\");\n  const insertBtn = document.getElementById(\"insertBtn\");\n  const searchBtn = document.getElementById(\"searchBtn\");\n  const deleteBtn = document.getElementById(\"deleteBtn\");\n  const clearBtn = document.getElementById(\"clearBtn\");\n\n  const inorderList = document.getElementById(\"inorderList\");\n  const preorderList = document.getElementById(\"preorderList\");\n  const postorderList = document.getElementById(\"postorderList\");\n\n  insertBtn.addEventListener(\"click\", () => {\n    const val = Number(inputValue.value);\n    if (inputValue.value === \"\" || isNaN(val)) {\n      showMessage(\"Please enter a valid number.\");\n      return;\n    }\n    // Check for duplicate by search first\n    if (BSTree.search(val) !== null) {\n      showMessage(\"Value already exists in the BST.\");\n      return;\n    }\n    BSTree.insert(val);\n    inputValue.value = \"\";\n    showMessage(`Inserted ${val} into BST.`);\n    updateDisplay();\n  });\n\n  searchBtn.addEventListener(\"click\", () => {\n    const val = Number(inputValue.value);\n    if (inputValue.value === \"\" || isNaN(val)) {\n      showMessage(\"Please enter a valid number.\");\n      return;\n    }\n    const node = BSTree.search(val);\n    if (node) {\n      showMessage(`Value ${val} found in the BST.`);\n      updateDisplay(val);\n    } else {\n      showMessage(`Value ${val} not found in the BST.`);\n      updateDisplay();\n    }\n  });\n\n  deleteBtn.addEventListener(\"click\", () => {\n    const val = Number(inputValue.value);\n    if (inputValue.value === \"\" || isNaN(val)) {\n      showMessage(\"Please enter a valid number.\");\n      return;\n    }\n    const deleted = BSTree.delete(val);\n    if (deleted) {\n      showMessage(`Deleted value ${val} from BST.`);\n      inputValue.value = \"\";\n      updateDisplay();\n    } else {\n      showMessage(`Value ${val} not found in the BST.`);\n    }\n  });\n\n  clearBtn.addEventListener(\"click\", () => {\n    BSTree.clear();\n    showMessage(\"Cleared the BST.\");\n    inputValue.value = \"\";\n    updateDisplay();\n  });\n\n  function showMessage(msg) {\n    messageDiv.textContent = msg;\n  }\n\n  // Calculate positions of nodes for visualization\n  // We'll perform an inorder traversal to position nodes horizontally,\n  // and vertically by their depth in the tree.\n  function calculateNodePositions(root) {\n    let positions = new Map();\n    let maxDepth = 0;\n    let x = 0;\n\n    function inorderPos(node, depth) {\n      if (!node) return;\n      inorderPos(node.left, depth + 1);\n      positions.set(node, {x: x++, depth});\n      if (depth > maxDepth) maxDepth = depth;\n      inorderPos(node.right, depth + 1);\n    }\n    inorderPos(root, 0);\n    return {positions, maxDepth};\n  }\n\n  // Draw the tree using SVG elements\n  function drawTree(root, highlightValue = null) {\n    while (svg.firstChild) svg.removeChild(svg.firstChild);\n\n    if (!root) return;\n\n    const {positions, maxDepth} = calculateNodePositions(root);\n\n    // Calculate horizontal spacing\n    const totalNodes = positions.size;\n    const hSpacing = width / (totalNodes + 1);\n    const vSpacing = height / (maxDepth + 2);\n\n    // Draw edges first (lines between parent and children)\n    for (let [node, pos] of positions) {\n      if (node.left) drawEdge(pos, positions.get(node.left), hSpacing, vSpacing);\n      if (node.right) drawEdge(pos, positions.get(node.right), hSpacing, vSpacing);\n    }\n\n    // Draw nodes\n    for (let [node, pos] of positions) {\n      let cx = (pos.x + 1) * hSpacing;\n      let cy = (pos.depth + 1) * vSpacing;\n      drawNode(cx, cy, node.value, highlightValue === node.value);\n    }\n  }\n\n  function drawNode(cx, cy, value, highlight = false) {\n    const group = document.createElementNS(\"http://www.w3.org/2000/svg\", \"g\");\n    group.setAttribute(\"class\", \"node\");\n\n    const circle = document.createElementNS(\"http://www.w3.org/2000/svg\", \"circle\");\n    circle.setAttribute(\"cx\", cx);\n    circle.setAttribute(\"cy\", cy);\n    circle.setAttribute(\"r\", nodeRadius);\n    circle.setAttribute(\"fill\", highlight ? \"#e94e77\" : \"#4a90e2\");\n    circle.setAttribute(\"stroke\", highlight ? \"#b33250\" : \"#2a5d9f\");\n    circle.setAttribute(\"stroke-width\", \"3\");\n\n    const text = document.createElementNS(\"http://www.w3.org/2000/svg\", \"text\");\n    text.setAttribute(\"x\", cx);\n    text.setAttribute(\"y\", cy + 5);\n    text.setAttribute(\"text-anchor\", \"middle\");\n    text.setAttribute(\"font-weight\", \"bold\");\n    text.setAttribute(\"font-size\", \"14\");\n    text.setAttribute(\"fill\", \"#fff\");\n    text.textContent = value;\n\n    group.appendChild(circle);\n    group.appendChild(text);\n    svg.appendChild(group);\n  }\n\n  function drawEdge(parentPos, childPos, hSpacing, vSpacing) {\n    const x1 = (parentPos.x + 1) * hSpacing;\n    const y1 = (parentPos.depth + 1) * vSpacing + nodeRadius;\n    const x2 = (childPos.x + 1) * hSpacing;\n    const y2 = (childPos.depth + 1) * vSpacing - nodeRadius;\n\n    const line = document.createElementNS(\"http://www.w3.org/2000/svg\", \"line\");\n    line.setAttribute(\"x1\", x1);\n    line.setAttribute(\"y1\", y1);\n    line.setAttribute(\"x2\", x2);\n    line.setAttribute(\"y2\", y2);\n    line.setAttribute(\"class\", \"edge\");\n    line.setAttribute(\"stroke\", \"#999\");\n    line.setAttribute(\"stroke-width\", \"2\");\n    svg.appendChild(line);\n  }\n\n  function updateDisplay(highlightValue = null) {\n    drawTree(BSTree.root, highlightValue);\n\n    inorderList.textContent = BSTree.inorder().join(\", \") || \"Empty\";\n    preorderList.textContent = BSTree.preorder().join(\", \") || \"Empty\";\n    postorderList.textContent = BSTree.postorder().join(\", \") || \"Empty\";\n  }\n\n  updateDisplay();\n\n  // UX: Enter key triggers Insert\n  inputValue.addEventListener(\"keydown\", e => {\n    if (e.key === \"Enter\") {\n      insertBtn.click();\n    }\n  });\n</script>\n</body>\n</html>"
  },
