    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Merge Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f0f0f0;\n  }\n  h1 {\n    text-align: center;\n  }\n  #array {\n    display: flex;\n    justify-content: center;\n    margin: 30px 0;\n    gap: 4px;\n  }\n  .bar {\n    background-color: #5dade2;\n    width: 30px;\n    margin: 0 2px;\n    color: white;\n    text-align: center;\n    border-radius: 4px;\n    user-select: none;\n    display: flex;\n    align-items: flex-end;\n    justify-content: center;\n    font-weight: bold;\n    transition: background-color 0.3s ease;\n  }\n  #controls {\n    text-align: center;\n    margin-bottom: 20px;\n  }\n  button {\n    font-size: 16px;\n    padding: 8px 16px;\n    margin: 0 5px;\n    cursor: pointer;\n    border: none;\n    border-radius: 5px;\n    background-color: #2980b9;\n    color: white;\n    transition: background-color 0.3s ease;\n  }\n  button:disabled {\n    background-color: #a9a9a9;\n    cursor: not-allowed;\n  }\n  button:hover:not(:disabled) {\n    background-color: #1c5980;\n  }\n  #description {\n    max-width: 700px;\n    margin: 0 auto 40px auto;\n    text-align: center;\n    color: #333;\n    font-size: 1.1em;\n  }\n</style>\n</head>\n<body>\n<h1>Merge Sort Visualization</h1>\n<div id=\"description\">\n  <p>\n    Merge Sort is a divide and conquer algorithm that divides the array into halves, sorts them and then merges them back together.\n  </p>\n  <p>\n    Click <b>Generate Array</b> to create a random array, then <b>Start Merge Sort</b> to watch the sorting process.\n  </p>\n</div>\n<div id=\"controls\">\n  <button id=\"generateBtn\">Generate Array</button>\n  <button id=\"startBtn\">Start Merge Sort</button>\n</div>\n<div id=\"array\"></div>\n\n<script>\n  const arrayContainer = document.getElementById(\"array\");\n  const generateBtn = document.getElementById(\"generateBtn\");\n  const startBtn = document.getElementById(\"startBtn\");\n\n  let array = [];\n  const ARRAY_SIZE = 15;\n  const MAX_VALUE = 100;\n  const DELAY = 400; // ms delay for visualization\n\n  function createRandomArray() {\n    return Array.from({ length: ARRAY_SIZE }, () =>\n      Math.floor(Math.random() * MAX_VALUE) + 5\n    );\n  }\n\n  function renderArray(arr, highlightIndices = [], mergeIndices = []) {\n    arrayContainer.innerHTML = \"\";\n    for (let i = 0; i < arr.length; i++) {\n      const bar = document.createElement(\"div\");\n      bar.classList.add(\"bar\");\n      bar.style.height = arr[i] * 3 + \"px\"; // scale height for better visibility\n      bar.textContent = arr[i];\n\n      // Highlight bars being compared or merged\n      if (highlightIndices.includes(i)) {\n        bar.style.backgroundColor = \"#e74c3c\"; // red for comparing\n      } else if (mergeIndices.includes(i)) {\n        bar.style.backgroundColor = \"#27ae60\"; // green for merge\n      }\n\n      arrayContainer.appendChild(bar);\n    }\n  }\n\n  // async helper for delay\n  function sleep(ms) {\n    return new Promise((resolve) => setTimeout(resolve, ms));\n  }\n\n  async function merge(arr, left, mid, right) {\n    let leftCopy = arr.slice(left, mid + 1);\n    let rightCopy = arr.slice(mid + 1, right + 1);\n\n    let i = 0;\n    let j = 0;\n    let k = left;\n\n    // Visualize the subarrays being merged\n    while (i < leftCopy.length && j < rightCopy.length) {\n      renderArray(arr, [k], [\n        left + i,\n        mid + 1 + j,\n      ]);\n      await sleep(DELAY);\n\n      if (leftCopy[i] <= rightCopy[j]) {\n        arr[k] = leftCopy[i];\n        i++;\n      } else {\n        arr[k] = rightCopy[j];\n        j++;\n      }\n      renderArray(arr, [], [k]);\n      await sleep(DELAY);\n      k++;\n    }\n\n    // Copy remaining elements of leftCopy, if any\n    while (i < leftCopy.length) {\n      arr[k] = leftCopy[i];\n      renderArray(arr, [], [k]);\n      await sleep(DELAY);\n      i++;\n      k++;\n    }\n\n    // Copy remaining elements of rightCopy, if any\n    while (j < rightCopy.length) {\n      arr[k] = rightCopy[j];\n      renderArray(arr, [], [k]);\n      await sleep(DELAY);\n      j++;\n      k++;\n    }\n  }\n\n  async function mergeSort(arr, left, right) {\n    if (left >= right) {\n      return;\n    }\n    const mid = Math.floor((left + right) / 2);\n    await mergeSort(arr, left, mid);\n    await mergeSort(arr, mid + 1, right);\n    await merge(arr, left, mid, right);\n  }\n\n  generateBtn.addEventListener(\"click\", () => {\n    array = createRandomArray();\n    renderArray(array);\n    startBtn.disabled = false;\n  });\n\n  startBtn.addEventListener(\"click\", async () => {\n    generateBtn.disabled = true;\n    startBtn.disabled = true;\n    await mergeSort(array, 0, array.length - 1);\n    renderArray(array);\n    generateBtn.disabled = false;\n  });\n\n  // Initial setup\n  array = createRandomArray();\n  renderArray(array);\n</script>\n</body>\n</html>"
