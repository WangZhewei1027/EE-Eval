    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Binary Search Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f4f8;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #arrayContainer {\n    display: flex;\n    justify-content: center;\n    margin: 1rem 0 2rem 0;\n    flex-wrap: wrap;\n    max-width: 600px;\n    margin-left: auto;\n    margin-right: auto;\n  }\n  .arrayItem {\n    width: 40px;\n    height: 40px;\n    margin: 5px;\n    background: #e0e7f3;\n    border: 2px solid #ccc;\n    border-radius: 5px;\n    line-height: 40px;\n    text-align: center;\n    font-weight: bold;\n    user-select: none;\n    transition: background-color 0.3s, border-color 0.3s;\n  }\n  .low {\n    background-color: #ffd580;\n    border-color: #ffb347;\n  }\n  .mid {\n    background-color: #90caf9;\n    border-color: #42a5f5;\n    color: white;\n  }\n  .high {\n    background-color: #ff8a80;\n    border-color: #e53935;\n    color: white;\n  }\n  .found {\n    background-color: #66bb6a;\n    border-color: #388e3c;\n    color: white;\n  }\n  #controls {\n    max-width: 400px;\n    margin: 1rem auto 2rem auto;\n    text-align: center;\n  }\n  input[type=\"number\"] {\n    width: 80px;\n    font-size: 1rem;\n    padding: 6px 8px;\n    margin-right: 0.5rem;\n  }\n  button {\n    padding: 8px 14px;\n    font-size: 1rem;\n    cursor: pointer;\n    border: none;\n    border-radius: 4px;\n    background: #1976d2;\n    color: white;\n    transition: background-color 0.3s;\n  }\n  button:disabled {\n    background: #90a4ae;\n    cursor: not-allowed;\n  }\n  #log {\n    max-width: 600px;\n    margin: 0 auto;\n    background: white;\n    padding: 1rem;\n    border-radius: 6px;\n    height: 180px;\n    overflow-y: auto;\n    box-shadow: 0 2px 8px rgb(0 0 0 / 0.1);\n    font-family: monospace;\n    font-size: 0.9rem;\n  }\n</style>\n</head>\n<body>\n<h1>Binary Search Visualization</h1>\n\n<div id=\"arrayContainer\"></div>\n\n<div id=\"controls\">\n  <input id=\"searchInput\" type=\"number\" placeholder=\"Enter target\" />\n  <button id=\"startBtn\">Start Search</button>\n  <button id=\"resetBtn\" disabled>Reset</button>\n</div>\n\n<div id=\"log\"></div>\n\n<script>\n  // Sorted array of unique integers\n  const array = [3, 7, 15, 23, 31, 42, 56, 63, 79, 88, 94, 101];\n\n  const arrayContainer = document.getElementById('arrayContainer');\n  const searchInput = document.getElementById('searchInput');\n  const startBtn = document.getElementById('startBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const log = document.getElementById('log');\n\n  let low = 0;\n  let high = array.length - 1;\n  let mid = null;\n  let target = null;\n  let searching = false;\n  let intervalId = null;\n\n  // Initialize array display\n  function displayArray() {\n    arrayContainer.innerHTML = '';\n    array.forEach((num, idx) => {\n      const div = document.createElement('div');\n      div.classList.add('arrayItem');\n      div.id = 'item-' + idx;\n      div.textContent = num;\n      arrayContainer.appendChild(div);\n    });\n  }\n\n  function clearHighlights() {\n    for (let i = 0; i < array.length; i++) {\n      const el = document.getElementById('item-' + i);\n      el.className = 'arrayItem';\n    }\n  }\n\n  function highlight(lowIdx, midIdx, highIdx) {\n    clearHighlights();\n    if (lowIdx >= 0 && lowIdx < array.length) {\n      document.getElementById('item-' + lowIdx).classList.add('low');\n    }\n    if (midIdx !== null && midIdx >= 0 && midIdx < array.length) {\n      document.getElementById('item-' + midIdx).classList.add('mid');\n    }\n    if (highIdx >= 0 && highIdx < array.length) {\n      document.getElementById('item-' + highIdx).classList.add('high');\n    }\n  }\n\n  function logMessage(message) {\n    const p = document.createElement('p');\n    p.textContent = message;\n    log.appendChild(p);\n    log.scrollTop = log.scrollHeight;\n  }\n\n  function disableControls(isSearching) {\n    searchInput.disabled = isSearching;\n    startBtn.disabled = isSearching;\n    resetBtn.disabled = !isSearching;\n  }\n\n  function binarySearchStep() {\n    if (low > high) {\n      logMessage(`Target ${target} not found in the array.`);\n      disableControls(false);\n      clearInterval(intervalId);\n      searching = false;\n      return;\n    }\n    mid = Math.floor((low + high) / 2);\n    highlight(low, mid, high);\n    logMessage(`Checking middle index ${mid}, value ${array[mid]}`);\n    \n    if (array[mid] === target) {\n      document.getElementById('item-' + mid).classList.add('found');\n      logMessage(`Target ${target} found at index ${mid}!`);\n      disableControls(false);\n      clearInterval(intervalId);\n      searching = false;\n    } else if (array[mid] < target) {\n      logMessage(`Value ${array[mid]} is less than target ${target}, searching right half.`);\n      low = mid + 1;\n    } else {\n      logMessage(`Value ${array[mid]} is greater than target ${target}, searching left half.`);\n      high = mid - 1;\n    }\n  }\n\n  function startSearch() {\n    target = Number(searchInput.value);\n\n    if (isNaN(target)) {\n      alert('Please enter a valid number as the target.');\n      return;\n    }\n\n    // Reset variables\n    low = 0;\n    high = array.length - 1;\n    mid = null;\n    searching = true;\n    log.innerHTML = '';\n    logMessage(`Starting binary search for target ${target}...`);\n    disableControls(true);\n    highlight(low, null, high);\n\n    intervalId = setInterval(binarySearchStep, 1500);\n  }\n\n  function reset() {\n    if (intervalId) {\n      clearInterval(intervalId);\n    }\n    searching = false;\n    low = 0;\n    high = array.length - 1;\n    mid = null;\n    target = null;\n    log.innerHTML = '';\n    searchInput.value = '';\n    clearHighlights();\n    displayArray();\n    disableControls(false);\n  }\n\n  startBtn.addEventListener('click', () => {\n    if (!searching) {\n      startSearch();\n    }\n  });\n\n  resetBtn.addEventListener('click', reset);\n\n  // Initial setup\n  displayArray();\n</script>\n</body>\n</html>"
