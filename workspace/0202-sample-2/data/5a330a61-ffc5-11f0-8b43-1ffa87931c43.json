    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Heap Sort Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 1rem;\n    background: #f0f0f0;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n  h1 {\n    margin-bottom: 0.2rem;\n  }\n  #arrayContainer {\n    margin: 1rem 0;\n    display: flex;\n    align-items: flex-end;\n    height: 250px;\n    width: 90vw;\n    max-width: 900px;\n    border: 2px solid #444;\n    background: white;\n    padding: 10px;\n    box-sizing: border-box;\n  }\n  .bar {\n    margin: 0 2px;\n    background-color: #3498db;\n    width: 100%;\n    max-width: 20px;\n    text-align: center;\n    color: white;\n    font-size: 12px;\n    user-select: none;\n    border-radius: 3px 3px 0 0;\n    display: flex;\n    align-items: flex-end;\n    justify-content: center;\n    font-weight: bold;\n  }\n  .bar.comparing {\n    background-color: #e67e22;\n  }\n  .bar.swapping {\n    background-color: #e74c3c;\n  }\n  .bar.sorted {\n    background-color: #2ecc71;\n  }\n  #controls {\n    margin-top: 1rem;\n  }\n  button {\n    padding: 0.5rem 1rem;\n    margin: 0 0.5rem;\n    font-size: 1rem;\n    cursor: pointer;\n    border: none;\n    border-radius: 5px;\n    background-color: #3498db;\n    color: white;\n    transition: background-color 0.3s;\n  }\n  button:disabled {\n    background-color: #95a5a6;\n    cursor: not-allowed;\n  }\n  button:hover:not(:disabled) {\n    background-color: #2980b9;\n  }\n  #speedControl {\n    margin-left: 1rem;\n  }\n  label {\n    font-size: 1rem;\n    margin-right: 0.5rem;\n  }\n  #explanation {\n    max-width: 900px;\n    margin-top: 2rem;\n    background: white;\n    padding: 1rem 1.5rem;\n    box-shadow: 0 0 8px rgba(0,0,0,0.1);\n    border-radius: 6px;\n    line-height: 1.5;\n  }\n  code {\n    background: #eee;\n    padding: 2px 5px;\n    border-radius: 3px;\n    font-family: monospace;\n  }\n</style>\n</head>\n<body>\n<h1>Heap Sort Visualization</h1>\n\n<div id=\"arrayContainer\"></div>\n\n<div id=\"controls\">\n  <button id=\"generateBtn\">Generate New Array</button>\n  <button id=\"startBtn\">Start Heap Sort</button>\n  <label for=\"speedRange\">Speed:</label>\n  <input type=\"range\" id=\"speedRange\" min=\"100\" max=\"2000\" value=\"600\" step=\"100\" />\n  <span id=\"speedValue\">600 ms</span>\n</div>\n\n<div id=\"explanation\">\n  <h2>What is Heap Sort?</h2>\n  <p><strong>Heap Sort</strong> is a comparison-based sorting algorithm that uses a binary heap data structure. It's an efficient sorting algorithm with <code>O(n log n)</code> time complexity in the worst, average, and best cases.</p>\n  <p>The two main steps of heap sort are:</p>\n  <ol>\n    <li>Build a max heap from the input data.</li>\n    <li>Repeatedly remove the largest element (root of the heap) and place it at the end of the array, then rebuild the heap with the remaining elements.</li>\n  </ol>\n  <p>This visualization demonstrates how the values \"bubble down\" in the heap during the heapify process and how the sorted portion grows from the end of the array.</p>\n</div>\n\n<script>\n  const arrayContainer = document.getElementById('arrayContainer');\n  const generateBtn = document.getElementById('generateBtn');\n  const startBtn = document.getElementById('startBtn');\n  const speedRange = document.getElementById('speedRange');\n  const speedValue = document.getElementById('speedValue');\n\n  let array = [];\n  const ARRAY_SIZE = 30;\n  let speed = parseInt(speedRange.value);\n  let isSorting = false;\n\n  // Utility: Sleep / delay function\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Generate random array between 5 and 250\n  function generateArray() {\n    array = [];\n    for (let i = 0; i < ARRAY_SIZE; i++) {\n      array.push(Math.floor(Math.random() * 245) + 5);\n    }\n  }\n\n  // Render array bars visually\n  function renderArray(highlightIndices = {}, sortedIndices = []) {\n    arrayContainer.innerHTML = '';\n    const maxVal = Math.max(...array);\n\n    array.forEach((value, index) => {\n      const bar = document.createElement('div');\n      bar.classList.add('bar');\n\n      // Set width so bars fit nicely\n      bar.style.width = `${100 / ARRAY_SIZE}%`;\n      bar.style.height = `${(value / maxVal) * 100}%`;\n\n      // Show value inside the bar\n      bar.textContent = value;\n\n      // Highlight bars depending on status\n      if (highlightIndices.comparing && highlightIndices.comparing.includes(index)) {\n        bar.classList.add('comparing');\n      }\n      if (highlightIndices.swapping && highlightIndices.swapping.includes(index)) {\n        bar.classList.add('swapping');\n      }\n      if (sortedIndices.includes(index)) {\n        bar.classList.add('sorted');\n      }\n\n      arrayContainer.appendChild(bar);\n    });\n  }\n\n  // HeapSort implementation with visualization\n\n  // Heapify subtree rooted at index i (max heap)\n  async function heapify(n, i, highlightState) {\n    let largest = i;\n    const l = 2 * i + 1;\n    const r = 2 * i + 2;\n\n    // Highlight current node and its children for comparison\n    highlightState.comparing = [i];\n    if (l < n) highlightState.comparing.push(l);\n    if (r < n) highlightState.comparing.push(r);\n    renderArray(highlightState);\n    await sleep(speed);\n\n    if (l < n && array[l] > array[largest]) {\n      largest = l;\n    }\n    if (r < n && array[r] > array[largest]) {\n      largest = r;\n    }\n\n    if (largest !== i) {\n      // Highlight swapping nodes\n      highlightState.swapping = [i, largest];\n      renderArray(highlightState);\n      await sleep(speed);\n\n      // Swap values\n      [array[i], array[largest]] = [array[largest], array[i]];\n      renderArray(highlightState);\n      await sleep(speed);\n\n      // Recursive heapify the affected subtree\n      await heapify(n, largest, highlightState);\n    } else {\n      // No swap, clear swapping highlight\n      highlightState.swapping = [];\n      renderArray(highlightState);\n      await sleep(speed);\n    }\n  }\n\n  // Main heap sort function\n  async function heapSort() {\n    isSorting = true;\n    generateBtn.disabled = true;\n    startBtn.disabled = true;\n    speedRange.disabled = true;\n\n    let n = array.length;\n    let highlightState = { comparing: [], swapping: [] };\n\n    // Build max heap\n    for (let i = Math.floor(n / 2) - 1; i >= 0; i--) {\n      await heapify(n, i, highlightState);\n    }\n\n    let sortedIndices = [];\n\n    // One by one extract elements\n    for (let i = n - 1; i > 0; i--) {\n      // Highlight for swapping root and last element\n      highlightState.swapping = [0, i];\n      renderArray(highlightState, sortedIndices);\n      await sleep(speed);\n\n      // Swap current root to end\n      [array[0], array[i]] = [array[i], array[0]];\n\n      // Mark the element \"sorted\"\n      sortedIndices.push(i);\n\n      // Clear swapping highlights on update\n      highlightState.swapping = [];\n      highlightState.comparing = [];\n\n      renderArray(highlightState, sortedIndices);\n      await sleep(speed);\n\n      // Heapify reduced heap\n      await heapify(i, 0, highlightState);\n    }\n    // The first element is also sorted now\n    sortedIndices.push(0);\n    renderArray({}, sortedIndices);\n\n    generateBtn.disabled = false;\n    startBtn.disabled = false;\n    speedRange.disabled = false;\n    isSorting = false;\n  }\n\n  // Event handlers\n  generateBtn.addEventListener('click', () => {\n    if (isSorting) return;\n    generateArray();\n    renderArray();\n  });\n\n  startBtn.addEventListener('click', () => {\n    if (isSorting) return;\n    heapSort();\n  });\n\n  speedRange.addEventListener('input', e => {\n    speed = parseInt(e.target.value);\n    speedValue.textContent = speed + ' ms';\n  });\n\n  // Initialize on load\n  generateArray();\n  renderArray();\n</script>\n</body>\n</html>"
