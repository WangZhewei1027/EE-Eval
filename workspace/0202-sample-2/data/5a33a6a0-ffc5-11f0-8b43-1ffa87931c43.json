    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Huffman Coding Demonstration</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    max-width: 900px;\n  }\n  h1 {\n    text-align: center;\n  }\n  textarea {\n    width: 100%;\n    height: 100px;\n    font-family: monospace;\n    font-size: 16px;\n  }\n  button {\n    margin: 10px 0 20px;\n    padding: 10px 20px;\n    font-size: 16px;\n  }\n  #output {\n    white-space: pre-wrap;\n    background: #f7f7f7;\n    padding: 10px;\n    border: 1px solid #ccc;\n    font-family: monospace;\n  }\n  table {\n    border-collapse: collapse;\n    width: 100%;\n    margin-top: 10px;\n  }\n  th, td {\n    border: 1px solid #999;\n    padding: 6px 10px;\n    text-align: center;\n  }\n  th {\n    background-color: #eee;\n  }\n  .tree-node {\n    display: inline-block;\n    text-align: center;\n    margin: 5px;\n    padding: 6px 10px;\n    border: 1px solid #888;\n    border-radius: 4px;\n    font-weight: bold;\n    background-color: #d1e7dd;\n    position: relative;\n  }\n  .tree-container {\n    margin-top: 20px;\n    overflow-x: auto;\n    white-space: nowrap;\n  }\n  .tree-children {\n    display: flex;\n    justify-content: center;\n    margin-top: 20px;\n  }\n  .tree-link {\n    position: absolute;\n    width: 1px;\n    background-color: #555;\n  }\n  .tree-link-left {\n    top: 100%;\n    left: 25%;\n    height: 20px;\n    border-left: 2px solid #555;\n    border-bottom: 2px solid #555;\n    width: 25px;\n    transform: rotate(-45deg);\n    transform-origin: top left;\n  }\n  .tree-link-right {\n    top: 100%;\n    left: 75%;\n    height: 20px;\n    border-left: 2px solid #555;\n    border-bottom: 2px solid #555;\n    width: 25px;\n    transform: rotate(45deg);\n    transform-origin: top right;\n  }\n  .code-bit {\n    font-size: 14px;\n    color: #444;\n    margin-left: 3px;\n    font-style: italic;\n  }\n</style>\n</head>\n<body>\n\n<h1>Huffman Coding Demonstration</h1>\n\n<p>Enter text below to see Huffman coding applied to it. The output shows frequencies, Huffman codes for each character, the encoded bitstring, and a visualization of the Huffman tree.</p>\n\n<textarea id=\"inputText\" placeholder=\"Type or paste text here...\">this is an example for huffman encoding</textarea>\n<br />\n<button id=\"processBtn\">Generate Huffman Codes</button>\n\n<div id=\"output\"></div>\n\n<script>\n(() => {\n  // Priority queue implementation for Huffman tree building\n  class PriorityQueue {\n    constructor() {\n      this.nodes = [];\n    }\n    enqueue(node) {\n      this.nodes.push(node);\n      this.nodes.sort((a, b) => a.freq - b.freq);\n    }\n    dequeue() {\n      return this.nodes.shift();\n    }\n    size() {\n      return this.nodes.length;\n    }\n  }\n\n  // Node class for Huffman tree\n  class Node {\n    constructor(char, freq, left = null, right = null) {\n      this.char = char;\n      this.freq = freq;\n      this.left = left;\n      this.right = right;\n    }\n  }\n\n  // Build Huffman Tree given frequencies map {char: freq}\n  function buildHuffmanTree(freqMap) {\n    const pq = new PriorityQueue();\n    for (const [char, freq] of Object.entries(freqMap)) {\n      pq.enqueue(new Node(char, freq));\n    }\n    while (pq.size() > 1) {\n      const left = pq.dequeue();\n      const right = pq.dequeue();\n      const merged = new Node(null, left.freq + right.freq, left, right);\n      pq.enqueue(merged);\n    }\n    return pq.dequeue();\n  }\n\n  // Generate codes from Huffman tree recursively\n  function generateCodes(node, prefix = '', codes = {}) {\n    if (!node.left && !node.right) {\n      // Leaf node: assign code\n      codes[node.char] = prefix || '0'; // Assign '0' if tree has single node\n    } else {\n      if (node.left) generateCodes(node.left, prefix + '0', codes);\n      if (node.right) generateCodes(node.right, prefix + '1', codes);\n    }\n    return codes;\n  }\n\n  // Encode input text using codes map {char: code}\n  function encodeText(text, codes) {\n    let encoded = '';\n    for (const ch of text) {\n      encoded += codes[ch];\n    }\n    return encoded;\n  }\n\n  // Calculate frequencies of characters in text\n  function frequencyMap(text) {\n    const freq = {};\n    for (const ch of text) {\n      freq[ch] = (freq[ch] || 0) + 1;\n    }\n    return freq;\n  }\n\n  // Create frequency table HTML\n  function createFrequencyTable(freqMap) {\n    const entries = Object.entries(freqMap).sort((a,b) => b[1] - a[1]);\n    let table = '<table><thead><tr><th>Character</th><th>Frequency</th></tr></thead><tbody>';\n    for (const [char, f] of entries) {\n      const dispChar = char === ' ' ? '[space]' : char === '\\n' ? '[newline]' : char;\n      table += `<tr><td>${escapeHTML(dispChar)}</td><td>${f}</td></tr>`;\n    }\n    table += '</tbody></table>';\n    return table;\n  }\n\n  // Create codes table HTML\n  function createCodesTable(codes, freqMap) {\n    let entries = Object.entries(codes).map(([ch, code]) => ({\n      ch,\n      code,\n      freq: freqMap[ch]\n    }));\n    entries.sort((a, b) => b.freq - a.freq);\n    let table = '<table><thead><tr><th>Character</th><th>Code</th><th>Frequency</th></tr></thead><tbody>';\n    for (const { ch, code, freq } of entries) {\n      const dispChar = ch === ' ' ? '[space]' : ch === '\\n' ? '[newline]' : ch;\n      table += `<tr><td>${escapeHTML(dispChar)}</td><td>${code}</td><td>${freq}</td></tr>`;\n    }\n    table += '</tbody></table>';\n    return table;\n  }\n\n  // Escape HTML entities\n  function escapeHTML(text) {\n    return text.replace(/[&<>\"']/g, (m) => {\n      switch(m) {\n        case '&': return '&amp;';\n        case '<': return '&lt;';\n        case '>': return '&gt;';\n        case '\"': return '&quot;';\n        case \"'\": return '&#39;';\n        default: return m;\n      }\n    });\n  }\n\n  // Render Huffman tree as nested divs and lines\n  function renderHuffmanTree(node) {\n    if (!node) return null;\n\n    if (!node.left && !node.right) {\n      // Leaf node: display character and freq\n      const dispChar = node.char === ' ' ? '[space]' : node.char === '\\n' ? '[newline]' : node.char;\n      return `\n      <div class=\"tree-node\" title=\"Char: ${escapeHTML(dispChar)}&#10;Frequency: ${node.freq}\">\n        ${escapeHTML(dispChar)}<br><span style=\"font-weight:normal;\">(${node.freq})</span>\n      </div>\n      `;\n    } else {\n      // Internal node: frequency, children below, with connecting lines showing 0/1\n      const leftHTML = renderHuffmanTree(node.left);\n      const rightHTML = renderHuffmanTree(node.right);\n      return `\n      <div style=\"display:inline-block; vertical-align: top; text-align:center; margin:0 10px;\">\n        <div class=\"tree-node\" title=\"Frequency: ${node.freq}\">\n          <span style=\"font-weight:normal;\">Freq</span><br>${node.freq}\n        </div>\n        <div class=\"tree-children\">\n          <div style=\"position:relative; margin-right:10px;\">\n            ${leftHTML}\n            <div style=\"position:absolute; bottom:-20px; left:50%; transform: translateX(-50%); font-size: 12px; color:#555;\">\n              0\n            </div>\n          </div>\n          <div style=\"position:relative; margin-left:10px;\">\n            ${rightHTML}\n            <div style=\"position:absolute; bottom:-20px; left:50%; transform: translateX(-50%); font-size: 12px; color:#555;\">\n              1\n            </div>\n          </div>\n        </div>\n      </div>\n      `;\n    }\n  }\n\n  // Main processing function\n  function processInput() {\n    const text = document.getElementById('inputText').value;\n    if (!text) {\n      alert('Please enter some text to encode.');\n      return;\n    }\n\n    const freqMap = frequencyMap(text);\n    const hTree = buildHuffmanTree(freqMap);\n    const codes = generateCodes(hTree);\n\n    const encodedStr = encodeText(text, codes);\n    const numBitsOriginal = text.length * 8; // 8 bits per char (ASCII/UTF-8)\n    const numBitsEncoded = encodedStr.length;\n    const compressionRatio = (numBitsEncoded / numBitsOriginal).toFixed(3);\n\n    const outputElm = document.getElementById('output');\n    let html = '';\n\n    html += '<h2>Character Frequencies</h2>';\n    html += createFrequencyTable(freqMap);\n\n    html += '<h2>Huffman Codes</h2>';\n    html += createCodesTable(codes, freqMap);\n\n    html += `<h2>Encoding Result</h2>\n      <p><b>Original size:</b> ${text.length} characters &times; 8 bits = ${numBitsOriginal} bits</p>\n      <p><b>Encoded size:</b> ${numBitsEncoded} bits</p>\n      <p><b>Compression ratio:</b> ${compressionRatio} (encoded/original)</p>\n      <p><b>Encoded bitstring:</b> <code>${escapeHTML(encodedStr)}</code></p>`;\n\n    html += '<h2>Huffman Tree Visualization</h2>';\n    html += `<div class=\"tree-container\">${renderHuffmanTree(hTree)}</div>`;\n\n    outputElm.innerHTML = html;\n  }\n\n  document.getElementById('processBtn').addEventListener('click', processInput);\n\n  // Run once on load for default sample text\n  window.addEventListener('load', processInput);\n})();\n</script>\n\n</body>\n</html>"
