    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>K-Nearest Neighbors (KNN) Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 1em;\n    background: #f9f9f9;\n  }\n  h1 {\n    text-align: center;\n  }\n  #container {\n    display: flex;\n    justify-content: center;\n    flex-wrap: wrap;\n    gap: 2em;\n  }\n  #canvas-container {\n    position: relative;\n  }\n  canvas {\n    border: 1px solid #ccc;\n    background: white;\n    cursor: crosshair;\n  }\n  #controls {\n    max-width: 400px;\n  }\n  label {\n    display: block;\n    margin-top: 1em;\n  }\n  input[type=range] {\n    width: 100%;\n  }\n  #info {\n    margin-top: 1em;\n    line-height: 1.5;\n  }\n  #legend {\n    margin-top: 1em;\n  }\n  .dot {\n    display: inline-block;\n    width: 13px;\n    height: 13px;\n    border-radius: 50%;\n    margin-right: 5px;\n    vertical-align: middle;\n  }\n  .classA {\n    background: #1f77b4;\n    box-shadow: 0 0 5px #1f77b4;\n  }\n  .classB {\n    background: #ff7f0e;\n    box-shadow: 0 0 5px #ff7f0e;\n  }\n  .unknownPoint {\n    background: black;\n    box-shadow: 0 0 7px black;\n  }\n  #clear-btn {\n    margin-top: 1em;\n    padding: 0.4em 1em;\n    font-size: 1rem;\n    cursor: pointer;\n  }\n  footer {\n    text-align: center;\n    margin-top: 2em;\n    color: #555;\n    font-size: 0.9rem;\n  }\n</style>\n</head>\n<body>\n<h1>K-Nearest Neighbors (KNN) Interactive Demo</h1>\n<div id=\"container\">\n  <div id=\"canvas-container\">\n    <canvas id=\"knnCanvas\" width=\"500\" height=\"500\" title=\"Click to add points: first two classes, then unknown\"></canvas>\n    <div id=\"legend\">\n      <span class=\"dot classA\"></span> Class A points<br />\n      <span class=\"dot classB\"></span> Class B points<br />\n      <span class=\"dot unknownPoint\"></span> Unknown points (to classify)\n    </div>\n  </div>\n  <div id=\"controls\">\n    <label for=\"kRange\">Number of Neighbors (k): <span id=\"kValue\">3</span></label>\n    <input type=\"range\" id=\"kRange\" min=\"1\" max=\"15\" step=\"2\" value=\"3\" />\n    <p><strong>Instructions:</strong></p>\n    <ol>\n      <li>Click on canvas to add blue Class A points (left mouse button).</li>\n      <li>Right-click to add orange Class B points.</li>\n      <li>Shift + click to add \"unknown\" points to classify.</li>\n      <li>The KNN algorithm will color unknown points based on their nearest neighbors.</li>\n      <li>Adjust <em>k</em> to see classification change.</li>\n      <li>Press \"Clear\" to reset.</li>\n    </ol>\n\n    <button id=\"clear-btn\">Clear All Points</button>\n\n    <div id=\"info\"></div>\n  </div>\n</div>\n\n<script>\n(() => {\n  const canvas = document.getElementById('knnCanvas');\n  const ctx = canvas.getContext('2d');\n  const kRange = document.getElementById('kRange');\n  const kValueLabel = document.getElementById('kValue');\n  const clearBtn = document.getElementById('clear-btn');\n  const infoDiv = document.getElementById('info');\n\n  // Data points arrays\n  let classAPoints = [];\n  let classBPoints = [];\n  let unknownPoints = [];\n\n  // Colors\n  const classAColor = '#1f77b4'; // blue\n  const classBColor = '#ff7f0e'; // orange\n  const unknownColor = 'black';\n  const radius = 7;\n\n  // Track last used class for convenience (optional)\n  // We'll use mouse buttons and shift key to distinguish:\n  // Left click: Class A\n  // Right click: Class B\n  // Shift + click: unknown point\n\n  // Utility: distance between two points\n  function dist(p1, p2) {\n    const dx = p1.x - p2.x;\n    const dy = p1.y - p2.y;\n    return Math.sqrt(dx * dx + dy * dy);\n  }\n\n  // Returns array of nearest neighbors for unknown point with k given, among classA + classB points\n  function getNeighbors(point, k) {\n    const allLabeledPoints = [];\n    classAPoints.forEach(p => allLabeledPoints.push({ x: p.x, y: p.y, label: 'A' }));\n    classBPoints.forEach(p => allLabeledPoints.push({ x: p.x, y: p.y, label: 'B' }));\n\n    // Calculate distances\n    const distances = allLabeledPoints.map(p => ({\n      label: p.label,\n      distance: dist(point, p),\n    }));\n    // Sort ascending by distance\n    distances.sort((a, b) => a.distance - b.distance);\n    // Return top k\n    return distances.slice(0, k);\n  }\n\n  // Classify one unknown point based on neighbors' majority vote\n  function classify(point, k) {\n    const neighbors = getNeighbors(point, k);\n    const votes = { A: 0, B: 0 };\n    neighbors.forEach(n => {\n      votes[n.label]++;\n    });\n    if(votes.A > votes.B) return 'A';\n    if(votes.B > votes.A) return 'B';\n\n    // Tie breaker: choose class of closest neighbor\n    return neighbors[0].label;\n  }\n\n  // Draw a point\n  function drawPoint(point, type, highlight = false) {\n    ctx.beginPath();\n    ctx.arc(point.x, point.y, radius, 0, 2 * Math.PI);\n\n    if (type === 'A') {\n      ctx.fillStyle = classAColor;\n      ctx.shadowColor = highlight ? \"#68a0ff\" : classAColor;\n      ctx.shadowBlur = highlight ? 15 : 5;\n    } else if (type === 'B') {\n      ctx.fillStyle = classBColor;\n      ctx.shadowColor = highlight ? \"#ffb060\" : classBColor;\n      ctx.shadowBlur = highlight ? 15 : 5;\n    } else if (type === 'unknown') {\n      ctx.fillStyle = unknownColor;\n      ctx.shadowColor = highlight ? \"#666\" : \"black\";\n      ctx.shadowBlur = highlight ? 15 : 7;\n    }\n    ctx.fill();\n    ctx.shadowBlur = 0;\n    ctx.strokeStyle = highlight ? '#444' : 'transparent';\n    ctx.lineWidth = highlight ? 2 : 0;\n    ctx.stroke();\n  }\n\n  // Draw lines from unknown point to neighbors\n  function drawLines(point, neighbors) {\n    neighbors.forEach(n => {\n      ctx.beginPath();\n      ctx.moveTo(point.x, point.y);\n      // Find actual neighbor point coords:\n      let neighborPoints = n.label === 'A' ? classAPoints : classBPoints;\n      // Closest point among those at the neighbor's distance (usually just one)\n      let dMin = Infinity;\n      let closestP = null;\n      for (const p of neighborPoints) {\n        const d = dist({x: p.x, y: p.y}, point);\n        if (Math.abs(d - n.distance) < 1e-5 && d < dMin) {\n          dMin = d;\n          closestP = p;\n        }\n      }\n      if(closestP) {\n        ctx.strokeStyle = n.label === 'A' ? classAColor : classBColor;\n        ctx.lineWidth = 1.5;\n        ctx.setLineDash([6, 6]);\n        ctx.moveTo(point.x, point.y);\n        ctx.lineTo(closestP.x, closestP.y);\n        ctx.stroke();\n        ctx.setLineDash([]);\n      }\n    });\n  }\n\n  // Redraw entire canvas\n  function redraw() {\n    ctx.clearRect(0, 0, canvas.width, canvas.height);\n    // Draw class A points\n    for (const p of classAPoints) {\n      drawPoint(p, 'A');\n    }\n    // Draw class B points\n    for (const p of classBPoints) {\n      drawPoint(p, 'B');\n    }\n    // Draw unknown points with classified color fill\n    const k = parseInt(kRange.value);\n    unknownPoints.forEach(p => {\n      // Classification\n      const predicted = classify(p, k);\n      drawPoint(p, 'unknown');\n      // Overlay with color of predicted class as smaller circle inside\n      ctx.beginPath();\n      ctx.arc(p.x, p.y, radius / 2, 0, 2 * Math.PI);\n      ctx.fillStyle = (predicted === 'A') ? classAColor : classBColor;\n      ctx.fill();\n\n      // Draw neighbor lines on hover is handled separately\n    });\n  }\n\n  // Store hovered unknown point index for highlight\n  let hoveredUnknownIndex = -1;\n\n  // Show neighbors for hovered unknown point\n  function drawHover() {\n    if (hoveredUnknownIndex < 0 || hoveredUnknownIndex >= unknownPoints.length) return;\n    const p = unknownPoints[hoveredUnknownIndex];\n    const k = parseInt(kRange.value);\n    const neighbors = getNeighbors(p, k);\n\n    // Highlight hovered unknown point\n    drawPoint(p, 'unknown', true);\n\n    // Highlight neighbors\n    neighbors.forEach(n => {\n      // Find neighbor points with exact distance match\n      let arr = n.label === 'A' ? classAPoints : classBPoints;\n      for (const pt of arr) {\n        if (Math.abs(dist(pt, p) - n.distance) < 1e-3) {\n          drawPoint(pt, n.label, true);\n          break; // highlight one per neighbor\n        }\n      }\n    });\n\n    // Draw dashed lines to neighbors\n    drawLines(p, neighbors);\n\n    // Show classification info\n    const votes = { A: 0, B: 0 };\n    neighbors.forEach(n => { votes[n.label]++; });\n    const predicted = classify(p, k);\n    infoDiv.innerHTML = `\n      <strong>Hovered Unknown Point</strong>: (${p.x.toFixed(0)}, ${p.y.toFixed(0)})<br/>\n      Neighbors (k = ${k}):<br/>\n      &nbsp;&nbsp;Class A: ${votes.A}<br/>\n      &nbsp;&nbsp;Class B: ${votes.B}<br/>\n      <strong>Predicted class: <span style=\"color:${predicted==='A'?classAColor:classBColor}\">${predicted}</span></strong>\n    `;\n  }\n\n  // Reset hover info\n  function clearHoverInfo() {\n    infoDiv.innerHTML = '';\n  }\n\n  // Handle mouse events to add points\n  canvas.addEventListener('mousedown', (e) => {\n    e.preventDefault();\n    const rect = canvas.getBoundingClientRect();\n    const x = e.clientX - rect.left;\n    const y = e.clientY - rect.top;\n\n    // Left click (e.button == 0) - Class A points\n    // Right click (e.button == 2) - Class B points\n    // Shift + click - unknown points\n    if (e.shiftKey) {\n      // Add unknown point\n      unknownPoints.push({x,y});\n    } else if (e.button === 0) {\n      classAPoints.push({x,y});\n    } else if (e.button === 2) {\n      classBPoints.push({x,y});\n    }\n    redraw();\n  });\n\n  // Prevent context menu on right-click inside canvas\n  canvas.addEventListener('contextmenu', (e) => e.preventDefault());\n\n  // Handle mouse move to detect hover on unknown points\n  canvas.addEventListener('mousemove', (e) => {\n    const rect = canvas.getBoundingClientRect();\n    const mx = e.clientX - rect.left;\n    const my = e.clientY - rect.top;\n    // Detect if hovering near an unknown point\n    let foundIdx = -1;\n    for (let i = 0; i < unknownPoints.length; i++) {\n      const p = unknownPoints[i];\n      if (dist(p, {x: mx, y: my}) <= radius) {\n        foundIdx = i;\n        break;\n      }\n    }\n    if (foundIdx !== hoveredUnknownIndex) {\n      hoveredUnknownIndex = foundIdx;\n      redraw();\n      if (hoveredUnknownIndex >= 0) {\n        drawHover();\n      } else {\n        clearHoverInfo();\n      }\n    }\n  });\n\n  // Clear hover info on mouse out\n  canvas.addEventListener('mouseleave', () => {\n    hoveredUnknownIndex = -1;\n    redraw();\n    clearHoverInfo();\n  });\n\n  // Handle k change\n  kRange.addEventListener('input', () => {\n    let k = parseInt(kRange.value);\n    // Always keep k odd to avoid ties easily\n    if (k % 2 === 0) {\n      k += 1;\n      if(k > parseInt(kRange.max)) k -= 2; // Clamp in max range\n      kRange.value = k;\n    }\n    kValueLabel.textContent = k;\n    redraw();\n    // If a point is hovered, redraw hover info with new k\n    if (hoveredUnknownIndex >= 0) {\n      drawHover();\n    }\n  });\n\n  // Clear all points\n  clearBtn.addEventListener('click', () => {\n    classAPoints = [];\n    classBPoints = [];\n    unknownPoints = [];\n    hoveredUnknownIndex = -1;\n    redraw();\n    clearHoverInfo();\n  });\n\n  // Initial draw\n  redraw();\n\n  // Add some initial example points for user convenience\n  function addExamplePoints() {\n    classAPoints = [\n      {x: 80, y: 100},\n      {x: 120, y: 130},\n      {x: 140, y: 90},\n      {x: 180, y: 120},\n      {x: 70, y: 180}\n    ];\n    classBPoints = [\n      {x: 350, y: 360},\n      {x: 380, y: 400},\n      {x: 420, y: 380},\n      {x: 400, y: 330},\n      {x: 450, y: 400}\n    ];\n    unknownPoints = [\n      {x: 220, y: 200},\n      {x: 300, y: 300},\n      {x: 160, y: 350},\n      {x: 280, y: 150}\n    ];\n    redraw();\n  }\n  addExamplePoints();\n})();\n</script>\n</body>\n</html>"
  },
