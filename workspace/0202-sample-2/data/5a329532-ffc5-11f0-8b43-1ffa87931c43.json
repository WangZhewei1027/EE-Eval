    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Heap (Min & Max) Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #f9f9f9;\n  }\n  h1 {\n    text-align: center;\n  }\n  .container {\n    max-width: 900px;\n    margin: 0 auto;\n  }\n  .controls {\n    display: flex;\n    gap: 10px;\n    margin-bottom: 15px;\n    flex-wrap: wrap;\n    justify-content: center;\n  }\n  input[type=number] {\n    width: 80px;\n    padding: 5px;\n    font-size: 1em;\n    text-align: center;\n  }\n  button {\n    padding: 7px 14px;\n    font-size: 1em;\n    cursor: pointer;\n    border: 1.5px solid #333;\n    border-radius: 4px;\n    background: white;\n    transition: background-color 0.2s;\n  }\n  button:hover:not(:disabled) {\n    background-color: #e0e0e0;\n  }\n  button:disabled {\n    opacity: 0.5;\n    cursor: not-allowed;\n  }\n  .heap-type {\n    margin-bottom: 10px;\n    text-align: center;\n  }\n  .heap-visual, .log-area {\n    background: white;\n    padding: 15px;\n    border: 1.5px solid #ccc;\n    border-radius: 8px;\n    min-height: 100px;\n    box-shadow: 2px 2px 6px #ddd;\n  }\n  .heap-array {\n    display: flex;\n    justify-content: center;\n    gap: 10px;\n    flex-wrap: wrap;\n    margin-top: 10px;\n  }\n  .heap-node {\n    width: 40px;\n    height: 40px;\n    background: #3a86ff;\n    color: white;\n    border-radius: 4px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    font-weight: bold;\n    box-shadow: 0 2px 5px rgba(0,0,0,0.15);\n    user-select: none;\n  }\n  .heap-node.highlight {\n    background: #ffbe0b;\n    color: #333;\n    box-shadow: 0 0 12px 4px #ffbe0b;\n  }\n  .heap-tree {\n    margin-top: 25px;\n    display: flex;\n    justify-content: center;\n  }\n  svg {\n    overflow: visible;\n  }\n  .log-area {\n    margin-top: 15px;\n    max-height: 180px;\n    overflow-y: auto;\n    font-family: monospace;\n    font-size: 0.9em;\n    white-space: pre-wrap;\n  }\n  @media (max-width: 600px) {\n    .controls {\n      flex-direction: column;\n      align-items: center;\n    }\n    .heap-array {\n      font-size: 0.85em;\n    }\n  }\n</style>\n</head>\n<body>\n<div class=\"container\">\n  <h1>Heap Visualization - Min Heap & Max Heap</h1>\n  <div class=\"heap-type\">\n    <label><input type=\"radio\" name=\"heapType\" value=\"min\" checked /> Min Heap</label>\n    <label><input type=\"radio\" name=\"heapType\" value=\"max\" /> Max Heap</label>\n  </div>\n  <div class=\"controls\">\n    <input type=\"number\" id=\"inputValue\" placeholder=\"Value\" />\n    <button id=\"insertBtn\">Insert</button>\n    <button id=\"extractBtn\">Extract Root</button>\n    <button id=\"clearBtn\">Clear</button>\n  </div>\n  <div>\n    <strong>Heap Array Representation:</strong>\n    <div class=\"heap-array\" id=\"heapArray\"></div>\n  </div>\n  <div>\n    <strong>Heap Tree Visualization:</strong>\n    <div class=\"heap-tree\" id=\"heapTree\"></div>\n  </div>\n  <div>\n    <strong>Operations Log:</strong>\n    <div class=\"log-area\" id=\"logArea\"></div>\n  </div>\n</div>\n\n<script>\n(() => {\n  const logArea = document.getElementById(\"logArea\");\n  const heapArrayDiv = document.getElementById(\"heapArray\");\n  const heapTreeDiv = document.getElementById(\"heapTree\");\n  const inputValue = document.getElementById(\"inputValue\");\n  const insertBtn = document.getElementById(\"insertBtn\");\n  const extractBtn = document.getElementById(\"extractBtn\");\n  const clearBtn = document.getElementById(\"clearBtn\");\n  const heapTypeRadios = document.getElementsByName(\"heapType\");\n\n  function log(message) {\n    logArea.textContent += message + \"\\n\";\n    logArea.scrollTop = logArea.scrollHeight;\n  }\n\n  class Heap {\n    constructor(type = \"min\") {\n      this.type = type; // \"min\" or \"max\"\n      this.data = [];\n    }\n\n    compare(i, j) {\n      if (this.type === \"min\") return this.data[i] < this.data[j];\n      else return this.data[i] > this.data[j];\n    }\n\n    swap(i, j) {\n      [this.data[i], this.data[j]] = [this.data[j], this.data[i]];\n      log(`Swapped indices ${i} and ${j}: [${this.data.join(\", \")}]`);\n    }\n\n    insert(value) {\n      log(`Inserting value: ${value}`);\n      this.data.push(value);\n      this.heapifyUp(this.data.length - 1);\n    }\n\n    heapifyUp(index) {\n      let current = index;\n      while (current > 0) {\n        let parent = Math.floor((current - 1) / 2);\n        if (this.compare(current, parent)) {\n          this.swap(current, parent);\n          current = parent;\n        } else break;\n      }\n    }\n\n    extractRoot() {\n      if (this.data.length === 0) {\n        log(\"Heap is empty, cannot extract root.\");\n        return null;\n      }\n      const rootVal = this.data[0];\n      log(`Extracting root: ${rootVal}`);\n      if (this.data.length === 1) {\n        this.data.pop();\n        return rootVal;\n      }\n      this.data[0] = this.data.pop();\n      log(`Moved last element to root: ${this.data[0]}`);\n      this.heapifyDown(0);\n      return rootVal;\n    }\n\n    heapifyDown(index) {\n      let current = index;\n      const length = this.data.length;\n      while (true) {\n        let left = 2 * current + 1;\n        let right = 2 * current + 2;\n        let swapIndex = current;\n\n        if (left < length && this.compare(left, swapIndex)) {\n          swapIndex = left;\n        }\n        if (right < length && this.compare(right, swapIndex)) {\n          swapIndex = right;\n        }\n        if (swapIndex !== current) {\n          this.swap(current, swapIndex);\n          current = swapIndex;\n        } else break;\n      }\n    }\n\n    clear() {\n      this.data = [];\n      log(\"Heap cleared.\");\n    }\n  }\n\n  // Visualization code for the tree\n  function createSvgElement(tag, attrs = {}) {\n    const elem = document.createElementNS(\"http://www.w3.org/2000/svg\", tag);\n    for (const attr in attrs) {\n      elem.setAttribute(attr, attrs[attr]);\n    }\n    return elem;\n  }\n\n  function renderHeapTree(heap) {\n    heapTreeDiv.innerHTML = \"\";\n    if (heap.data.length === 0) {\n      heapTreeDiv.textContent = \"Heap is empty.\";\n      return;\n    }\n\n    // Prepare svg\n    const width = 800;\n    const height = 300;\n    const svg = createSvgElement(\"svg\", { width, height });\n\n    // Calculate node positions by levels in a binary tree fashion\n    const positions = [];\n    const levels = Math.floor(Math.log2(heap.data.length)) + 1;\n    const levelHeight = height / (levels + 1);\n\n    // We calculate horizontal positions per level\n    for (let i = 0; i < heap.data.length; i++) {\n      const level = Math.floor(Math.log2(i + 1));\n      const levelIndex = i - (Math.pow(2, level) - 1);\n      const nodesInLevel = Math.pow(2, level);\n      const horizontalSpace = width / (nodesInLevel + 1);\n      const x = (levelIndex + 1) * horizontalSpace;\n      const y = (level + 1) * levelHeight;\n      positions.push({ x, y });\n    }\n\n    // Draw edges first (lines from parent to children)\n    for (let i = 0; i < heap.data.length; i++) {\n      const leftChildIndex = 2 * i + 1;\n      const rightChildIndex = 2 * i + 2;\n      if (leftChildIndex < heap.data.length) {\n        const line = createSvgElement(\"line\", {\n          x1: positions[i].x,\n          y1: positions[i].y,\n          x2: positions[leftChildIndex].x,\n          y2: positions[leftChildIndex].y,\n          stroke: \"#777\",\n          \"stroke-width\": \"2\"\n        });\n        svg.appendChild(line);\n      }\n      if (rightChildIndex < heap.data.length) {\n        const line = createSvgElement(\"line\", {\n          x1: positions[i].x,\n          y1: positions[i].y,\n          x2: positions[rightChildIndex].x,\n          y2: positions[rightChildIndex].y,\n          stroke: \"#777\",\n          \"stroke-width\": \"2\"\n        });\n        svg.appendChild(line);\n      }\n    }\n\n    // Draw nodes (circles with text)\n    for (let i = 0; i < heap.data.length; i++) {\n      const group = createSvgElement(\"g\", { cursor: \"default\" });\n\n      const circle = createSvgElement(\"circle\", {\n        cx: positions[i].x,\n        cy: positions[i].y,\n        r: 20,\n        fill: i === 0 ? \"#ffbe0b\" : \"#3a86ff\",\n        stroke: \"#333\",\n        \"stroke-width\": 1.5,\n        filter: \"drop-shadow(1px 1px 1px rgba(0,0,0,0.2))\"\n      });\n\n      const text = createSvgElement(\"text\", {\n        x: positions[i].x,\n        y: positions[i].y + 6,\n        \"text-anchor\": \"middle\",\n        \"font-size\": \"16\",\n        fill: i === 0 ? \"#333\" : \"#fff\",\n        \"font-weight\": \"bold\",\n        \"pointer-events\": \"none\",\n        \"user-select\": \"none\"\n      });\n      text.textContent = heap.data[i];\n\n      group.appendChild(circle);\n      group.appendChild(text);\n\n      svg.appendChild(group);\n    }\n\n    heapTreeDiv.appendChild(svg);\n  }\n\n  function renderHeapArray(heap) {\n    heapArrayDiv.innerHTML = \"\";\n    if (heap.data.length === 0) {\n      heapArrayDiv.textContent = \"Heap is empty.\";\n      return;\n    }\n    heap.data.forEach((value, i) => {\n      const node = document.createElement(\"div\");\n      node.className = \"heap-node\";\n      if (i === 0) node.classList.add(\"highlight\");\n      node.title = `Index ${i}`;\n      node.textContent = value;\n      heapArrayDiv.appendChild(node);\n    });\n  }\n\n  // Initialize heap\n  let heap = new Heap(\"min\");\n\n  // Update heap when type changes\n  function onHeapTypeChange() {\n    const selected = [...heapTypeRadios].find(r => r.checked).value;\n    const oldData = [...heap.data];\n    heap = new Heap(selected);\n    log(`\\nSwitched to ${selected === \"min\" ? \"Min Heap\" : \"Max Heap\"}. Rebuilding heap...`);\n    oldData.forEach(val => heap.insert(val));\n    renderHeapArray(heap);\n    renderHeapTree(heap);\n  }\n\n  // Insert value handler\n  function onInsert() {\n    const val = Number(inputValue.value);\n    if (Number.isNaN(val)) {\n      alert(\"Please enter a valid number.\");\n      return;\n    }\n    heap.insert(val);\n    renderHeapArray(heap);\n    renderHeapTree(heap);\n    inputValue.value = \"\";\n    inputValue.focus();\n  }\n\n  // Extract root handler\n  function onExtract() {\n    const root = heap.extractRoot();\n    if (root !== null) {\n      log(`Extracted root value: ${root}`);\n    }\n    renderHeapArray(heap);\n    renderHeapTree(heap);\n  }\n\n  function onClear() {\n    heap.clear();\n    renderHeapArray(heap);\n    renderHeapTree(heap);\n  }\n\n  insertBtn.addEventListener(\"click\", onInsert);\n  extractBtn.addEventListener(\"click\", onExtract);\n  clearBtn.addEventListener(\"click\", onClear);\n  heapTypeRadios.forEach(radio => radio.addEventListener(\"change\", onHeapTypeChange));\n  // allow enter key to insert\n  inputValue.addEventListener(\"keydown\", e => {\n    if(e.key === \"Enter\") onInsert();\n  });\n\n  // Initial render\n  renderHeapArray(heap);\n  renderHeapTree(heap);\n  log(\"Heap Visualization Initialized.\\nUse the controls above to insert or extract from the heap.\\n\");\n})();\n</script>\n</body>\n</html>"
  },
