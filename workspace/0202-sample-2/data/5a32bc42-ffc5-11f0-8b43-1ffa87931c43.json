    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Adjacency Matrix Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 1rem;\n    background: #f7f9fc;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #graph-input {\n    margin-bottom: 1rem;\n    max-width: 600px;\n  }\n  label {\n    font-weight: bold;\n    display: block;\n    margin-bottom: 0.4rem;\n  }\n  textarea {\n    width: 100%;\n    height: 100px;\n    font-family: monospace;\n    font-size: 1rem;\n    resize: vertical;\n    margin-bottom: 0.5rem;\n  }\n  button {\n    padding: 0.5rem 1rem;\n    font-size: 1rem;\n    cursor: pointer;\n  }\n  #matrix-container {\n    margin-top: 2rem;\n    overflow-x: auto;\n  }\n  table {\n    border-collapse: collapse;\n    margin: 0 auto;\n  }\n  th,\n  td {\n    border: 1px solid #666;\n    padding: 0.4rem 0.6rem;\n    text-align: center;\n    min-width: 30px;\n    font-family: monospace;\n  }\n  th {\n    background: #007bff;\n    color: white;\n    position: sticky;\n    top: 0;\n    z-index: 1;\n  }\n  .header-col {\n    background: #007bff;\n    color: white;\n    position: sticky;\n    left: 0;\n    z-index: 2;\n  }\n  #instructions {\n    max-width: 600px;\n    margin: 0 auto 1rem auto;\n    background: #e3f2fd;\n    border: 1px solid #90caf9;\n    border-radius: 5px;\n    padding: 1rem;\n    font-size: 0.95rem;\n    line-height: 1.4;\n  }\n  #graph-visual {\n    margin-top: 3rem;\n    text-align: center;\n  }\n  #canvas {\n    background: white;\n    border: 1px solid #ccc;\n    margin: 1rem auto;\n    display: block;\n  }\n</style>\n</head>\n<body>\n<h1>Adjacency Matrix</h1>\n<div id=\"instructions\">\n  <p><strong>How to use:</strong></p>\n  <p>Input your graph’s edges in the textarea below, one edge per line, using the format: <code>node1 node2</code>.</p>\n  <p>Nodes can be numbers or strings without spaces. The graph is undirected (edges go both ways).</p>\n  <p>Example input:</p>\n  <pre>\nA B\nA C\nB C\nC D\n  </pre>\n  <p>Click \"Build Matrix\" to see the adjacency matrix and a visualization.</p>\n</div>\n<div id=\"graph-input\">\n  <label for=\"edges\">Enter edges (one per line):</label>\n  <textarea id=\"edges\" placeholder=\"A B&#10;A C&#10;B C&#10;C D\"></textarea>\n  <button id=\"buildBtn\">Build Matrix</button>\n</div>\n<div id=\"matrix-container\"></div>\n<div id=\"graph-visual\">\n  <canvas id=\"canvas\" width=\"500\" height=\"500\"></canvas>\n</div>\n\n<script>\n(() => {\n  const edgesInput = document.getElementById('edges');\n  const buildBtn = document.getElementById('buildBtn');\n  const matrixContainer = document.getElementById('matrix-container');\n  const canvas = document.getElementById('canvas');\n  const ctx = canvas.getContext('2d');\n\n  function parseEdges(text) {\n    const lines = text.trim().split('\\n');\n    const edges = [];\n    for (const line of lines) {\n      const trimmed = line.trim();\n      if (!trimmed) continue;\n      const parts = trimmed.split(/\\s+/);\n      if (parts.length !== 2) {\n        alert('Each line should contain exactly two nodes separated by space.');\n        return null;\n      }\n      edges.push(parts);\n    }\n    return edges;\n  }\n\n  function buildAdjacencyMatrix(nodes, edges) {\n    const size = nodes.length;\n    // Initialize matrix with zeros\n    const matrix = Array(size).fill(null).map(() => Array(size).fill(0));\n    // Build a map for node -> index\n    const indexMap = {};\n    nodes.forEach((n, i) => { indexMap[n] = i; });\n\n    for (const [a, b] of edges) {\n      if (!(a in indexMap) || !(b in indexMap)) continue;\n      const i = indexMap[a];\n      const j = indexMap[b];\n      matrix[i][j] = 1;\n      matrix[j][i] = 1; // undirected graph\n    }\n    return matrix;\n  }\n\n  function renderMatrix(nodes, matrix) {\n    const table = document.createElement('table');\n    // Header row\n    const head = document.createElement('thead');\n    const headRow = document.createElement('tr');\n    const cornerTh = document.createElement('th');\n    cornerTh.textContent = '';\n    headRow.appendChild(cornerTh);\n    for (const node of nodes) {\n      const th = document.createElement('th');\n      th.textContent = node;\n      headRow.appendChild(th);\n    }\n    head.appendChild(headRow);\n    table.appendChild(head);\n\n    // Body rows\n    const body = document.createElement('tbody');\n    for (let i = 0; i < nodes.length; i++) {\n      const tr = document.createElement('tr');\n      const headerCell = document.createElement('th');\n      headerCell.textContent = nodes[i];\n      headerCell.className = 'header-col';\n      tr.appendChild(headerCell);\n      for (let j = 0; j < nodes.length; j++) {\n        const td = document.createElement('td');\n        td.textContent = matrix[i][j];\n        tr.appendChild(td);\n      }\n      body.appendChild(tr);\n    }\n    table.appendChild(body);\n    matrixContainer.innerHTML = '';\n    matrixContainer.appendChild(table);\n  }\n\n  function drawGraph(nodes, edges) {\n    const W = canvas.width;\n    const H = canvas.height;\n    ctx.clearRect(0, 0, W, H);\n\n    if (nodes.length === 0) return;\n\n    // Calculate positions for nodes in a circle\n    const centerX = W / 2;\n    const centerY = H / 2;\n    const radius = Math.min(W, H) / 2 * 0.7;\n    const angles = nodes.map((_, i) => (2 * Math.PI * i) / nodes.length);\n    const positions = angles.map(a => ({\n      x: centerX + radius * Math.cos(a),\n      y: centerY + radius * Math.sin(a),\n    }));\n\n    // Draw edges\n    ctx.strokeStyle = '#888';\n    ctx.lineWidth = 2;\n    for (const [a, b] of edges) {\n      const i = nodes.indexOf(a);\n      const j = nodes.indexOf(b);\n      if (i === -1 || j === -1) continue;\n      const p1 = positions[i];\n      const p2 = positions[j];\n      ctx.beginPath();\n      ctx.moveTo(p1.x, p1.y);\n      ctx.lineTo(p2.x, p2.y);\n      ctx.stroke();\n    }\n\n    // Draw nodes\n    const nodeRadius = 20;\n    ctx.fillStyle = '#007bff';\n    ctx.strokeStyle = '#004085';\n    ctx.lineWidth = 3;\n    ctx.font = 'bold 14px Arial';\n    ctx.textAlign = 'center';\n    ctx.textBaseline = 'middle';\n\n    positions.forEach((pos, i) => {\n      // Circle\n      ctx.beginPath();\n      ctx.fillStyle = '#007bff';\n      ctx.strokeStyle = '#004085';\n      ctx.lineWidth = 3;\n      ctx.arc(pos.x, pos.y, nodeRadius, 0, 2 * Math.PI);\n      ctx.fill();\n      ctx.stroke();\n\n      // Text\n      ctx.fillStyle = 'white';\n      ctx.fillText(nodes[i], pos.x, pos.y);\n    });\n  }\n\n  buildBtn.addEventListener('click', () => {\n    const edges = parseEdges(edgesInput.value);\n    if (!edges) return;\n\n    // Extract unique nodes\n    const nodeSet = new Set();\n    edges.forEach(edge => {\n      nodeSet.add(edge[0]);\n      nodeSet.add(edge[1]);\n    });\n    const nodes = Array.from(nodeSet).sort((a, b) => {\n      // numeric sort if possible or alphabetic\n      if (!isNaN(a) && !isNaN(b)) return Number(a) - Number(b);\n      return a.localeCompare(b);\n    });\n\n    const matrix = buildAdjacencyMatrix(nodes, edges);\n    renderMatrix(nodes, matrix);\n    drawGraph(nodes, edges);\n  });\n\n  // Initialize with example\n  edgesInput.value = `A B\nA C\nB C\nC D`;\n  buildBtn.click();\n})();\n</script>\n</body>\n</html>"
