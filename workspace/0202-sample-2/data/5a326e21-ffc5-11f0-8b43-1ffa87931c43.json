  "answer": {
    "role": "assistant",
    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Hash Map Concept Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f0f4f8;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #hashmap-demo {\n    max-width: 600px;\n    margin: 2rem auto;\n    background: white;\n    padding: 1.5rem;\n    border-radius: 8px;\n    box-shadow: 0 4px 8px rgb(0 0 0 / 0.1);\n  }\n  .section {\n    margin-bottom: 1.5rem;\n  }\n  label, button {\n    font-weight: bold;\n  }\n  input[type=\"text\"] {\n    width: 150px;\n    padding: 0.3rem 0.5rem;\n    margin-right: 1rem;\n    border: 1px solid #bbb;\n    border-radius: 4px;\n  }\n  button {\n    cursor: pointer;\n    background: #007BFF;\n    border: none;\n    color: white;\n    padding: 0.5rem 1rem;\n    border-radius: 4px;\n    transition: background-color 0.2s ease-in-out;\n  }\n  button:hover:not(:disabled) {\n    background: #0056b3;\n  }\n  button:disabled {\n    background: #AAA;\n    cursor: not-allowed;\n  }\n  #output {\n    background: #e7f1ff;\n    border: 1px solid #a3c8ff;\n    padding: 1rem;\n    border-radius: 6px;\n    min-height: 60px;\n    white-space: pre-wrap;\n    font-family: monospace;\n  }\n  table {\n    width: 100%;\n    border-collapse: collapse;\n    margin-top: 1rem;\n  }\n  th, td {\n    border: 1px solid #ccc;\n    padding: 0.4rem 0.7rem;\n    text-align: center;\n  }\n  th {\n    background: #007BFF;\n    color: white;\n  }\n  .key-cell {\n    font-weight: bold;\n    background: #dbe9ff;\n  }\n  .highlight {\n    background: #fff7cc !important;\n  }\n  small {\n    color: #666;\n  }\n</style>\n</head>\n<body>\n<h1>Hash Map Concept Demo</h1>\n\n<div id=\"hashmap-demo\" aria-label=\"Hash map demonstration and interaction\">\n\n  <div class=\"section\">\n    <h2>What is a Hash Map?</h2>\n    <p>\n      A <strong>Hash Map</strong> is a data structure that stores key-value pairs allowing very fast access,\n      insertion, and deletion of values based on keys. Internally, it uses a <em>hash function</em> to compute\n      an index for placing data, enabling nearly <em>constant time complexity</em> on average.\n    </p>\n  </div>\n\n  <div class=\"section\" aria-label=\"Add key-value to hash map\">\n    <h2>Add / Update Key-Value Pair</h2>\n    <label for=\"keyInput\">Key:</label>\n    <input id=\"keyInput\" type=\"text\" placeholder=\"Enter key\" aria-required=\"true\" />\n    <label for=\"valueInput\">Value:</label>\n    <input id=\"valueInput\" type=\"text\" placeholder=\"Enter value\" aria-required=\"true\" />\n    <button id=\"addBtn\">Add / Update</button>\n  </div>\n\n  <div class=\"section\" aria-label=\"Lookup value by key\">\n    <h2>Lookup Value</h2>\n    <label for=\"lookupKeyInput\">Key:</label>\n    <input id=\"lookupKeyInput\" type=\"text\" placeholder=\"Enter key to lookup\" />\n    <button id=\"lookupBtn\">Lookup</button>\n  </div>\n\n  <div class=\"section\" aria-label=\"Delete key from map\">\n    <h2>Delete Key</h2>\n    <label for=\"deleteKeyInput\">Key:</label>\n    <input id=\"deleteKeyInput\" type=\"text\" placeholder=\"Enter key to delete\" />\n    <button id=\"deleteBtn\">Delete</button>\n  </div>\n\n  <div class=\"section\" aria-label=\"Current hash map contents\">\n    <h2>Current Hash Map Contents</h2>\n    <table id=\"hashmapTable\" aria-live=\"polite\" aria-label=\"Table showing current keys and values in hash map\">\n      <thead>\n        <tr>\n          <th>Index (Hash)</th>\n          <th>Key</th>\n          <th>Value</th>\n        </tr>\n      </thead>\n      <tbody>\n        <!-- Filled dynamically -->\n      </tbody>\n    </table>\n  </div>\n\n  <div class=\"section\" aria-label=\"Output messages\">\n    <h2>Output</h2>\n    <div id=\"output\" role=\"region\" aria-live=\"polite\" aria-atomic=\"true\"></div>\n  </div>\n\n  <div class=\"section\">\n    <h2>How This Works (Simplified)</h2>\n    <p>\n      This demo uses a simple hash function that converts a string key into an index between 0 and 9.\n      Each index stores a list of <em>entries</em> (to handle collisions using chaining).\n      When adding or looking up keys, it:\n    </p>\n    <ul>\n      <li>Hashes the key into an index</li>\n      <li>At that index, searches if the key exists</li>\n      <li>Adds updates or retrieves the value as necessary</li>\n    </ul>\n    <p><small>(See the source code below to explore the implementation)</small></p>\n  </div>\n</div>\n\n<script>\n  // Simple hash map class with fixed buckets and chaining for collision resolution\n  class SimpleHashMap {\n    constructor(size = 10) {\n      this.size = size;\n      // Each bucket is an array of {key, value} pairs\n      this.buckets = Array.from({ length: size }, () => []);\n    }\n\n    // Basic hash function: sum char codes mod size\n    hash(key) {\n      let hashSum = 0;\n      for (let i = 0; i < key.length; i++) {\n        hashSum += key.charCodeAt(i);\n      }\n      return hashSum % this.size;\n    }\n\n    set(key, value) {\n      const index = this.hash(key);\n      const bucket = this.buckets[index];\n      const foundIndex = bucket.findIndex(entry => entry.key === key);\n      if (foundIndex !== -1) {\n        bucket[foundIndex].value = value; // update\n        return false; // indicates update\n      } else {\n        bucket.push({ key, value }); // insert\n        return true; // indicates new insertion\n      }\n    }\n\n    get(key) {\n      const index = this.hash(key);\n      const bucket = this.buckets[index];\n      const entry = bucket.find(el => el.key === key);\n      return entry ? entry.value : undefined;\n    }\n\n    delete(key) {\n      const index = this.hash(key);\n      const bucket = this.buckets[index];\n      const foundIndex = bucket.findIndex(entry => entry.key === key);\n      if (foundIndex !== -1) {\n        bucket.splice(foundIndex, 1);\n        return true; // deleted\n      }\n      return false; // nothing to delete\n    }\n\n    entries() {\n      // Return array of [index, key, value] for all items\n      const all = [];\n      this.buckets.forEach((bucket, index) => {\n        bucket.forEach(entry => {\n          all.push([index, entry.key, entry.value]);\n        });\n      });\n      return all;\n    }\n  }\n\n  // Instantiate hashmap\n  const hashMap = new SimpleHashMap(10);\n\n  // UI Elements\n  const keyInput = document.getElementById('keyInput');\n  const valueInput = document.getElementById('valueInput');\n  const addBtn = document.getElementById('addBtn');\n\n  const lookupKeyInput = document.getElementById('lookupKeyInput');\n  const lookupBtn = document.getElementById('lookupBtn');\n\n  const deleteKeyInput = document.getElementById('deleteKeyInput');\n  const deleteBtn = document.getElementById('deleteBtn');\n\n  const output = document.getElementById('output');\n  const tableBody = document.querySelector('#hashmapTable tbody');\n\n  // Update table function\n  function updateTable(highlightIndex = null, highlightKey = null) {\n    tableBody.innerHTML = '';\n    const items = hashMap.entries();\n    if (items.length === 0) {\n      const row = document.createElement('tr');\n      const noDataCell = document.createElement('td');\n      noDataCell.colSpan = 3;\n      noDataCell.textContent = 'Hash map is empty.';\n      noDataCell.style.fontStyle = 'italic';\n      row.appendChild(noDataCell);\n      tableBody.appendChild(row);\n      return;\n    }\n    for (const [index, key, value] of items) {\n      const row = document.createElement('tr');\n      if (highlightIndex === index && highlightKey === key) {\n        row.classList.add('highlight');\n      }\n      const cellIndex = document.createElement('td');\n      cellIndex.textContent = index;\n      const cellKey = document.createElement('td');\n      cellKey.textContent = key;\n      cellKey.classList.add('key-cell');\n      const cellValue = document.createElement('td');\n      cellValue.textContent = value;\n      row.appendChild(cellIndex);\n      row.appendChild(cellKey);\n      row.appendChild(cellValue);\n      tableBody.appendChild(row);\n    }\n  }\n\n  // Show output message\n  function showMessage(msg) {\n    output.textContent = msg;\n  }\n\n  // Add / update handler\n  addBtn.addEventListener('click', () => {\n    const key = keyInput.value.trim();\n    const value = valueInput.value.trim();\n    if (!key) {\n      showMessage('Error: Key cannot be empty.');\n      keyInput.focus();\n      return;\n    }\n    if (!value) {\n      showMessage('Error: Value cannot be empty.');\n      valueInput.focus();\n      return;\n    }\n    const isNew = hashMap.set(key, value);\n    showMessage(isNew\n      ? `Added new key \"${key}\" with value \"${value}\".`\n      : `Updated key \"${key}\" to new value \"${value}\".`);\n    updateTable(hashMap.hash(key), key);\n    // Clear inputs for convenience\n    // keyInput.value = '';\n    valueInput.value = '';\n    valueInput.focus();\n  });\n\n  // Lookup handler\n  lookupBtn.addEventListener('click', () => {\n    const key = lookupKeyInput.value.trim();\n    if (!key) {\n      showMessage('Error: Key cannot be empty for lookup.');\n      lookupKeyInput.focus();\n      return;\n    }\n    const val = hashMap.get(key);\n    if (val === undefined) {\n      showMessage(`Key \"${key}\" not found in the hash map.`);\n      updateTable(); // clear highlights\n    } else {\n      showMessage(`Lookup Result: Key \"${key}\" has value \"${val}\".`);\n      updateTable(hashMap.hash(key), key);\n    }\n  });\n\n  // Delete handler\n  deleteBtn.addEventListener('click', () => {\n    const key = deleteKeyInput.value.trim();\n    if (!key) {\n      showMessage('Error: Key cannot be empty for deletion.');\n      deleteKeyInput.focus();\n      return;\n    }\n    const deleted = hashMap.delete(key);\n    if (deleted) {\n      showMessage(`Key \"${key}\" deleted from the hash map.`);\n      updateTable();\n    } else {\n      showMessage(`Key \"${key}\" not found, cannot delete.`);\n    }\n  });\n\n  // Initialize view\n  updateTable();\n  showMessage('Add some key-value pairs to see them appear here!');\n</script>\n</body>\n</html>"
  },
