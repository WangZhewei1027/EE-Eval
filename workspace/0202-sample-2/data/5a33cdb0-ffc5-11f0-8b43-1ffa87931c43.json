    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Sliding Window Visualization</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 20px;\n      background: #f0f4f8;\n      color: #333;\n    }\n    h1 {\n      text-align: center;\n      margin-bottom: 10px;\n    }\n    p {\n      max-width: 700px;\n      margin: 0 auto 20px auto;\n      font-size: 1rem;\n      line-height: 1.5;\n    }\n    #array-container {\n      display: flex;\n      justify-content: center;\n      margin-bottom: 20px;\n      user-select: none;\n    }\n    .element {\n      width: 40px;\n      height: 40px;\n      line-height: 40px;\n      margin: 0 4px;\n      background: #ddd;\n      border-radius: 6px;\n      text-align: center;\n      font-weight: 600;\n      font-size: 1.25rem;\n      transition: background-color 0.3s, color 0.3s;\n      box-shadow: 0 2px 5px rgb(0 0 0 / 0.1);\n      position: relative;\n    }\n    .element.window {\n      background: #4a90e2;\n      color: white;\n      box-shadow: 0 0 12px #4a90e2;\n    }\n    .element.current {\n      border: 3px solid #f39c12;\n      box-shadow: 0 0 15px #f39c12;\n      z-index: 10;\n    }\n    #controls {\n      display: flex;\n      justify-content: center;\n      gap: 10px;\n      margin-bottom: 20px;\n      flex-wrap: wrap;\n    }\n    #controls > * {\n      font-size: 1rem;\n      padding: 8px 12px;\n      border-radius: 6px;\n      border: 1px solid #ccc;\n      outline: none;\n      transition: border-color 0.3s;\n    }\n    #controls > input[type=\"number\"] {\n      width: 80px;\n      text-align: center;\n    }\n    #controls > input[type=\"number\"]:focus,\n    #controls > button:hover {\n      border-color: #4a90e2;\n    }\n    #message {\n      max-width: 700px;\n      margin: 0 auto;\n      font-size: 1.1rem;\n      text-align: center;\n      min-height: 1.5em;\n      font-weight: 600;\n      color: #333;\n    }\n    footer {\n      margin-top: 40px;\n      text-align: center;\n      font-size: 0.9rem;\n      color: #777;\n    }\n  </style>\n</head>\n<body>\n  <h1>Sliding Window Technique</h1>\n  <p>\n    The <b>Sliding Window</b> technique is used to efficiently solve problems involving subarrays or subsequences by maintaining a window that slides over data, avoiding repeated computations. Here, we demonstrate finding the sum of every contiguous subarray of size <i>k</i> and highlight the current window.\n  </p>\n\n  <div id=\"array-container\"></div>\n\n  <div id=\"controls\">\n    <label>\n      Array (comma separated):\n      <input type=\"text\" id=\"input-array\" value=\"2,1,5,1,3,2\" />\n    </label>\n    <label>\n      Window Size (k):\n      <input type=\"number\" id=\"input-k\" min=\"1\" value=\"3\" />\n    </label>\n    <button id=\"start-btn\">Start</button>\n    <button id=\"prev-btn\" disabled>&lt; Prev</button>\n    <button id=\"next-btn\" disabled>Next &gt;</button>\n    <button id=\"auto-btn\">Auto Play</button>\n  </div>\n\n  <div id=\"message\"></div>\n\n  <footer>\n    Sliding Window Visualization — Demonstration by ChatGPT\n  </footer>\n\n  <script>\n    (() => {\n      const arrayInput = document.getElementById(\"input-array\");\n      const kInput = document.getElementById(\"input-k\");\n      const arrayContainer = document.getElementById(\"array-container\");\n      const message = document.getElementById(\"message\");\n      const startBtn = document.getElementById(\"start-btn\");\n      const prevBtn = document.getElementById(\"prev-btn\");\n      const nextBtn = document.getElementById(\"next-btn\");\n      const autoBtn = document.getElementById(\"auto-btn\");\n\n      let array = [];\n      let k = 0;\n      let sums = [];\n      let currentIndex = 0;\n      let autoPlay = false;\n      let autoPlayInterval = null;\n\n      function parseArray(input) {\n        return input\n          .split(\",\")\n          .map(s => s.trim())\n          .filter(s => s.length > 0)\n          .map(Number)\n          .filter(n => !isNaN(n));\n      }\n\n      // Calculate sums of all contiguous subarrays of size k using sliding window\n      function slidingWindowSums(arr, k) {\n        const result = [];\n        if (k > arr.length) return result;\n\n        // Initial window sum\n        let windowSum = 0;\n        for (let i = 0; i < k; i++) {\n          windowSum += arr[i];\n        }\n        result.push(windowSum);\n\n        // Slide the window\n        for (let i = k; i < arr.length; i++) {\n          windowSum += arr[i] - arr[i - k];\n          result.push(windowSum);\n        }\n        return result;\n      }\n\n      function renderArray() {\n        arrayContainer.innerHTML = \"\";\n        for (let i = 0; i < array.length; i++) {\n          const el = document.createElement(\"div\");\n          el.className = \"element\";\n          el.textContent = array[i];\n          arrayContainer.appendChild(el);\n        }\n      }\n\n      // Highlight current window and current element\n      function highlightWindow(index) {\n        // Clear previous highlights\n        const elems = arrayContainer.children;\n        for (let i = 0; i < elems.length; i++) {\n          elems[i].classList.remove(\"window\", \"current\");\n        }\n        if (index < 0 || index >= sums.length) return;\n\n        // Highlight window elements\n        for (let i = index; i < index + k; i++) {\n          if (elems[i]) elems[i].classList.add(\"window\");\n        }\n        // Highlight current rightmost element of window\n        if (elems[index + k - 1]) elems[index + k - 1].classList.add(\"current\");\n      }\n\n      function updateMessage(index) {\n        if (index < 0 || index >= sums.length) {\n          message.textContent = \"\";\n          return;\n        }\n        message.textContent = `Window [${index}..${index + k - 1}] sum = ${sums[index]}`;\n      }\n\n      function updateControls() {\n        prevBtn.disabled = currentIndex <= 0;\n        nextBtn.disabled = currentIndex >= sums.length - 1;\n      }\n\n      function moveToStep(index) {\n        currentIndex = index;\n        highlightWindow(currentIndex);\n        updateMessage(currentIndex);\n        updateControls();\n      }\n\n      function startVisualization() {\n        array = parseArray(arrayInput.value);\n        k = parseInt(kInput.value);\n\n        if (!array.length) {\n          alert(\"Please enter a valid array (comma separated numbers).\");\n          return;\n        }\n        if (isNaN(k) || k < 1) {\n          alert(\"Please enter a valid window size k (>= 1).\");\n          return;\n        }\n        if (k > array.length) {\n          alert(\"Window size k cannot be larger than the array length.\");\n          return;\n        }\n\n        sums = slidingWindowSums(array, k);\n        currentIndex = 0;\n        renderArray();\n        highlightWindow(currentIndex);\n        updateMessage(currentIndex);\n        updateControls();\n        stopAutoPlay();\n      }\n\n      // Auto play controls\n      function autoPlayStep() {\n        if (currentIndex < sums.length - 1) {\n          moveToStep(currentIndex + 1);\n        } else {\n          stopAutoPlay();\n        }\n      }\n      function startAutoPlay() {\n        if (autoPlay) return;\n        if(!sums.length) return;\n        autoPlay = true;\n        autoBtn.textContent = \"Pause\";\n        autoPlayInterval = setInterval(autoPlayStep, 1500);\n      }\n      function stopAutoPlay() {\n        autoPlay = false;\n        autoBtn.textContent = \"Auto Play\";\n        if (autoPlayInterval) {\n          clearInterval(autoPlayInterval);\n          autoPlayInterval = null;\n        }\n      }\n      function toggleAutoPlay() {\n        if (autoPlay) stopAutoPlay();\n        else startAutoPlay();\n      }\n\n      startBtn.addEventListener(\"click\", startVisualization);\n      prevBtn.addEventListener(\"click\", () => {\n        if (currentIndex > 0) {\n          moveToStep(currentIndex - 1);\n          stopAutoPlay();\n        }\n      });\n      nextBtn.addEventListener(\"click\", () => {\n        if (currentIndex < sums.length - 1) {\n          moveToStep(currentIndex + 1);\n          stopAutoPlay();\n        }\n      });\n      autoBtn.addEventListener(\"click\", () => {\n        toggleAutoPlay();\n      });\n\n      // Initial render\n      startVisualization();\n    })();\n  </script>\n</body>\n</html>"
