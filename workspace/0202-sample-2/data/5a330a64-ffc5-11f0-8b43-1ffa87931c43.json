    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Linear Search Demonstration</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 2rem;\n      background-color: #f9f9f9;\n      color: #333;\n    }\n    h1 {\n      text-align: center;\n      color: #2c3e50;\n    }\n    #arrayContainer {\n      display: flex;\n      justify-content: center;\n      margin: 1rem 0 2rem 0;\n      flex-wrap: wrap;\n      max-width: 600px;\n      margin-left: auto;\n      margin-right: auto;\n    }\n    .arrayElement {\n      width: 40px;\n      height: 40px;\n      border: 2px solid #34495e;\n      margin: 5px;\n      line-height: 40px;\n      text-align: center;\n      font-weight: bold;\n      border-radius: 5px;\n      transition: background-color 0.3s, color 0.3s, border-color 0.3s;\n      user-select: none;\n      font-size: 18px;\n    }\n    .current {\n      background-color: #f39c12;\n      color: white;\n      border-color: #e67e22;\n    }\n    .found {\n      background-color: #27ae60;\n      color: white;\n      border-color: #2ecc71;\n    }\n    .notFound {\n      background-color: #c0392b;\n      color: white;\n      border-color: #e74c3c;\n    }\n    #controls {\n      text-align: center;\n      margin-bottom: 1.5rem;\n    }\n    input[type=\"number\"] {\n      padding: 0.5rem;\n      font-size: 16px;\n      width: 120px;\n      border: 1px solid #bdc3c7;\n      border-radius: 4px;\n      margin-right: 10px;\n    }\n    button {\n      padding: 0.5rem 1rem;\n      font-size: 16px;\n      border: none;\n      background-color: #2980b9;\n      color: white;\n      border-radius: 4px;\n      cursor: pointer;\n      transition: background-color 0.2s;\n    }\n    button:disabled {\n      background-color: #7f8c8d;\n      cursor: not-allowed;\n    }\n    button:hover:not(:disabled) {\n      background-color: #3498db;\n    }\n    #message {\n      text-align: center;\n      font-size: 18px;\n      margin-top: 1rem;\n      min-height: 24px;\n    }\n    #legend {\n      max-width: 300px;\n      margin: 2rem auto 0 auto;\n      display: flex;\n      justify-content: space-around;\n    }\n    .legendItem {\n      display: flex;\n      align-items: center;\n      gap: 8px;\n      font-size: 14px;\n    }\n    .colorBox {\n      width: 20px;\n      height: 20px;\n      border-radius: 4px;\n      border: 2px solid #333;\n    }\n    .colorCurrent {\n      background-color: #f39c12;\n      border-color: #e67e22;\n    }\n    .colorFound {\n      background-color: #27ae60;\n      border-color: #2ecc71;\n    }\n    .colorNotFound {\n      background-color: #c0392b;\n      border-color: #e74c3c;\n    }\n  </style>\n</head>\n<body>\n  <h1>Linear Search Demonstration</h1>\n  <div id=\"controls\">\n    <input type=\"number\" id=\"searchInput\" placeholder=\"Enter number to find\" />\n    <button id=\"startBtn\">Start Search</button>\n  </div>\n  <div id=\"arrayContainer\" aria-label=\"Array elements for searching\"></div>\n  <div id=\"message\" role=\"alert\" aria-live=\"polite\"></div>\n  <div id=\"legend\" aria-label=\"Color legend for linear search visualization\">\n    <div class=\"legendItem\"><div class=\"colorBox colorCurrent\"></div>Currently Checking</div>\n    <div class=\"legendItem\"><div class=\"colorBox colorFound\"></div>Found Element</div>\n    <div class=\"legendItem\"><div class=\"colorBox colorNotFound\"></div>Checked and Not Found</div>\n  </div>\n\n  <script>\n    (() => {\n      const array = [7, 13, 5, 9, 20, 2, 15, 8, 10, 11];\n      const arrayContainer = document.getElementById('arrayContainer');\n      const startBtn = document.getElementById('startBtn');\n      const searchInput = document.getElementById('searchInput');\n      const messageBox = document.getElementById('message');\n\n      let currentIndex = 0;\n      let searchValue = null;\n      let searching = false;\n\n      function createArrayElements() {\n        arrayContainer.innerHTML = '';\n        array.forEach((num) => {\n          const el = document.createElement('div');\n          el.classList.add('arrayElement');\n          el.textContent = num;\n          arrayContainer.appendChild(el);\n        });\n      }\n\n      function reset() {\n        searching = false;\n        currentIndex = 0;\n        messageBox.textContent = '';\n        createArrayElements();\n        startBtn.disabled = false;\n        searchInput.disabled = false;\n      }\n\n      async function sleep(ms) {\n        return new Promise(resolve => setTimeout(resolve, ms));\n      }\n\n      async function linearSearch(value) {\n        searching = true;\n        startBtn.disabled = true;\n        searchInput.disabled = true;\n        messageBox.textContent = 'Starting linear search...';\n\n        for (currentIndex = 0; currentIndex < array.length; currentIndex++) {\n          updateHighlights(currentIndex, null);\n\n          messageBox.textContent = `Checking element at index ${currentIndex} (value: ${array[currentIndex]})...`;\n          await sleep(1000);\n\n          if (array[currentIndex] === value) {\n            updateHighlights(currentIndex, 'found');\n            messageBox.textContent = `Value ${value} found at index ${currentIndex}!`;\n            searching = false;\n            startBtn.disabled = false;\n            searchInput.disabled = false;\n            return;\n          }\n\n          updateHighlights(currentIndex, 'notFound');\n          await sleep(500);\n        }\n        messageBox.textContent = `Value ${value} not found in the array.`;\n        searching = false;\n        startBtn.disabled = false;\n        searchInput.disabled = false;\n      }\n\n      function updateHighlights(currentIdx, status) {\n        const elems = arrayContainer.children;\n        for (let i = 0; i < elems.length; i++) {\n          elems[i].classList.remove('current', 'found', 'notFound');\n          if (status === null) {\n            if (i === currentIdx) elems[i].classList.add('current');\n          } else if (status === 'found') {\n            if (i === currentIdx) elems[i].classList.add('found');\n          } else if (status === 'notFound') {\n            if (i === currentIdx) elems[i].classList.add('notFound');\n          }\n        }\n      }\n\n      startBtn.addEventListener('click', () => {\n        if (searching) return;\n        const val = parseInt(searchInput.value, 10);\n        if (isNaN(val)) {\n          messageBox.textContent = 'Please enter a valid number to search.';\n          return;\n        }\n        searchValue = val;\n        reset();\n        linearSearch(searchValue);\n      });\n\n      // Initialize array display on page load\n      createArrayElements();\n    })();\n  </script>\n</body>\n</html>"
