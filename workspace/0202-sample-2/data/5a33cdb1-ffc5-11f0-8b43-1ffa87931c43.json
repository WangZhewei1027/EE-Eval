    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Two Pointers Technique Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 2rem;\n    background: #f7f7f7;\n    color: #333;\n  }\n  h1 {\n    text-align: center;\n  }\n  #arrayContainer {\n    margin: 1rem 0 2rem;\n    font-size: 1.2rem;\n    display: flex;\n    justify-content: center;\n  }\n  .element {\n    width: 40px;\n    height: 40px;\n    margin: 0 4px;\n    background: #e0e0e0;\n    border-radius: 5px;\n    line-height: 40px;\n    text-align: center;\n    font-weight: bold;\n    position: relative;\n    transition: background-color 0.3s ease;\n  }\n  .pointer {\n    position: absolute;\n    top: -25px;\n    width: 100%;\n    font-size: 0.8rem;\n    font-weight: bold;\n  }\n  .left-pointer {\n    color: #007bff;\n  }\n  .right-pointer {\n    color: #dc3545;\n  }\n  #controls {\n    display: flex;\n    justify-content: center;\n    margin-bottom: 1.5rem;\n    gap: 1rem;\n  }\n  button {\n    padding: 0.6rem 1.2rem;\n    font-size: 1rem;\n    border: none;\n    border-radius: 5px;\n    cursor: pointer;\n    background-color: #007bff;\n    color: white;\n    transition: background-color 0.2s ease;\n  }\n  button:disabled {\n    background-color: #a0a0a0;\n    cursor: not-allowed;\n  }\n  button:hover:not(:disabled) {\n    background-color: #0056b3;\n  }\n  #result {\n    text-align: center;\n    font-size: 1.1rem;\n    min-height: 1.5em;\n    margin-top: 1rem;\n  }\n  #description {\n    max-width: 700px;\n    margin: 0 auto 2rem;\n    font-size: 1rem;\n    line-height: 1.5;\n    background: white;\n    padding: 1rem 1.5rem;\n    border-radius: 6px;\n    border: 1px solid #ddd;\n  }\n</style>\n</head>\n<body>\n<h1>Two Pointers Technique Demo</h1>\n\n<div id=\"description\">\n  <p>\n    <strong>Two Pointers</strong> is a common algorithm technique where two indices (pointers) iterate over data structures (usually arrays or linked lists) to solve problems efficiently without nested loops.\n  </p>\n  <p>\n    This demo shows how the Two Pointers technique can find two numbers in a <em>sorted</em> array that sum up to a target value.\n  </p>\n  <p>\n    Both pointers start at opposite ends of the array and move inward depending on the sum compared to the target.\n  </p>\n</div>\n\n<div id=\"arrayContainer\"></div>\n\n<div id=\"controls\">\n  <button id=\"startBtn\">Start</button>\n  <button id=\"stepBtn\" disabled>Step</button>\n  <button id=\"resetBtn\" disabled>Reset</button>\n</div>\n\n<div id=\"result\"></div>\n\n<script>\n(() => {\n  // Sorted array and target sum\n  const arr = [1, 3, 4, 5, 7, 8, 10, 12, 14, 15];\n  const target = 15;\n\n  const arrayContainer = document.getElementById(\"arrayContainer\");\n  const startBtn = document.getElementById(\"startBtn\");\n  const stepBtn = document.getElementById(\"stepBtn\");\n  const resetBtn = document.getElementById(\"resetBtn\");\n  const result = document.getElementById(\"result\");\n\n  let left = 0;\n  let right = arr.length - 1;\n  let running = false;\n  let foundPair = false;\n\n  // Create array display elements\n  function createArrayElems() {\n    arrayContainer.innerHTML = \"\";\n    for (let i = 0; i < arr.length; i++) {\n      const el = document.createElement(\"div\");\n      el.classList.add(\"element\");\n      el.textContent = arr[i];\n      el.dataset.index = i;\n      arrayContainer.appendChild(el);\n    }\n  }\n\n  // Update pointers visualization\n  function updatePointers() {\n    // Clear all pointer labels and colors\n    const elems = document.querySelectorAll(\"#arrayContainer .element\");\n    elems.forEach((el) => {\n      // remove pointer span if any\n      const prevPointer = el.querySelector(\".pointer\");\n      if (prevPointer) prevPointer.remove();\n\n      el.style.backgroundColor = \"#e0e0e0\";\n    });\n\n    if (left <= right) {\n      // left pointer\n      const leftEl = elems[left];\n      const leftPointer = document.createElement(\"div\");\n      leftPointer.classList.add(\"pointer\", \"left-pointer\");\n      leftPointer.textContent = \"L\";\n      leftEl.appendChild(leftPointer);\n      leftEl.style.backgroundColor = \"#cce5ff\";\n\n      // right pointer\n      const rightEl = elems[right];\n      const rightPointer = document.createElement(\"div\");\n      rightPointer.classList.add(\"pointer\", \"right-pointer\");\n      rightPointer.textContent = \"R\";\n      rightEl.appendChild(rightPointer);\n      rightEl.style.backgroundColor = \"#f8d7da\";\n    }\n  }\n\n  function reset() {\n    left = 0;\n    right = arr.length - 1;\n    running = false;\n    foundPair = false;\n    updatePointers();\n    result.textContent = \"\";\n    startBtn.disabled = false;\n    stepBtn.disabled = true;\n    resetBtn.disabled = true;\n  }\n\n  function step() {\n    if (foundPair || left > right) {\n      result.textContent = \"No more steps possible.\";\n      stepBtn.disabled = true;\n      return;\n    }\n\n    const sum = arr[left] + arr[right];\n    result.textContent = `Checking arr[${left}] + arr[${right}] = ${arr[left]} + ${arr[right]} = ${sum}`;\n\n    const elems = document.querySelectorAll(\"#arrayContainer .element\");\n    // highlight current pointers elements\n    elems[left].style.backgroundColor = \"#b3d7ff\";\n    elems[right].style.backgroundColor = \"#f5c6cb\";\n\n    if (sum === target) {\n      result.textContent = `Found! arr[${left}] + arr[${right}] = ${arr[left]} + ${arr[right]} = ${target}`;\n      foundPair = true;\n      stepBtn.disabled = true;\n      resetBtn.disabled = false;\n    } else if (sum < target) {\n      left++;\n      updatePointers();\n      if (left > right) {\n        result.textContent = \"No pair found that sums to target.\";\n        stepBtn.disabled = true;\n        resetBtn.disabled = false;\n      }\n    } else {\n      right--;\n      updatePointers();\n      if (left > right) {\n        result.textContent = \"No pair found that sums to target.\";\n        stepBtn.disabled = true;\n        resetBtn.disabled = false;\n      }\n    }\n  }\n\n  startBtn.addEventListener(\"click\", () => {\n    if (running) return;\n    running = true;\n    startBtn.disabled = true;\n    stepBtn.disabled = false;\n    resetBtn.disabled = false;\n    updatePointers();\n    result.textContent = `Target sum: ${target}. Press \"Step\" to proceed.`;\n  });\n\n  stepBtn.addEventListener(\"click\", step);\n\n  resetBtn.addEventListener(\"click\", () => {\n    reset();\n  });\n\n  createArrayElems();\n  reset();\n})();\n</script>\n</body>\n</html>"
