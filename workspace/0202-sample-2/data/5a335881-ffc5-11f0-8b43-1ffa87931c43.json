    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Topological Sort Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 1rem;\n  }\n  h1 {\n    color: #333;\n  }\n  #graphInput {\n    width: 100%;\n    height: 120px;\n    font-family: monospace;\n    font-size: 1rem;\n    margin-bottom: 1rem;\n  }\n  #runBtn {\n    padding: 0.5rem 1rem;\n    font-size: 1rem;\n    margin-bottom: 1rem;\n  }\n  #result {\n    white-space: pre-wrap;\n    background: #f8f8f8;\n    border: 1px solid #ddd;\n    padding: 1rem;\n    min-height: 4rem;\n  }\n  #error {\n    color: #b00020;\n    margin-bottom: 1rem;\n  }\n  #explanation {\n    max-width: 600px;\n    line-height: 1.4;\n    margin-bottom: 2rem;\n  }\n  .graph-visual {\n    margin: 1rem 0;\n  }\n</style>\n</head>\n<body>\n<h1>Topological Sort Demonstration</h1>\n<div id=\"explanation\">\n  <p>\n    Topological Sort is an ordering of the vertices in a Directed Acyclic Graph (DAG) such that for every directed edge u → v,\n    vertex u comes before vertex v in the ordering.\n  </p>\n  <p>\n    It is useful for scheduling tasks, resolving dependencies, and other scenarios where certain items must come before others.\n  </p>\n  <p>\n    Enter your graph as adjacency list below. Format:\n  </p>\n  <pre>\nNode: Child1, Child2, Child3\nFor example:\nA: C, D\nB: D\nC: E\nD: E\nE:\n  </pre>\n</div>\n\n<textarea id=\"graphInput\" placeholder=\"Enter graph adjacency list here...\">A: C, D\nB: D\nC: E\nD: E\nE:</textarea>\n<br />\n<button id=\"runBtn\">Run Topological Sort</button>\n\n<div id=\"error\"></div>\n\n<h2>Topological Order Result:</h2>\n<div id=\"result\"></div>\n\n<script>\n  // Parses the adjacency list input text to graph map\n  function parseGraph(input) {\n    const graph = new Map();\n    const lines = input.trim().split('\\n');\n\n    for (let line of lines) {\n      line = line.trim();\n      if (!line) continue;\n      const parts = line.split(':');\n      if (parts.length !== 2) throw new Error(\"Invalid format: missing ':' separator\");\n      const node = parts[0].trim();\n      if (!node) throw new Error(\"Invalid node name empty\");\n      const childrenStr = parts[1].trim();\n      // If empty children, then empty array:\n      const children = childrenStr ? childrenStr.split(',').map(c => c.trim()).filter(c => c) : [];\n      graph.set(node, children);\n    }\n    return graph;\n  }\n  \n  // Detect if graph has cycles: returns true if cycle detected\n  function detectCycle(graph) {\n    const visited = new Set();\n    const recStack = new Set();\n\n    function dfs(node) {\n      if(recStack.has(node)) return true; // cycle found\n      if(visited.has(node)) return false;\n\n      visited.add(node);\n      recStack.add(node);\n\n      const neighbors = graph.get(node) || [];\n      for(let neigh of neighbors) {\n        if(!graph.has(neigh)) {\n          throw new Error(`Graph node \"${neigh}\" is referenced but not defined.`);\n        }\n        if(dfs(neigh)) return true;\n      }\n      recStack.delete(node);\n      return false;\n    }\n\n    for(let node of graph.keys()) {\n      if(dfs(node)) return true;\n    }\n    return false;\n  }\n\n  // Topological sort using DFS\n  function topologicalSort(graph) {\n    const visited = new Set();\n    const order = [];\n\n    function dfs(node) {\n      if(visited.has(node)) return;\n      visited.add(node);\n      for(let neigh of graph.get(node) || []) {\n        dfs(neigh);\n      }\n      order.push(node);\n    }\n\n    // Because graph may not be connected, loop through all nodes:\n    for(let node of graph.keys()) {\n      dfs(node);\n    }\n    return order.reverse();\n  }\n\n  // Hook up UI\n  document.getElementById('runBtn').addEventListener('click', () => {\n    const input = document.getElementById('graphInput').value;\n    const errorDiv = document.getElementById('error');\n    const resultDiv = document.getElementById('result');\n    errorDiv.textContent = '';\n    resultDiv.textContent = '';\n    try {\n      const graph = parseGraph(input);\n\n      // Check for undefined nodes\n      for(let [node, children] of graph) {\n        children.forEach(child => {\n          if(!graph.has(child)) {\n            throw new Error(`Node \"${child}\" referenced by \"${node}\" is not defined.`);\n          }\n        });\n      }\n\n      if(detectCycle(graph)) {\n        throw new Error('The graph contains a cycle. Topological sorting is not possible.');\n      }\n      const sorted = topologicalSort(graph);\n\n      resultDiv.textContent = sorted.join(' → ');\n    }\n    catch(e) {\n      errorDiv.textContent = 'Error: ' + e.message;\n    }\n  });\n</script>\n</body>\n</html>"
