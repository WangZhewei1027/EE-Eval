    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>JavaScript Array Demo</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      margin: 2em;\n      background: #f9f9f9;\n      color: #333;\n    }\n    h1 {\n      color: #2c3e50;\n    }\n    #arrayContent {\n      margin: 1em 0;\n      background: #ecf0f1;\n      padding: 1em;\n      border-radius: 5px;\n      white-space: pre-wrap;\n      font-family: monospace;\n    }\n    button {\n      background-color: #2980b9;\n      color: white;\n      border: none;\n      padding: 0.5em 1em;\n      margin: 0.5em 0.2em 1em 0;\n      border-radius: 4px;\n      cursor: pointer;\n    }\n    button:hover {\n      background-color: #3498db;\n    }\n    input[type=\"text\"], input[type=\"number\"] {\n      padding: 0.3em;\n      margin-right: 0.5em;\n      border: 1px solid #bdc3c7;\n      border-radius: 4px;\n    }\n    label {\n      font-weight: bold;\n    }\n    .section {\n      margin-bottom: 2em;\n    }\n  </style>\n</head>\n<body>\n  <h1>JavaScript Array Demo</h1>\n  <p>This page demonstrates the basic concepts and operations on <code>Array</code> in JavaScript.</p>\n\n  <div class=\"section\">\n    <h2>Initial Array</h2>\n    <div id=\"arrayContent\"></div>\n  </div>\n\n  <div class=\"section\">\n    <h2>Array Operations</h2>\n\n    <div>\n      <label for=\"pushValue\">Push Value:</label>\n      <input type=\"text\" id=\"pushValue\" placeholder=\"Enter value\" />\n      <button id=\"btnPush\">Push to Array</button>\n    </div>\n\n    <div>\n      <label for=\"popResult\">Pop Result:</label>\n      <input type=\"text\" id=\"popResult\" readonly />\n      <button id=\"btnPop\">Pop from Array</button>\n    </div>\n\n    <div>\n      <label for=\"unshiftValue\">Unshift Value:</label>\n      <input type=\"text\" id=\"unshiftValue\" placeholder=\"Enter value\" />\n      <button id=\"btnUnshift\">Unshift to Array</button>\n    </div>\n\n    <div>\n      <label for=\"shiftResult\">Shift Result:</label>\n      <input type=\"text\" id=\"shiftResult\" readonly />\n      <button id=\"btnShift\">Shift from Array</button>\n    </div>\n\n    <div>\n      <label for=\"indexOfValue\">Index Of:</label>\n      <input type=\"text\" id=\"indexOfValue\" placeholder=\"Enter value\" />\n      <button id=\"btnIndexOf\">Find Index</button>\n      <span id=\"indexOfResult\"></span>\n    </div>\n\n    <div>\n      <label for=\"spliceIndex\">Splice Index:</label>\n      <input type=\"number\" id=\"spliceIndex\" min=\"0\" style=\"width: 4em\"/>\n      <label for=\"spliceCount\">Count:</label>\n      <input type=\"number\" id=\"spliceCount\" min=\"0\" style=\"width: 4em\"/>\n      <label for=\"spliceInsert\">Insert Value:</label>\n      <input type=\"text\" id=\"spliceInsert\" placeholder=\"Optional\" />\n      <button id=\"btnSplice\">Splice Array</button>\n    </div>\n  </div>\n\n  <div class=\"section\">\n    <h2>Array Properties & Methods Demo</h2>\n    <button id=\"btnLength\">Show Length</button>\n    <button id=\"btnJoin\">Show Join (comma separated)</button>\n    <button id=\"btnReverse\">Reverse Array</button>\n    <button id=\"btnSort\">Sort Array</button>\n    <button id=\"btnMap\">Map (to uppercase if string)</button>\n    <button id=\"btnFilter\">Filter (strings with length &gt; 3)</button>\n    <button id=\"btnClear\">Reset to Initial Array</button>\n    <div id=\"output\" style=\"margin-top: 1em; font-family: monospace; white-space: pre-wrap;\"></div>\n  </div>\n\n  <script>\n    (() => {\n      // Initial array with different types\n      const initialArray = ['apple', 'banana', 'cherry', 'date', 42, true, null];\n      let arr = [...initialArray];\n\n      const arrayContent = document.getElementById('arrayContent');\n      const output = document.getElementById('output');\n\n      function updateDisplay() {\n        arrayContent.textContent = JSON.stringify(arr, null, 2);\n      }\n\n      function clearOutput() {\n        output.textContent = '';\n      }\n\n      // Show initial array on load\n      updateDisplay();\n\n      // Buttons and inputs\n      const btnPush = document.getElementById('btnPush');\n      const pushValueInput = document.getElementById('pushValue');\n\n      const btnPop = document.getElementById('btnPop');\n      const popResultInput = document.getElementById('popResult');\n\n      const btnUnshift = document.getElementById('btnUnshift');\n      const unshiftValueInput = document.getElementById('unshiftValue');\n\n      const btnShift = document.getElementById('btnShift');\n      const shiftResultInput = document.getElementById('shiftResult');\n\n      const btnIndexOf = document.getElementById('btnIndexOf');\n      const indexOfValueInput = document.getElementById('indexOfValue');\n      const indexOfResultSpan = document.getElementById('indexOfResult');\n\n      const btnSplice = document.getElementById('btnSplice');\n      const spliceIndexInput = document.getElementById('spliceIndex');\n      const spliceCountInput = document.getElementById('spliceCount');\n      const spliceInsertInput = document.getElementById('spliceInsert');\n\n      const btnLength = document.getElementById('btnLength');\n      const btnJoin = document.getElementById('btnJoin');\n      const btnReverse = document.getElementById('btnReverse');\n      const btnSort = document.getElementById('btnSort');\n      const btnMap = document.getElementById('btnMap');\n      const btnFilter = document.getElementById('btnFilter');\n      const btnClear = document.getElementById('btnClear');\n\n      // Utility to interpret input string to a typed value if possible\n      function interpretValue(val) {\n        if (val === 'true') return true;\n        if (val === 'false') return false;\n        if (val === 'null') return null;\n        if (!isNaN(Number(val)) && val.trim() !== '') return Number(val);\n        return val;\n      }\n\n      btnPush.addEventListener('click', () => {\n        const val = interpretValue(pushValueInput.value);\n        arr.push(val);\n        updateDisplay();\n        pushValueInput.value = '';\n        clearOutput();\n      });\n\n      btnPop.addEventListener('click', () => {\n        const popped = arr.pop();\n        popResultInput.value = popped === undefined ? '' : String(popped);\n        updateDisplay();\n        clearOutput();\n      });\n\n      btnUnshift.addEventListener('click', () => {\n        const val = interpretValue(unshiftValueInput.value);\n        arr.unshift(val);\n        updateDisplay();\n        unshiftValueInput.value = '';\n        clearOutput();\n      });\n\n      btnShift.addEventListener('click', () => {\n        const shifted = arr.shift();\n        shiftResultInput.value = shifted === undefined ? '' : String(shifted);\n        updateDisplay();\n        clearOutput();\n      });\n\n      btnIndexOf.addEventListener('click', () => {\n        const val = interpretValue(indexOfValueInput.value);\n        const idx = arr.indexOf(val);\n        indexOfResultSpan.textContent = idx === -1 ? 'Value not found' : `Index: ${idx}`;\n        clearOutput();\n      });\n\n      btnSplice.addEventListener('click', () => {\n        const index = Number(spliceIndexInput.value);\n        const count = Number(spliceCountInput.value);\n        if (isNaN(index) || index < 0 || index > arr.length) {\n          alert('Please enter a valid splice index.');\n          return;\n        }\n        if (isNaN(count) || count < 0) {\n          alert('Please enter a valid splice count.');\n          return;\n        }\n        let insertedValues = [];\n        const insertValRaw = spliceInsertInput.value.trim();\n        if (insertValRaw !== '') {\n          insertedValues.push(interpretValue(insertValRaw));\n        }\n\n        const removed = arr.splice(index, count, ...insertedValues);\n        output.textContent = `Removed elements:\\n${JSON.stringify(removed, null, 2)}`;\n        updateDisplay();\n      });\n\n      btnLength.addEventListener('click', () => {\n        output.textContent = `Array length: ${arr.length}`;\n      });\n\n      btnJoin.addEventListener('click', () => {\n        output.textContent = `Array joined with \",\":\\n${arr.join(',')}`;\n      });\n\n      btnReverse.addEventListener('click', () => {\n        arr.reverse();\n        updateDisplay();\n        output.textContent = 'Array reversed.';\n      });\n\n      btnSort.addEventListener('click', () => {\n        // Use simple sort as strings\n        arr.sort((a, b) => {\n          if (typeof a === 'string' && typeof b === 'string') return a.localeCompare(b);\n          return String(a).localeCompare(String(b));\n        });\n        updateDisplay();\n        output.textContent = 'Array sorted (as strings).';\n      });\n\n      btnMap.addEventListener('click', () => {\n        arr = arr.map(item => {\n          if (typeof item === 'string') return item.toUpperCase();\n          return item;\n        });\n        updateDisplay();\n        output.textContent = 'Mapped array (strings to uppercase).';\n      });\n\n      btnFilter.addEventListener('click', () => {\n        const filtered = arr.filter(item => typeof item === 'string' && item.length > 3);\n        output.textContent = `Filtered array (strings with length > 3):\\n${JSON.stringify(filtered, null, 2)}`;\n      });\n\n      btnClear.addEventListener('click', () => {\n        arr = [...initialArray];\n        updateDisplay();\n        output.textContent = 'Array reset to initial array.';\n        clearOutput();\n      });\n    })();\n  </script>\n</body>\n</html>"
  },
