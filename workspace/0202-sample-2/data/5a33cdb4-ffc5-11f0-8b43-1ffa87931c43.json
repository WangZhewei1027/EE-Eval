    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>K-Means Clustering Demo</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    text-align: center;\n    margin: 0;\n    background: #fafafa;\n  }\n  h1 {\n    margin: 1rem 0 0.2rem 0;\n    color: #333;\n  }\n  #canvasContainer {\n    display: inline-block;\n    position: relative;\n    margin: 1rem 0;\n  }\n  canvas {\n    background: #fff;\n    border: 1px solid #ccc;\n    cursor: crosshair;\n  }\n  #controls {\n    margin: 15px 0;\n  }\n  label, input, button {\n    font-size: 1rem;\n  }\n  input[type=number] {\n    width: 50px;\n    margin-left: 5px;\n    margin-right: 15px;\n    text-align: center;\n  }\n  #instructions {\n    width: 400px;\n    margin: 0 auto 1rem auto;\n    font-size: 0.9rem;\n    color: #555;\n  }\n  #legend {\n    margin-top: 10px;\n    font-size: 0.9rem;\n  }\n  .color-box {\n    display: inline-block;\n    width: 14px;\n    height: 14px;\n    margin-right: 5px;\n    vertical-align: middle;\n  }\n</style>\n</head>\n<body>\n<h1>K-Means Clustering Demo</h1>\n\n<div id=\"instructions\">\n  <p>Click on the canvas to add data points (up to 200). Adjust the number of clusters (K), then press \"Run K-Means\" to cluster the points.\n  You can also press \"Reset\" to clear all points.</p>\n</div>\n\n<div id=\"canvasContainer\">\n  <canvas id=\"canvas\" width=\"600\" height=\"400\" title=\"Click to add points\"></canvas>\n</div>\n\n<div id=\"controls\">\n  <label for=\"clusters\">Number of clusters (K):</label>\n  <input type=\"number\" id=\"clusters\" min=\"1\" max=\"10\" value=\"3\" />\n  <button id=\"runBtn\">Run K-Means</button>\n  <button id=\"resetBtn\">Reset</button>\n</div>\n\n<div id=\"legend\"></div>\n\n<script>\n(() => {\n  const canvas = document.getElementById('canvas');\n  const ctx = canvas.getContext('2d');\n  const runBtn = document.getElementById('runBtn');\n  const resetBtn = document.getElementById('resetBtn');\n  const clustersInput = document.getElementById('clusters');\n  const legendDiv = document.getElementById('legend');\n\n  const WIDTH = canvas.width;\n  const HEIGHT = canvas.height;\n  const POINT_RADIUS = 5;\n  const CENTER_RADIUS = 10;\n  const MAX_POINTS = 200;\n\n  let points = []; // {x, y, cluster} cluster will be -1 if unassigned\n  let centers = []; // {x, y}\n\n  // Predefined colors (up to 10)\n  const COLORS = [\n    '#e6194b', '#3cb44b', '#ffe119', '#4363d8', '#f58231',\n    '#911eb4', '#46f0f0', '#f032e6', '#bcf60c', '#fabebe'\n  ];\n\n  // Draw everything: points and centers\n  function draw() {\n    ctx.clearRect(0, 0, WIDTH, HEIGHT);\n\n    // Draw points\n    for (const p of points) {\n      ctx.beginPath();\n      ctx.arc(p.x, p.y, POINT_RADIUS, 0, Math.PI * 2);\n      if (p.cluster === -1) {\n        ctx.fillStyle = '#999'; // unassigned grey\n      } else {\n        ctx.fillStyle = COLORS[p.cluster % COLORS.length];\n      }\n      ctx.fill();\n      ctx.strokeStyle = '#555';\n      ctx.stroke();\n    }\n\n    // Draw cluster centers\n    centers.forEach((center, idx) => {\n      ctx.beginPath();\n      ctx.arc(center.x, center.y, CENTER_RADIUS, 0, Math.PI * 2);\n      ctx.fillStyle = COLORS[idx % COLORS.length];\n      ctx.globalAlpha = 0.8;\n      ctx.fill();\n      ctx.globalAlpha = 1;\n      ctx.lineWidth = 2;\n      ctx.strokeStyle = '#222';\n      ctx.stroke();\n      ctx.lineWidth = 1;\n    });\n  }\n\n  // Assign points to nearest center\n  function assignClusters() {\n    let changed = false;\n    points.forEach(p => {\n      let minDist = Infinity;\n      let assignedCluster = -1;\n      centers.forEach((center, idx) => {\n        const dx = p.x - center.x;\n        const dy = p.y - center.y;\n        const dist = dx * dx + dy * dy; // no sqrt for efficiency\n        if (dist < minDist) {\n          minDist = dist;\n          assignedCluster = idx;\n        }\n      });\n      if (p.cluster !== assignedCluster) {\n        changed = true;\n        p.cluster = assignedCluster;\n      }\n    });\n    return changed;\n  }\n\n  // Update centers as mean of assigned points\n  function updateCenters() {\n    const sums = centers.map(() => ({x:0, y:0, count:0}));\n\n    points.forEach(p => {\n      if (p.cluster !== -1) {\n        sums[p.cluster].x += p.x;\n        sums[p.cluster].y += p.y;\n        sums[p.cluster].count++;\n      }\n    });\n\n    let moved = false;\n    centers.forEach((center, idx) => {\n      if (sums[idx].count === 0) {\n        // No points assigned to this cluster, do not update center\n        return;\n      }\n      const newX = sums[idx].x / sums[idx].count;\n      const newY = sums[idx].y / sums[idx].count;\n\n      if (center.x !== newX || center.y !== newY) {\n        moved = true;\n        center.x = newX;\n        center.y = newY;\n      }\n    });\n    return moved;\n  }\n\n  // Run full K-Means algorithm iteratively\n  async function runKMeans() {\n    if (points.length === 0) {\n      alert('Add some points first!');\n      return;\n    }\n    const k = parseInt(clustersInput.value);\n    if (k < 1 || k > 10) {\n      alert('Please select K between 1 and 10.');\n      return;\n    }\n    if (points.length < k) {\n      alert(`Number of clusters (K) cannot exceed number of points (${points.length}).`);\n      return;\n    }\n\n    initializeCenters(k);\n\n    let iterations = 0;\n    let maxIters = 100;\n    let changed = true;\n\n    runBtn.disabled = true;\n    clustersInput.disabled = true;\n    resetBtn.disabled = true;\n\n    while (changed && iterations < maxIters) {\n      changed = assignClusters();\n      const moved = updateCenters();\n      draw();\n      await sleep(200); // visualization delay\n      changed = changed || moved;\n      iterations++;\n    }\n\n    draw();\n    runBtn.disabled = false;\n    clustersInput.disabled = false;\n    resetBtn.disabled = false;\n\n    updateLegend(k);\n  }\n\n  // Initialize centers randomly from distinct points\n  function initializeCenters(k) {\n    centers = [];\n    // Pick k unique indices from points randomly\n    const usedIndices = new Set();\n    while (centers.length < k) {\n      const idx = Math.floor(Math.random() * points.length);\n      if (!usedIndices.has(idx)) {\n        usedIndices.add(idx);\n        centers.push({x: points[idx].x, y: points[idx].y});\n      }\n    }\n    // Reset all clusters to unassigned\n    points.forEach(p => (p.cluster = -1));\n  }\n\n  // Sleep utility for delay (async visualization)\n  function sleep(ms) {\n    return new Promise(resolve => setTimeout(resolve, ms));\n  }\n\n  // Update legend color boxes and cluster labels\n  function updateLegend(k) {\n    legendDiv.innerHTML = '';\n    for (let i = 0; i < k; i++) {\n      const colorBox = document.createElement('span');\n      colorBox.className = 'color-box';\n      colorBox.style.backgroundColor = COLORS[i % COLORS.length];\n\n      const label = document.createElement('span');\n      label.textContent = `Cluster ${i + 1}`;\n      label.style.marginRight = '15px';\n\n      legendDiv.appendChild(colorBox);\n      legendDiv.appendChild(label);\n    }\n  }\n\n  // Event listeners\n  canvas.addEventListener('click', e => {\n    if (points.length >= MAX_POINTS) {\n      alert(`Maximum of ${MAX_POINTS} points reached.`);\n      return;\n    }\n    const rect = canvas.getBoundingClientRect();\n    const x = e.clientX - rect.left;\n    const y = e.clientY - rect.top;\n    points.push({x, y, cluster: -1});\n    draw();\n    legendDiv.innerHTML = '';\n  });\n\n  runBtn.addEventListener('click', () => {\n    runKMeans();\n  });\n\n  resetBtn.addEventListener('click', () => {\n    points = [];\n    centers = [];\n    draw();\n    legendDiv.innerHTML = '';\n  });\n\n  // Initial draw call\n  draw();\n\n})();\n</script>\n</body>\n</html>"
  },
