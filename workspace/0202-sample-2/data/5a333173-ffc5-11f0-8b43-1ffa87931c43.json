    "content": "<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\" />\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n<title>Bellman-Ford Algorithm Visualization</title>\n<style>\n  body {\n    font-family: Arial, sans-serif;\n    margin: 20px;\n    background: #fafafa;\n  }\n  h1 {\n    text-align: center;\n    color: #222;\n  }\n  #graphContainer {\n    margin: 20px auto;\n    width: 700px;\n    height: 450px;\n    border: 1px solid #ccc;\n    background: #fff;\n    position: relative;\n  }\n  #controls {\n    text-align: center;\n    margin: 15px;\n  }\n  button {\n    font-size: 1rem;\n    padding: 8px 15px;\n    margin: 0 8px;\n    cursor: pointer;\n  }\n  svg {\n    width: 700px;\n    height: 450px;\n  }\n  .node circle {\n    fill: #4A90E2;\n    stroke: #2C64B9;\n    stroke-width: 3px;\n    transition: fill 0.3s ease;\n  }\n  .node text {\n    fill: #fff;\n    font-weight: bold;\n    font-size: 14px;\n    pointer-events: none;\n  }\n  .edge line {\n    stroke: #999;\n    stroke-width: 2px;\n    marker-end: url(#arrowhead);\n  }\n  .edge text {\n    font-size: 12px;\n    fill: #333;\n  }\n  .visited circle {\n    fill: #e67e22;\n  }\n  #distanceTable {\n    max-width: 700px;\n    margin: 15px auto;\n    border-collapse: collapse;\n    width: 700px;\n    box-shadow: 0 0 5px #ccc;\n  }\n  #distanceTable th, #distanceTable td {\n    border: 1px solid #ddd;\n    padding: 8px 12px;\n    text-align: center;\n  }\n  #distanceTable th {\n    background-color: #4A90E2;\n    color: white;\n  }\n  #message {\n    max-width: 700px;\n    margin: 10px auto;\n    font-weight: bold;\n    font-size: 1.1rem;\n    color: #222;\n    text-align: center;\n    min-height: 28px;\n  }\n  footer {\n    text-align: center;\n    margin-top: 30px;\n    font-size: 0.9rem;\n    color: #666;\n  }\n</style>\n</head>\n<body>\n<h1>Bellman-Ford Algorithm Visualization</h1>\n\n<div id=\"graphContainer\">\n  <svg id=\"graphSVG\" viewBox=\"0 0 700 450\" xmlns=\"http://www.w3.org/2000/svg\">\n    <defs>\n      <marker id=\"arrowhead\" markerWidth=\"10\" markerHeight=\"7\"\n        refX=\"10\" refY=\"3.5\" orient=\"auto\">\n        <polygon points=\"0 0, 10 3.5, 0 7\" fill=\"#999\" />\n      </marker>\n    </defs>\n  </svg>\n</div>\n\n<div id=\"controls\">\n  <label for=\"sourceSelect\">Source Vertex: </label>\n  <select id=\"sourceSelect\"></select>\n  <button id=\"startBtn\">Start</button>\n  <button id=\"nextStepBtn\" disabled>Next Step</button>\n  <button id=\"resetBtn\">Reset</button>\n</div>\n\n<table id=\"distanceTable\" hidden>\n  <thead>\n    <tr>\n      <th>Vertex</th>\n      <th>Distance from Source</th>\n      <th>Predecessor</th>\n    </tr>\n  </thead>\n  <tbody id=\"distanceBody\"></tbody>\n</table>\n\n<div id=\"message\"></div>\n\n<footer>\n  &copy; Bellman-Ford Visualization &mdash; Negative edges allowed, detects negative cycles\n</footer>\n\n<script>\n// Bellman-Ford Implementation and Visualization\n\n// Graph definition:\n// We'll define a moderate graph with some negative edges (no negative cycles)\nconst graph = {\n  vertices: ['A', 'B', 'C', 'D', 'E'],\n  edges: [\n    {from: 'A', to: 'B', weight: 6},\n    {from: 'A', to: 'D', weight: 6},\n    {from: 'B', to: 'C', weight: 5},\n    {from: 'B', to: 'D', weight: -2},\n    {from: 'C', to: 'E', weight: 1},\n    {from: 'D', to: 'C', weight: 2},\n    {from: 'D', to: 'E', weight: 2},\n    {from: 'E', to: 'B', weight: -3},\n  ],\n  coords: { // For visualization (x,y)\n    A: {x: 100, y: 375},\n    B: {x: 275, y: 275},\n    C: {x: 525, y: 275},\n    D: {x: 300, y: 100},\n    E: {x: 500, y: 100},\n  }\n};\n\nlet distances = {};\nlet predecessors = {};\nlet step = 0;\nlet source = null;\nlet edgesToRelax = []; // sequence of edges to check on each iteration\nlet maxSteps;\nlet negativeCycleFound = false;\n\nconst svg = document.getElementById('graphSVG');\nconst distanceTable = document.getElementById('distanceTable');\nconst distanceBody = document.getElementById('distanceBody');\nconst messageDiv = document.getElementById('message');\n\nconst startBtn = document.getElementById('startBtn');\nconst nextStepBtn = document.getElementById('nextStepBtn');\nconst resetBtn = document.getElementById('resetBtn');\nconst sourceSelect = document.getElementById('sourceSelect');\n\nfunction clearSVG() {\n  while(svg.firstChild) {\n    svg.removeChild(svg.firstChild);\n  }\n  // Re-add the marker defs\n  const defs = document.createElementNS('http://www.w3.org/2000/svg', 'defs');\n  defs.innerHTML = `\n  <marker id=\"arrowhead\" markerWidth=\"10\" markerHeight=\"7\"\n    refX=\"10\" refY=\"3.5\" orient=\"auto\">\n    <polygon points=\"0 0, 10 3.5, 0 7\" fill=\"#999\" />\n  </marker>\n  `;\n  svg.appendChild(defs);\n}\n\nfunction drawGraph() {\n  clearSVG();\n\n  // Draw edges\n  graph.edges.forEach((edge, idx) => {\n    const fromCoord = graph.coords[edge.from];\n    const toCoord = graph.coords[edge.to];\n\n    // Calculate line with offset if needed (for better arrow heads)\n    const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');\n    line.setAttribute('x1', fromCoord.x);\n    line.setAttribute('y1', fromCoord.y);\n    line.setAttribute('x2', toCoord.x);\n    line.setAttribute('y2', toCoord.y);\n    line.setAttribute('stroke', '#999');\n    line.setAttribute('stroke-width', '2');\n    line.setAttribute('marker-end', 'url(#arrowhead)');\n    line.classList.add('edge-line');\n    line.dataset.idx = idx;\n    svg.appendChild(line);\n\n    // Edge weight label - mid point with small offset perpendicular\n    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n    const midX = (fromCoord.x + toCoord.x) / 2;\n    const midY = (fromCoord.y + toCoord.y) / 2;\n\n    // Calculate perpendicular offset\n    const dx = toCoord.x - fromCoord.x;\n    const dy = toCoord.y - fromCoord.y;\n    const len = Math.sqrt(dx*dx + dy*dy);\n    const offsetX = -dy / len * 15;\n    const offsetY = dx / len * 15;\n\n    text.setAttribute('x', midX + offsetX);\n    text.setAttribute('y', midY + offsetY + 5);\n    text.setAttribute('fill', '#333');\n    text.setAttribute('font-size', '14');\n    text.textContent = edge.weight;\n    svg.appendChild(text);\n  });\n\n  // Draw nodes\n  graph.vertices.forEach(v => {\n    const group = document.createElementNS('http://www.w3.org/2000/svg', 'g');\n    group.classList.add('node');\n    group.id = `node-${v}`;\n    group.setAttribute('transform', `translate(${graph.coords[v].x},${graph.coords[v].y})`);\n\n    const circle = document.createElementNS('http://www.w3.org/2000/svg', 'circle');\n    circle.setAttribute('r', 20);\n    group.appendChild(circle);\n\n    const text = document.createElementNS('http://www.w3.org/2000/svg', 'text');\n    text.setAttribute('text-anchor', 'middle');\n    text.setAttribute('dy', '8');\n    text.textContent = v;\n    group.appendChild(text);\n\n    svg.appendChild(group);\n  });\n}\n\nfunction populateSourceSelect() {\n  graph.vertices.forEach(v => {\n    const option = document.createElement('option');\n    option.value = v;\n    option.textContent = v;\n    sourceSelect.appendChild(option);\n  });\n  sourceSelect.value = graph.vertices[0];\n}\n\nfunction resetState() {\n  distances = {};\n  predecessors = {};\n  step = 0;\n  edgesToRelax = [];\n  negativeCycleFound = false;\n  nextStepBtn.disabled = true;\n  distanceTable.hidden = true;\n  messageDiv.textContent = '';\n  source = null;\n  drawGraph();\n}\n\nfunction initializeBellmanFord(src) {\n  source = src;\n  distances = {};\n  predecessors = {};\n\n  // Initialization\n  graph.vertices.forEach(v => {\n    distances[v] = Infinity;\n    predecessors[v] = null;\n  });\n  distances[src] = 0;\n\n  // Prepare edges for relaxation\n  // We will relax all edges V-1 times:\n  edgesToRelax = [];\n  for(let i = 0; i < graph.vertices.length - 1; i++) {\n    // Each iteration includes all edges\n    edgesToRelax.push(...graph.edges);\n  }\n  maxSteps = edgesToRelax.length;\n\n  step = 0;\n  distanceTable.hidden = false;\n  updateDistanceTable();\n  highlightCurrentStep(-1, -1);\n  messageDiv.textContent = `Bellman-Ford started. Total iterations: ${graph.vertices.length - 1}`;\n}\n\nfunction relaxEdge(edge) {\n  const {from, to, weight} = edge;\n  if(distances[from] !== Infinity && distances[from] + weight < distances[to]) {\n    distances[to] = distances[from] + weight;\n    predecessors[to] = from;\n    return true;\n  }\n  return false;\n}\n\nfunction highlightCurrentStep(edgeIndex, iteration) {\n  // Clear all highlights\n  svg.querySelectorAll('line').forEach(line => {\n    line.setAttribute('stroke', '#999');\n    line.setAttribute('stroke-width', '2');\n    line.setAttribute('marker-end', 'url(#arrowhead)');\n  });\n\n  svg.querySelectorAll('g.node circle').forEach(circle => {\n    circle.classList.remove('visited');\n    circle.setAttribute('fill', '#4A90E2');\n  });\n\n  if(edgeIndex >= 0) {\n    // Highlight current edge\n    const line = svg.querySelectorAll('line')[edgeIndex];\n    if(line) {\n      line.setAttribute('stroke', '#e67e22');\n      line.setAttribute('stroke-width', '4');\n      line.setAttribute('marker-end', 'url(#arrowhead)');\n    }\n    // Highlight from and to nodes\n    const edge = edgesToRelax[step];\n    if(edge) {\n      const fromCircle = document.querySelector(`#node-${edge.from} circle`);\n      const toCircle = document.querySelector(`#node-${edge.to} circle`);\n      if(fromCircle) fromCircle.setAttribute('fill', '#f39c12');\n      if(toCircle) toCircle.setAttribute('fill', '#e67e22');\n    }\n  }\n}\n\nfunction updateDistanceTable() {\n  distanceBody.innerHTML = '';\n  graph.vertices.forEach(v => {\n    const tr = document.createElement('tr');\n    if(distances[v] === Infinity) {\n      tr.innerHTML = `<td>${v}</td><td>∞</td><td>${predecessors[v] === null ? '-' : predecessors[v]}</td>`;\n    } else {\n      tr.innerHTML = `<td>${v}</td><td>${distances[v]}</td><td>${predecessors[v] === null ? '-' : predecessors[v]}</td>`;\n    }\n    distanceBody.appendChild(tr);\n  });\n}\n\nfunction doNextStep() {\n  if(step >= maxSteps) {\n    nextStepBtn.disabled = true;\n    checkNegativeCycle();\n    return;\n  }\n  const edge = edgesToRelax[step];\n  const edgeIndexInGraph = graph.edges.findIndex(e => e.from === edge.from && e.to === edge.to && e.weight === edge.weight);\n\n  highlightCurrentStep(edgeIndexInGraph, Math.floor(step / (graph.vertices.length - 1)) + 1);\n\n  const relaxed = relaxEdge(edge);\n  updateDistanceTable();\n\n  messageDiv.textContent = `Iteration ${Math.floor(step / (graph.vertices.length - 1)) + 1} - relaxing edge (${edge.from} → ${edge.to}) with weight ${edge.weight}${relaxed ? ' - updated!' : ''}`;\n  step++;\n\n  if(step === maxSteps) {\n    nextStepBtn.disabled = true;\n    checkNegativeCycle();\n  }\n}\n\nfunction checkNegativeCycle() {\n  // After V-1 iterations, check for negative cycles\n  let negativeCycle = false;\n  graph.edges.forEach(edge => {\n    if(distances[edge.from] !== Infinity && distances[edge.from] + edge.weight < distances[edge.to]) {\n      negativeCycle = true;\n    }\n  });\n  if(negativeCycle) {\n    messageDiv.textContent = \"Graph contains a negative-weight cycle!\";\n    negativeCycleFound = true;\n  } else {\n    messageDiv.textContent = \"No negative-weight cycles detected. Shortest paths computed.\";\n  }\n}\n\n// Initialize UI elements and events\nfunction init() {\n  populateSourceSelect();\n  drawGraph();\n\n  startBtn.addEventListener('click', () => {\n    resetState();\n    initializeBellmanFord(sourceSelect.value);\n    nextStepBtn.disabled = false;\n  });\n\n  nextStepBtn.addEventListener('click', () => {\n    doNextStep();\n  });\n\n  resetBtn.addEventListener('click', () => {\n    resetState();\n  });\n\n  sourceSelect.addEventListener('change', () => {\n    resetState();\n  });\n}\n\ninit();\n\n</script>\n</body>\n</html>"
  },
