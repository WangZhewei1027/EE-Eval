    "content": "<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />\n  <title>Priority Queue Demo</title>\n  <style>\n    body {\n      font-family: Arial, sans-serif;\n      max-width: 600px;\n      margin: 2rem auto;\n      padding: 1rem;\n      background-color: #f9f9f9;\n      color: #333;\n    }\n    h1 {\n      text-align: center;\n    }\n    label {\n      display: block;\n      margin-top: 1rem;\n      font-weight: bold;\n    }\n    input[type=\"text\"], input[type=\"number\"] {\n      width: 100%;\n      box-sizing: border-box;\n      padding: 0.5rem;\n      margin-top: 0.25rem;\n      font-size: 1rem;\n    }\n    button {\n      margin-top: 1rem;\n      padding: 0.6rem 1.2rem;\n      font-size: 1.1rem;\n      cursor: pointer;\n      background-color: #007bff;\n      color: white;\n      border: none;\n      border-radius: 4px;\n    }\n    button:hover {\n      background-color: #0056b3;\n    }\n    #queue-list {\n      margin-top: 1rem;\n      background: white;\n      border: 1px solid #ccc;\n      border-radius: 4px;\n      padding: 1rem;\n      min-height: 80px;\n    }\n    #dequeued {\n      margin-top: 1rem;\n      font-weight: bold;\n      color: #d6336c;\n    }\n    .item {\n      margin-bottom: 0.3rem;\n      font-size: 1.1rem;\n    }\n    .priority {\n      font-weight: normal;\n      font-size: 0.9rem;\n      color: #777;\n      margin-left: 0.5rem;\n    }\n    footer {\n      margin-top: 3rem;\n      font-size: 0.9rem;\n      color: #777;\n      text-align: center;\n    }\n    small {\n      font-style: italic;\n    }\n  </style>\n</head>\n<body>\n  <h1>Priority Queue Demo</h1>\n  <p>\n    A <em>priority queue</em> is a data structure where each element has a priority.\n    Elements with higher priority are dequeued before those with lower priority.\n  </p>\n  <form id=\"enqueue-form\">\n    <label for=\"value\">Value (string):</label>\n    <input type=\"text\" id=\"value\" name=\"value\" required placeholder=\"Enter value to enqueue\" />\n\n    <label for=\"priority\">Priority (number, higher = higher priority):</label>\n    <input type=\"number\" id=\"priority\" name=\"priority\" required placeholder=\"Enter priority\" />\n\n    <button type=\"submit\">Enqueue</button>\n  </form>\n\n  <button id=\"dequeue-btn\" style=\"margin-top: 1rem;\">Dequeue Highest Priority</button>\n\n  <h2>Queue State</h2>\n  <div id=\"queue-list\">Queue is empty.</div>\n\n  <div id=\"dequeued\"></div>\n\n  <footer>\n    <small>Priority Queue implemented using a simple array sorted by priority.</small>\n  </footer>\n\n  <script>\n    // Simple priority queue class\n    class PriorityQueue {\n      constructor() {\n        this.items = [];\n      }\n\n      // Inserts element based on priority (higher priority first)\n      enqueue(element, priority) {\n        const queueElement = { element, priority };\n        if (this.isEmpty()) {\n          this.items.push(queueElement);\n        } else {\n          // find the right place to insert\n          let added = false;\n          for (let i = 0; i < this.items.length; i++) {\n            if (queueElement.priority > this.items[i].priority) {\n              this.items.splice(i, 0, queueElement);\n              added = true;\n              break;\n            }\n          }\n          if (!added) {\n            this.items.push(queueElement);\n          }\n        }\n      }\n\n      // Removes and returns the highest priority element\n      dequeue() {\n        if (this.isEmpty()) {\n          return null;\n        }\n        return this.items.shift();\n      }\n\n      front() {\n        return this.isEmpty() ? null : this.items[0];\n      }\n\n      isEmpty() {\n        return this.items.length === 0;\n      }\n\n      size() {\n        return this.items.length;\n      }\n\n      clear() {\n        this.items = [];\n      }\n\n      toArray() {\n        return this.items.slice();\n      }\n    }\n\n    const pq = new PriorityQueue();\n\n    const enqueueForm = document.getElementById(\"enqueue-form\");\n    const dequeueBtn = document.getElementById(\"dequeue-btn\");\n    const queueList = document.getElementById(\"queue-list\");\n    const dequeuedDiv = document.getElementById(\"dequeued\");\n    const valueInput = document.getElementById(\"value\");\n    const priorityInput = document.getElementById(\"priority\");\n\n    function renderQueue() {\n      const arr = pq.toArray();\n      if (arr.length === 0) {\n        queueList.textContent = \"Queue is empty.\";\n        return;\n      }\n      // show elements with priority\n      queueList.innerHTML = arr\n        .map(\n          (item, i) =>\n            `<div class=\"item\">${i + 1}. <strong>${item.element}</strong> <span class=\"priority\">(priority: ${item.priority})</span></div>`\n        )\n        .join(\"\");\n    }\n\n    enqueueForm.addEventListener(\"submit\", (e) => {\n      e.preventDefault();\n      const val = valueInput.value.trim();\n      const prio = Number(priorityInput.value);\n      if (val === \"\" || isNaN(prio)) {\n        alert(\"Please enter valid value and priority.\");\n        return;\n      }\n      pq.enqueue(val, prio);\n      renderQueue();\n      dequeuedDiv.textContent = \"\";\n      valueInput.value = \"\";\n      priorityInput.value = \"\";\n      valueInput.focus();\n    });\n\n    dequeueBtn.addEventListener(\"click\", () => {\n      if (pq.isEmpty()) {\n        dequeuedDiv.textContent = \"Queue is empty. Nothing to dequeue.\";\n        return;\n      }\n      const item = pq.dequeue();\n      dequeuedDiv.textContent = `Dequeued: \"${item.element}\" with priority ${item.priority}`;\n      renderQueue();\n    });\n\n    renderQueue();\n  </script>\n</body>\n</html>"
  },
